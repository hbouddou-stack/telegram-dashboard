        "ts": "2:50",
        "sec": 170,
        "text": "وبَرِحَ، وانْفَكَّ؛ فهذِه لا بد لها لكي تعمل هذا العمل",
        "video_link": null
      },
      {
        "ts": "2:57",
        "sec": 177,
        "text": "أن تُسبق بهذا الذي ذُكر؛ بالنفي أو النهي أو الدعاء،",
        "video_link": null
      },
      {
        "ts": "3:03",
        "sec": 183,
        "text": "نحو: {وَلَا يَزَالُونَ مُخْتَلِفِينَ}؛ لاحظ لا هذِه النافية، إذن الشرط متحقق وهو",
        "video_link": null
      },
      {
        "ts": "3:13",
        "sec": 193,
        "text": "وجود النفي، ثم إذاً يزالون هذِه تعمل هذا النسخ فهي إذن تكون من أخوات كَانَ.",
        "video_link": null
      },
      {
        "ts": "3:22",
        "sec": 202,
        "text": "يزالون؛ واو الجماعة: اسم يَزَالُ، ومختلفين: خبر يَزَالُ،",
        "video_link": null
      },
      {
        "ts": "3:35",
        "sec": 215,
        "text": "يعني منصوب وعلامة نصبه الياء النائبة عن الفتحة لأنه جمع مذكر سالم.",
        "video_link": null
      },
      {
        "ts": "3:44",
        "sec": 224,
        "text": "{لَن نَّبْرَحَ عَلَيْهِ عَاكِفِينَ}؛ النفي إذن موجود وذلك في لَنْ، {لَنْ نَبْرَحَ}.",
        "video_link": null
      },
      {
        "ts": "3:54",
        "sec": 234,
        "text": "منصوب بِلَنْ وعلامة نصبه الفتحة الظاهرة على آخره، عاكفين هو اسم نَبْرَحَ",
        "video_link": null
      },
      {
        "ts": "4:03",
        "sec": 243,
        "text": "عفواً هو خبر نَبْرَحَ، اسمها ضمير متصل ضمير مستتر",
        "video_link": null
      },
      {
        "ts": "4:13",
        "sec": 253,
        "text": "تقديره نحن؛ لن نبرح نحن عاكفين، عاكفين هو خبر نَبْرَحَ منصوب على",
        "video_link": null
      },
      {
        "ts": "4:22",
        "sec": 262,
        "text": "منصوب به الياء النائبة عن الفتحة لأنه جمع مذكر سالم.",
        "video_link": null
      },
      {
        "ts": "4:28",
        "sec": 268,
        "text": "وقول الشاعر: *\"صاحِ شَمِّرْ وَلا تَزَلْ ذاكِرَ المَوتِ فَنِسيانُهُ ضَلالٌ مُبينُ\"*،",
        "video_link": null
      },
      {
        "ts": "4:35",
        "sec": 275,
        "text": "*\"فَنِسيانُهُ ضَلالٌ مُبينُ. صاحِ شَمِّرْ وَلا تَزَلْ ذاكِرَ المَوتِ\"*؛ هنا مثال على النهي، لأن لا هذِه ليست نافية كما في قوله تعالى {وَلَا يَزَالُونَ",
        "video_link": null
      },
      {
        "ts": "4:50",
        "sec": 290,
        "text": "مُخْتَلِفِينَ}، وإنما هي ناهية. ولا الناهية كنا قد ذكرنا",
        "video_link": null
      },
      {
        "ts": "4:56",
        "sec": 296,
        "text": "من قبل أنها إذا دخلت على الفعل المضارع فإنها تجزمه \"لا تكتب\"؛ فإذاً هنا",
        "video_link": null
      },
      {
        "ts": "5:05",
        "sec": 305,
        "text": "\"تَزَالُ\" أنت تَزَالُ دخلت عليها لا الناهية فصارت: لا تَزلْ. هي في الحقيقة من جهة الصرف",
        "video_link": null
      },
      {
        "ts": "5:14",
        "sec": 314,
        "text": "نقول صارت لا تزالُ، إذا جُزمت وكانت علامة الجزم السكون ثم التقى الساكنان اللذان",
        "video_link": null
      },
      {
        "ts": "5:22",
        "sec": 322,
        "text": "أولهما حرف لين فحُذف، فتحولت لا تزالُ إلى لا تَزلْ.",
        "video_link": null
      },
      {
        "ts": "5:29",
        "sec": 329,
        "text": "ثم الشرط متحقق فهي تعمل هذا العمل، فنقول اسمها: ضمير مستتر تقديره أنت، \"لا",
        "video_link": null
      },
      {
        "ts": "5:39",
        "sec": 339,
        "text": "تزل أنت ذاكرَ\"، ذاكرَ: خبر تَزَلْ منصوب على من وعلامة نصبه الفتحة",
        "video_link": null
      },
      {
        "ts": "5:47",
        "sec": 347,
        "text": "الظاهرة على آخره. وكذلك وقوله: *\"وَلا زالَ مُنْهَلّاً بِجَرْعائِكَ القَطْرُ\"*،",
        "video_link": null
      },
      {
        "ts": "5:54",
        "sec": 354,
        "text": "*\"أَلا اسْلَمِي يا دارَ مَيَّ على البِلى ... وَلا زالَ مُنْهَلّاً بِجَرْعائِكَ القَطْرُ\"*؛ هنا مثال على الدعاء،",
        "video_link": null
      },
      {
        "ts": "6:03",
        "sec": 363,
        "text": "أي على تقدم الدعاء على زَالَ؛ *\"وَلا زالَ مُنْهَلّاً بِجَرْعائِكَ القَطْرُ\"* أي يدعو بأن",
        "video_link": null
      },
      {
        "ts": "6:12",
        "sec": 372,
        "text": "يدعو لهذا لهذه الدار دار ميّ يدعو بأن تصيبها يصيبها الغيث أو تصيبها السماء، وأن",
        "video_link": null
      },
      {
        "ts": "6:22",
        "sec": 382,
        "text": "يستمر ذلك دائماً لكي يعني يبقى تبقى حية بنزول هذِه الأمطار",
        "video_link": null
      },
      {
        "ts": "6:30",
        "sec": 390,
        "text": "عليها، فهذا دعاء ليس نفياً ولا نهياً. وقوله: *\"وَلا زالَ مُنْهَلّاً بِجَرْعائِكَ القَطْرُ\"*،",
        "video_link": null
      },
      {
        "ts": "6:39",
        "sec": 399,
        "text": "زَالَ إذاً تعمل عمل كَانَ من أخوات كَانَ والشرط متحقق فيها؛ القطرُ: اسمها مرفوع",
        "video_link": null
      },
      {
        "ts": "6:48",
        "sec": 408,
        "text": "وعلامة رفعه الضمة الظاهرة، منهلاً: خبرها منصوب وعلامة نصبه الفتحة الظاهرة على",
        "video_link": null
      },
      {
        "ts": "6:56",
        "sec": 416,
        "text": "آخره. النوع الثالث قال: ما يعمل هذا العمل بشرط",
        "video_link": null
      },
      {
        "ts": "7:01",
        "sec": 421,
        "text": "أن تتقدمه \"مَا\" المصدرية الظرفية وهو دَامَ، نحو: مَا دُمْتُ حَيّاً،",
        "video_link": null
      },
      {
        "ts": "7:10",
        "sec": 430,
        "text": "وسُميت مَا هذِه مصدرية لأنها تُقدر بالمصدر وهو الدوام،",
        "video_link": null
      },
      {
        "ts": "7:16",
        "sec": 436,
        "text": "وسُميت ظرفية للنيابة عن الظرف وهو المدة؛ مَا دُمْتُ حَيّاً",
        "video_link": null
      },
      {
        "ts": "7:24",
        "sec": 444,
        "text": "أي مدة دوامي حياً، مدة دوامي حياً؛ فأنت ترى أن",
        "video_link": null
      },
      {
        "ts": "7:33",
        "sec": 453,
        "text": "\"دُمْتُ\" مع مَا تتحول إلى مصدر وظرف.",
        "video_link": null
      },
      {
        "ts": "7:41",
        "sec": 461,
        "text": "الظرف هو مدة، والمصدر هو دوام؛ فتأويل دَامَ مع مَا المصدرية الظرفية",
        "video_link": null
      },
      {
        "ts": "7:51",
        "sec": 471,
        "text": "بمصدر وظرف، لأجله قلنا بأن مَا هذِه مصدرية ظرفية.",
        "video_link": null
      },
      {
        "ts": "7:58",
        "sec": 478,
        "text": "فـ {مَا دُمْتُ حَيًّا} أي مدة دوامي حياً، هذا معنى قوله سُميت مصدرية لأنها تُقدر بالمصدر وهو الدوام وسُميت ظرفية لنيابتها عن الظرف",
        "video_link": null
      },
      {
        "ts": "8:07",
        "sec": 487,
        "text": "وهو المدة. إذاً تحقق الشرط فنقول مَا دُمْتُ حَيّاً، التاء:",
        "video_link": null
      },
      {
        "ts": "8:14",
        "sec": 494,
        "text": "هي ضمير متصل مبني في محل رفع اسم دَامَ،",
        "video_link": null
      },
      {
        "ts": "8:21",
        "sec": 501,
        "text": "وحياً: خبر دَامَ منصوب وعلامة نصبه الفتحة الظاهرة. قال: ويجوز في خبر هذِه الأفعال أن",
        "video_link": null
      },
      {
        "ts": "8:29",
        "sec": 509,
        "text": "يتوسط بينها وبين اسمها، نحو: {وَكَانَ حَقًّا عَلَيْنَا نَصْرُ الْمُؤْمِنِينَ}؛",
        "video_link": null
      },
      {
        "ts": "8:37",
        "sec": 517,
        "text": "كان نصرُ حقاً، إذاً النصرُ هو اسم كَانَ وحقاً: خبر كَانَ.",
        "video_link": null
      },
      {
        "ts": "8:46",
        "sec": 526,
        "text": "فهنا تقدم الخبر على الاسم",
        "video_link": null
      },
      {
        "ts": "8:52",
        "sec": 532,
        "text": "وتوسط بين كَانَ والاسم، {وَكَانَ حَقًّا} هو الخبر،",
        "video_link": null
      },
      {
        "ts": "8:58",
        "sec": 538,
        "text": "نصرُ حقاً علينا نصرُ المؤمنين هو المبتدأ. وكذلك جاء قول الشاعر: *\"سَلِي إِنْ جَهِلْتِ النَّاسَ عَنَّا وَعَنْهُمُ ... فَلَيْسَ سَوَاءً عَالِمٌ وَجَهُولُ\"*،",
        "video_link": null
      },
      {
        "ts": "9:12",
        "sec": 552,
        "text": "لَيْسَ، عالمٌ: هو اسم لَيْسَ وسواءً: خبر لَيْسَ؛ كما ترى توسط بين",
        "video_link": null
      },
      {
        "ts": "9:21",
        "sec": 561,
        "text": "لَيْسَ واسمها، هذا على سبيل الجواز.",
        "video_link": null
      },
      {
        "ts": "9:28",
        "sec": 568,
        "text": "ويجوز أن يتقدم أخبارهن عليهنَّ إلا لَيْسَ ودَامَ،",
        "video_link": null
      },
      {
        "ts": "9:36",
        "sec": 576,
        "text": "كقولك: عَالِماً كَانَ زَيْدٌ؛ بمعنى في كَانَ وأخواتها كلها باستثناء لَيْسَ ودَامَ يمكن أن",
        "video_link": null
      },
      {
        "ts": "9:46",
        "sec": 586,
        "text": "يتقدم الخبر ليس فقط على اسمها ولكن أن يتقدم على الأفعال نفسها، نحو: عَالِماً كَانَ",
        "video_link": null
      },
      {
        "ts": "9:53",
        "sec": 593,
        "text": "زَيْدٌ، واضح؛ فزيدٌ: اسم كَانَ وعالماً: خبر كَانَ مقدم. لكن",
        "video_link": null
      },
      {
        "ts": "10:02",
        "sec": 602,
        "text": "يقول يقول النحاة: لا يكون ذلك في لَيْسَ ولا في دَامَ على الصحيح، القضية فيها خلاف لكن على الصحيح أن ذلك",
        "video_link": null
      },
      {
        "ts": "10:11",
        "sec": 611,
        "text": "ممتنع. قال: ولتصاريف هذِه الأفعال من المضارع",
        "video_link": null
      },
      {
        "ts": "10:19",
        "sec": 619,
        "text": "والوالأمر والمصدر واسم الفاعل ما للماضي من العمل، نحو: {حَتَّىٰ يَكُونُوا مُؤْمِنِينَ}،",
        "video_link": null
      },
      {
        "ts": "10:29",
        "sec": 629,
        "text": "{قُلْ كُونُوا حِجَارَةً}؛ يَكُونُوا مُؤْمِنِينَ هذا مضارع كَانَ",
        "video_link": null
      },
      {
        "ts": "10:37",
        "sec": 637,
        "text": "يعمل مثل الماضي، فنقول يَكُونُوا مُؤْمِنِينَ؛ واو الجماعة هو اسم",
        "video_link": null
      },
      {
        "ts": "10:46",
        "sec": 646,
        "text": "يَكُونُ ومؤمنين: خبر يَكُونُ منصوب علامة نصبه الياء النائبة عن",
        "video_link": null
      },
      {
        "ts": "10:51",
        "sec": 651,
        "text": "الفتحة لأنه جمع مذكر سالم. {قُلْ كُونُوا حِجَارَةً أَوْ حَدِيدًا}،",
        "video_link": null
      },
      {
        "ts": "10:58",
        "sec": 658,
        "text": "كُونُوا هذا فعل الأمر، الواو هي اسم كُونُوا،",
        "video_link": null
      },
      {
        "ts": "11:07",
        "sec": 667,
        "text": "الخبر هو حجارةً وهو منصوب وعلامة نصبه الفتحة الظاهرة. وكذلك",
        "video_link": null
      },
      {
        "ts": "11:13",
        "sec": 673,
        "text": "المصدر، مثلاً كأن تقول: كَوْنُكَ",
        "video_link": null
      },
      {
        "ts": "11:20",
        "sec": 680,
        "text": "كَوْنُكَ مُجْتَهِداً مَطْلُوبٌ مِنْكَ، واضح؛ كَوْنُكَ مُجْتَهِداً مَطْلُوبٌ.",
        "video_link": null
      },
      {
        "ts": "11:28",
        "sec": 688,
        "text": "فأنت ترى بأن قولك كَوْنُكَ مُجْتَهِداً، مجتهداً هذا",
        "video_link": null
      },
      {
        "ts": "11:33",
        "sec": 693,
        "text": "خبر كَوْنُ؛ فالكَوْن الذي هو مصدر يعمل كما يعمل الفعل الماضي أو المضارع أو الأمر،",
        "video_link": null
      },
      {
        "ts": "11:42",
        "sec": 702,
        "text": "وكَوْنُ: مبتدأ ومطلوبٌ: خبر المبتدأ. قال: وتُستعمل هذِه الأفعال تامة؛ أي مستغنية",
        "video_link": null
      },
      {
        "ts": "11:52",
        "sec": 712,
        "text": "عن الخبر. لم نذكر بأن الأفعال التي تحدثنا عنها آنفاً وهي كَانَ وأخواتها تُسمى",
        "video_link": null
      },
      {
        "ts": "12:02",
        "sec": 722,
        "text": "أفعالاً ناقصة، تُسمى أفعالاً ناقصة؛",
        "video_link": null
      },
      {
        "ts": "12:07",
        "sec": 727,
        "text": "لِمَ هي ناقصة؟ لأنها محتاجة إلى الخبر. لكن يفيدنا فائدة هنا فيقول إنها قد",
        "video_link": null
      },
      {
        "ts": "12:17",
        "sec": 737,
        "text": "تُستعمل تامة لا ناقصة، ومعنى كونها تامة أي هي مستغنية عن الخبر،",
        "video_link": null
      },
      {
        "ts": "12:27",
        "sec": 747,
        "text": "ومثَّل لذلك بقول الله سبحانه وتعالى: {وَإِن كَانَ ذُو عُسْرَةٍ}؛ كَانَ هناك تامة بمعنى وُجد،",
        "video_link": null
      },
      {
        "ts": "12:36",
        "sec": 756,
        "text": "حصل، وقع؛ إن حصل ذو عسرة، إن وقع، إن وُجد ذو عسرة فنظرة.",
        "video_link": null
      },
      {
        "ts": "12:45",
        "sec": 765,
        "text": "يعني هنا ذُو ماذا نقول فيه؟ نقول: فاعل كَانَ، فكَانَ هنا ليست من النواسخ وليست ناقصة بل هي تامة،",
        "video_link": null
      },
      {
        "ts": "12:53",
        "sec": 773,
        "text": "وحينئذٍ فإنها تحتاج إلى فاعل فقط ولا",
        "video_link": null
      },
      {
        "ts": "13:00",
        "sec": 780,
        "text": "تحتاج إلى خبر. وكذلك قول الله سبحانه وتعالى: {فَسُبْحَانَ اللَّهِ",
        "video_link": null
      },
      {
        "ts": "13:07",
        "sec": 787,
        "text": "حِينَ تُمْسُونَ وَحِينَ تُصْبِحُونَ}؛ تُمْسُونَ وتُصْبِحُونَ كلاهما أفعال تامة،",
        "video_link": null
      },
      {
        "ts": "13:16",
        "sec": 796,
        "text": "كلاهما فعل تام وليستا ناقصتين؛ فإذاً تُمْسُونَ لا نبحث عن اسمها",
        "video_link": null
      },
      {
        "ts": "13:24",
        "sec": 804,
        "text": "وخبرها وإنما لها فاعل. تُمْسُونَ: فعل مضارع",
        "video_link": null
      },
      {
        "ts": "13:31",
        "sec": 811,
        "text": "مرفوع لتجرده عن الناصب والجازم وعلامة رفعه ثبوت النون لأنه من الأفعال الخمسة،",
        "video_link": null
      },
      {
        "ts": "13:37",
        "sec": 817,
        "text": "وواو الجماعة ضمير متصل مبني في محل رفع فاعل تُمْسُونَ، وكذلك نقول في",
        "video_link": null
      },
      {
        "ts": "13:46",
        "sec": 826,
        "text": "تُصْبِحُونَ. فمعنى تُمْسُونَ: تدخلون في المساء، وتُصْبِحُونَ:",
        "video_link": null
      },
      {
        "ts": "13:53",
        "sec": 833,
        "text": "تدخلون في الصباح. أما أَمْسَى وأَصْبَحَ التي هي من النواسخ فهي تدل على معنى الصيرورة؛",
        "video_link": null
      },
      {
        "ts": "14:01",
        "sec": 841,
        "text": "هي في الأصل راجعة إلى معنى المساء والصباح لكن يُراد بها معنى الصيرورة والتحول.",
        "video_link": null
      },
      {
        "ts": "14:08",
        "sec": 848,
        "text": "قال: إلا زَالَ، وفَتِئَ، ولَيْسَ؛ فإنها ملازمة للنقص، أي لا",
        "video_link": null
      },
      {
        "ts": "14:17",
        "sec": 857,
        "text": "تُستعمل قط تامة. الكلام عن زَالَ التي",
        "video_link": null
      },
      {
        "ts": "14:27",
        "sec": 867,
        "text": "مضارعها يَزَالُ \"زَالَ يَزَالُ\"، وليست \"زَالَ يَزُولُ\"؛ إلا زَالَ يَزُولُ فعل آخر لا علاقة له بما نحن",
        "video_link": null
      },
      {
        "ts": "14:36",
        "sec": 876,
        "text": "بصدده أصلاً، لكن الكلام عن زَالَ يَزَالُ وكذلك ولَيْسَ، فهذِه لا تكون تامة.",
        "video_link": null
      },
      {
        "ts": "14:45",
        "sec": 885,
        "text": "قال: وتختص كَانَ بجواز زيادتها بشرط أن تكون بلفظ الماضي وأن تكون في حشو الكلام، نحو:",
        "video_link": null
      },
      {
        "ts": "14:55",
        "sec": 895,
        "text": "مَا كَانَ أَحْسَنَ زَيْداً؛ بمعنى كَانَ قد يُؤتى بها زائدة،",
        "video_link": null
      },
      {
        "ts": "15:05",
        "sec": 905,
        "text": "وذلك يكون بهذين الشرطين: أن تكون في الماضي فإذاً لا",
        "video_link": null
      },
      {
        "ts": "15:11",
        "sec": 911,
        "text": "تُزاد إذا كانت في المضارع أو الأمر، وأن تكون في حشو الكلام",
        "video_link": null
      },
      {
        "ts": "15:18",
        "sec": 918,
        "text": "كما في يعني بأن تقع ما معنى في حشو الكلام؟ أي أن تقع في وسط الكلام بين شيئين",
        "video_link": null
      },
      {
        "ts": "15:24",
        "sec": 924,
        "text": "متلازمين، كأن تكون مثلاً بين مبتدأ وخبره؛ فمثال ذلك: مَا كَانَ أَحْسَنَ زَيْداً، وأكثر",
        "video_link": null
      },
      {
        "ts": "15:34",
        "sec": 934,
        "text": "استعمالها زائدة هي في مثل هذا المثال يعني أن تكون بين مَا يعني في صيغة التعجب،",
        "video_link": null
      },
      {
        "ts": "15:41",
        "sec": 941,
        "text": "بين مَا وأَحْسَنَ؛ فهنا كَانَ زائدة لأن أصل الكلام: مَا أَحْسَنَ",
        "video_link": null
      },
      {
        "ts": "15:49",
        "sec": 949,
        "text": "زَيْداً. وحين تقول: مَا كَانَ أَحْسَنَ زَيْداً، أنت لا تزيد شيئاً ولا تغير شيئاً من الناحية الإعرابية؛ صحيح أنها تفيد معنى زائداً من",
        "video_link": null
      },
      {
        "ts": "15:59",
        "sec": 959,
        "text": "جهة التوكيد ونحو ذلك، لكن من جهة علم النحو هي زائدة.",
        "video_link": null
      },
      {
        "ts": "16:07",
        "sec": 967,
        "text": "مَا كَانَ أَحْسَنَ زَيْداً؛ إذن مَا هذِه تعجبية، وكَانَ زائدة لا فاعل لها، وأَحْسَنَ هذا فعل تعجب",
        "video_link": null
      },
      {
        "ts": "16:16",
        "sec": 976,
        "text": "مبني على الفتح، والفاعل ضمير مستتر تقديره هو، زيداً: المفعول به؛ إذن نحو مَا كَانَ أَحْسَنَ زَيْداً",
        "video_link": null
      },
      {
        "ts": "16:25",
        "sec": 985,
        "text": "هذِه زائدة، وكما قلنا تكون كثيراً هذِه الزائدة مع صيغة التعجب،",
        "video_link": null
      },
      {
        "ts": "16:33",
        "sec": 993,
        "text": "أيضاً هذا من خصوصيات كَانَ. من خصوصياتها كذلك وتختص أيضاً بجواز حذفها مع اسمها",
        "video_link": null
      },
      {
        "ts": "16:41",
        "sec": 1001,
        "text": "وإبقاء خبرها، وذلك كثير بعد \"لَوْ\" و\"إِنْ\" الشرطيتين؛ كقول رسول",
        "video_link": null
      },
      {
        "ts": "16:49",
        "sec": 1009,
        "text": "الله صلى الله عليه وسلم: \"الْتَمِسْ وَلَوْ خَاتَماً مِنْ حَدِيدٍ\"؛ هنا كَانَ مع اسمها",
        "video_link": null
      },
      {
        "ts": "16:59",
        "sec": 1019,
        "text": "محذوفان، إذ تقدير الكلام في قوله \"الْتَمِسْ",
        "video_link": null
      },
      {
        "ts": "17:04",
        "sec": 1024,
        "text": "وَلَوْ خَاتَماً مِنْ حَدِيدٍ\" تقدير كذا: التمس ولو كان",
        "video_link": null
      },
      {
        "ts": "17:11",
        "sec": 1031,
        "text": "ما تلتمسه خاتماً من حديد؛ لكن لاختصار الكلام حُذف كل ذلك وبقي الخبر",
        "video_link": null
      },
      {
        "ts": "17:18",
        "sec": 1038,
        "text": "فقط \"ولو كان\"، حُذفت ما تلتمس أو الملتمس هذا",
        "video_link": null
      },
      {
        "ts": "17:26",
        "sec": 1046,
        "text": "اسمه، كَانَ واسمها حُذف وبقي الخبر وهو خاتماً من حديد. وكذلك",
        "video_link": null
      },
      {
        "ts": "17:34",
        "sec": 1054,
        "text": "في قولهم: \"الناس مجزيون بأعمالهم، إن خيراً",
        "video_link": null
      },
      {
        "ts": "17:41",
        "sec": 1061,
        "text": "فخيراً، وإن شراً فشرّاً\"؛ الناس مجزيون بأعمالهم إن خيراً فخيراً، أي إن",
        "video_link": null
      },
      {
        "ts": "17:51",
        "sec": 1071,
        "text": "كان عملهم خيراً فجزاؤهم خيراً، وإن كان عملهم شراً فجزاؤهم شرّاً.",
        "video_link": null
      },
      {
        "ts": "17:58",
        "sec": 1078,
        "text": "إذن حُذفت كَانَ وحُذف اسمها الذي هو عملهم وبقي الخبر فقط وهو خيراً،",
        "video_link": null
      },
      {
        "ts": "18:07",
        "sec": 1087,
        "text": "جميل أيضاً. إذاً تختص كَانَ بأمر أول قلنا هو",
        "video_link": null
      },
      {
        "ts": "18:14",
        "sec": 1094,
        "text": "يعني أن تكون زائدة، وتختص بشيء ثاني وهو جواز حذفها مع اسمها مع بقاء الخبر، وتختص",
        "video_link": null
      },
      {
        "ts": "18:22",
        "sec": 1102,
        "text": "ثالثاً بجواز حذف نون مضارعها المجزوم إن لم يلقَها ساكن ولا ضمير نصب.",
        "video_link": null
      },
      {
        "ts": "18:31",
        "sec": 1111,
        "text": "شروط؛ ما معنى هذا الكلام؟ معناه كما في قوله ربنا سبحانه وتعالى: {وَلَمْ أَكُ بَغِيًّا}، أصلها:",
        "video_link": null
      },
      {
        "ts": "18:38",
        "sec": 1118,
        "text": "أكونُ؛ إذاً ما الذي وقع؟ حُذفت النون، لكن لا بد من توفر هذِه الشروط: أولاً نون",
        "video_link": null
      },
      {
        "ts": "18:48",
        "sec": 1128,
        "text": "المضارع فلا تكون في الماضي ولا الأمر \"نون المضارع\"، ثانياً أن يكون هذا المضارع",
        "video_link": null
      },
      {
        "ts": "18:55",
        "sec": 1135,
        "text": "مجزوماً كما في \"وَلَمْ أَكُ\"، أكونُ هذِه مجزومة بِلَمْ،",
        "video_link": null
      },
      {
        "ts": "19:02",
        "sec": 1142,
        "text": "والشرط الثالث ألا يلتقي بها ساكن،",
        "video_link": null
      },
      {
        "ts": "19:09",
        "sec": 1149,
        "text": "إن لم يكن أو كما قال إن لم يلقَها ساكن كما هنا {أَكُ بَغِيًّا} لا يوجد ساكن بعدها،",
        "video_link": null
      },
      {
        "ts": "19:19",
        "sec": 1159,
        "text": "ولا ضمير نصب ولا ضمير نصب في قوله،",
        "video_link": null
      },
      {
        "ts": "19:29",
        "sec": 1169,
        "text": "ولا ضمير نصب أي متصل كان أو بالنون فلا تُحذف النون",
        "video_link": null
      },
      {
        "ts": "19:37",
        "sec": 1177,
        "text": "في مثلاً في قول رسول الله صلى الله عليه وسلم في",
        "video_link": null
      },
      {
        "ts": "19:43",
        "sec": 1183,
        "text": "حديث الدجال المعروف: \"إِنْ يَكُنْهُ فَلَنْ تُسَلَّطَ عَلَيْهِ\"،",
        "video_link": null
      },
      {
        "ts": "19:52",
        "sec": 1192,
        "text": "لا تُحذف النون هنا مع توفر الشروط الأخرى؛ لأنه \"يَكُنْهُ\" هو هذِه مجزومة لأنها فعل الشرط \"يَكُنْ\"،",
        "video_link": null
      },
      {
        "ts": "20:00",
        "sec": 1200,
        "text": "وهذا كَانَ المضارع إذاً المضارع مجزوم وليس بعدها ساكن \"يَكُنْهُ\"،",
        "video_link": null
      },
      {
        "ts": "20:08",
        "sec": 1208,
        "text": "ولكن الإشكال وجود ضمير نصب متصل بها لأن \"يَكُنْهُ\" هو على الهاء ضمير في محل نصب؛",
        "video_link": null
      },
      {
        "ts": "20:20",
        "sec": 1220,
        "text": "فهنا لا يجوز حذف النون فلا تقول: \"إن يكه\".",
        "video_link": null
      },
      {
        "ts": "20:27",
        "sec": 1227,
        "text": "جميل، ومثال يعني قلنا الساكن \"حذفنا إن لم يلقَها",
        "video_link": null
      },
      {
        "ts": "20:36",
        "sec": 1236,
        "text": "ساكن\"، فإن لقيها ساكن لا تُحذف النون كذلك، كما في قول ربنا سبحانه وتعالى:",
        "video_link": null
      },
      {
        "ts": "20:43",
        "sec": 1243,
        "text": "{لَّمْ يَكُنِ اللَّهُ لِيَغْفِرَ لَهُمْ}؛ لا يقال \"لم يك الله ليغفر لهم\" بل تثبت",
        "video_link": null
      },
      {
        "ts": "20:52",
        "sec": 1252,
        "text": "النون وتُكسر لالتقاء الساكنين في مثل هذِه الحالة.",
        "video_link": null
      },
      {
        "ts": "20:59",
        "sec": 1259,
        "text": "عند التقاء الساكنين لا تحذف وتكسر، فيقال: {لَّمْ يَكُنِ اللَّهُ لِيَغْفِرَ لَهُمْ}، جميل.",
        "video_link": null
      },
      {
        "ts": "21:09",
        "sec": 1269,
        "text": "إذاً إذا توفرت هذِه الشروط الأربعة جاز حذف النون كما في {وَلَمْ أَكُ بَغِيًّا}؛ لَمْ: حرف نفي",
        "video_link": null
      },
      {
        "ts": "21:17",
        "sec": 1277,
        "text": "وجزم وقلب، أَكُ: فعل مضارع مجزوم بِلَمْ وعلامة جزمه السكون على النون،",
        "video_link": null
      },
      {
        "ts": "21:25",
        "sec": 1285,
        "text": "أين النون؟ المحذوفة تخفيفاً، السكون على النون المحذوفة تخفيفاً لأن أصله",
        "video_link": null
      },
      {
        "ts": "21:33",
        "sec": 1293,
        "text": "أكونُ، جُزم فصار \"لم أكنْ\" ثم حُذفت هذِه النون تخفيفاً.",
        "video_link": null
      },
      {
        "ts": "21:42",
        "sec": 1302,
        "text": "{وَلَا تَكُ فِي ضَيْقٍ}، {وَلَا تَكُ فِي ضَيْقٍ}؛ لا هذِه الناهية الجازمة، نفس الشيء أصلها تكونُ",
        "video_link": null
      },
      {
        "ts": "21:50",
        "sec": 1310,
        "text": "صارت \"ولا تكُ\". {وَإِن تَكُ حَسَنَةً يُضَاعِفْهَا}؛ الشيء نفسه، {وَإِن تَكُ}",
        "video_link": null
      },
      {
        "ts": "21:57",
        "sec": 1317,
        "text": "أصلها تكونُ، وهي فعل الشرط مجزوم فجاز حذف ماذا؟ حذف النون منها. انتهينا من",
        "video_link": null
      },
      {
        "ts": "22:06",
        "sec": 1326,
        "text": "كَانَ وأخواتها. الفصل الآخر متعلق بالحروف المشبهة بِلَيْسَ، قال: وأما الحروف المشبهة بِلَيْسَ فأربعة: مَا،",
        "video_link": null
      },
      {
        "ts": "22:15",
        "sec": 1335,
        "text": "ولَا، وإِنْ، ولَاتَ؛ فأما مَا فتعمل عمل لَيْسَ عند",
        "video_link": null
      },
      {
        "ts": "22:21",
        "sec": 1341,
        "text": "الحجازيين بشرط أن لا يقترن اسمها بِإِنْ، وأن لا يقترن خبرها بِإِلَّا، وأن لا يتقدم خبرها على",
        "video_link": null
      },
      {
        "ts": "22:31",
        "sec": 1351,
        "text": "اسمها، ولا معمول خبرها على اسمها إلا إذا كان المعمول ظرفاً أو جارّاً ومجروراً.",
        "video_link": null
      },
      {
        "ts": "22:38",
        "sec": 1358,
        "text": "فالمستوفية للشروط نحو: مَا زَيْدٌ ذَاهِباً عند الحجازيين؛ مَا: عاملة،",
        "video_link": null
      },
      {
        "ts": "22:48",
        "sec": 1368,
        "text": "زيدٌ: اسمها، ذاهباً: خبرها؛ فَمَا هذِه حرف",
        "video_link": null
      },
      {
        "ts": "22:55",
        "sec": 1375,
        "text": "يعمل عمل لَيْسَ، مَا زَيْدٌ ذَاهِباً كما لو قلت: لَيْسَ زَيْدٌ ذَاهِباً، لكن عند الحجازيين أما التميميون فيهملونها،",
        "video_link": null
      },
      {
        "ts": "23:04",
        "sec": 1384,
        "text": "واضح. وكقول الله سبحانه وتعالى: {مَا هَٰذَا بَشَرًا}؛",
        "video_link": null
      },
      {
        "ts": "23:10",
        "sec": 1390,
        "text": "إذاً مَا عاملة عمل لَيْسَ، هذا: اسمها اسم إشارة",
        "video_link": null
      },
      {
        "ts": "23:15",
        "sec": 1395,
        "text": "مبني في محل رفع اسم مَا، بشراً: خبر مَا منصوب",
        "video_link": null
      },
      {
        "ts": "23:22",
        "sec": 1402,
        "text": "وعلامة نصبه الفتحة الظاهرة. {مَّا هُنَّ أُمَّهَاتِهِمْ}؛ هنَّ: ضمير منفصل مبني في محل رفع اسم مَا",
        "video_link": null
      },
      {
        "ts": "23:32",
        "sec": 1412,
        "text": "المشبهة بِلَيْسَ، أمهاتِ: خبر مَا منصوب وعلامة نصبه الكسرة النائبة عن الفتحة لأنه",
        "video_link": null
      },
      {
        "ts": "23:42",
        "sec": 1422,
        "text": "جمع مؤنث سالم وهو مضاف، والهاء: مضاف إليه، والميم: علامة الجمع. إذن هذِه أمثلة",
        "video_link": null
      },
      {
        "ts": "23:50",
        "sec": 1430,
        "text": "على مَا توفرت فيه الشروط التي ذُكر من قبل. الآن تلك الشروط؛ لأنه قال بشرط أن لا",
        "video_link": null
      },
      {
        "ts": "23:59",
        "sec": 1439,
        "text": "تقترن خبر وإلى غير ذلك، الآن سيذكر أمثلة على ما لم تتوفر فيه هذِه الشروط؛ فأول ذلك",
        "video_link": null
      },
      {
        "ts": "24:08",
        "sec": 1448,
        "text": "شرط إِنْ قال: فإن اقترنت بِإِنْ بطل عملها، نحو:",
        "video_link": null
      },
      {
        "ts": "24:15",
        "sec": 1455,
        "text": "مَا إِنْ زَيْدٌ قَائِمٌ؛ مَا إِنْ زَيْدٌ قَائِمٌ، إِنْ هذِه زائدة",
        "video_link": null
      },
      {
        "ts": "24:24",
        "sec": 1464,
        "text": "فليست نافية بل هي زائدة تكف مَا عن العمل.",
        "video_link": null
      },
      {
        "ts": "24:31",
        "sec": 1471,
        "text": "أصل الكلام \"مَا زَيْدٌ قَائِماً\"، حين تدخل إِنْ زائدة الكافة يصبح: مَا إِنْ زَيْدٌ قَائِمٌ فلا تعمل.",
        "video_link": null
      },
      {
        "ts": "24:43",
        "sec": 1483,
        "text": "كذلك عدم توفر الشرط الثاني، وكذا إن اقترن",
        "video_link": null
      },
      {
        "ts": "24:48",
        "sec": 1488,
        "text": "خبرها بِإِلَّا، نحو: {وَمَا مُحَمَّدٌ إِلَّا رَسُولٌ}؛",
        "video_link": null
      },
      {
        "ts": "24:55",
        "sec": 1495,
        "text": "أصل ذلك لو أعملنا مَا أن نقول \"ما محمدٌ رسولاً\"، لكن",
        "video_link": null
      },
      {
        "ts": "25:03",
        "sec": 1503,
        "text": "\"رسولٌ\" وهو خبر مَا العاملة عمل لَيْسَ اقترن",
        "video_link": null
      },
      {
        "ts": "25:08",
        "sec": 1508,
        "text": "هذا الخبر بِإِلَّا، فحينئذٍ بطل عمل مَا ولم تعد تعمل عمل لَيْسَ، بل نقول محمدٌ: مبتدأ، ورسولٌ:",
