        "ts": "3:36",
        "sec": 216,
        "text": "سُنَّةٍ سَهْواً يُسَنْ *** قَبْلَ السَّلَامِ سَجْدَتَانِ أَوْ سُنَنْ *** إِنْ أُكِّدَتْ\". معنى هذا الكلام؛ يقول لك الناظم: مَن نقص",
        "video_link": null
      },
      {
        "ts": "3:53",
        "sec": 233,
        "text": "سنة مؤكدة أو سنتين",
        "video_link": null
      },
      {
        "ts": "3:59",
        "sec": 239,
        "text": "خفيفتين -هذا مشهور مذهب المالكية، يقولون: مَن نقص سنة",
        "video_link": null
      },
      {
        "ts": "4:07",
        "sec": 247,
        "text": "مؤكدة أو سنتين خفيفتين- يُشرع له أن يأتي بسجود",
        "video_link": null
      },
      {
        "ts": "4:15",
        "sec": 255,
        "text": "السهو. نحن الآن نتحدث عن الحالة الأولى التي هي حالة النقص؛ نقص المصلي من",
        "video_link": null
      },
      {
        "ts": "4:24",
        "sec": 264,
        "text": "صلاته. مَن نقص ركناً سوف يأتي الحديث عنه إن شاء الله؛ الركن لا يُجبر بسجود السهو، الركن",
        "video_link": null
      },
      {
        "ts": "4:31",
        "sec": 271,
        "text": "لا بد من الإتيان به وسيأتي الحديث عنه بعدُ إن شاء الله عز وجل، لكن من غير الأركان؛ مَن",
        "video_link": null
      },
      {
        "ts": "4:39",
        "sec": 279,
        "text": "نقص سنة مؤكدة أو سنتين خفيفتين (السنتين الخفيفتين المندوبات،",
        "video_link": null
      },
      {
        "ts": "4:47",
        "sec": 287,
        "text": "السنتين الخفيفتين السنن الخفيفة والمندوبات التي تقدمت معنا). السنن",
        "video_link": null
      },
      {
        "ts": "4:54",
        "sec": 294,
        "text": "المؤكدة هي التي رأيناها عند قول الناظم رحمه الله: سُنَّنُهَا السُّورَةُ بَعْدَ الْوَاقِيَهْ *** مَعَ الْقِيَامِ أَوَّلًا وَالثَّانِيَهْ جَهْرٌ وَسِرٌّ بِمَحَلٍّ لَهُمَا *** تَكْبِيرُهُ إِلَّا الَّذِي تَقَدَّمَا كُلُّ تَشَهُّدٍ جُلُوسٌ أَوَّلُ *** وَالثَّانِي لَا مَا لِلسَّلَامِ يَحْصُلُ وَسَمِعَ اللَّهُ لِمَنْ حَمِدَهُ *** فِي الرَّفْعِ مِنْ رُكُوعِهِ أَوْرَدَهُ الْفَذُّ وَالْإِمَامُ هَذَا أَكَّدَا ***",
        "video_link": null
      },
      {
        "ts": "5:21",
        "sec": 321,
        "text": "أي هذه سنن مؤكدة؛ وجمعها بعض علمائنا بقوله: سِينانِ شِينانِ ثُمَّ تَاءَانِ جِيمَانِ *** عَدُّ السُنَنِ الثَّمَانِ هي ثماني سنن مؤكدة: سِينانِ شِينانِ ثُمَّ جِيمَانِ تَاءَانِ *** عَدُّ سُنَنِ الثَّمَانِ",
        "video_link": null
      },
      {
        "ts": "5:46",
        "sec": 346,
        "text": "السينان: السورة والسر؛ السورة التي بعد الفاتحة",
        "video_link": null
      },
      {
        "ts": "5:54",
        "sec": 354,
        "text": "والسر. الشينان: التشهد الأول والتشهد",
        "video_link": null
      },
      {
        "ts": "6:04",
        "sec": 364,
        "text": "الثاني. الجيمان:",
        "video_link": null
      },
      {
        "ts": "6:09",
        "sec": 369,
        "text": "الجهر والجلوس للتشهد الأول والثاني؛ جلوس للتشهد (الجلوس)، إذاً الجهر والجلوس للتشهد",
        "video_link": null
      },
      {
        "ts": "6:19",
        "sec": 379,
        "text": "الأول والثاني. التاءان: التكبير من غير تكبيرة الإحرام،",
        "video_link": null
      },
      {
        "ts": "6:27",
        "sec": 387,
        "text": "التكبير والتسميع؛ \"مع الله لمن حمده\" (التكبير",
        "video_link": null
      },
      {
        "ts": "6:32",
        "sec": 392,
        "text": "والتسميع: سمع الله لمن حمده). إذاً هذه ثماني سنن هي السنن المؤكدة التي مَن ترك واحداً",
        "video_link": null
      },
      {
        "ts": "6:43",
        "sec": 403,
        "text": "منها سهواً يسجد للسهو، أو يقول أو ترك سنتين",
        "video_link": null
      },
      {
        "ts": "6:53",
        "sec": 413,
        "text": "خفيفتين أو مندوبين؛ مثلاً ترك التأمين",
        "video_link": null
      },
      {
        "ts": "7:01",
        "sec": 421,
        "text": "والتحميد، لم يقل آمين ولم يقل ربنا ولك الحمد؛ فمن ترك هذا يُسن له أن",
        "video_link": null
      },
      {
        "ts": "7:11",
        "sec": 431,
        "text": "يسجد سجدتين للسهو. وهاتان السجدتان تكونان",
        "video_link": null
      },
      {
        "ts": "7:18",
        "sec": 438,
        "text": "قبليتين؛ أي سجود يكون السجود قبلياً، لذلك قال رحمه الله: \"فَصْلٌ لِنَقْصِ سُنَّةٍ",
        "video_link": null
      },
      {
        "ts": "7:27",
        "sec": 447,
        "text": "سَهْواً يُسَنْ *** قَبْلَ السَّلَامِ سَجْدَتَانِ\". يدل على هذا حديث عبد الله بن بحينة رضي الله عنه في صحيح مسلم: \"أن رسول",
        "video_link": null
      },
      {
        "ts": "7:40",
        "sec": 460,
        "text": "الله صلى الله عليه وسلم مرة\" يعني كان يصلي الظهر أو العصر \"فَقَامَ فِي الشَّفْعِ\" ا",
        "video_link": null
      },
      {
        "ts": "7:49",
        "sec": 469,
        "text": "(وإن قام للركعة الثالثة) ولم يجلس للتشهد الأوسط، فسبَّح به الناس فلم يرجع صلى الله",
        "video_link": null
      },
      {
        "ts": "7:58",
        "sec": 478,
        "text": "عليه وسلم حتى إذا قضى صلاته وانتظر الناس",
        "video_link": null
      },
      {
        "ts": "8:04",
        "sec": 484,
        "text": "تسليمه، سجد سجدتين ثم سلَّم. هذا السجود",
        "video_link": null
      },
      {
        "ts": "8:09",
        "sec": 489,
        "text": "القبلي؛ يعني أنك تتشهد التشهد الأخير",
        "video_link": null
      },
      {
        "ts": "8:16",
        "sec": 496,
        "text": "قبل أن تسلّم تقول: \"الله أكبر\" وتسجد السجدة الأولى، ثم",
        "video_link": null
      },
      {
        "ts": "8:24",
        "sec": 504,
        "text": "تقوم، ثم تسجد السجدة الثانية، ثم تقوم وتسلّم. والمالكية يرجحون وغيرهم يرجحون",
        "video_link": null
      },
      {
        "ts": "8:31",
        "sec": 511,
        "text": "التشهد، وفيه كلام من الناحية الحديثية حيث يُرجح أنه شاذ كـ التشهد في هذا الموطن، فيسلم",
        "video_link": null
      },
      {
        "ts": "8:40",
        "sec": 520,
        "text": "الإنسان بعد ذلك؛ فهذا السجود القبلي دليله حديث عبد الله بن بحينة الذي",
        "video_link": null
      },
      {
        "ts": "8:49",
        "sec": 529,
        "text": "ذكرنا، فالرسول صلى الله عليه وسلم عنده نقص؛ ماذا ترك؟ ترك التشهد الأوسط، ترك",
        "video_link": null
      },
      {
        "ts": "8:56",
        "sec": 536,
        "text": "التشهد الأوسط وهو سنة مؤكدة وهو من سنن الصلاة المؤكدة فتركه،",
        "video_link": null
      },
      {
        "ts": "9:01",
        "sec": 541,
        "text": "فسجد سجدتين قبل السلام. قال رحمه الله: \"وَمَنْ يَزِدْ سَهْواً سَجَدْ *** بَعْدُ\".",
        "video_link": null
      },
      {
        "ts": "9:10",
        "sec": 550,
        "text": "\"وَمَنْ يَزِدْ سَهْواً سَجَدْ بَعْدُ\"؛ أي مَن زاد في صلاته",
        "video_link": null
      },
      {
        "ts": "9:18",
        "sec": 558,
        "text": "سهواً سجد أي بعد السلام، وهو الذي يُسمى السجود",
        "video_link": null
      },
      {
        "ts": "9:25",
        "sec": 565,
        "text": "البعدي؛ السجود البعدي.",
        "video_link": null
      },
      {
        "ts": "9:31",
        "sec": 571,
        "text": "دليله أن النبي صلى الله عليه وسلم مرة صلى الظهر",
        "video_link": null
      },
      {
        "ts": "9:36",
        "sec": 576,
        "text": "خمساً، صلى الظهر خمساً؛ فلما سلّم صلى الله عليه وسلم قيل له: \"أزيد في الصلاة؟\" قال له:",
        "video_link": null
      },
      {
        "ts": "9:44",
        "sec": 584,
        "text": "\"وَمَا ذَاكَ؟\" فأخبروه، فسجد سجدتين. ويدل عليه أيضاً حديث مشهور وهو حديث",
        "video_link": null
      },
      {
        "ts": "9:51",
        "sec": 591,
        "text": "ذي اليدين، وسيأتي معنا الـ ذكر بعض مسائله والعزو إليه إن شاء",
        "video_link": null
      },
      {
        "ts": "9:58",
        "sec": 598,
        "text": "الله عز وجل. حديث ذي اليدين، حديث ذي اليدين هذا: \"أن النبي صلى الله عليه وسلم صلى إحدى صلاتي",
        "video_link": null
      },
      {
        "ts": "10:06",
        "sec": 606,
        "text": "العَشِي الظهر أو العصر، فصلى صلى فسلَّم من ركعتين ثم قام صلى",
        "video_link": null
      },
      {
        "ts": "10:14",
        "sec": 614,
        "text": "الله عليه وسلم واستند إلى جذع في القبلة كالمغضب، وخرج سرعان الناس خرجوا من المسجد",
        "video_link": null
      },
      {
        "ts": "10:22",
        "sec": 622,
        "text": "وفي القوم أبو بكر وعمر فهابا أن يكلما رسول الله صلى الله عليه وسلم\" ويسألاه لِمَ صلى ركعتين؟ \"وفي القوم رجل يقال له ذو اليدين",
        "video_link": null
      },
      {
        "ts": "10:31",
        "sec": 631,
        "text": "-لأن كان في يديه طول- فقال: يا رسول الله أنسيتَ أم قصرتِ الصلاة؟ قال: كُلُّ ذَلِكَ لَمْ يَكُنْ\"",
        "video_link": null
      },
      {
        "ts": "10:39",
        "sec": 639,
        "text": "(يعني لم أنسَ ولم تقصر الصلاة)، قال: \"بلى يا رسول الله فإنك قد صليت ركعتين\"؛ فالتفت صلى الله عليه وسلم إلى أبي بكر وعمر والصحابة وقال: \"أَحَقٌّ",
        "video_link": null
      },
      {
        "ts": "10:48",
        "sec": 648,
        "text": "مَا يَقُولُ ذُو الْيَدَيْنِ؟\" قالوا: نعم؛ فكبر صلى الله عليه وسلم وصلى الركعتين المتبقيتين ثم سلّم، ثم سجد سجدتي",
        "video_link": null
      },
      {
        "ts": "10:58",
        "sec": 658,
        "text": "السهو؛ يعني عنده زيادة، زيادة السلام الذي زيد فـ",
        "video_link": null
      },
      {
        "ts": "11:07",
        "sec": 667,
        "text": "الـ سجد هنا صلى الله عليه وسلم السجدتين للسهو. إذاً عندما يكون النقص تسجد السجود القبلي،",
        "video_link": null
      },
      {
        "ts": "11:17",
        "sec": 677,
        "text": "وعندما تكون الزيادة تسجد البعدي. بعض فقهائنا الظرفاء جمعوا هذا في كلمة، هاد القاعدة",
        "video_link": null
      },
      {
        "ts": "11:25",
        "sec": 685,
        "text": "في كلمة سموها: **نَقْزَبْ**؛ نَقْزَبْ، النون: النقص، القاف: القبلي.",
        "video_link": null
      },
      {
        "ts": "11:34",
        "sec": 694,
        "text": "النون: النقص (عندك نقص في الصلاة)، القاف: تسجد القبلي. الزاي:",
        "video_link": null
      },
      {
        "ts": "11:41",
        "sec": 701,
        "text": "الزيادة، الباء: البعدي؛ فإذا كان النقص تصلي تسجد القبلي، وإذا كانت عندك الزيادة تسجد البعدي، فقالوا:",
        "video_link": null
      },
      {
        "ts": "11:50",
        "sec": 710,
        "text": "نَقْزَبْ. قال رحمه الله تعالى: \"إِنْ أُكِّدَتْ\"؛ قال: \"وَمَنْ يَزِدْ سَهْواً سَجَدْ بَعْدُ *** كَذَا وَالنَّقْصُ غَلَبْ\".",
        "video_link": null
      },
      {
        "ts": "12:05",
        "sec": 725,
        "text": "ثم قال: \"وَالنَّقْصُ غَلَبْ إِنْ وَرَدْ\"، \"وَالنَّقْصُ غَلَبْ إِنْ وَرَدْ\"؛",
        "video_link": null
      },
      {
        "ts": "12:12",
        "sec": 732,
        "text": "يعني دابا إحنا ذكرنا أن أنه أن في السهو ثلاث حالات: حالة النقص، وحالة الزيادة؛ الآن",
        "video_link": null
      },
      {
        "ts": "12:21",
        "sec": 741,
        "text": "حالة اجتماع الزيادة والنقص، الإنسان زاد شيئاً ونقص",
        "video_link": null
      },
      {
        "ts": "12:27",
        "sec": 747,
        "text": "شيئاً؛ زاد شيئاً ونقص شيئاً. فهذا الذي",
        "video_link": null
      },
      {
        "ts": "12:33",
        "sec": 753,
        "text": "زاد ونقص، قال الناظم رحمه الله: \"وَالنَّقْصُ غَلَبْ إِنْ وَرَدْ\"؛ يعني أنك تسجد",
        "video_link": null
      },
      {
        "ts": "12:44",
        "sec": 764,
        "text": "القبلي. مثلاً إنسان نقص",
        "video_link": null
      },
      {
        "ts": "12:51",
        "sec": 771,
        "text": "التأمين (لم يؤمِّن) وزاد القراءة في",
        "video_link": null
      },
      {
        "ts": "12:59",
        "sec": 779,
        "text": "الركوع، فاجتمع النقص والزيادة؛ يسجد القبلي، يسجد القبلي يغلب",
        "video_link": null
      },
      {
        "ts": "13:06",
        "sec": 786,
        "text": "جانب النقص؛ قال رحمه الله تعالى: \"وَالنَّقْصُ غَلَبْ إِنْ",
        "video_link": null
      },
      {
        "ts": "13:14",
        "sec": 794,
        "text": "وَرَدْ\". لكن بالمناسبة، لما نقول في النقص تسجد",
        "video_link": null
      },
      {
        "ts": "13:22",
        "sec": 802,
        "text": "القبلي وفي الزيادة تسجد البعدي، لا بد أن نشير إلى أنه ينوب كل من السجودين يعني الآخر؛ لو أن",
        "video_link": null
      },
      {
        "ts": "13:31",
        "sec": 811,
        "text": "إنساناً عنده نقص ويُشرع له أن يسجد سجودا",
        "video_link": null
      },
      {
        "ts": "13:39",
        "sec": 819,
        "text": "قبلياً ثم سلَّم، ولما يسجد بعدُ السجود القبلي يسجد بعد السلام صلاته صحيحة؛ لا",
        "video_link": null
      },
      {
        "ts": "13:47",
        "sec": 827,
        "text": "يؤتر. لو إنسان عنده زيادة ويُشرع له أن يسجد البعدي لكنه سجد",
        "video_link": null
      },
      {
        "ts": "13:56",
        "sec": 836,
        "text": "القبلي، صحت صلاته ولا إشكال؛ فكل من السجودين ينوب عن",
        "video_link": null
      },
      {
        "ts": "14:04",
        "sec": 844,
        "text": "الآخر. طيب هذه مسألة؛ مسألة أخرى: لا يتعدد السجود بتعدد السهو، لا",
        "video_link": null
      },
      {
        "ts": "14:12",
        "sec": 852,
        "text": "يتعدد السجود بتعدد السهو؛ مثلاً",
        "video_link": null
      },
      {
        "ts": "14:18",
        "sec": 858,
        "text": "إنسان -دعنا نقول- نسي ثلاث سنن",
        "video_link": null
      },
      {
        "ts": "14:25",
        "sec": 865,
        "text": "مؤكدة؛ ترك التسميع (لم يقل سمع الله لمن حمده)، وترك التشهد",
        "video_link": null
      },
      {
        "ts": "14:33",
        "sec": 873,
        "text": "الأوسط مثلاً، وترك إحدى التكبيرات؛ نسي ثلاث سنن",
        "video_link": null
      },
      {
        "ts": "14:41",
        "sec": 881,
        "text": "مؤكدة، طيب هو سنة مؤكدة واحدة يُشرع",
        "video_link": null
      },
      {
        "ts": "14:47",
        "sec": 887,
        "text": "لها سجود السهو، فالآن الآن تعدد سهوه هل يُشرع له أن يسجد ست سجدات لكل سنة",
        "video_link": null
      },
      {
        "ts": "14:58",
        "sec": 898,
        "text": "مؤكدة تركها سجدتان؟ لا، سجدتا",
        "video_link": null
      },
      {
        "ts": "15:05",
        "sec": 905,
        "text": "السهو تكفيانه وتجبران كل تلك السنن الثلاث المؤكدة التي",
        "video_link": null
      },
      {
        "ts": "15:13",
        "sec": 913,
        "text": "تركها. لو الإنسان زاد ثلاثة أشياء وأربعة أشياء، سجدتان تكفيان؛",
        "video_link": null
      },
      {
        "ts": "15:21",
        "sec": 921,
        "text": "فلا يتعدد السجود بتعدد السهو. ثم قال رحمه",
        "video_link": null
      },
      {
        "ts": "15:28",
        "sec": 928,
        "text": "الله: وَاسْتَدْرِكِ الْقَبْلِيَّ مَعْ قُرْبِ السَّلَامْ *** وَاسْتَدْرِكِ الْبَعْدِي وَلَوْ مِنْ بَعْدِ عَامْ",
        "video_link": null
      },
      {
        "ts": "15:36",
        "sec": 936,
        "text": "إنسان ترك سنة مؤكدة أو سنتين خفيفتين أو",
        "video_link": null
      },
      {
        "ts": "15:46",
        "sec": 946,
        "text": "أكثر، وحقه أن يسجد سجوداً قبلياً لكنه",
        "video_link": null
      },
      {
        "ts": "15:53",
        "sec": 953,
        "text": "سها وسلَّم ولم يتذكر السجود القبلي،",
        "video_link": null
      },
      {
        "ts": "16:02",
        "sec": 962,
        "text": "لم يسجده نسيه أيضاً؛ عليه أن يستدركه. قال",
        "video_link": null
      },
      {
        "ts": "16:11",
        "sec": 971,
        "text": "الناظم: \"وَاسْتَدْرِكِ الْقَبْلِيَّ مَعْ قُرْبِ السَّلَامْ\"؛ إذا سلَّمت وتتذكرته تأتي به إذا سلَّمت وتحركت وفعلت بعض الأشياء، إن كان الوقت",
        "video_link": null
      },
      {
        "ts": "16:25",
        "sec": 985,
        "text": "قريباً تستدرك وتأتي بالقبلي؛ فيُفهم من كلام الناظم رحمه الله أنه إذا",
        "video_link": null
      },
      {
        "ts": "16:32",
        "sec": 992,
        "text": "طال الفصل وطال الوقت ذهب وقت السجود (سجود القبلي) ولا تدركه ولا يؤثر،",
        "video_link": null
      },
      {
        "ts": "16:42",
        "sec": 1002,
        "text": "إن شاء الله الصلاة صحيحة؛ الإنسان فقط الهدف من السجود هو جبر الصلاة حتى تكون الصلاة",
        "video_link": null
      },
      {
        "ts": "16:49",
        "sec": 1009,
        "text": "كاملة. قال: \"وَاسْتَدْرِكِ الْبَعْدِي وَلَوْ مِنْ بَعْدِ عَامْ\"؛ \"وَاسْتَدْرِكِ الْبَعْدِي وَلَوْ مِنْ بَعْدِ عَامْ\". طيب،",
        "video_link": null
      },
      {
        "ts": "16:58",
        "sec": 1018,
        "text": "الإنسان صلى وحصلت له",
        "video_link": null
      },
      {
        "ts": "17:06",
        "sec": 1026,
        "text": "زيادة، فأرد أن يسجد السجود البعدي؛ فسلّم من صلاته ونسي أن يسجد السجود",
        "video_link": null
      },
      {
        "ts": "17:13",
        "sec": 1033,
        "text": "البعدي وقام، قام وذهب لحال سبيله؛ يقول الناظم: تستدرك سجود البعدي ولو مرَّ",
        "video_link": null
      },
      {
        "ts": "17:20",
        "sec": 1040,
        "text": "عام، يعني أنك متى تذكرت أنك لم تسجد سجود البعدي",
        "video_link": null
      },
      {
        "ts": "17:28",
        "sec": 1048,
        "text": "تسجده؛ قمت بعد ساعة بعد ساعتين تذكرت أنك لم تسجد السجود البعدي، تنزل وتسجد وتسجد",
        "video_link": null
      },
      {
        "ts": "17:36",
        "sec": 1056,
        "text": "السجود البعدي؛ فقال رحمه الله: \"وَاسْتَدْرِكِ الْبَعْدِي وَلَوْ مِنْ بَعْدِ عَامْ\" (ولو من بعد",
        "video_link": null
      },
      {
        "ts": "17:45",
        "sec": 1065,
        "text": "عام). أيضاً مما أُشير إليه أن الإنسان لو سها في سجود السهو، ما يحتاج أن",
        "video_link": null
      },
      {
        "ts": "17:56",
        "sec": 1076,
        "text": "يأتي بسجود السهو؛ سهو في السهو نفسه، سها فيه حصل فيه سهو، فلا يحتاج أن فلا يُجبر السهو",
        "video_link": null
      },
      {
        "ts": "18:03",
        "sec": 1083,
        "text": "في سجود السهو بسجود سهو آخر، بل ا يعني يتم",
        "video_link": null
      },
      {
        "ts": "18:09",
        "sec": 1089,
        "text": "فقط. قال رحمه الله: \"عَنْ مُقْتَدٍ يَحْمِلُ هَذَيْنِ الْإِمَامْ\"؛",
        "video_link": null
      },
      {
        "ts": "18:15",
        "sec": 1095,
        "text": "\"عَنْ مُقْتَدٍ يَحْمِلُ هَذَيْنِ الْإِمَامْ\"؛ يعني إذا سها",
        "video_link": null
      },
      {
        "ts": "18:23",
        "sec": 1103,
        "text": "المأموم، إذا سها المأموم زيادة أو نقصاً لا شيء",
        "video_link": null
      },
      {
        "ts": "18:30",
        "sec": 1110,
        "text": "عليه، المأموم إذا سها لا شيء عليه؛ سها فنقص من الصلاة شيئاً",
        "video_link": null
      },
      {
        "ts": "18:38",
        "sec": 1118,
        "text": "أو زاد. أكرر: لا نتحدث عن الفرائض (عن فرائض الصلاة)؛ فرائض الصلاة وأركان الصلاة هذه لها حكم سوف يأتي بعدُ إن شاء الله، إحنا",
        "video_link": null
      },
      {
        "ts": "18:45",
        "sec": 1125,
        "text": "نتكلم الآن في السنن؛ السنن المؤكدة والسنن الخفيفة، فإذا سها المأموم خلف",
        "video_link": null
      },
      {
        "ts": "18:52",
        "sec": 1132,
        "text": "إمامه فزاد أو نقص فلا شيء عليه إن شاء الله تعالى، يحمل الإمام يحمل عنه الإمام",
        "video_link": null
      },
      {
        "ts": "19:00",
        "sec": 1140,
        "text": "ذلك. ثم قال رحمه الله: وَبَطَلَتْ بِعَمْدِ نَفْخٍ أَوْ كَلَامْ ***",
        "video_link": null
      },
      {
        "ts": "19:07",
        "sec": 1147,
        "text": "الان انتقل الناظم رحمه الله للحديث عن مبطلات الصلاة، وبعدها سوف يرجع للحديث",
        "video_link": null
      },
      {
        "ts": "19:14",
        "sec": 1154,
        "text": "عن عن بعض الأحكام المتعلقة بسجود السهو إن شاء الله؛ قال رحمه الله: \"وَبَطَلَتْ بِعَمْدِ نَفْخٍ أَوْ كَلَامْ\". ما الذي يبطل الصلاة؟ مجموعة من المبطلات؛ قال: \"وَبَطَلَتْ بِعَمْدِ نَفْخٍ أَوْ كَلَامْ\".",
        "video_link": null
      },
      {
        "ts": "19:31",
        "sec": 1171,
        "text": "المبطل الأول: تعمد النفخ في الصلاة، تعمد النفخ في الصلاة؛ قال الناظم رحمه الله يبطل",
        "video_link": null
      },
      {
        "ts": "19:38",
        "sec": 1178,
        "text": "الصلاة. المبطل الثاني: تعمد الكلام؛ تعمد الكلام يبطل الصلاة",
        "video_link": null
      },
      {
        "ts": "19:47",
        "sec": 1187,
        "text": "بالإجماع، بإجماع العلماء. في الصحيحين",
        "video_link": null
      },
      {
        "ts": "19:54",
        "sec": 1194,
        "text": "ا من حديث من حديث عبد الله بن مسعود،عفواً من حديث زيد بن أرقم في الصحيحين؛ من حديث زيد بن أرقم رضي الله",
        "video_link": null
      },
      {
        "ts": "20:01",
        "sec": 1201,
        "text": "عنه، قال: \"كُنَّا نَتَكَلَّمُ فِي الصَّلَاةِ؛ يُكَلِّمُ الرَّجُلُ مِنَّا صَاحِبَهُ وَهُوَ إِلَى جَنْبِهِ فِي",
        "video_link": null
      },
      {
        "ts": "20:09",
        "sec": 1209,
        "text": "الصَّلَاةِ، حَتَّى نَزَلَتْ: {وَقُومُوا لِلَّهِ قَانِتِينَ}، فَأُمِرْنَا بِالسُّكُوتِ وَنُهِينَا عَنِ",
        "video_link": null
      },
      {
        "ts": "20:20",
        "sec": 1220,
        "text": "الْكَلَامِ\"؛ فهذا حديث يبين أن المسلمين كانوا في بداية أمرهم، في",
        "video_link": null
      },
      {
        "ts": "20:30",
        "sec": 1230,
        "text": "أول أمرهم يكلم بعضهم بعضاً في الصلاة، فلما نزلت الآية: {وَقُومُوا لِلَّهِ قَانِتِينَ} أُمروا بالسكوت ونُهوا عن الكلام.",
        "video_link": null
      },
      {
        "ts": "20:38",
        "sec": 1238,
        "text": "واتفق العلماء على أن الكلام في الصلاة مبطل لها؛ لأنه",
        "video_link": null
      },
      {
        "ts": "20:47",
        "sec": 1247,
        "text": "ينافي الصلاة والمطلوب فيها.",
        "video_link": null
      },
      {
        "ts": "20:55",
        "sec": 1255,
        "text": "ا قال: \"وَبَطَلَتْ بِعَمْدِ نَفْخٍ أَوْ كَلَامْ\"؛ قلنا تعمد الكلام، لماذا تعمد الكلام هو الذي",
        "video_link": null
      },
      {
        "ts": "21:03",
        "sec": 1263,
        "text": "يبطل الصلاة؟ تعمد الكلام هو يبطل الصلاة، أما أما الكلام سهواً فهذا لا يبطل الصلاة؛ الكلام سهواً أو نسياناً أو جهلاً لا يبطل",
        "video_link": null
      },
      {
        "ts": "21:11",
        "sec": 1271,
        "text": "الصلاة، بدليل حديث معاوية بن الحكم السلمي رضي الله عنه؛ هذا رجل قصته مشهورة أنه ا",
        "video_link": null
      },
      {
        "ts": "21:19",
        "sec": 1279,
        "text": "جاء إلى المدينة ودخل يصلي مع رسول الله صلى الله عليه وسلم في",
        "video_link": null
      },
      {
        "ts": "21:25",
        "sec": 1285,
        "text": "المسجد، فعطس أحد القوم (أحد المصلين عطس)؛ فمعاوية بن الحكم السلمي رضي الله عنه",
        "video_link": null
      },
      {
        "ts": "21:34",
        "sec": 1294,
        "text": "قال له: \"يرحمك الله\" (كلام في الصلاة). يقول: \"فرماني القوم بأبصارهم\" يعني الناس نظرت إليه نظرة نظرة",
        "video_link": null
      },
      {
        "ts": "21:43",
        "sec": 1303,
        "text": "شَزْر، يعني كانوا يلومونه لِمَا تكلمت في الصلاة؛ فهو رأى الجميع رماه رماه القوم",
        "video_link": null
      },
      {
        "ts": "21:52",
        "sec": 1312,
        "text": "بأبصارهم، فـ فقال: \"واثُكْلَ أُمِّيَاهْ! مَا شَأْنُكُمْ تَنْظُرُونَ إِلَيَّ؟\" (يعني مم تنظرون إليَّ؟) فهم نظروا إليه تلك النظرة الحادة ليسكت فزاد في الكلام؛ قال: \"فجعلوا",
        "video_link": null
      },
      {
        "ts": "22:06",
        "sec": 1326,
        "text": "يضربون بأيديهم على أفخاذهم يصمتونني\" يقول يعني اصمت،",
        "video_link": null
      },
      {
        "ts": "22:13",
        "sec": 1333,
        "text": "فسكتُّ. فلما انتهت الصلاة نداه صلى الله عليه وسلم وقاله (هو أراد أن يرد عليهم لكنه قرر أن يسكت فلما انتهت الصلاة)؛",
        "video_link": null
      },
      {
        "ts": "22:22",
        "sec": 1342,
        "text": "قال: \"فَدَعَانِي رَسُولُ اللَّهِ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ، فَبِأَبِي هُوَ وَأُمِّي مَا رَأَيْتُ مُعَلِّماً أَفْضَلَ مِنْهُ؛ فَوَاللَّهِ مَا كَهَرَنِي وَلَا نَهَرَنِي وَلَا ضَرَبَنِي،",
        "video_link": null
      },
      {
        "ts": "22:31",
        "sec": 1351,
        "text": "وَإِنَّمَا قَالَ لِي: إِنَّ هَذِهِ الصَّلَاةَ لَا يَصْلُحُ فِيهَا شَيْءٌ مِنْ كَلَامِ النَّاسِ، إِنَّمَا هِيَ التَّسْبِيحُ وَالتَّكْبِيرُ وَقِرَاءَةُ الْقُرْآنِ\" أو كما قال صلى الله عليه وسلم؛",
        "video_link": null
      },
      {
        "ts": "22:39",
        "sec": 1359,
        "text": "فهذا فالرسول صلى الله عليه وسلم لم يأمره بإعادة الصلاة؛ لأن كلامه لم يكن عمداً. طيب أرجع إلى قضية",
        "video_link": null
      },
      {
        "ts": "22:47",
        "sec": 1367,
        "text": "النفخ؛ لماذا لماذا يعتبر المالكية رحمه الله عليهم النفخ مبطلاً؟ يعتبرونه",
        "video_link": null
      },
      {
        "ts": "22:54",
        "sec": 1374,
        "text": "مبطلاً لأنه في النفخ عادة تظهر بعض الحروف، فقالوا: إذا ظهرت الحروف فإذن هذا كلام،",
        "video_link": null
      },
      {
        "ts": "23:02",
        "sec": 1382,
        "text": "وهذا حق؛ إذا نفخ الإنسان فظهرت حروف، فإذا ظهرت الحروف هذا كلام؛ فتعمد",
        "video_link": null
      },
      {
        "ts": "23:10",
        "sec": 1390,
        "text": "النفخ إذاً تعمد النفخ فظهرت حروف هذا كلام يبطل الصلاة. لكن لو نفخ ولم لم تظهر حروف،",
        "video_link": null
      },
      {
        "ts": "23:20",
        "sec": 1400,
        "text": "لوجه القول ببطلان الصلاة في هذه الحالة؟ خصوصاً أن النبي صلى الله عليه وسلم ثبت عنه أنه في صلاة الكسوف نفخ؛ نفخ صلى الله",
        "video_link": null
      },
      {
        "ts": "23:28",
        "sec": 1408,
        "text": "عليه وسلم في صلاة الكسوف لأنه عُرضت عليه النار فنفخ صلى الله عليه وسلم؛ فالنفخ إذا لم تظهر الحروف لا يبطل",
        "video_link": null
      },
      {
        "ts": "23:37",
        "sec": 1417,
        "text": "الصلاة ولو تعمده الإنسان، لكن لو ظهرت بعض الحروف فهنا لأن هذا يؤول إلى قضية الكلام.",
        "video_link": null
      },
      {
        "ts": "23:44",
        "sec": 1424,
        "text": "قال رحمه الله: \"وَبَطَلَتْ بِعَمْدِ نَفْخٍ أَوْ كَلَامْ لِغَيْرِ إِصْلَاحٍ\"؛ لِغير إصلاح؛ أي الكلام الكلام المتعمد الذي",
        "video_link": null
      },
      {
        "ts": "23:55",
        "sec": 1435,
        "text": "يبطل الصلاة هو الذي يكون لغير إصلاح الصلاة، لغير إصلاح الصلاة؛",
        "video_link": null
      },
      {
        "ts": "24:03",
        "sec": 1443,
        "text": "فإذا كان تعمد الكلام لإصلاح الصلاة، هذا لا يبطل الصلاة.",
        "video_link": null
      },
      {
        "ts": "24:10",
        "sec": 1450,
        "text": "مثلاً إمام يصلي ا بدل أن يقوم للركعة",
        "video_link": null
      },
      {
        "ts": "24:18",
        "sec": 1458,
        "text": "الرابعة، جلس في الركعة الثالثة وبدأ يتشهد التشهد الأخير؛ فقلت له: \"سبحان الله، سبحان الله\"",
        "video_link": null
      },
      {
        "ts": "24:26",
        "sec": 1466,
        "text": "ليقوم ليأتي بالركعة الرابعة، لكنه لم",
        "video_link": null
      },
      {
        "ts": "24:32",
        "sec": 1472,
        "text": "يفهم؛ فيصح أن تقول له: \"قم للركعة الرابعة فقد صليت ثلاثاً",
        "video_link": null
      },
      {
        "ts": "24:39",
        "sec": 1479,
        "text": "فقط\". هنا كلام هذا لإصلاح الصلاة لا يؤثر في الصلاة ولا يبطلها،",
        "video_link": null
      },
      {
        "ts": "24:47",
        "sec": 1487,
        "text": "دليله حديث ذي اليدين الذي ذكرناه آنفاً؛ فذو اليدين تكلم مع رسول الله صلى الله عليه وسلم، والرسول صلى الله عليه وسلم كلم",
        "video_link": null
      },
      {
        "ts": "24:57",
        "sec": 1497,
        "text": "الناس ثم أتموا صلاتهم، ولم يقول لم يقل صلى الله عليه وسلم: \"الآن تكلمنا فنعيد",
        "video_link": null
      },
      {
        "ts": "25:04",
        "sec": 1504,
        "text": "الصلاة من الأول\" لا؛ فالرسول صلى الله عليه وسلم أتى بركعتين فقط، الركعتين الأخيرتين",
        "video_link": null
      },
      {
        "ts": "25:10",
        "sec": 1510,
        "text": "فقط. فهنا هذا الكلام الذي حصل فهو الواقع وقع أثناء الصلاة (وسط الصلاة)، لأن صلّى",
        "video_link": null
      },
      {
        "ts": "25:18",
        "sec": 1518,
        "text": "النبي صلى الله عليه وسلم الركعتين الأوليتين ثم ركعتين الأخيرتين؛ فهذا كلام حصل وسط الصلاة ولكنه كلام لإصلاح الصلاة فلم",
        "video_link": null
      },
      {
        "ts": "25:26",
        "sec": 1526,
        "text": "يؤثر. قال رحمه الله: \"لِغَيْرِ إِـ\" لِغير",
        "video_link": null
      },
      {
        "ts": "25:33",
        "sec": 1533,
        "text": "إصلاح، ثم قال: لِغَيْرِ إِصْلَاحٍ وَبِالْمُشْغِلِ عَنْ *** فَرْضٍ وَفِي الْوَقْتِ أَعِدْ إِذَا يُسَنْ \\وَحَدَثٍ وَسَهْوِ زَيْدِ الْمِثْلِ مَعْ *** قَهْقَهَةٍ وَعَمْدِ شُرْبٍ أَكْلٍ دَعْ وَعَمْدِ سَجْدَةٍ قَيْءٍ وَذِكْرِ فَرْضِ *** أَقَلَّ مِنْ سِتٍّ كَذِكْرِ الْبَعْضِ وَفَوْتِ قَبْلِيٍّ ثَلَاثَ سُنَنِ *** بِفَصْلِ مَسْجِدٍ كَطُولِ الزَّمَنِ",
        "video_link": null
      },
      {
        "ts": "25:40",
        "sec": 1540,
        "text": "المبطل الثالث: حدوث ما يشغل في الصلاة، أو ما يشغل عن الصلاة -بعبارة أدق- حدوث",
        "video_link": null
      },
      {
        "ts": "25:48",
        "sec": 1548,
        "text": "ما يشغل عن الصلاة.",
        "video_link": null
      },
      {
        "ts": "25:54",
        "sec": 1554,
        "text": "ا ما يشغل عن الصلاة إما أن يشغل عن فرض، وإما أن يشغل عن سنة؛ إذا أشغل عن فرض بطلت",
        "video_link": null
      },
      {
        "ts": "26:04",
        "sec": 1564,
        "text": "الصلاة، إذا أشغل عن سنة تُستحب الإعادة؛ إذاً قال رحمه الله: \"وِبِالْمُشْغِلِ عَنْ فَرْضٍ\". مثال",
        "video_link": null
      },
      {
        "ts": "26:12",
        "sec": 1572,
        "text": "المشغل عن فرض: مثلاً لو إنسان شغله مدافعة الأخبثين عن الطمأنينة وعن الاعتدال -وهما",
        "video_link": null
      },
      {
        "ts": "26:21",
        "sec": 1581,
        "text": "من أركان الصلاة- الصلاة بطلت؛ كان يدافع الأخبثين كان حاقناً يحتاج",
        "video_link": null
      },
      {
        "ts": "26:28",
        "sec": 1588,
        "text": "إلى البول أو الغائط، ولذلك النبي صلى الله عليه وسلم نهى عن الصلاة أن يصلي الإنسان وهو يدافع الأخبثين؛ فأسرع في صلاته فلم",
        "video_link": null
      },
      {
        "ts": "26:37",
        "sec": 1597,
        "text": "يعتدل ولم يطمئن، هنا بطلت الصلاة. قال: \"وَفِي الْوَقْتِ أَعِدْ إِذَا يُسَنْ\"؛ أي إذا شُغل عن أمر",
        "video_link": null
      },
      {
        "ts": "26:45",
        "sec": 1605,
        "text": "مسنون يُشرع له أن يعيد في الوقت، لما يقول المالكية رحمه الله عليهم \"تعيد في الوقت\" أي أن الإعادة",
        "video_link": null
      },
      {
        "ts": "26:53",
        "sec": 1613,
        "text": "مستحبة. ثم قال: \"وَحَدَثٍ\"؛ أي مما يبطل الصلاة الحدث، والحدث هذا من مبطلات الصلاة باتفاق",
        "video_link": null
      },
      {
        "ts": "27:01",
        "sec": 1621,
        "text": "وبإجماع، وتقدم معنا ذكر الأدلة أدلة هذا في أبواب الطهارات؛ يقول النبي صلى",
        "video_link": null
      },
      {
        "ts": "27:09",
        "sec": 1629,
        "text": "الله عليه وسلم: \"لَا يَقْبَلُ اللَّهُ صَلَاةَ أَحَدِكُمْ إِذَا أَحْدَثَ حَتَّىٰ يَتَوَضَّأَ\". وسُئل صلى الله عليه وسلم عن الرجل يجد",
        "video_link": null
      },
      {
        "ts": "27:16",
        "sec": 1636,
        "text": "شيئاً في صلاته، فقال صلى الله عليه وسلم: \"لَا يَنْفَتِلْ -أَوْ لَا يَنْصَرِفْ- حَتَّىٰ يَسْمَعَ صَوْتاً أَوْ يَجِدَ رِيحاً\". طيب.",
        "video_link": null
      },
      {
        "ts": "27:25",
        "sec": 1645,
        "text": "قال: \"وَسَهْوِ زَيْدِ الْمِثْلِ\". المبطل الخامس: زيادة",
        "video_link": null
      },
      {
        "ts": "27:30",
        "sec": 1650,
        "text": "المثل؛ ما معنى زيادة المثل؟ زيادة مثل الصلاة؛ زيادة مثل الصلاة: \"زَيْدِ الْمِثْلِ\". مثلاً",
        "video_link": null
      },
      {
        "ts": "27:40",
        "sec": 1660,
        "text": "الصبح ركعتان هو صلى أربع ركعات سهواً (بزاف على السهو، هذا سهو كثير يعني",
        "video_link": null
      },
      {
        "ts": "27:48",
        "sec": 1668,
        "text": "هذا واضح أنه أنه لاهٍ جداً). الظهر أربع ركعات فهو صلى ثماني ركعات زاد أربع ركعات",
        "video_link": null
      },
      {
        "ts": "27:57",
        "sec": 1677,
        "text": "كلها؛ كثير هذا كأنه لم يصلِّ، فهذا يعيد الصلاة. هذا هو المقصد بقوله بقوله: \"وَسَهْوِ زَيْدِ الْمِثْلِ\"؛ أي زاد مثل الصلاة؛ صلى المغرب ست ركعات، صلى العشاء ثماني ركعات، صلى الصبح أربع ركعات؛ فهذا يعيد",
        "video_link": null
      },
      {
        "ts": "28:16",
        "sec": 1696,
        "text": "الصلاة. قال رحمه الله تعالى: \"مَعْ قَهْقَهَةٍ\"؛ القهقهة هي الضحك بصوت مسموع، الضحك",
        "video_link": null
      },
      {
        "ts": "28:25",
        "sec": 1705,
        "text": "بصوت مسموع؛ هذه تبطل الصلاة بالإجماع؛ قال: \"مَعْ قَهْقَهَةٍ\". مَن ضحك في الصلاة بصوت مسموع هذه القهقهة تبطل الصلاة بالإجماع، هذه أغلظ من",
        "video_link": null
      },
      {
        "ts": "28:39",
        "sec": 1719,
        "text": "الكلام؛ إذا كانت الصلاة تبطل بتعمد الكلام، ستبطل بالـ القهقهة؛ فالقهقهة أغلظ",
        "video_link": null
      },
      {
        "ts": "28:47",
        "sec": 1727,
        "text": "من الكلام ولأنها تدل على على الخروج عن هيئة الصلاة. ولو رأيت إنساناً يقهقه ما",
        "video_link": null
      },
      {
        "ts": "28:55",
        "sec": 1735,
        "text": "تظن أنه يصلي؛ يصلي تيلعب، فيعيد الصلاة؛ بخلاف التبسم، الإنسان تذكر الشيطان وذكَّره",
        "video_link": null
      },
      {
        "ts": "29:03",
        "sec": 1743,
        "text": "بشيء فتبسم، فالتبسم هذا الخفيف لا يؤثر لا يبطل الصلاة لا يبطل، وإلا فهو لا ينبغي",
        "video_link": null
      },
      {
        "ts": "29:11",
        "sec": 1751,
        "text": "ولا يبطل الصلاة؛ لكن القهقهة تبطل الصلاة. قال: \"مَعْ قَهْقَهَةٍ وَعَمْدِ شُرْبٍ أَكْلٍ دَعْ\"؛ أي",
        "video_link": null
      },
      {
        "ts": "29:20",
        "sec": 1760,
        "text": "تعمد الأكل والشرب، هذا المبطل السابع: تعمد الأكل والشرب، وهذا بالإجماع أيضاً؛ أجمع",
        "video_link": null
      },
      {
        "ts": "29:28",
        "sec": 1768,
        "text": "علماء المسلمين على أن تعمد الأكل والشرب مبطل للصلاة وهذا بالإجماع. ولأن هذا",
        "video_link": null
      },
      {
        "ts": "29:36",
        "sec": 1776,
        "text": "أغلظ من الكلام أيضاً، ولأنه خارج عن جنس الصلاة؛ والإجماع حجة كما لعلكم رأيتم في الأصول،",
        "video_link": null
      },
      {
        "ts": "29:43",
        "sec": 1783,
        "text": "فالإجماع من من الأدلة الشرعية من الحجج؛ إذاً",
        "video_link": null
      },
      {
        "ts": "29:51",
        "sec": 1791,
        "text": "\"وَعَمْدِ شُرْبٍ أَكْلٍ\". قال: \"وَعَمْدِ شُرْبٍ أَكْلٍ دَعْ وَعَمْدِ سَجْدَةٍ\"؛",
        "video_link": null
      },
      {
        "ts": "29:58",
        "sec": 1798,
        "text": "\"وَعَمْدِ سَجْدَةٍ\" يشير بها إلى المبطل الثامن،",
        "video_link": null
      },
      {
        "ts": "30:04",
        "sec": 1804,
        "text": "وهو تعمد زيادة ركن في الصلاة؛ لأنه قال: \"وَعَمْدِ شُرْبٍ أَكْلٍ دَعْ وَعَمْدِ سَجْدَةٍ\"؛ أي وعمد سجدة تعمد زيادة ركن في الصلاة. مثلاً تعمد أن يزيد",
        "video_link": null
      },
      {
        "ts": "30:19",
        "sec": 1819,
        "text": "سجدة فصلى ثلاث سجدات، أو تعمد أن يزيد ركوعاً ركع ركوعين؛ فمن تعمد زيادة ركن في",
        "video_link": null
      },
      {
        "ts": "30:29",
        "sec": 1829,
        "text": "الصلاة بطلت صلاته، لماذا؟ لأن هذه ليست الصلاة المفروضة المشروعة والمفروضة التي شرعها رسول الله صلى الله عليه وسلم، وقد قال صلى الله عليه وسلم: \"مَنْ عَمِلَ عَمَلاً لَيْسَ عَلَيْهِ أَمْرُنَا فَهُوَ رَدٌّ\"؛ فهنا ذكره للسجدة هذا من باب التمثيل فقط،",
        "video_link": null
      },
      {
        "ts": "30:45",
        "sec": 1845,
        "text": "من باب التمثيل فقط، وإلا فزيادة ركن عمداً مبطل",
        "video_link": null
      },
      {
        "ts": "30:53",
        "sec": 1853,
        "text": "بالصلاة. قال: \"وَعَمْدِ سَجْدَةٍ قَيْءٍ\"؛ أي وتعمد القيء، فتعمد القيء أيضاً مبطل للصلاة لأنه ليس من",
        "video_link": null
      },
      {
        "ts": "31:01",
        "sec": 1861,
        "text": "جنس الصلاة؛ في الصلاة ويتعمد أن يقيء، هذا ليس هذا من مبطلات الصلاة. قال: \"وَذِكْرِ فَرْضٍ أَقَلَّ مِنْ سِتٍّ كَذِكْرِ الْبَعْضِ\"؛ وذكر فرض أقل من ست كذكر بعضه؛ هذه مسألة تحتاج إلى شيء من التركيز بارك الله",
        "video_link": null
      },
      {
        "ts": "31:19",
        "sec": 1879,
        "text": "فيكم، وهي تذكر أقل من ست صلوات أثناء الصلاة. نحن ذكرنا من قبل أن الفرض قال: \"وَالْفَرْضُ يُقْضَى أَبَداً وَبِالتَّوَالْ\"؛ إنسان نسي الصلاة مفروضة",
        "video_link": null
      },
      {
        "ts": "31:34",
        "sec": 1894,
        "text": "فيقضيها. لو الإنسان نسي صلاة -حتى نبهم كل حال كل حاجة تُفهم في",
        "video_link": null
      },
      {
        "ts": "31:42",
        "sec": 1902,
        "text": "موضعها- لو إنسان مثلاً نسي صلاة الظهر ثم صلى العصر صلى المغرب صلى العشاء؛",
        "video_link": null
      },
      {
        "ts": "31:49",
        "sec": 1909,
        "text": "بعد صلاة العشاء تذكر أنه لم يصلي الظهر، هذا ماذا يفعل؟ يصلي الظهر لقوله صلى الله عليه وسلم: \"مَنْ نَسِيَ صَلَاةً أَوْ نَامَ عَنْهَا فَلْيُصَلِّهَا إِذَا ذَكَرَهَا\"؛ فيصلي الظهر لوحدها. لكن لو",
        "video_link": null
      },
      {
        "ts": "32:07",
        "sec": 1927,
        "text": "أن إنساناً تذكر أثناء الصلاة؛ وهو يصلي العشاء فتذكر",
        "video_link": null
      },
      {
        "ts": "32:16",
        "sec": 1936,
        "text": "أنه نسي الظهر والعصر والمغرب، تبطل صلاة العشاء؛ لماذا تبطل صلاة",
        "video_link": null
      },
      {
        "ts": "32:24",
        "sec": 1944,
        "text": "العشاء؟ لأن الترتيب واجب؛ ترتيب أداء الصلوات وقضائها واجب،",
        "video_link": null
      },
      {
        "ts": "32:32",
        "sec": 1952,
        "text": "فتبطل صلاة العشاء التي التي هو فيها تبطل، فينبغي أن يخرج من",
        "video_link": null
      },
      {
        "ts": "32:39",
        "sec": 1959,
        "text": "صلاته فيصلي الظهر والعصر والمغرب ويصلي العشاء. بالمناسبة هنا ما لم يكن مأموماً؛",
        "video_link": null
      },
      {
        "ts": "32:48",
        "sec": 1968,
        "text": "إذا كان مأموماً هذا الحكم خاص بالإمام والمنفرد، أما الماموم فيتم مع صلاته نافلة",
        "video_link": null
      },
      {
        "ts": "32:56",
        "sec": 1976,
        "text": "بنية النافلة (غيكمل بنية النافلة)، وبعد أن تنتهي الصلاة يقوم فيصلي الظهر والعصر والمغرب والعشاء. لكن ما وجه قولنا: تذكر",
        "video_link": null
      },
      {
        "ts": "33:05",
        "sec": 1985,
        "text": "أقل من ست صلوات أثناء صلاة؟ لماذا قال: \"وَذِكْرِ فَرْضٍ أَقَلَّ مِنْ سِتٍّ\"؟ يعني لو هناك إنسان",
        "video_link": null
      },
      {
        "ts": "33:14",
        "sec": 1994,
        "text": "نسي خمس صلوات أو أقل؛ إنسان نسي ست صلوات أو",
        "video_link": null
      },
      {
        "ts": "33:20",
        "sec": 2000,
        "text": "أكثر، قالوا يقول فقهاؤنا: لو نسي خمس صلوات فاقل تبطل الصلاة التي هو",
        "video_link": null
      },
      {
        "ts": "33:29",
        "sec": 2009,
        "text": "فيها، لماذا؟ لأن هذا العدد يقول عدد قليل لا",
        "video_link": null
      },
      {
        "ts": "33:35",
        "sec": 2015,
        "text": "يؤثر. مثلاً نفترض أنه نسي عشاء البارحة، والصبح اليوم، وظهره، وعصره،",
        "video_link": null
      },
      {
        "ts": "33:43",
        "sec": 2023,
        "text": "ومغربه؛ وبدأ يصلي صلاة العشاء ثم تذكر (المهم قد يقع هذا، المهم فتذكر الإنسان)",
        "video_link": null
      },
      {
        "ts": "33:52",
        "sec": 2032,
        "text": "فهنا وهو صلاة العشاء تذكر، يقطع صلاة العشاء بطلت صلاته؛ فيأتي بعشاء الأمس،",
        "video_link": null
      },
      {
        "ts": "34:00",
        "sec": 2040,
        "text": "والصبح، والظهر، والعصر، والمغرب، والعشاء (الترتيب). لكن لو نسي ست صلوات أو سبعاً أو أكثر، وهو يصلي صلاة العشاء تذكر أن عليه",
        "video_link": null
      },
      {
        "ts": "34:10",
        "sec": 2050,
        "text": "ست صلوات لم يؤدها، قالوا: يستمر في صلاته ولا تبطل صلاته، وبعد أن ينتهي من صلاته",
        "video_link": null
      },
      {
        "ts": "34:17",
        "sec": 2057,
        "text": "يأتي بتلك الصلوات؛ لأن هذا اعتبروه عدداً كثيراً، فـ بعد أن ينهي صلاته يأتي بتلك",
        "video_link": null
      },
      {
        "ts": "34:25",
        "sec": 2065,
        "text": "الصلوات الست أو السبع أو الأكثر التي يلزمه قضاؤها؛ فأرجو أن تكون المسألة قد اتضحت إن",
        "video_link": null
      },
      {
        "ts": "34:32",
        "sec": 2072,
        "text": "شاء الله. قال رحمه الله: \"وَذِكْرِ فَرْضٍ أَقَلَّ مِنْ سِتٍّ كَذِكْرِ الْبَعْضِ\".",
        "video_link": null
      },
      {
        "ts": "34:41",
        "sec": 2081,
        "text": "ثم قال: \"وَفَوْتِ قَبْلِيٍّ ثَلَاثَ سُنَنِ *** بِفَصْلِ مَسْجِدٍ كَطُولِ الزَّمَنِ\"؛",
        "video_link": null
      },
      {
        "ts": "34:50",
        "sec": 2090,
        "text": "يعني قال هنا: \"وَفَوْتِ",
        "video_link": null
      },
      {
        "ts": "34:58",
        "sec": 2098,
        "text": "قَبْلِيٍّ\"؛ فوت لا عفوأً قبلها عفواً قبلها قال: \"كَذِكْرِ الْبَعْضِ\"؛ كذكر",
        "video_link": null
      },
      {
        "ts": "35:13",
        "sec": 2113,
        "text": "البعض؛ أي ذكر بعض صلاة نسيه. مثلاً هو الآن يصلي صلاة",
        "video_link": null
      },
      {
        "ts": "35:23",
        "sec": 2123,
        "text": "العشاء، تذكر أنه في صلاة المغرب نسي الركوع؛ نسي الركوع من الركعة الثانية في",
        "video_link": null
      },
      {
