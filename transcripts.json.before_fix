        "citation": "باب المفعول به؛ قال: وهو الاسم الذي يقع عليه الفعل... وقد يضمر وجوباً، وذلك في مواضع؛ منها: باب الاشتغال.",
        "explanation": "عرّف الشيخ المفعول به كاسم يقع عليه الفعل، ثم انتقل لمسألة الاشتغال موضحاً حالات تقدم الاسم على عامل يشتغل بضميره، مؤكداً مذهب البصريين في أن الاسم المتقدم حينئذٍ يُنصب بفعل محذوف وجوباً يفسره المذكور.",
        "video_link": null,
        "search_text": "المفعول به: تعريفه وأحكامه وباب الاشتغال باب المفعول به؛ قال: وهو الاسم الذي يقع عليه الفعل... وقد يضمر وجوباً، وذلك في مواضع؛ منها: باب الاشتغال. عرّف الشيخ المفعول به كاسم يقع عليه الفعل، ثم انتقل لمسألة الاشتغال موضحاً حالات تقدم الاسم على عامل يشتغل بضميره، مؤكداً مذهب البصريين في أن الاسم المتقدم حينئذٍ يُنصب بفعل محذوف وجوباً يفسره المذكور."
      }
    ],
    "video_url": null,
    "segments": [
      {
        "ts": "0:00",
        "sec": 0,
        "text": "بسم الله الرحمن الرحيم، الحمد لله رب العالمين، وصلى الله وسلم وبارك على نبينا",
        "video_link": null
      },
      {
        "ts": "0:06",
        "sec": 6,
        "text": "محمد وعلى آله وصحبه والتابعين، ومن تبعهم بإحسان إلى يوم الدين.",
        "video_link": null
      },
      {
        "ts": "0:14",
        "sec": 14,
        "text": "قال فصل: وأما ظَنَّ وأخواتها فإنها تدخل بعد استيفاء فاعلها على المبتدأ والخبر",
        "video_link": null
      },
      {
        "ts": "0:23",
        "sec": 23,
        "text": "فتنصبهما على أنهما مفعولان لها. تدخل على المبتدأ والخبر بعد استيفاء",
        "video_link": null
      },
      {
        "ts": "0:30",
        "sec": 30,
        "text": "فاعلها، لا بد لها من فاعل أولاً؛ مثلاً: ظَنَنْتُ زَيْداً قَائِماً، أصلها مبتدأ وخبر هو:",
        "video_link": null
      },
      {
        "ts": "0:39",
        "sec": 39,
        "text": "زَيْدٌ قَائِمٌ، ثم دخلت ظَنَّ ومعها فاعلها \"ظَنَنْتُ\" أو",
        "video_link": null
      },
      {
        "ts": "0:45",
        "sec": 45,
        "text": "ظَنَنْتَ أو ظَنَّ؛ يعني بغض النظر عن الفاعل ما هو، فتستوفي فاعلها ثم تدخل على المبتدأ",
        "video_link": null
      },
      {
        "ts": "0:55",
        "sec": 55,
        "text": "والخبر وتنصبهما معاً على أنهما مفعولان؛ فيصبح",
        "video_link": null
      },
      {
        "ts": "1:03",
        "sec": 63,
        "text": "\"زيداً\" مفعولاً أول، و\"قائماً\" مفعولاً ثانياً لِظَنَّ. قال: وهي نوعان؛",
        "video_link": null
      },
      {
        "ts": "1:10",
        "sec": 70,
        "text": "أحدهما: أفعال القلوب، وهي: ظَنَنْتُ، وحَسِبْتُ، وخِلْتُ، ورَأَيْتُ، وعَلِمْتُ، وزَعَمْتُ، وجَعَلْتُ، وحَجَوْتُ، وعَدَدْتُ، وهَبْ،",
        "video_link": null
      },
      {
        "ts": "1:18",
        "sec": 78,
        "text": "ووَجَدْتُ، وأَلْفَيْتُ، ودَرَيْتُ، وتَعَلَّمْ؛ بمعنى",
        "video_link": null
      },
      {
        "ts": "1:25",
        "sec": 85,
        "text": "وتَعَلَّمْ بمعنى اِعْلَمْ، نحو:",
        "video_link": null
      },
      {
        "ts": "1:32",
        "sec": 92,
        "text": "سيمثّل لهذه أفعال القلوب، لكن هنا مسألة؛ أفعال",
        "video_link": null
      },
      {
        "ts": "1:39",
        "sec": 99,
        "text": "القلوب هذه منها ما هو قليل الاستعمال أو حتى نادر الاستعمال جداً، فلأجل ذلك",
        "video_link": null
      },
      {
        "ts": "1:46",
        "sec": 106,
        "text": "سنذكرها، لكن لا ينبغي أن يعني تجد نوع حرج من كثرة هذه الأفعال؛ فإن بعضها أكثر",
        "video_link": null
      },
      {
        "ts": "1:56",
        "sec": 116,
        "text": "استعمالاً ببعضها الآخر. ظَنَنْتُ زَيْداً قَائِماً، واضح؛ حَسِبْتُ زَيْداً عَالِماً.",
        "video_link": null
      },
      {
        "ts": "2:05",
        "sec": 125,
        "text": "وقول الشاعر: *\"حَسِبْتُ التُّقَى وَالْجُودَ خَيْرَ تِجَارَةٍ\"*، واضح؛ حَسِبْتُ: فعل وفاعله، التُّقَى: مفعول أول،",
        "video_link": null
      },
      {
        "ts": "2:14",
        "sec": 134,
        "text": "الْجُودَ عفواً الجودَ: معطوف على التقى، خَيْرَ: مفعول ثانٍ، ومضاف تجارةٍ: مضاف إليه. خِلْتُ",
        "video_link": null
      },
      {
        "ts": "2:22",
        "sec": 142,
        "text": "عَمْراً شَاخِصاً؛ عمراً وشاخصاً: مفعولان.",
        "video_link": null
      },
      {
        "ts": "2:29",
        "sec": 149,
        "text": "{إِنَّهُمْ يَرَوْنَهُ بَعِيدًا * وَنَرَاهُ قَرِيبًا}؛",
        "video_link": null
      },
      {
        "ts": "2:36",
        "sec": 156,
        "text": "{إِنَّهُمْ يَرَوْنَهُ بَعِيدًا}، الهاء: مفعول أول",
        "video_link": null
      },
      {
        "ts": "2:42",
        "sec": 162,
        "text": "و\"بعيداً\": مفعول ثانٍ؛ {وَنَرَاهُ قَرِيبًا}، الهاء:",
        "video_link": null
      },
      {
        "ts": "2:49",
        "sec": 169,
        "text": "مفعول أول، و\"قريباً\": مفعول ثانٍ. وقوله تعالى: {فَإِنْ عَلِمْتُمُوهُنَّ مُؤْمِنَاتٍ}؛",
        "video_link": null
      },
      {
        "ts": "2:59",
        "sec": 179,
        "text": "عَلِمْتُمُوهُنَّ، هنَّ: مفعول أول، مؤمناتٍ: مفعول ثانٍ منصوب بالكسرة النائبة عن الفتحة لأنه جمع",
        "video_link": null
      },
      {
        "ts": "3:08",
        "sec": 188,
        "text": "مؤنث سالم. وقول الشاعر: *\"زَعَمَتْنِي شَيْخاً\"*،",
        "video_link": null
      },
      {
        "ts": "3:15",
        "sec": 195,
        "text": "*\"زَعَمَتْنِي شَيْخاً وَلَسْتُ بِشَيْخٍ ... إِنَّمَا الشَّيْخُ مَنْ يَدِبُّ دَبِيباً\"*؛ زعمتني شيخاً، ياء المتكلم:",
        "video_link": null
      },
      {
        "ts": "3:24",
        "sec": 204,
        "text": "زعمتْ: فعل ماض مبني على الفتح، والتاء: تاء التأنيث الساكنة،",
        "video_link": null
      },
      {
        "ts": "3:33",
        "sec": 213,
        "text": "والفاعل: ضمير مستتر تقديره هي، والنون: نون الوقاية، وياء المتكلم: مفعول",
        "video_link": null
      },
      {
        "ts": "3:40",
        "sec": 220,
        "text": "أول، وشيخاً: مفعول ثانٍ. وقوله تعالى: {وَجَعَلُوا الْمَلَائِكَةَ الَّذِينَ هُمْ",
        "video_link": null
      },
      {
        "ts": "3:48",
        "sec": 228,
        "text": "عِبَادُ الرَّحْمَٰنِ إِنَاثًا}؛ جعلوا: فعل وفاعله وهو واو الجماعة، الملائكةَ: مفعول أول، إناثاً:",
        "video_link": null
      },
      {
        "ts": "3:57",
        "sec": 237,
        "text": "مفعول ثانٍ؛ وجَعَلَ هذه تُستعمل كثيراً. وقول الشاعر (هذه قليلة، حَجَوْتُ أحجو): *\"قَدْ كُنْتُ أَحْجُو أَبَا عَمْرٍو أَخَا ثِقَةٍ\"*،",
        "video_link": null
      },
      {
        "ts": "4:07",
        "sec": 247,
        "text": "*\"قَدْ كُنْتُ أَحْجُو أَبَا عَمْرٍو أَخَا ثِقَةٍ ... حَتَّى أَلَمَّتْ بِنَا يَوْماً مُلِمَّاتُ\"*؛ قد كنتُ أحجو أبا عمرو، أحجو: الفاعل ضمير",
        "video_link": null
      },
      {
        "ts": "4:16",
        "sec": 256,
        "text": "أنا، أبا: المفعول الأول وهو مضاف، عمروٍ: مضاف إليه،",
        "video_link": null
      },
      {
        "ts": "4:23",
        "sec": 263,
        "text": "المفعول الثاني: وهو منصوب وعلامة نصبه الألف لأنه من الأسماء",
        "video_link": null
      },
      {
        "ts": "4:29",
        "sec": 269,
        "text": "الستة وهو مضاف، ثقةٍ: مضاف إليه. وقول الآخر: *\"فَلَا تَعْدُدِ الْمَوْلَى شَرِيكَكَ فِي الْغِنَى\"*،",
        "video_link": null
      },
      {
        "ts": "4:39",
        "sec": 279,
        "text": "*\"فَلَا تَعْدُدِ الْمَوْلَى شَرِيكَكَ فِي الْغِنَى ... وَلَكِنَّمَا الْمَوْلَى شَرِيكُكَ فِي الْعَدَمِ\"*؛ فلا تعددِ المولى شريكَك؛ المولى: مفعول أول،",
        "video_link": null
      },
      {
        "ts": "4:48",
        "sec": 288,
        "text": "الفاعل: ضمير تقديره أنت، المولى: مفعول أول منصوب وعلامة نصبه الفتحة المقدرة على",
        "video_link": null
      },
      {
        "ts": "4:55",
        "sec": 295,
        "text": "الألف لأنه اسم مقصور منع من ظهورها التعذر، شريكَك: مفعول ثانٍ منصوب وعلامة نصبه الفتحة الظاهرة.",
        "video_link": null
      },
      {
        "ts": "5:03",
        "sec": 303,
        "text": "وقوله: *\"فَقُلْتُ أَجِرْنِي أَبَا مَالِكٍ ... وَإِلَّا فَهَبْنِي امْرَأً هَالِكاً\"*؛ هبني امرأً هالكاً، الياء:",
        "video_link": null
      },
      {
        "ts": "5:14",
        "sec": 314,
        "text": "هي المفعول الأول، وامرأً: مفعول ثانٍ، وهالكاً: نعت، والفاعل: ضمير",
        "video_link": null
      },
      {
        "ts": "5:22",
        "sec": 322,
        "text": "تقديره أنت، والنون: نون الوقاية. وقوله تعالى: {تَجِدُوهُ عِندَ اللَّهِ هُوَ خَيْرًا}؛",
        "video_link": null
      },
      {
        "ts": "5:31",
        "sec": 331,
        "text": "المفعول الأول هو الضمير الهاء \"تَجِدُوهُ\"، وخيراً: مفعول ثانٍ،",
        "video_link": null
      },
      {
        "ts": "5:41",
        "sec": 341,
        "text": "أما \"هُوَ\" فهذا ضمير الفصل؛ إذن: تجدوه خيراً. وقوله تعالى: {إِنَّهُمْ أَلْفَوْا آبَاءَهُمْ ضَالِّينَ}؛",
        "video_link": null
      },
      {
        "ts": "5:51",
        "sec": 351,
        "text": "ألفوا: فعل وفاعله وهو واو الجماعة، آباءَ: مفعول أول منصوب وعلامة نصبه الفتحة الظاهرة،",
        "video_link": null
      },
      {
        "ts": "5:59",
        "sec": 359,
        "text": "وهو مضاف والهاء: مضاف إليه، والميم: علامة الجمع؛ آباءهم ضالين، ضالين: مفعول ثانٍ",
        "video_link": null
      },
      {
        "ts": "6:06",
        "sec": 366,
        "text": "منصوب وعلامة نصبه الياء النائبة عن الفتحة لأنه جمع مذكر سالم.",
        "video_link": null
      },
      {
        "ts": "6:12",
        "sec": 372,
        "text": "دَرَيْتُ زَيْداً قَائِماً؛ دريتُ: فعل وفاعله، ثم زيداً: مفعول أول، قائماً: مفعول ثانٍ. وقول الشاعر",
        "video_link": null
      },
      {
        "ts": "6:20",
        "sec": 380,
        "text": "(دُريتَ، عُفواً دريتَ هذه مبني للمجهول): *\"دُرِيتَ الْوَفِيَّ الْعَهْدِ يَا عُرْوُ فَاهْتَبِطْ\"*،",
        "video_link": null
      },
      {
        "ts": "6:30",
        "sec": 390,
        "text": "*\"دُرِيتَ الْوَفِيَّ الْعَهْدِ يَا عُرْوُ فَاهْتَبِطْ ... فَإِنَّ ارْتِبَاطاً بِالْوَفَاءِ حَمِيدُ\"*؛ فمثل",
        "video_link": null
      },
      {
        "ts": "6:38",
        "sec": 398,
        "text": "لِـ دَرَيْتُ بالبناء للفاعل، ولِـ دُرِيتَ بالبناء للمفعول: *\"دُرِيتَ الْوَفِيَّ الْعَهْدِ",
        "video_link": null
      },
      {
        "ts": "6:46",
        "sec": 406,
        "text": "يَا عُرْوُ فَاهْتَبِطْ ... فَإِنَّ ارْتِبَاطاً بِالْوَفَاءِ حَمِيدُ\"*،",
        "video_link": null
      },
      {
        "ts": "6:54",
        "sec": 414,
        "text": "مع نائب الفاعل؛ التاء هي الضمير نائب الفاعل",
        "video_link": null
      },
      {
        "ts": "7:01",
        "sec": 421,
        "text": "وهو من أخوات ظَنَّ، إذن ينصب مفعولين؛ قلنا التاء هي نائب الفاعل وهي",
        "video_link": null
      },
      {
        "ts": "7:09",
        "sec": 429,
        "text": "المفعول الأول لِـ دَرَى، والوفيَّ: المفعول الثاني. من هذه الآن",
        "video_link": null
      },
      {
        "ts": "7:16",
        "sec": 436,
        "text": "خصوصية وهي أنه حين غُيّر هذا الفعل غُيّرت صيغته فصار مبنياً للمجهول،",
        "video_link": null
      },
      {
        "ts": "7:24",
        "sec": 444,
        "text": "أو لنقل للمفعول؛ حينئذٍ صار نائب الفاعل هو المفعول الأول،",
        "video_link": null
      },
      {
        "ts": "7:34",
        "sec": 454,
        "text": "المفعول الأول لِـ دَرَى؛ \"دُرِيتَ الْوَفِيَّ الْعَهْدِ\"، نعم.",
        "video_link": null
      },
      {
        "ts": "7:40",
        "sec": 460,
        "text": "وقول الشاعر (تَعَلَّمْ، هذا نادر يعني استعمال تَعَلَّمْ بمعنى اِعْلَمْ): *\"تَعَلَّمْ شِفَاءَ النَّفْسِ قَهْرَ عَدُوِّهَا\"*،",
        "video_link": null
      },
      {
        "ts": "7:50",
        "sec": 470,
        "text": "*\"تَعَلَّمْ شِفَاءَ النَّفْسِ قَهْرَ عَدُوِّهَا ... فَبَالِغْ بِلُطْفٍ فِي التَّحِيُّلِ وَالْمَكْرِ\"*؛ تَعَلَّمْ: فعل أمر مبني على السكون يعمل عمل ظَنَّ،",
        "video_link": null
      },
      {
        "ts": "7:56",
        "sec": 476,
        "text": "والفاعل: ضمير مستتر تقديره أنت، تَعَلَّمْ شِفَاءَ: مفعول أول، وقَهْرَ: مفعول ثانٍ.",
        "video_link": null
      },
      {
        "ts": "8:08",
        "sec": 488,
        "text": "قال: وإذا كان ظَنَّ بمعنى اِتَّهَمَ، ورَأَى بمعنى أَبْصَرَ، وعَلِمَ بمعنى عَرَفَ؛ لم تتعدَّ إلا إلى",
        "video_link": null
      },
      {
        "ts": "8:17",
        "sec": 497,
        "text": "مفعول واحد، نحو: ظَنَنْتُ زَيْداً؛ أي اِتَّهَمْتُ زَيْداً.",
        "video_link": null
      },
      {
        "ts": "8:26",
        "sec": 506,
        "text": "اِتَّهَمْتُ زَيْداً. وظَنَّ تأتي بمعنى اتهم كما في قول ربنا سبحانه وتعالى: {وَمَا هُوَ عَلَى الْغَيْبِ",
        "video_link": null
      },
      {
        "ts": "8:35",
        "sec": 515,
        "text": "بِظَنِينٍ} إذا كان بالظاء، والقراءة الأخرى: {وَمَا هُوَ عَلَى الْغَيْبِ بِضَنِينٍ} بالضاد من الضنّ الذي",
        "video_link": null
      },
      {
        "ts": "8:44",
        "sec": 524,
        "text": "هو الشح، أما الأولى من الظن الذي هو التهمة؛",
        "video_link": null
      },
      {
        "ts": "8:52",
        "sec": 532,
        "text": "بمعنى اتهمته. ورَأَيْتُ زَيْداً بمعنى أَبْصَرْتُهُ، هذه لا تتعدى إلى مفعولين؛ رَأَيْتُ زَيْداً مفعول",
        "video_link": null
      },
      {
        "ts": "8:59",
        "sec": 539,
        "text": "واحد، ولذلك يقولون (ستجد هذا في كثير من الكتب): رأى علمية ورأى بصرية؛ فرأى البصرية",
        "video_link": null
      },
      {
        "ts": "9:06",
        "sec": 546,
        "text": "تتعدى إلى مفعول واحد \"رأيت زيداً\"، ورأى العلمية تتعدى إلى مفعولين \"رأيت زيداً",
        "video_link": null
      },
      {
        "ts": "9:12",
        "sec": 552,
        "text": "قائماً\"؛ يعني علمت زيداً قائماً، أو ظننت زيداً قائماً أو حسبته كذلك. وكذلك عَلِمَ بمعنى عَرَفَ؛ عَلِمْتُ الْمَسْأَلَةَ بمعنى",
        "video_link": null
      },
      {
        "ts": "9:22",
        "sec": 562,
        "text": "عرفتها، مفعول واحد. إذن هذا كله في النوع الأول من أنواع ظَنَّ وأخواتها وهي أفعال",
        "video_link": null
      },
      {
        "ts": "9:29",
        "sec": 569,
        "text": "القلوب. النوع الثاني: أفعال التصيير؛ التصيير هو الجعل والتحويل، نحو: جَعَلَ، ورَدَّ،",
        "video_link": null
      },
      {
        "ts": "9:37",
        "sec": 577,
        "text": "واِتَّخَذَ، وصَيَّرَ، وهَبَ. قال الله تعالى أمثلة: {فَجَعَلْنَاهُ هَبَاءً مَّنثُورًا}؛",
        "video_link": null
      },
      {
        "ts": "9:45",
        "sec": 585,
        "text": "جعلنا: فعل، ونا: فاعله وهو يعمل عمل الظن، الهاء: مفعول",
        "video_link": null
      },
      {
        "ts": "9:52",
        "sec": 592,
        "text": "أول، هباءً: مفعول ثانٍ، ومنثوراً: نعت. وقال تعالى: {لَوْ يَرُدُّونَكُم مِّن بَعْدِ إِيمَانِكُمْ كُفَّارًا}؛",
        "video_link": null
      },
      {
        "ts": "10:00",
        "sec": 600,
        "text": "الكاف: مفعول أول، والميم: علامة الجمع، وكفاراً: مفعول ثانٍ. وقال تعالى: {وَاتَّخَذُ اللَّهُ",
        "video_link": null
      },
      {
        "ts": "10:08",
        "sec": 608,
        "text": "إِبْرَاهِيمَ خَلِيلًا}؛ اتخذَ: فعل، اللهُ: فاعله، واتَّخَذَ يعمل عمل ظَنَّ، إبراهيمَ: مفعول أول،",
        "video_link": null
      },
      {
        "ts": "10:17",
        "sec": 617,
        "text": "خليلاً: مفعول ثانٍ. صَيَّرْتُ الطِّينَ خَزَفاً؛ الطينَ وخزفاً: مفعولان.",
        "video_link": null
      },
      {
        "ts": "10:25",
        "sec": 625,
        "text": "هَبَنِي اللَّهُ فِدَاءَكَ؛ اللهُ: هو الفاعل، والنون: نون الوقاية، والياء: هي المفعول الأول،",
        "video_link": null
      },
      {
        "ts": "10:33",
        "sec": 633,
        "text": "وهبني فداءَك، فداءَك: مفعول ثانٍ.",
        "video_link": null
      },
      {
        "ts": "10:40",
        "sec": 640,
        "text": "واعلم أن لأفعال هذا الباب ثلاثة أحكام؛ الأول: الإعمال وهو الأصل وهو واقع في",
        "video_link": null
      },
      {
        "ts": "10:47",
        "sec": 647,
        "text": "الجميع؛ والثاني: الإلغاء (أي عدم الإعمال)، وهو إبطال",
        "video_link": null
      },
      {
        "ts": "10:55",
        "sec": 655,
        "text": "العمل لفظاً ومحلاً لضعف العامل. بأي شيء",
        "video_link": null
      },
      {
        "ts": "11:00",
        "sec": 660,
        "text": "يضعف العامل؟ قال: بتوسطه أو تأخره؛ نحو: زَيْدٌ ظَنَنْتُ قَائِمٌ.",
        "video_link": null
      },
      {
        "ts": "11:10",
        "sec": 670,
        "text": "هنا ظَنَّ لا تعمل لِمَا؟ لأنها توسطت بين المفعولين؛ ظَنَنْتُ زَيْداً",
        "video_link": null
      },
      {
        "ts": "11:18",
        "sec": 678,
        "text": "قَائِماً، جئنا بِظَنَّ متوسطة بين مفعولين فهي لا تعمل،",
        "video_link": null
      },
      {
        "ts": "11:25",
        "sec": 685,
        "text": "يبطل عملها لفظاً ومحلاً؛ تقول: زَيْدٌ ظَنَنْتُ قَائِمٌ. وكذلك هذا في حالة التوسط، هذه حالة التوسط؛",
        "video_link": null
      },
      {
        "ts": "11:32",
        "sec": 692,
        "text": "كذلك حالة ماذا؟ التأخر: زَيْدٌ قَائِمٌ ظَنَنْتُ، كذلك لا تعمل. قال: وهو جائز لا واجب؛ أي هذا",
        "video_link": null
      },
      {
        "ts": "11:43",
        "sec": 703,
        "text": "الإلغاء جائز ليس واجباً، فيمكن أن تلغي ويمكن أن لا تلغي. قال:",
        "video_link": null
      },
      {
        "ts": "11:50",
        "sec": 710,
        "text": "وإلغاء المتأخر أقوى من إعماله، والمتوسط بالعكس؛ يعني في صورة المتأخر وهي: زَيْدٌ قَائِمٌ",
        "video_link": null
      },
      {
        "ts": "11:58",
        "sec": 718,
        "text": "ظَنَنْتُ، الإلغاء أقوى والإعمال ضعيف وهو أن تقول: زَيْداً قَائِماً",
        "video_link": null
      },
      {
        "ts": "12:06",
        "sec": 726,
        "text": "ظَنَنْتُ، ضعيف. أما في حالة التوسط فالعكس، حالة التوسط هي: زَيْدٌ ظَنَنْتُ قَائِمٌ، بالعكس؛",
        "video_link": null
      },
      {
        "ts": "12:14",
        "sec": 734,
        "text": "بمعنى ماذا؟ بمعنى أن الإعمال أقوى، فتقول: زَيْداً ظَنَنْتُ قَائِماً، ويجوز الإلغاء وهو أضعف",
        "video_link": null
      },
      {
        "ts": "12:24",
        "sec": 744,
        "text": "فتقول: زَيْدٌ ظَنَنْتُ قَائِمٌ. ولا يجوز إلغاء العامل المتقدم، نحو: ظَنَنْتُ",
        "video_link": null
      },
      {
        "ts": "12:33",
        "sec": 753,
        "text": "زَيْداً قَائِماً، خلافاً للكوفيين. إذاً حالة التوسط فهمناها، حالة التأخر فهمناها؛ أما الحالة الأصلية حين يكون",
        "video_link": null
      },
      {
        "ts": "12:41",
        "sec": 761,
        "text": "العامل متقدماً: ظَنَنْتُ زَيْداً قَائِماً، يقول: هذا لا يجوز قطعاً، لا يجوز ماذا؟ إلغاؤه، خلافاً",
        "video_link": null
      },
      {
        "ts": "12:49",
        "sec": 769,
        "text": "للكوفيين؛ بمعنى أن الكوفيين ومعهم الأخفش أجازوا الإلغاء مع تقدم العامل واستدلوا",
        "video_link": null
      },
      {
        "ts": "12:56",
        "sec": 776,
        "text": "ببعض الشواهد. إذن الحالة الأولى أو الحكم الأول: الإعمال، الحكم الثاني: الإلغاء،",
        "video_link": null
      },
      {
        "ts": "13:05",
        "sec": 785,
        "text": "الحكم الثالث: التعليق؛ ما معنى التعليق؟ قال: هو إبطال العمل لفظاً لا محلاً، لفظاً لا محلاً،",
        "video_link": null
      },
      {
        "ts": "13:14",
        "sec": 794,
        "text": "لمجيء ما له صدر الكلام بعده وهو لام الابتداء، نحو: ظَنَنْتُ لَزَيْدٌ قَائِمٌ؛",
        "video_link": null
      },
      {
        "ts": "13:24",
        "sec": 804,
        "text": "وهي لها صدر الكلام؛ فحين جاءت لام الابتداء",
        "video_link": null
      },
      {
        "ts": "13:31",
        "sec": 811,
        "text": "بعده بعد العامل فإنك تقول: ظَنَنْتُ لَزَيْدٌ قَائِمٌ،",
        "video_link": null
      },
      {
        "ts": "13:38",
        "sec": 818,
        "text": "فتلغي العمل في اللفظ، تلغي العمل في اللفظ.",
        "video_link": null
      },
      {
        "ts": "13:45",
        "sec": 825,
        "text": "ولذلك تقول ظَنَنْتُ: فعل وفاعله، اللام: لِلاِبتداء، زيدٌ: مبتدأ، قائمٌ: خبره. اللام",
        "video_link": null
      },
      {
        "ts": "13:51",
        "sec": 831,
        "text": "هذه تقتضي لأنها لام ابتداء لها صدر الكلام، لا يمكن أن تأتي بعدها بمفعول؛ المفعول لا",
        "video_link": null
      },
      {
        "ts": "14:00",
        "sec": 840,
        "text": "ليس مما يكون في بدء الكلام وإنما يكون في وسط الكلام في حشوه، فحين يُؤتى بهذه اللام هذا يقتضي أن يكون",
        "video_link": null
      },
      {
        "ts": "14:09",
        "sec": 849,
        "text": "ما بعدها شيئاً مما يكون في أول الكلام وهو المبتدأ؛ فلذلك تقول: زيدٌ قائمٌ، زيدٌ مبتدأ وقائمٌ خبره،",
        "video_link": null
      },
      {
        "ts": "14:17",
        "sec": 857,
        "text": "والجملة كلها في محل نصب سدت مسد مفعولَي",
        "video_link": null
      },
      {
        "ts": "14:24",
        "sec": 864,
        "text": "ظَنَّ، هكذا نقول في الإعراب واضح. كأن كأنهم يريدون أن يقولوا في حالة",
        "video_link": null
      },
      {
        "ts": "14:32",
        "sec": 872,
        "text": "التعليق هذه أن لام الابتداء لصدارتها لا يمكن أن يتخطاها العامل؛ هي",
        "video_link": null
      },
      {
        "ts": "14:40",
        "sec": 880,
        "text": "تكون في البداية عندك العامل وهو ظَنَنْتُ، لام الابتداء حاجز تكون في أول الكلام فلا يمكن أن يعمل فيها",
        "video_link": null
      },
      {
        "ts": "14:50",
        "sec": 890,
        "text": "ما قبلها، أن يعمل ما قبلها فيما بعدها لا يمكن لأنه هي في أول الكلام؛ فلذلك ظَنَّ هذه لم تعد تستطيع العمل،",
        "video_link": null
      },
      {
        "ts": "14:59",
        "sec": 899,
        "text": "أو على الأقل أن يظهر هذا العمل فيما بعد لام الابتداء.",
        "video_link": null
      },
      {
        "ts": "15:05",
        "sec": 905,
        "text": "فمن جهة اللفظ رُوعي هذا المعنى، رُوعي أن لام الابتداء لا يعمل ما قبلها فيما",
        "video_link": null
      },
      {
        "ts": "15:15",
        "sec": 915,
        "text": "بعدها، فلم يظهر النصب على الجزءين \"زيد\" و\"قائم\"؛ ولكن من جهة المعنى",
        "video_link": null
      },
      {
        "ts": "15:23",
        "sec": 923,
        "text": "رُوعي العامل، لأن العامل كأنه يعني في معركة مع عامل الابتداء؛ فالعامل يقتضي",
        "video_link": null
      },
      {
        "ts": "15:29",
        "sec": 929,
        "text": "عمله ويقول: \"أنا أريد أن أعمل\"، واضح؛ أرضيناه",
        "video_link": null
      },
      {
        "ts": "15:35",
        "sec": 935,
        "text": "بأن قيل بأن الجملة مع ذلك في محل نصب سدت مسد مفعولَي ظَنَّ.",
        "video_link": null
      },
      {
        "ts": "15:44",
        "sec": 944,
        "text": "ولأجل ذلك نقول التعليق ما هو التعليق؟ هو إبطال العمل لفظاً",
        "video_link": null
      },
      {
        "ts": "15:51",
        "sec": 951,
        "text": "لا محلاً؛ أي أنه من جهة اللفظ لا يظهر العمل، لكن من جهة المحل نبقي على عمل",
        "video_link": null
      },
      {
        "ts": "16:00",
        "sec": 960,
        "text": "العامل، بحيث تكون الجملة التي عُلق عنها عُلق عنها العامل تكون في محل نصب.",
        "video_link": null
      },
      {
        "ts": "16:11",
        "sec": 971,
        "text": "قال نحو: ظَنَنْتُ لَزَيْدٌ قَائِمٌ. ومَا النافية، كقوله تعالى (إذن لام الابتداء، ثانياً ما النافية):",
        "video_link": null
      },
      {
        "ts": "16:19",
        "sec": 979,
        "text": "{لَقَدْ عَلِمْتَ مَا هَٰؤُلَاءِ يَنطِقُونَ}.",
        "video_link": null
      },
      {
        "ts": "16:26",
        "sec": 986,
        "text": "نفس الشيء نقول: مَا، {لَقَدْ عَلِمْتَ مَا هَٰؤُلَاءِ يَنطِقُونَ}؛",
        "video_link": null
      },
      {
        "ts": "16:31",
        "sec": 991,
        "text": "علمتَ: هذه فعل وفاعله، هؤلاءِ: مبتدأ، ينطقون: جملة فعلية هي الخبر،",
        "video_link": null
      },
      {
        "ts": "16:40",
        "sec": 1000,
        "text": "ونقول إن هذه الجملة المكونة من الفعل وفاعله في محل رفع",
        "video_link": null
      },
      {
        "ts": "16:48",
        "sec": 1008,
        "text": "عفواً الجملة المبتدأ والخبر هي جملة \"هؤلاء ينطقون\"؛ هذه الجملة كلها الجملة الاسمية في",
        "video_link": null
      },
      {
        "ts": "16:54",
        "sec": 1014,
        "text": "محل نصب سدت مسد مفعولَي عَلِمْتُ.",
        "video_link": null
      },
      {
        "ts": "17:02",
        "sec": 1022,
        "text": "وكذلك قال: ولَا النافية، نحو: عَلِمْتُ لَا زَيْدٌ قَائِمٌ وَلَا عَمْرٌو؛",
        "video_link": null
      },
      {
        "ts": "17:08",
        "sec": 1028,
        "text": "الشيء نفسه: علمتُ وبعدها لا، وبعدها زيدٌ قائمٌ مبتدأ وخبره، ونقول إن الجملة في محل",
        "video_link": null
      },
      {
        "ts": "17:16",
        "sec": 1036,
        "text": "نصب سدت سدت مفعولَي عَلِمَ. وإِنْ النافية، نحو: عَلِمْتُ إِنْ زَيْدٌ قَائِمٌ، الشيء",
        "video_link": null
      },
      {
        "ts": "17:25",
        "sec": 1045,
        "text": "نفسه. وهمزة الاستفهام، نحو: عَلِمْتُ أَزَيْدٌ قَائِمٌ أَمْ عَمْرٌو؛ زيدٌ قائمٌ مبتدأ وخبر، والجملة في",
        "video_link": null
      },
      {
        "ts": "17:34",
        "sec": 1054,
        "text": "محل نصب كذلك سدت مسد مفعولَي عَلِمَ.",
        "video_link": null
      },
      {
        "ts": "17:43",
        "sec": 1063,
        "text": "وكون أحد المفعولين اسم استفهام، نحو: عَلِمْتُ أَيُّهُمْ أَبُوكَ، نفس الشيء؛ لأن اسم الاستفهام له",
        "video_link": null
      },
      {
        "ts": "17:53",
        "sec": 1073,
        "text": "الصدارة في الكلام، فهذه هي المسوغات النحوية؛ عَلِمْتُ أَيُّهُمْ أَبُوكَ نفس الشيء، أيُّهم أيبوك؛ اسم",
        "video_link": null
      },
      {
        "ts": "18:02",
        "sec": 1082,
        "text": "استفهام مبتدأ، أبوك: خبره، والجملة في محل نصب سدت مسد",
        "video_link": null
      },
      {
        "ts": "18:10",
        "sec": 1090,
        "text": "مفعولَي عَلِمَ؛ فالتعليق واجب إذا وُجد شيء من هذه يعني",
        "video_link": null
      },
      {
        "ts": "18:18",
        "sec": 1098,
        "text": "هذه الأشياء التي قلنا؛ لام الابتداء، ومَا النافية، ولَا النافية. ولا يدخل التعليق ولا الإلغاء في شيء من أفعال التصيير التي",
        "video_link": null
      },
      {
        "ts": "18:26",
        "sec": 1106,
        "text": "ذكرنا آنفاً، ولا في قلبي جامد وهو اثنان: هَبْ وتَعَلَّمْ؛ وهو اثنان ما هو اللي واثنان؟ الفعل",
        "video_link": null
      },
      {
        "ts": "18:35",
        "sec": 1115,
        "text": "القلبي الجامد. إذن أفعال التصيير كلها لا يدخلها هذا التعليق والإلغاء، وكذلك لا يدخل التعليق والإلغاء في",
        "video_link": null
      },
      {
        "ts": "18:45",
        "sec": 1125,
        "text": "فعل من أفعال القلوب الجامدة وهو اثنان فقط: هَبْ وتَعَلَّمْ. قال: فإنهما ملازمان صيغة",
        "video_link": null
      },
      {
        "ts": "18:53",
        "sec": 1133,
        "text": "الأمر، واضح؛ وما عداهما من أفعال الباب يتصرف،",
        "video_link": null
      },
      {
        "ts": "18:59",
        "sec": 1139,
        "text": "يأتي منه المضارع والأمر وغيرهما؛ إلا وَهَبَ من أفعال التصيير فإنه ملازم",
        "video_link": null
      },
      {
        "ts": "19:09",
        "sec": 1149,
        "text": "لصيغة الماضي. إذن لما قيل بأن هَبْ وتَعَلَّمْ فعلان جامدان؟ لأنه ملازمان لصيغة الأمر،",
        "video_link": null
      },
      {
        "ts": "19:16",
        "sec": 1156,
        "text": "والأفعال الأخرى منها الماضي والمضارع والأمر؛ باستثناء باستثناء وَهَبَ من أفعال التصيير فإنه ملازم لصيغة الماضي فلا يأتي",
        "video_link": null
      },
      {
        "ts": "19:24",
        "sec": 1164,
        "text": "منه المضارع ولا غيره. قال: ولتصاريِفهنَّ ما لهنَّ مما تقدم من الأحكام،",
        "video_link": null
      },
      {
        "ts": "19:32",
        "sec": 1172,
        "text": "وتقدمت بعض أمثلة ذلك؛ يعني لا يلزم أن يكون بصيغة الماضي \"ظَنَنْتُ زَيْداً قَائِماً\"، بل يمكن",
        "video_link": null
      },
      {
        "ts": "19:39",
        "sec": 1179,
        "text": "بصيغة المضارع مثلاً: أَظُنُّ زَيْداً قَائِماً، هذا واضح. ويجوز حذف المفعولين أو أحدهما لدليل،",
        "video_link": null
      },
      {
        "ts": "19:46",
        "sec": 1186,
        "text": "نحو: {أَيْنَ شُرَكَائِيَ الَّذِينَ كُنتُمْ تَزْعُمُونَ}؛ أي",
        "video_link": null
      },
      {
        "ts": "19:52",
        "sec": 1192,
        "text": "الذين كنتم تزعمونهم شركائي، فهنا حُذف المفعولان.",
        "video_link": null
      },
      {
        "ts": "20:01",
        "sec": 1201,
        "text": "{أَيْنَ شُرَكَائِيَ الَّذِينَ كُنتُمْ تَزْعُمُونَ}؛ تزعمونهم: شركائي مفعول أول، وشركائي: مفعول ثانٍ؛ لكن لا",
        "video_link": null
      },
      {
        "ts": "20:11",
        "sec": 1211,
        "text": "يحتاج إليهما لأن السياق يدل عليهما: {أَيْنَ شُرَكَائِيَ الَّذِينَ كُنتُمْ تَزْعُمُونَ}.",
        "video_link": null
      },
      {
        "ts": "20:17",
        "sec": 1217,
        "text": "وإذا قيل لك: \"من ظننته قائماً؟\" فتقول: \"ظننتُ زيداً\"؛ تقصد: ظننتُ زيداً قائماً، ولا تحتاج أن",
        "video_link": null
      },
      {
        "ts": "20:25",
        "sec": 1225,
        "text": "تعيد \"قائماً\" فأنت تحذف الخبر لأن السياق يدل عليه. وعدّ صاحب الآجرومية من هذه",
        "video_link": null
      },
      {
        "ts": "20:33",
        "sec": 1233,
        "text": "الأفعال \"سَمِعْتُ\" تبعاً للأخفش ومن وافقه؛ يعني هذا ليس متفقاً عليه، ولا بد أن يكون",
        "video_link": null
      },
      {
        "ts": "20:41",
        "sec": 1241,
        "text": "مفعولها الثاني جملة مما يُسمع، نحو: سَمِعْتُ زَيْداً يَقُولُ كَذَا.",
        "video_link": null
      },
      {
        "ts": "20:49",
        "sec": 1249,
        "text": "سَمِعْتُ زَيْداً يَقُولُ كَذَا؛ فعلى قول الأخفش ومن وافقه، زيداً:",
        "video_link": null
      },
      {
        "ts": "20:55",
        "sec": 1255,
        "text": "مفعول أول، ويَقُولُ كَذَا: مفعول ثانٍ. وكقوله تعالى: {قَالُوا سَمِعْنَا فَتًى}",
        "video_link": null
      },
      {
        "ts": "21:05",
        "sec": 1265,
        "text": "إلى آخر الأمثلة التي يمكن أن تُذكر. قال: ومذهب الجمهور خلافاً للأخفش",
        "video_link": null
      },
      {
        "ts": "21:14",
        "sec": 1274,
        "text": "وابن آجروم الذي تبعه على ذلك، مذهب الجمهور أن \"سَمِعَ\" فعل متعدٍّ إلى واحد؛",
        "video_link": null
      },
      {
        "ts": "21:22",
        "sec": 1282,
        "text": "فإن كان معرفة كالمثال الأول فالجملة التي بعده حال، وإن كان نكرة فالجملة صفة.",
        "video_link": null
      },
      {
        "ts": "21:30",
        "sec": 1290,
        "text": "فـ \"سَمِعْتُ زَيْداً يَقُولُ كَذَا\"، زيدٌ معرفة، وحينئذٍ سمعتُ زيداً؛ فعل سمعتُ: فعل وفاعله،",
        "video_link": null
      },
      {
        "ts": "21:39",
        "sec": 1299,
        "text": "زيداً: مفعول به لا يوجد مفعول أول مفعول ثانٍ بل هو مفعول به واحد،",
        "video_link": null
      },
      {
        "ts": "21:45",
        "sec": 1305,
        "text": "وجملة \"يَقُولُ كَذَا\" في محل نصب حال؛ لِمَا؟ لأن زيداً",
        "video_link": null
      },
      {
        "ts": "21:53",
        "sec": 1313,
        "text": "معرفة، والجمل بعد المعارف أحوال كما أن الجمل بعد النكرات صفات؛ هذه قاعدة يذكرونها،",
        "video_link": null
      },
      {
        "ts": "22:01",
        "sec": 1321,
        "text": "ربما نأتي إليها فيما بعد أو عند إعراب أو عند ذكر مثلاً بعض متون ماذا",
        "video_link": null
      },
      {
        "ts": "22:08",
        "sec": 1328,
        "text": "الإعراب الجمل. وإن كان نكرة فالجملة صفة: سَمِعْتُ رَجُلاً",
        "video_link": null
      },
      {
        "ts": "22:17",
        "sec": 1337,
        "text": "يَقُولُ كَذَا، رجلاً: نكرة، حينئذٍ \"يَقُولُ كَذَا\" جملة في محل",
        "video_link": null
      },
      {
        "ts": "22:24",
        "sec": 1344,
        "text": "نصب نعت لِرجُل. انتهينا إذاً من هذا الباب المتعلق بالنواسخ كلها، وبالتالي",
        "video_link": null
      },
      {
        "ts": "22:34",
        "sec": 1354,
        "text": "انتهينا من مرفوعات الأسماء، ويبدأ باب المنصوبات من الأسماء؛ قال المنصوبات خمسة",
        "video_link": null
      },
      {
        "ts": "22:41",
        "sec": 1361,
        "text": "عشر، وهي: المفعول به، ومنه المنادى كما سيأتي بيانه، والمصدر ويُسمى المفعول المطلق، وظرف الزمان،",
        "video_link": null
      },
      {
        "ts": "22:49",
        "sec": 1369,
        "text": "وظرف المكان ويُسمى مفعولاً فيه، والمفعول من أجله، والمشبه بالمفعول به،",
        "video_link": null
      },
      {
        "ts": "22:56",
        "sec": 1376,
        "text": "والحال، والتمييز، والمستثنى، وخبر كَانَ وأخواتها، وخبر الحروف المشبهة بليس، وخبر أفعال المقاربة، واسم إِنَّ وأخواتها، واسم",
        "video_link": null
      },
      {
        "ts": "23:06",
        "sec": 1386,
        "text": "التي لنفي الجنس، والتابع للمنصوب وهو أربعة أشياء كما تقدم. هذا كله لن نشرحه",
        "video_link": null
      },
      {
        "ts": "23:12",
        "sec": 1392,
        "text": "لِمَا؟ لأنه إجمال سيأتي بعده التفصيل؛ فذكر أو سرد المنصوبات كلها ثم سيبدأ بها",
        "video_link": null
      },
      {
        "ts": "23:21",
        "sec": 1401,
        "text": "بشرحها واحداً تلو الآخر، وسيبدأ من ذلك بالمفعول به لأنه أشهرها.",
        "video_link": null
      },
      {
        "ts": "23:28",
        "sec": 1408,
        "text": "باب المفعول به؛ قال: وهو الاسم الذي يقع عليه الفعل، نحو: ضَرَبْتُ زَيْداً، ورَكِبْتُ الْفَرَسَ،",
        "video_link": null
      },
      {
        "ts": "23:35",
        "sec": 1415,
        "text": "و {وَاتَّقُوا اللَّهَ}، و {وَيُقِيمُونَ الصَّلَاةَ} إلى آخره؛ إذن ضربتُ زيداً، زيداً: مفعول به، ركبتُ الفرسَ،",
        "video_link": null
      },
      {
        "ts": "23:45",
        "sec": 1425,
        "text": "كذلك الفرسَ؛ اسم الجلالة في {وَاتَّقُوا اللَّهَ}، {وَيُقِيمُونَ الصَّلَاةَ}، الصلاةَ: مفعول به.",
        "video_link": null
      },
      {
        "ts": "23:53",
        "sec": 1433,
        "text": "فالمفعول به إذاً هو الاسم الذي يقع عليه الفعل؛ فزيداً هو الذي يقع عليه الضرب،",
        "video_link": null
      },
      {
        "ts": "24:00",
        "sec": 1440,
        "text": "والفرس هو الذي يقع عليه الركوب إلى غير ذلك. وهو على قسمين: ظاهر ومضمر؛ فالظاهر ما تقدم",
        "video_link": null
      },
      {
        "ts": "24:10",
        "sec": 1450,
        "text": "ذكره، والمضمر قسمان: متصل ومنفصل؛ متصل نحو: أَكْرَمَنِي وأخواته؛ أَكْرَمَنِي،",
        "video_link": null
      },
      {
        "ts": "24:18",
        "sec": 1458,
        "text": "وأَكْرَمَكَ، وأَكْرَمَكِ، وأَكْرَمَكُمَا، وإلى آخره، وأَكْرَمَهُ، وأَكْرَمَهَا؛ فتقول: أكرمَ: فعل ماضي مبني على",
        "video_link": null
      },
      {
        "ts": "24:25",
        "sec": 1465,
        "text": "الفتح، والنون: نون الوقاية، والياء: ياء المتكلم في محل نصب مفعول به. والمنفصل",
        "video_link": null
      },
      {
        "ts": "24:31",
        "sec": 1471,
        "text": "نحو: إِيَّايَ وأخواته، وقد تقدم ذلك في فصل المضمر؛ {إِيَّاكَ نَعْبُدُ}، إِيَّاكَ:",
        "video_link": null
      },
      {
        "ts": "24:39",
        "sec": 1479,
        "text": "ضمير منفصل مبني في محل نصب مفعول به مقدم، وهو نعم مقدم، والكاف: علامة",
        "video_link": null
      },
      {
        "ts": "24:50",
        "sec": 1490,
        "text": "علامة ماذا؟ علامة الخطاب، ونَعْبُدُ: فعل وفاعل.",
        "video_link": null
      },
      {
        "ts": "24:56",
        "sec": 1496,
        "text": "والأصل فيه أن يتاخر عن الفاعل، نحو: {وَوَرِثَ سُلَيْمَانُ دَاوُودَ}؛ ورثَ: فعل، سليمانُ: فاعل، داوودَ:",
        "video_link": null
      },
      {
        "ts": "25:04",
        "sec": 1504,
        "text": "مفعول به. وقد يتقدم على الفاعل جوازاً ووجوباً، وقد يتقدم على الفعل والفاعل كما",
        "video_link": null
      },
      {
        "ts": "25:12",
        "sec": 1512,
        "text": "تقدم في باب الفاعل؛ هذا ذكرناه من قبل لا نحتاج إلى إعادته.",
        "video_link": null
      },
      {
        "ts": "25:18",
        "sec": 1518,
        "text": "ومنه ما أُضمر عامله جوازاً، نحو: {قَالُوا خَيْرًا}، و {وَقِيلَ لِلَّذِينَ اتَّقَوْا مَاذَا أَنزَلَ رَبُّكُمْ ۚ قَالُوا",
        "video_link": null
      },
      {
        "ts": "25:28",
        "sec": 1528,
        "text": "خَيْرًا}؛ تقدير الكلام: قالوا أنزلَ خيراً، فإذاً العامل مضمر محذوف",
        "video_link": null
      },
      {
        "ts": "25:34",
        "sec": 1534,
        "text": "جوازاً كان بالإمكان أن يُقال \"قالوا أنزل خيراً\". وقد يُضمر وجوباً، وذلك في مواضع؛ منها:",
        "video_link": null
      },
      {
        "ts": "25:42",
        "sec": 1542,
        "text": "باب الاشتغال، وحقيقته: أن يتقدم اسم، ويتأخر عنه فعل أو",
        "video_link": null
      },
      {
        "ts": "25:50",
        "sec": 1550,
        "text": "وصف مشتغل بالعمل في ضمير الاسم السابق، أو عن ملابسه عن العمل في الاسم السابق؛ نحو:",
        "video_link": null
      },
      {
        "ts": "25:58",
        "sec": 1558,
        "text": "زَيْداً اِضْرِبْهُ، وزَيْداً أَنَا ضَارِبُهُ الآنَ أَوْ غَداً، وزَيْداً ضَرَبْتُ غُلَامَهُ إلى آخره.",
        "video_link": null
      },
      {
        "ts": "26:06",
        "sec": 1566,
        "text": "طيب. باب الاشتغال ما معنى الاشتغال؟",
        "video_link": null
      },
      {
        "ts": "26:13",
        "sec": 1573,
        "text": "مثلاً في مثل نعم في مثل: زَيْداً اِضْرِبْهُ،",
        "video_link": null
      },
      {
        "ts": "26:23",
        "sec": 1583,
        "text": "هنا عندنا اسم هو \"زيداً\" متقدم، بعده فعل \"اِضْرِبْ\"،",
        "video_link": null
      },
      {
        "ts": "26:32",
        "sec": 1592,
        "text": "وهذا الفعل مشتغل بالعمل في ضمير اللي هو الهاء \"اِضْرِبْهُ\".",
        "video_link": null
      },
      {
        "ts": "26:39",
        "sec": 1599,
        "text": "إذن اِضْرِبْ: فعل وفاعله، والهاء: مفعول به؛ إذن \"اِضْرِبْ\" يعمل في هذه الهاء، وهذه الهاء",
        "video_link": null
      },
      {
        "ts": "26:47",
        "sec": 1607,
        "text": "هذا الضمير يرجع على ذلك الاسم الأول على \"زيداً\"؛ لأن اضربه الهاء ترجع تعود على زيداً.",
        "video_link": null
      },
      {
        "ts": "26:57",
        "sec": 1617,
        "text": "أو: زَيْداً أَنَا ضَارِبُهُ، فنفس الشيء هنا؛ \"ضاربٌ\" هذا يعمل عمل الفعل،",
        "video_link": null
      },
      {
        "ts": "27:06",
        "sec": 1626,
        "text": "إذن هو وصف ليس فعلاً لكنه وصف يعمل عمل الفعل، وهو مشتغل بالعمل في ضمير هذا الضمير هو الهاء يرجع على ذلك الاسم",
        "video_link": null
      },
      {
        "ts": "27:15",
        "sec": 1635,
        "text": "المتقدم \"زَيْداً أَنَا ضَارِبُهُ الآنَ أَوْ غَداً\". وزَيْداً ضَرَبْتُ غُلَامَهُ،",
        "video_link": null
      },
      {
        "ts": "27:24",
        "sec": 1644,
        "text": "هنا زيداً: اسم متقدم، ضَرَبَ: فعل",
        "video_link": null
      },
      {
        "ts": "27:30",
        "sec": 1650,
        "text": "وفاعله ومفعول به، وهذا المفعول به مقترن بضمير",
        "video_link": null
      },
      {
        "ts": "27:39",
        "sec": 1659,
        "text": "ملابس لهذا المفعول؛ هذا الضمير ماذا؟ راجع على ذلك الاسم المتقدم. إذن في هذه الأحوال",
        "video_link": null
      },
      {
        "ts": "27:48",
        "sec": 1668,
        "text": "كلها عندنا ما يُسمى بالاشتغال؛ أي اسم متقدم،",
        "video_link": null
      },
      {
        "ts": "27:56",
        "sec": 1676,
        "text": "وبعده عامل فعل أو وصف مشتغل بالعمل في ضمير الاسم السابق، أو",
        "video_link": null
      },
      {
        "ts": "28:06",
        "sec": 1686,
        "text": "عن ملابسه عن العمل. وكذلك: {وَكُلَّ إِنسَانٍ أَلْزَمْنَاهُ طَائِرَهُ",
        "video_link": null
      },
      {
        "ts": "28:14",
        "sec": 1694,
        "text": "فِي عُنُقِهِ}؛ نفس الشيء، كلَّ: هذا هو الاسم المتقدم، ألزمنا: مشتغل بالهاء العائدة على \"كلَّ\". إذاً ما الحكم في",
        "video_link": null
      },
      {
        "ts": "28:23",
        "sec": 1703,
        "text": "هذا كله؟ الحكم قال: فالنصب في ذلك كله بمحذوف وجوباً يفسره ما بعده.",
        "video_link": null
      },
      {
        "ts": "28:32",
        "sec": 1712,
        "text": "فحين تقول \"زَيْداً اِضْرِبْهُ\"؛ تقول زيداً: مفعول به لفعل محذوف تقديره:",
        "video_link": null
      },
      {
        "ts": "28:40",
        "sec": 1720,
        "text": "اِضْرِبْ؛ كيف نعرف تقديره؟ نعرفه من الفعل المذكور \"زَيْداً اِضْرِبْهُ\" نقدر: اضربْ أنا،",
        "video_link": null
      },
      {
        "ts": "28:50",
        "sec": 1730,
        "text": "\"زَيْداً أَنَا ضَارِبُهُ\" نقدر: أنا ضاربٌ زيداً، أنا ضاربهم،",
        "video_link": null
      },
      {
        "ts": "28:56",
        "sec": 1736,
        "text": "\"زَيْداً ضَرَبْتُ غُلَامَهُ\" تقدر: أهنْتَ زيداً ضربتَ غلامه،",
        "video_link": null
      },
      {
        "ts": "29:03",
        "sec": 1743,
        "text": "{وَكُلَّ إِنسَانٍ أَلْزَمْنَاهُ طَائِرَهُ} نقدر: ألزمْنا كلَّ إنسانٍ ألزمناه طائره.",
        "video_link": null
      },
      {
        "ts": "29:10",
        "sec": 1750,
        "text": "إذن هذا عند البصريين، فإنهم يقولون إن ذلك الاسم المتقدم يكون منصوباً بماذا؟",
        "video_link": null
      },
      {
        "ts": "29:20",
        "sec": 1760,
