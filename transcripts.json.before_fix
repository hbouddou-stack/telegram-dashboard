    "video_url": null,
    "segments": [
      {
        "ts": "0:00",
        "sec": 0,
        "text": "بسم الله الرحمن الرحيم، الحمد لله رب العالمين، وصلى الله وسلم وبارك على نبينا محمد وعلى آله وصحبه والتابعين، ومن تبعهم",
        "video_link": null
      },
      {
        "ts": "0:09",
        "sec": 9,
        "text": "بإحسان إلى يوم الدين. ذكرنا المبتدأ وبقي أن نذكر قسيمه وهو",
        "video_link": null
      },
      {
        "ts": "0:16",
        "sec": 16,
        "text": "الخبر؛ قال: والخبر هو الجزء الذي تتم به الفائدة مع المبتدأ. إذن",
        "video_link": null
      },
      {
        "ts": "0:24",
        "sec": 24,
        "text": "عرفنا المبتدأ وأنه هو الاسم المرفوع الذي يبدأ به الكلام،",
        "video_link": null
      },
      {
        "ts": "0:30",
        "sec": 30,
        "text": "والذي ليس لرفعه من عامل سوى التجرد، يعني",
        "video_link": null
      },
      {
        "ts": "0:37",
        "sec": 37,
        "text": "ليس له عامل لفظي، وإنما له عامل معنوي عمل فيه الرفع وهو الابتداء. إذن إذا عرفنا",
        "video_link": null
      },
      {
        "ts": "0:44",
        "sec": 44,
        "text": "المبتدأ، فهذا المبتدأ لا تكتمل فائدة الكلام به إلا مع الخبر؛ فالخبر كما يقول",
        "video_link": null
      },
      {
        "ts": "0:52",
        "sec": 52,
        "text": "ابن مالك: *\"والخبر الجزء المتم الفائدة\"*؛ أي جزء الكلام الذي تتم به فائدة الكلام مع",
        "video_link": null
      },
      {
        "ts": "1:00",
        "sec": 60,
        "text": "المبتدأ. فحين تقول مثلاً: زَيْدٌ قَائِمٌ، مجرد قولك \"زيدٌ\" هذا غير كافٍ في حصول الفائدة ولا",
        "video_link": null
      },
      {
        "ts": "1:09",
        "sec": 69,
        "text": "تتم الفائدة إلا بقولك \"قائمٌ\"؛ فتخبر حينئذٍ عن زيد بالقيام، وهو قسمان: مفرد وغير مفرد.",
        "video_link": null
      },
      {
        "ts": "1:18",
        "sec": 78,
        "text": "فالمفرد نحو: زَيْدٌ قَائِمٌ، والزَّيْدَانِ قَائِمَانِ، والزَّيْدُونَ قَائِمُونَ، وزَيْدٌ أَخُوكَ.",
        "video_link": null
      },
      {
        "ts": "1:29",
        "sec": 89,
        "text": "حين قال المفرد ليس المقصود ما يقابل المثنى والجمع، وإنما قصده ما يقابل الجملة",
        "video_link": null
      },
      {
        "ts": "1:37",
        "sec": 97,
        "text": "وشبهها، ولذلك فقد مثّل هنا بخبر مفرد ومثنى",
        "video_link": null
      },
      {
        "ts": "1:46",
        "sec": 106,
        "text": "ومجموع، وبخبر هو مضاف",
        "video_link": null
      },
      {
        "ts": "1:51",
        "sec": 111,
        "text": "فقوله \"زَيْدٌ أَخُوكَ\" هذا مضاف والكاف مضاف إليه ضمير متصل مبني في محل جر مضاف إليه؛ لكن",
        "video_link": null
      },
      {
        "ts": "2:00",
        "sec": 120,
        "text": "هذه الأمثلة كلها داخلة في الخبر الذي هو مفرد، أي الذي ليس جملة ولا شبهها.",
        "video_link": null
      },
      {
        "ts": "2:08",
        "sec": 128,
        "text": "وغير المفرد؛ إما جملة اسمية نحو: زَيْدٌ جَارِيَتُهُ ذَاهِبَةٌ.",
        "video_link": null
      },
      {
        "ts": "2:16",
        "sec": 136,
        "text": "والإعراب؛ زيدٌ: مبتدأ أول مرفوع وعلامة رفعه الضمة الظاهرة على آخره، جاريةُ:",
        "video_link": null
      },
      {
        "ts": "2:26",
        "sec": 146,
        "text": "مبتدأ ثانٍ مرفوع وعلامة رفعه الضمة الظاهرة على آخره وهو مضاف، والهاء: ضمير متصل مبني",
        "video_link": null
      },
      {
        "ts": "2:34",
        "sec": 154,
        "text": "في محل جر مضاف إليه، ذاهبةٌ: خبر المبتدأ الثاني مرفوع وعلامة رفعه الضمة الظاهرة،",
        "video_link": null
      },
      {
        "ts": "2:42",
        "sec": 162,
        "text": "والجملة الاسمية من المبتدأ والخبر في محل رفع خبر المبتدأ الأول.",
        "video_link": null
      },
      {
        "ts": "2:51",
        "sec": 171,
        "text": "ومثّل لذلك أيضاً بقوله تعالى: {وَلِبَاسُ التَّقْوَىٰ ذَٰلِكَ خَيْرٌ} على بعض القراءات؛ لباسُ: مبتدأ وهو",
        "video_link": null
      },
      {
        "ts": "3:00",
        "sec": 180,
        "text": "مضاف، والتقوى: مضاف إليه، وذلكَ: مبتدأ ثانٍ اسم إشارة يعني مبني في محل رفع",
        "video_link": null
      },
      {
        "ts": "3:09",
        "sec": 189,
        "text": "المبتدأ الثاني، خيرٌ: خبر المبتدأ الثاني، والجملة الاسمية",
        "video_link": null
      },
      {
        "ts": "3:15",
        "sec": 195,
        "text": "\"ذلك خير\" في محل رفع خبر المبتدأ الأول. وكذلك: {قُلْ هُوَ اللَّهُ أَحَدٌ}؛ هو: مبتدأ أول، اللهُ:",
        "video_link": null
      },
      {
        "ts": "3:25",
        "sec": 205,
        "text": "مبتدأ ثانٍ، أحدٌ: خبر المبتدأ الثاني، وجملة \"الله أحد\" خبر المبتدأ الأول.",
        "video_link": null
      },
      {
        "ts": "3:43",
        "sec": 223,
        "text": "وأما جملة فعلية نحو: زَيْدٌ قَامَ أَبُوهُ؛ زيدٌ: مبتدأ، قامَ: فعل ماض مبني على الفتح، أبو:",
        "video_link": null
      },
      {
        "ts": "3:54",
        "sec": 234,
        "text": "فاعل مرفوع وعلامة رفعه الواو النائبة عن الضمة لأنه من الأسماء الستة وهو مضاف،",
        "video_link": null
      },
      {
        "ts": "4:01",
        "sec": 241,
        "text": "والهاء: ضمير متصل مبني في محل جر مضاف إليه، والجملة الفعلية \"قام أبوه\" في",
        "video_link": null
      },
      {
        "ts": "4:08",
        "sec": 248,
        "text": "محل رفع خبر المبتدأ. وقوله تعالى: {وَرَبُّكَ يَخْلُقُ مَا يَشَاءُ}؛ الشيء نفسه، ربُّ: مبتدأ وهو",
        "video_link": null
      },
      {
        "ts": "4:16",
        "sec": 256,
        "text": "مضاف، والكاف: مضاف إليه، يخلقُ: فعل مضارع مرفوع لتجرده عن الناصب والجازم،",
        "video_link": null
      },
      {
        "ts": "4:23",
        "sec": 263,
        "text": "والفاعل: ضمير مستتر تقديره هو، والجملة الفعلية \"يخلق ما يشاء\"؛",
        "video_link": null
      },
      {
        "ts": "4:31",
        "sec": 271,
        "text": "عفواً \"ما\" هذا هو في محل مبني في محل رفع في محل نصب مفعول به،",
        "video_link": null
      },
      {
        "ts": "4:41",
        "sec": 281,
        "text": "ويشاءُ: صلة الموصول، وجملة \"يخلق ما يشاء\" كلها هي خبر المبتدأ. وكذلك: {اللَّهُ يَقْبِضُ",
        "video_link": null
      },
      {
        "ts": "4:51",
        "sec": 291,
        "text": "وَيَبْسُطُ}؛ اللهُ: مبتدأ، وجملة \"يقبض\" خبر المبتدأ، و\"يبسط\" معطوفة على يقبض. {اللَّهُ",
        "video_link": null
      },
      {
        "ts": "5:00",
        "sec": 300,
        "text": "يَتَوَفَّى الْأَنْفُسَ}؛ الشيء نفسه، اللهُ: مبتدأ، يتوفى الأنفسَ: فعل وفاعل ومفعول به، والجملة",
        "video_link": null
      },
      {
        "ts": "5:09",
        "sec": 309,
        "text": "الفعلية في محل رفع خبر المبتدأ. قال: وأما شبه الجملة؛ إذن إما أن يكون الخبر جملة اسمية أو جملة",
        "video_link": null
      },
      {
        "ts": "5:19",
        "sec": 319,
        "text": "فعلية أو شبه جملة، والمقصود بذلك الظرف والجار والمجرور. فالظرف نحو: زَيْدٌ عِنْدَكَ،",
        "video_link": null
      },
      {
        "ts": "5:28",
        "sec": 328,
        "text": "والسَّفَرُ غَداً، وقوله تعالى: {وَالرَّكْبُ أَسْفَلَ مِنكُمْ}.",
        "video_link": null
      },
      {
        "ts": "5:34",
        "sec": 334,
        "text": "الركب أسفل منكم؛ الركبُ: مبتدأ، أسفلَ: ظرف مكان منصوب،",
        "video_link": null
      },
      {
        "ts": "5:42",
        "sec": 342,
        "text": "وشبه الجملة يمكن أن نقول بأنها في هذا الوقت الراهن نقول إنها هي الخبر، لكن",
        "video_link": null
      },
      {
        "ts": "5:49",
        "sec": 349,
        "text": "سيأتينا مباشرة بعد قليل أننا نقول إن هذا الظرف متعلق بمحذوف هو الخبر.",
        "video_link": null
      },
      {
        "ts": "5:58",
        "sec": 358,
        "text": "وكذلك في الجار والمجرور نحو: زَيْدٌ فِي الدَّارِ، وقوله تعالى: {الْحَمْدُ لِلَّهِ}.",
        "video_link": null
      },
      {
        "ts": "6:04",
        "sec": 364,
        "text": "الحمدُ: مبتدأ، للهِ: جار ومجرور، وهذا الجار",
        "video_link": null
      },
      {
        "ts": "6:11",
        "sec": 371,
        "text": "والمجرور شبه الجملة هذه متعلقة بمحذوف هو الخبر؛ وذلك ما بينه بقوله: ويتعلق الظرف",
        "video_link": null
      },
      {
        "ts": "6:19",
        "sec": 379,
        "text": "والجار والمجرور إذا وقع خبراً بمحذوف وجوباً تقديره كائن أو مستقر، كما قال ابن",
        "video_link": null
      },
      {
        "ts": "6:29",
        "sec": 389,
        "text": "مالك: *\"وَأَخْبَرُوا بِظَرْفٍ أَوْ بِحَرْفِ جَر ... نَاوِينَ مَعْنَى كَائِنٍ أَوِ اسْتَقَر\"*؛ بمعنى حين",
        "video_link": null
      },
      {
        "ts": "6:37",
        "sec": 397,
        "text": "إذا أردنا أن نرجع إلى الأمثلة السابقة، مثلاً: زَيْدٌ فِي الدَّارِ، تقول: زيدٌ مبتدأ، وتقول:",
        "video_link": null
      },
      {
        "ts": "6:43",
        "sec": 403,
        "text": "في الدارِ جار ومجرور، لكن تسجيل تقول: جار ومجرور متعلق",
        "video_link": null
      },
      {
        "ts": "6:50",
        "sec": 410,
        "text": "بمحذوف هو الخبر تقديره كائن، أو يمكن أن تقدره فعلاً فتقول \"استقر\"؛ تقدير الكلام: زيدٌ",
        "video_link": null
      },
      {
        "ts": "6:59",
        "sec": 419,
        "text": "كائن في الدار، أو زيدٌ استقر في الدار.",
        "video_link": null
      },
      {
        "ts": "7:04",
        "sec": 424,
        "text": "قال: ولا يُخبر بظرف الزمان عن الذات، وإنما يُخبر به عن المعاني؛ نحو: الصَّوْمُ الْيَوْمَ،",
        "video_link": null
      },
      {
        "ts": "7:15",
        "sec": 435,
        "text": "والسَّفَرُ غَداً. بمعنى لا يمكنك أن تخبر",
        "video_link": null
      },
      {
        "ts": "7:22",
        "sec": 442,
        "text": "عن الذات مثل زيد،",
        "video_link": null
      },
      {
        "ts": "7:27",
        "sec": 447,
        "text": "الرجل، السفر، الصوم؛ لا، عفواً هذه أسماء المعاني. مثل زيد، الرجل،",
        "video_link": null
      },
      {
        "ts": "7:36",
        "sec": 456,
        "text": "الكتاب، وما أشبه ذلك؛ هذه ذوات، واضح؛ هذه الذوات لا يمكن أن تخبر عنها",
        "video_link": null
      },
      {
        "ts": "7:46",
        "sec": 466,
        "text": "بظرف الزمان، وذلك لعدم حصول الفائدة بذلك.",
        "video_link": null
      },
      {
        "ts": "7:52",
        "sec": 472,
        "text": "فالذات مستقلة عن الزمن لا تختص بزمن دون آخر؛ يعني ما يمكنك أن تقول مثلاً: زيدٌ",
        "video_link": null
      },
      {
        "ts": "8:00",
        "sec": 480,
        "text": "اليومَ؛ لِمَ؟ لأن زيداً اسم ذات وهو غير مرتبط بالزمان فلا تحصل",
        "video_link": null
      },
      {
        "ts": "8:08",
        "sec": 488,
        "text": "فائدة بقولك \"زيد اليوم\" أو \"زيد غداً\"، بخلاف المعاني؛ فإن أسماء المعاني هذه",
        "video_link": null
      },
      {
        "ts": "8:18",
        "sec": 498,
        "text": "يمكنها أن توجد في زمن دون زمن آخر، المعاني يمكنها أن تقترن بالزمان؛",
        "video_link": null
      },
      {
        "ts": "8:27",
        "sec": 507,
        "text": "لأن هذه المعاني هي يعني تصرفات، أفعال،",
        "video_link": null
      },
      {
        "ts": "8:33",
        "sec": 513,
        "text": "حركات تكون في أزمنة ولا تكون في أزمنة أخرى، فلاجل ذلك يمكن أن تخبر عن هذه",
        "video_link": null
      },
      {
        "ts": "8:41",
        "sec": 521,
        "text": "المعاني باسم الزمان؛ فمثلاً: الصَّوْمُ الْيَوْمَ، نعم هذا تحصل به الفائدة لِمَ؟ لأن الصوم من",
        "video_link": null
      },
      {
        "ts": "8:51",
        "sec": 531,
        "text": "المعاني التي يمكن أن توجد في زمن وأن لا توجد في زمن غيره، وكذلك: السَّفَرُ غَداً؛ فأنت",
        "video_link": null
      },
      {
        "ts": "8:58",
        "sec": 538,
        "text": "تخبر بأن السفر سيكون في زمن معين ومقتضى ذلك أنه لا يوجد في زمن غيره، بخلاف \"زيدٌ",
        "video_link": null
      },
      {
        "ts": "9:06",
        "sec": 546,
        "text": "اليومَ\" فهذا لا معنى له لأن زيداً اليوم أو غداً أو بعده لا يتغير فيه شيء.",
        "video_link": null
      },
      {
        "ts": "9:13",
        "sec": 553,
        "text": "وقولهم: \"اللَّيْلَةَ الْهِلالُ\" مؤول؛ بمعنى بعد أن ذكر القاعدة،",
        "video_link": null
      },
      {
        "ts": "9:20",
        "sec": 560,
        "text": "أورد على نفسه مثالاً من كلام العرب يمكن أن يتوهم قارئ",
        "video_link": null
      },
      {
        "ts": "9:28",
        "sec": 568,
        "text": "الكتاب أنه مخالف للقاعدة وهو قولهم: اللَّيْلَةَ الْهِلالُ.",
        "video_link": null
      },
      {
        "ts": "9:35",
        "sec": 575,
        "text": "فإن ظاهر هذا الكلام أن الهلالُ مبتدأ مؤخر، والليلةَ ظرف",
        "video_link": null
      },
      {
        "ts": "9:44",
        "sec": 584,
        "text": "متعلق بمحذوف وهذا الظرف هو الخبر؛ فهنا أُخبر عن الذات وهي الهلال",
        "video_link": null
      },
      {
        "ts": "9:54",
        "sec": 594,
        "text": "باسم زمان، فهذا يخالف القاعدة. فهو يقول: وقولهم (أي قول العرب): اللَّيْلَةَ الْهِلالُ",
        "video_link": null
      },
      {
        "ts": "10:02",
        "sec": 602,
        "text": "مؤول؛ ما معنى مؤول؟ أي تقدر محذوفاً فتقول: اللَّيْلَةَ الْهِلالُ،",
        "video_link": null
      },
      {
        "ts": "10:10",
        "sec": 610,
        "text": "التقدير ذلك: الليلةَ رؤيةُ الهلالِ،",
        "video_link": null
      },
      {
        "ts": "10:17",
        "sec": 617,
        "text": "واضح؛ فالذي يختص بهذا الزمن المخصوص الذي هو الليلة ليس هو الهلال ليس اسم الذات،",
        "video_link": null
      },
      {
        "ts": "10:25",
        "sec": 625,
        "text": "وإنما معنى من المعاني وهو رؤية الهلال؛ لكن هم يختصرون الكلام فيقولون: الليلةَ",
        "video_link": null
      },
      {
        "ts": "10:33",
        "sec": 633,
        "text": "الهلالُ، وإنما يقصدون الهلال عفواً وإنما يقصدون رؤية الهلال الليلة، الليلةَ رؤيةُ",
        "video_link": null
      },
      {
        "ts": "10:41",
        "sec": 641,
        "text": "الهلالِ. ومن ذلك مثلاً قول امرئ القيس في القصة المشهورة حين أُخبر بأن بني أسد",
        "video_link": null
      },
      {
        "ts": "10:49",
        "sec": 649,
        "text": "قتلوا أباه وهو كان في مجلس خمر، فقال: *\"الْيَوْمَ خَمْرٌ وَغَداً أَمْرٌ\"*؛ بمعنى يخبر بأنه اليوم على كل حال سيستمر في",
        "video_link": null
      },
      {
        "ts": "11:06",
        "sec": 666,
        "text": "منادمة أصحابه ثم بعد ذلك يمضي لأخذ ثأر أبيه؛ لكن قوله \"الْيَوْمَ خَمْرٌ\"،",
        "video_link": null
      },
      {
        "ts": "11:14",
        "sec": 674,
        "text": "الخمر ذات واليوم ظرف زمان، ففي ظاهره إخبار عن",
        "video_link": null
      },
      {
        "ts": "11:23",
        "sec": 683,
        "text": "الذات بالزمان، فهذا أيضاً مؤول وتاويله: اليومَ شُرْبُ خَمْرٍ، اليوم شرب خمر، نعم.",
        "video_link": null
      },
      {
        "ts": "11:34",
        "sec": 694,
        "text": "ثم قال: ويجوز تعدد الخبر، نحو: زَيْدٌ كَاتِبٌ شَاعِرٌ،",
        "video_link": null
      },
      {
        "ts": "11:40",
        "sec": 700,
        "text": "وكقوله تعالى: {وَهُوَ الْغَفُورُ الْوَدُودُ * ذُو الْعَرْشِ الْمَجِيدُ * فَعَّالٌ لِّمَا يُرِيدُ}؛ بمعنى يمكنك أن تخبر",
        "video_link": null
      },
      {
        "ts": "11:49",
        "sec": 709,
        "text": "عن مبتدأ واحد بأخبار متعددة، باثنين أو بأكثر،",
        "video_link": null
      },
      {
        "ts": "11:57",
        "sec": 717,
        "text": "واضح؛ مثلاً: زَيْدٌ كَاتِبٌ شَاعِرٌ؛ زيدٌ: مبتدأ، كاتبٌ: خبر أول، شاعرٌ: خبر ثانٍ؛ فأنت تخبر عن زيد",
        "video_link": null
      },
      {
        "ts": "12:07",
        "sec": 727,
        "text": "بأمرين اثنين بوصفين، تخبر عنه بتحقق وصف الكتابة فيه ووصف",
        "video_link": null
      },
      {
        "ts": "12:14",
        "sec": 734,
        "text": "الشاعرية فيه، وكذلك وهو ربنا سبحانه وتعالى: {الْغَفُورُ الْوَدُودُ * ذُو الْعَرْشِ}",
        "video_link": null
      },
      {
        "ts": "12:22",
        "sec": 742,
        "text": "على قراءةِ {الْمَجِيدُ * فَعَّالٌ لِّمَا يُرِيدُ}؛ فهذه",
        "video_link": null
      },
      {
        "ts": "12:27",
        "sec": 747,
        "text": "كلها أخبار عن ربنا سبحانه وتعالى، واضح.",
        "video_link": null
      },
      {
        "ts": "12:35",
        "sec": 755,
        "text": "لكن خلافاً لقول القائل مثلاً: الرُّمَّانُ حُلْوٌ حَامِضٌ.",
        "video_link": null
      },
      {
        "ts": "12:42",
        "sec": 762,
        "text": "الرمان حامض؛ ففي مثل هذا المثال \"حلوٌ\" لا يستقل بالخبر،",
        "video_link": null
      },
      {
        "ts": "12:52",
        "sec": 772,
        "text": "وكذلك \"حامضٌ\" لا يستقل بالخبر، وإنما الخبر هو مجموعهما؛ فإنك حين تقول: الرُّمَّانُ حُلْوٌ حَامِضٌ، تقصد أنه قد اجتمعت فيه الحلاوة والحموضة، ولا تقصد أنه كما في \"زيد كاتب\" أنه كاتب",
        "video_link": null
      },
      {
        "ts": "13:11",
        "sec": 791,
        "text": "وأنه كذلك شاعر، بحيث لو قلت \"زيد كاتب\" فقط فكان صحيحاً ولو قلت \"زيد شاعر\" صحيحاً؛ حينئذٍ",
        "video_link": null
      },
      {
        "ts": "13:19",
        "sec": 799,
        "text": "هذان خبران. لكن في \"الرمان حلو حامض\" وأنت تقصد اجتماعهما، فلو قلت \"الرمان حلو\" لكان",
        "video_link": null
      },
      {
        "ts": "13:28",
        "sec": 808,
        "text": "خطأ ولو قلت \"الرمان حامض\" لكان خطأ لأنك تقصد أنه وسط بين الحلاوة والحموضة، فلذلك",
        "video_link": null
      },
      {
        "ts": "13:36",
        "sec": 816,
        "text": "في هذه الحالة لا تقول \"حلو\" خبر أول \"حامض\" خبر ثانٍ، بل تقول كلاهما يعني \"حلو حامض\"",
        "video_link": null
      },
      {
        "ts": "13:43",
        "sec": 823,
        "text": "كله هو الخبر. وقد يتقدم على المبتدأ جوازاً، نحو: فِي الدَّارِ",
        "video_link": null
      },
      {
        "ts": "13:50",
        "sec": 830,
        "text": "زَيْدٌ، ووجوباً نحو: أَيْنَ زَيْدٌ؟ وإِنَّمَا عِنْدَكَ زَيْدٌ. قد يتقدم على المبتدأ جوازاً في مثل: فِي",
        "video_link": null
      },
      {
        "ts": "14:00",
        "sec": 840,
        "text": "الدَّارِ زَيْدٌ، ويمكنك أن تقول \"زيدٌ في الدار\" فلا إشكال في هذا، ولذلك هذا تقديم على جهة الجواز. لكن",
        "video_link": null
      },
      {
        "ts": "14:09",
        "sec": 849,
        "text": "يمكن أن يكون هذا التقديم واجباً، وذلك في مجموعة من الصور أو من المسائل؛ من بينها:",
        "video_link": null
      },
      {
        "ts": "14:16",
        "sec": 856,
        "text": "أن يكون الخبر مما له صدر الكلام كالاستفهام، فـ \"أَيْنَ زَيْدٌ؟\" لا يمكن أن تقول \"زيدٌ",
        "video_link": null
      },
      {
        "ts": "14:25",
        "sec": 865,
        "text": "أين\"؛ لِمَ؟ لأن أين اسم استفهام والاستفهام له صدر الكلام، فلا بد أن تبدأ به قبل أن تأتي",
        "video_link": null
      },
      {
        "ts": "14:36",
        "sec": 876,
        "text": "قبل أن تأتي بالمبتدأ. والصورة الثانية: إِنَّمَا عِنْدَكَ زَيْدٌ.",
        "video_link": null
      },
      {
        "ts": "14:45",
        "sec": 885,
        "text": "إنما عندك زيد؛ هذه الصيغة تفيد معنى الحصر،",
        "video_link": null
      },
      {
        "ts": "14:51",
        "sec": 891,
        "text": "أي تحصر مَن عندك في زيد \"إِنَّمَا عِنْدَكَ زَيْدٌ\"، فلو قلت",
        "video_link": null
      },
      {
        "ts": "15:00",
        "sec": 900,
        "text": "يعني لو أردت أن تقلب بحيث تقول \"زيد عندك\" يعني لا يتحقق بها معنى الحصر،",
        "video_link": null
      },
      {
        "ts": "15:09",
        "sec": 909,
        "text": "فأنت تريد أن تحصر يعني من الصيغ البلاغية المشهورة فلا يتحقق حصر",
        "video_link": null
      },
      {
        "ts": "15:18",
        "sec": 918,
        "text": "المبتدأ، أي أن يكون المبتدأ محصوراً؛ عفواً زيد هو المحصور \"إِنَّمَا عِنْدَكَ زَيْدٌ\" زيد",
        "video_link": null
      },
      {
        "ts": "15:28",
        "sec": 928,
        "text": "محصور في كونه عندك. يعني على كل حال قضية إنما والحصر بها وأي",
        "video_link": null
      },
      {
        "ts": "15:37",
        "sec": 937,
        "text": "الجزءين يكون محصوراً هذا مبحث بلاغي لا أرجع إليه الآن؛ لكن المقصود أن المبتدأ لو",
        "video_link": null
      },
      {
        "ts": "15:46",
        "sec": 946,
        "text": "أُخّر لأوهمه خلاف ذلك، يعني لو قيل \"إنما زيدٌ عندك\"",
        "video_link": null
      },
      {
        "ts": "15:57",
        "sec": 957,
        "text": "لكان المحصور ليس المبتدأ وإنما الخبر؛ أنه فرق بين أن تحصر زيداً في كونه عندك،",
        "video_link": null
      },
      {
        "ts": "16:04",
        "sec": 964,
        "text": "وبين أن تحصر مَن عندك في زيد، ولا يُعلم المحصور من غيره إلا بالترتيب؛",
        "video_link": null
      },
      {
        "ts": "16:14",
        "sec": 974,
        "text": "فقولك \"إِنَّمَا عِنْدَكَ زَيْدٌ\" غير قولك \"إنما زيدٌ عندك\".",
        "video_link": null
      },
      {
        "ts": "16:24",
        "sec": 984,
        "text": "والصورة الثالثة مثّل لها بقول الله سبحانه وتعالى: {أَمْ عَلَىٰ قُلُوبٍ أَقْفَالُهَا}؛ {أَمْ عَلَىٰ قُلُوبٍ",
        "video_link": null
      },
      {
        "ts": "16:33",
        "sec": 993,
        "text": "أَقْفَالُهَا} لو عُكس الآن؛ عندنا \"أقفالٌ\" هي المبتدأ، و\"على قلوب\" هو الجار والمجرور شبه الجملة المتعلق",
        "video_link": null
      },
      {
        "ts": "16:42",
        "sec": 1002,
        "text": "بالخبر. لو عُكس فقيل \"أقفالها على قلوب\"، حينئذٍ هذا الضمير الموجود في أقفالها هذا",
        "video_link": null
      },
      {
        "ts": "16:51",
        "sec": 1011,
        "text": "راجع على القلوب، فيكون حينئذٍ راجعاً يكون الضمير عائداً على متأخر في اللفظ والرتبة؛ متأخر في اللفظ",
        "video_link": null
      },
      {
        "ts": "17:01",
        "sec": 1021,
        "text": "لأنه \"على قلوب\" عفواً \"أقفالها على قلوبها\" راجع على القلوب إذن متأخر في اللفظ،",
        "video_link": null
      },
      {
        "ts": "17:07",
        "sec": 1027,
        "text": "ومتأخر في الرتبة لأن الضمير الموجود مع المبتدأ راجع على الخبر، والخبر متأخر في",
        "video_link": null
      },
      {
        "ts": "17:16",
        "sec": 1036,
        "text": "الرتبة يعني المبتدأ. وقد أسلفنا مثالاً من قبل بينا فيه أنهم يقولون بامتناع عود",
        "video_link": null
      },
      {
        "ts": "17:24",
        "sec": 1044,
        "text": "الضمير على متأخر في اللفظ والرتبة، هذا من حيث الأصل. والصورة",
        "video_link": null
      },
      {
        "ts": "17:31",
        "sec": 1051,
        "text": "الرابعة أو المسألة الرابعة مثّل لها بقول القائل: فِي الدَّارِ رَجُلٌ، فِي الدَّارِ رَجُلٌ.",
        "video_link": null
      },
      {
        "ts": "17:41",
        "sec": 1061,
        "text": "لِمَ هنا يجب تقديم الخبر؟ لأنك لو قلت \"رجلٌ في الدار\"",
        "video_link": null
      },
      {
        "ts": "17:49",
        "sec": 1069,
        "text": "فهنا يكون عندك احتمال؛ الاحتمال الأول \"رجلٌ\" مبتدأ و\"في الدار\" هو الخبر،",
        "video_link": null
      },
      {
        "ts": "17:58",
        "sec": 1078,
        "text": "أو أن تكون \"في الدار\" صفة لرجل،",
        "video_link": null
      },
      {
        "ts": "18:04",
        "sec": 1084,
        "text": "وحينئذٍ نحتاج أن نبحث عن الخبر. لِمَ السبب في هذا؟ السبب هو أن \"رجل\" نكرة،",
        "video_link": null
      },
      {
        "ts": "18:12",
        "sec": 1092,
        "text": "والنكرة تطلب ظرفاً أو جاراً ومجروراً",
        "video_link": null
      },
      {
        "ts": "18:21",
        "sec": 1101,
        "text": "واضح لكي تختص بها؛ ذكرنا آنفاً أن الابتداء بالنكرة لا يسوغ،",
        "video_link": null
      },
      {
        "ts": "18:30",
        "sec": 1110,
        "text": "وأن من مسوغات الابتداء بالنكرة أن يؤتى بالنكرة موصوفة. فحين تقول رجل",
        "video_link": null
      },
      {
        "ts": "18:38",
        "sec": 1118,
        "text": "في الدار، قد يظن الظان أن \"في الدار\" هذا إنما هو قيد وصف",
        "video_link": null
      },
      {
        "ts": "18:44",
        "sec": 1124,
        "text": "قيّدت به النكرة لتسويغ الابتداء بها ثم يأتي بعد ذلك الخبر، فتقول: رجلٌ في الدار",
        "video_link": null
      },
      {
        "ts": "18:53",
        "sec": 1133,
        "text": "عالمٌ، واضح. أما إذا كنت تقصد الإخبار بكونه في الدار، فيجب تقديم الجار والمجرور فتقول:",
        "video_link": null
      },
      {
        "ts": "19:03",
        "sec": 1143,
        "text": "فِي الدَّارِ رَجُلٌ. وأنت ترى أن ينبغي أن تفرق بين هذه الصورة بين الصورة",
        "video_link": null
      },
      {
        "ts": "19:10",
        "sec": 1150,
        "text": "الصورة الأولى التي ذُكر: فِي الدَّارِ زَيْدٌ؛ فهذه التقديم فيها جائز وليس واجباً، ما",
        "video_link": null
      },
      {
        "ts": "19:18",
        "sec": 1158,
        "text": "الفرق بينهما؟ الفرق أن زيداً معرفة، وأن رجلاً نكرة، والابتداء بالنكرة كما ذكرنا إنما يسوغ",
        "video_link": null
      },
      {
        "ts": "19:27",
        "sec": 1167,
        "text": "بأشياء من بينها التقيد بالصفة؛ هذه هي المسألة الرابعة وهي أن يكون تأخير",
        "video_link": null
      },
      {
        "ts": "19:35",
        "sec": 1175,
        "text": "الخبر موقعاً في التباس ظاهر. ثم قال: وقد يُحذف كل من المبتدأ والخبر",
        "video_link": null
      },
      {
        "ts": "19:42",
        "sec": 1182,
        "text": "جوازاً، نحو: {سَلَامٌ قَوْمٌ مُّنكَرُونَ}؛ تقدير الكلام: أي سلامٌ عليكم أنتم قومٌ",
        "video_link": null
      },
      {
        "ts": "19:51",
        "sec": 1191,
        "text": "منكرون. هنا يجوز إثبات المبتدأ والخبر ويجوز حذفهما؛ فحُذف الخبر",
        "video_link": null
      },
      {
        "ts": "20:02",
        "sec": 1202,
        "text": "في \"سلام عليكم\"، ثم حُذف المبتدأ من \"أنتم قوم منكرون\"؛ أنتم هذا هو المبتدأ وقومٌ خبره، جميل.",
        "video_link": null
      },
      {
        "ts": "20:12",
        "sec": 1212,
        "text": "هذا حذف جائز. وقد يكون الحذف واجباً؛ قال: ويجب الحذف،",
        "video_link": null
      },
      {
        "ts": "20:19",
        "sec": 1219,
        "text": "ويجب حذف الخبر بعد لو بعد لولا نحو إلى آخره؛ يجب حذف الخبر في مسائل هو لا يذكر هكذا في",
        "video_link": null
      },
      {
        "ts": "20:27",
        "sec": 1227,
        "text": "المسألة الأولى المسألة الثانية، إنما يذكر ذلك بطريق التمثيل؛ إذن يجب حذف الخبر",
        "video_link": null
      },
      {
        "ts": "20:33",
        "sec": 1233,
        "text": "أولاً بعد لولا، نحو: {لَوْلَا أَنتُمْ لَكُنَّا مُؤْمِنِينَ}؛",
        "video_link": null
      },
      {
        "ts": "20:39",
        "sec": 1239,
        "text": "أي لولا أنتم موجودون، واضح؛ لولا هذه دالة على امتناع الشيء",
        "video_link": null
      },
      {
        "ts": "20:47",
        "sec": 1247,
        "text": "لوجود غيره، أي لولا وجود وجودكم لا",
        "video_link": null
      },
      {
        "ts": "20:55",
        "sec": 1255,
        "text": "لكنا مؤمنين لا يعني لأجل امتناع الشيء لوجود شيء آخر.",
        "video_link": null
      },
      {
        "ts": "21:06",
        "sec": 1266,
        "text": "لولا وجودكم لكنا مؤمنين؛ لولا أنتم موجودون لكنا مؤمنين،",
        "video_link": null
      },
      {
        "ts": "21:14",
        "sec": 1274,
        "text": "ثم هنا عندنا \"أنتم\" هذا هو المبتدأ خبره محذوف وجوباً تقديره",
        "video_link": null
      },
      {
        "ts": "21:23",
        "sec": 1283,
        "text": "موجودون، واضح؛ {لَكُنَّا مُؤْمِنِينَ} كنا مؤمنين هذه جملة فعلية.",
        "video_link": null
      },
      {
        "ts": "21:33",
        "sec": 1293,
        "text": "الشاهد عندنا هو وجوب حذف الخبر هنا بعد لولا.",
        "video_link": null
      },
      {
        "ts": "21:44",
        "sec": 1304,
        "text": "هنا مسألة يذكرونها وهي أن هذا الخبر الذي يجب حذفه بعد لولا إنما يجب حذفه إذا كان",
        "video_link": null
      },
      {
        "ts": "21:54",
        "sec": 1314,
        "text": "كما يقولون كوناً مطلقاً مطلق الوجود، كما في هذا المثال: لولا أنتم",
        "video_link": null
      },
      {
        "ts": "22:01",
        "sec": 1321,
        "text": "موجودون لكنا مؤمنين؛ إما يعني الكون المطلق أو الكون",
        "video_link": null
      },
      {
        "ts": "22:10",
        "sec": 1330,
        "text": "لولا زيدٌ لأكرمتك؛ أي لولا زيدٌ موجودٌ لأكرمتك، هنا يجب حذف هذا",
        "video_link": null
      },
      {
        "ts": "22:18",
        "sec": 1338,
        "text": "الخبر. أما إذا كان هذا الخبر كوناً خاصاً",
        "video_link": null
      },
      {
        "ts": "22:28",
        "sec": 1348,
        "text": "فحينئذٍ يقولون نعم، فحينئذٍ يقولون",
        "video_link": null
      },
      {
        "ts": "22:36",
        "sec": 1356,
        "text": "لا يُحذف إلا إن وُجدت قرينة دالة عليه، يعني",
        "video_link": null
      },
      {
        "ts": "22:43",
        "sec": 1363,
        "text": "مثلاً: لولا زيدٌ محسنٌ",
        "video_link": null
      },
      {
        "ts": "22:50",
        "sec": 1370,
        "text": "إليَّ لهلكتُ؛ أي لولا أن زيداً يحسن إليَّ لهلكتُ، لولا زيدٌ",
        "video_link": null
      },
      {
        "ts": "22:57",
        "sec": 1377,
        "text": "محسنٌ له، أي لولا إحسانُ زيدٍ لهلكتُ.",
        "video_link": null
      },
      {
        "ts": "23:36",
        "sec": 1416,
        "text": "هذا النوع الأول. النوع الثاني أو المسألة الثانية: وبعد القسم الصريح، نحو: {لَعَمْرُكَ إِنَّهُمْ}؛",
        "video_link": null
      },
      {
        "ts": "23:45",
        "sec": 1425,
        "text": "أي لعمرك قسمي، فهنا أيضاً الخبر محذوف،",
        "video_link": null
      },
      {
        "ts": "23:52",
        "sec": 1432,
        "text": "أليس كذلك؛ فهنا أيضاً الخبر محذوف وتقديره لعمرك وتقديره قسمي.",
        "video_link": null
      },
      {
        "ts": "24:01",
        "sec": 1441,
        "text": "فاللام هذه لام الابتداء، وعمرُ مبتدأ مرفوع،",
        "video_link": null
      },
      {
        "ts": "24:08",
        "sec": 1448,
        "text": "والكاف ضمير متصل في محل جر بالإضافة وهذا قسم \"لعمرك\"،",
        "video_link": null
      },
      {
        "ts": "24:16",
        "sec": 1456,
        "text": "ثم الخبر محذوف تقديره قسمي.",
        "video_link": null
      },
      {
        "ts": "24:23",
        "sec": 1463,
        "text": "ومثل هذا الخبر يجب حذفه كما ذكر. وأيضاً بعد واو المعية، نحو: كُلُّ صَانِعٍ وَمَا صَنَعَ؛ أي",
        "video_link": null
      },
      {
        "ts": "24:33",
        "sec": 1473,
        "text": "مقرونان. واو المعية هذه هي الواو التي تعطف اسماً",
        "video_link": null
      },
      {
        "ts": "24:42",
        "sec": 1482,
        "text": "آخر على المبتدأ؛ فـ \"كلُّ\" مبتدأ وصانعٍ مضاف إليه،",
        "video_link": null
      },
      {
        "ts": "24:50",
        "sec": 1490,
        "text": "الواو حرف عطف يدل على معنى المعية، ومَا مصدرية تسبك مع الفعل بعدها",
        "video_link": null
      },
      {
        "ts": "25:00",
        "sec": 1500,
        "text": "في مصدر واضح، وهذا المصدر معطوف على كل صانع.",
        "video_link": null
      },
      {
        "ts": "25:05",
        "sec": 1505,
        "text": "التقدير: كلُّ صانعٍ وصنعتُه، واضح؛ والخبر أين هو؟ كل صانع وصنعته أين",
        "video_link": null
      },
      {
        "ts": "25:15",
        "sec": 1515,
        "text": "الخبر؟ الخبر محذوف تقديره مقرونان؛ من أين أتينا بمعنى القرن أو الاقتران؟ أتينا به",
        "video_link": null
      },
      {
        "ts": "25:22",
        "sec": 1522,
        "text": "من واو المعية فإنه يحذف وجوباً لأن واو",
        "video_link": null
      },
      {
        "ts": "25:28",
        "sec": 1528,
        "text": "المعية تدل عليه فلا يحتاج إلى ذكره. وأخيراً وقبل الحال التي لا تصلح أن تكون",
        "video_link": null
      },
      {
        "ts": "25:37",
        "sec": 1537,
        "text": "خبراً، نحو: ضَرْبِي زَيْداً قَائِماً؛ أي إذا كان قائماً.",
        "video_link": null
      },
      {
        "ts": "25:43",
        "sec": 1543,
        "text": "فضربي زيداً قائماً؛ ضربي: مبتدأ مرفوع وعلامة رفعه الضمة المقدرة على ما",
        "video_link": null
      },
      {
        "ts": "25:51",
        "sec": 1551,
        "text": "قبل ياء المتكلم، منع من ظهورها اشتغال المحل بحركة المناسبة \"ضربي\"،",
        "video_link": null
      },
      {
        "ts": "25:59",
        "sec": 1559,
        "text": "ثم ضربي زيداً يعني هذه المتكلم، ثم ضربي هذا مصدر وهو يعمل عمل الفعل، زيداً: معمول",
        "video_link": null
      },
      {
        "ts": "26:07",
        "sec": 1567,
        "text": "له إذن زيداً مفعول به للمصدر، قائماً: حال",
        "video_link": null
      },
      {
        "ts": "26:15",
        "sec": 1575,
        "text": "من ضمير يعود على زيد وهو مستتر في \"كان\" المحذوفة لأن تقدير",
        "video_link": null
      },
      {
        "ts": "26:25",
        "sec": 1585,
        "text": "الكلام: ضربي زيداً إذ كان قائماً، جميل.",
        "video_link": null
      },
      {
        "ts": "26:33",
        "sec": 1593,
        "text": "وقوله وقبل الحال التي لا تصلح أن تكون خبراً؛ لأن هذه الحال \"قائمٌ\" لا يصلح أن يكون",
        "video_link": null
      },
      {
        "ts": "26:41",
        "sec": 1601,
        "text": "خبراً عن الضرب فلا يمكنك",
        "video_link": null
      },
      {
        "ts": "26:45",
        "sec": 1605,
        "text": "أن، يعني لا يمكن أن يكون القيام خبراً",
        "video_link": null
      },
      {
        "ts": "26:52",
        "sec": 1612,
        "text": "عن الضرب فلاجل ذلك هنالك خبر محذوف ولا بد من تقديره. ثم قال: باب العوامل الداخلة على المبتدأ والخبر وتسمى النواسخ؛",
        "video_link": null
      },
      {
        "ts": "27:17",
        "sec": 1637,
        "text": "لِمَ؟ لأنها تنسخ حكماً سابقاً، فالمبتدأ الأصل فيه أن يكون",
        "video_link": null
      },
      {
        "ts": "27:26",
        "sec": 1646,
        "text": "مرفوعاً والخبر أن يكون مرفوعاً، ثم تأتي النواسخ فتغير هذا الحكم",
        "video_link": null
      },
      {
        "ts": "27:33",
        "sec": 1653,
        "text": "فتجعل أحدهما منصوباً أو تجعلهما منصوبين وتغير الأحكام، فهي ناسخة لحكم المبتدأ",
        "video_link": null
      },
      {
        "ts": "27:42",
        "sec": 1662,
        "text": "والخبر، وتسمى النواسخ ونواسخ الابتداء؛ أي هذا اسم آخر، أنها",
        "video_link": null
      },
      {
        "ts": "27:49",
        "sec": 1669,
        "text": "تنسخ معنى الابتداء الموجود في الجملة الاسمية، وهي ثلاثة أنواع؛ النوع الأول: ما يرفع المبتدأ وينصب الخبر وهو كان وأخواتها",
        "video_link": null
      },
      {
        "ts": "27:58",
        "sec": 1678,
        "text": "والحروف المشبهة بليس وأفعال المقاربة؛ هذه الأنواع الثلاثة كلها تتفق في الحكم من",
        "video_link": null
      },
      {
        "ts": "28:06",
        "sec": 1686,
        "text": "جهة أنها ترفع المبتدأ أي تترك المبتدأ على حال رفعه وتنصب الخبر. النوع الثاني بعكس ذلك:",
        "video_link": null
      },
      {
        "ts": "28:15",
        "sec": 1695,
        "text": "ما ينصب المبتدأ ويرفع الخبر وهو إن وأخواتها ولا التي لنفي الجنس. والنوع",
        "video_link": null
      },
      {
        "ts": "28:23",
        "sec": 1703,
        "text": "الثالث: ما ينصب المبتدأ والخبر جميعاً وهو ظن وأخواتها. إذن هذه النواسخ سنذكرها",
        "video_link": null
      },
      {
        "ts": "28:31",
        "sec": 1711,
        "text": "الواحدة تلو الأخرى، ونبدأ أولاً بالفصل الأول وهو كان وأخواتها، ونجعل ذلك بإذن",
        "video_link": null
      },
      {
        "ts": "28:40",
        "sec": 1720,
        "text": "الله عز وجل في درسنا المقبل. أقول قولي هذا وأستغفر الله لي ولكم، والحمد لله رب",
        "video_link": null
      },
      {
        "ts": "28:48",
        "sec": 1728,
        "text": "العالمين.",
        "video_link": null
      }
    ]
  },
  {
    "subject": "nahw",
    "subjectLabel": "علم النحو والصرف",
    "lesson": "الدرس 18",
    "lessonNum": 18,
    "title": "الدرس 18",
    "summary": "إليك ملخص شامل ومنظم لهذا الدرس الأكاديمي، مصمم بطريقة سلسة ومبسطة تساعد على الفهم والاستذكار السريع.\n\n<b><i>\n\n### 1. موضوع الدرس الرئيسي\n\nتناول الأستاذ في هذا الدرس باب </b>نواسخ الابتداء<b>، وهي الأدوات التي تدخل على الجملة الاسمية (المبتدأ والخبر) فتغير حكمها الإعرابي. وركز الدرس على محورين أساسيين:\n</i> </b>الفصل الأول:<b> \"كان\" وأخواتها (أفعال النسخ).\n<i> </b>الفصل الثاني:<b> الحروف المشبهة بـ \"ليس\" (حروف النسخ).\n\n---\n\n### 2. المحاور والنقاط الأساسية\n\n#### أولاً: كان وأخواتها (عملها وأقسامها)\nعملها: تدخل على الجملة الاسمية فترفع المبتدأ ويسمى اسمها (تشبيهاً بالفاعل)، وتنصب الخبر ويسمى خبرها (تشبيهاً بالمفعول به). وتُقسم هذه الأفعال من حيث شروط العمل إلى ثلاثة أقسام:\n\n1. </b>ما يعمل بلا شرط (8 أفعال):<b>\nوهي: كان، أمسى، أصبح، أضحى، ظل، بات، صار، ليس.\n\n2. </b>ما يعمل بشرط أن يتقدمه نفي أو نهي أو دعاء (4 أفعال):<b>\nوهي: زال، فتئ، برح، انفك.\n\n3. </b>ما يعمل بشرط أن تتقدمه \"ما\" المصدرية الظرفية (فعل واحد):<b>\nوهو: دام. وسُميت \"ما\" بذلك لأنها تُقدّر بالمصدر (الدوام) وبالظرف (المدة).\n\n#### ثانياً: أحكام ترتيب جملة \"كان\" وأخواتها\n</i> </b>توسط الخبر:<b> يجوز إعرابياً أن يتقدم الخبر ليتوسط بين الفعل الناسخ واسمه.\n<i> </b>تقدم الخبر على الفعل نفسه:<b> يجوز أن يتقدم الخبر على الأداة والاسم معاً في جميع الأفعال، باستثناء (ليس) و(دام) فإنه يمتنع تقديم خبرهما عليهما على الأصح.\n\n#### ثالثاً: تصرف الأفعال الناسخة\nما يتصرف من هذه الأفعال (مضارع، أمر، مصدر، اسم فاعل) يعمل عمل الفعل الماضي تماماً.\n\n#### رابعاً: التمام والنقصان في \"كان\" وأخواتها\n</i> </b>الأفعال الناقصة:<b> هي التي تحتاج إلى اسم وخبر لإتمام معناها.\n<i> </b>الأفعال التامة:<b> هي التي تكتفي بمرفوعها (الفاعل) وتستغني عن الخبر، وتكون بمعنى (وُجد أو حصل أو دخل في الوقت).\n</i> </b>ملاحظة:<b> جميع الأفعال قد تأتي تامة إلا ثلاثة أفعال تلازم النقصان دائماً وهي: (زال، فتئ، ليس).\n\n#### خامساً: الخصائص الفريدة لـ \"كان\"\nتتميز \"كان\" عن أخواتها بثلاث خصائص:\n1. </b>جواز زيادتها:<b> بشرط أن تكون بلفظ الماضي، وأن تقع في حشو الكلام (بين شيئين متلازمين كصيغة التعجب).\n2. </b>حذفها مع اسمها وإبقاء خبرها:<b> ويكثر ذلك بعد \"لو\" و\"إن\" الشرطيتين.\n3. </b>حذف نون مضارعها المجزوم تخفيفاً:<b> بأربعة شروط (أن يكون فعلاً مضارعاً، مجزوماً، وألا يليه ساكن، وألا يتصل به ضمير نصب).\n\n#### سادساً: الحروف المشبهة بـ \"ليس\"\nوهي أربعة حروف تعمل عمل \"ليس\" (ترفع المبتدأ وتنصب الخبر)، تم شرح حرفين منها في هذا الدرس:\n\n1. </b>الحرف الأول (ما):<b> وتعمل عمل ليس عند الحجازيين (وتسمى ما الحجازية) بأربعة شروط:\n<i> ألا يقترن اسمها بـ \"إن\" الزائدة.\n</i> ألا يقترن خبرها بـ \"إلا\".\n<i> ألا يتقدم خبرها على اسمها.\n</i> ألا يتقدم معمول خبرها على اسمها (إلا إذا كان المعمول ظرفاً أو جاراً ومجروراً).\n<i> </b>ملاحظة:<b> بنو تميم يهملون \"ما\" دائماً ولا يعملونها حتى لو استوفت الشروط.\n\n2. </b>الحرف الثاني (لا):<b> تعمل عمل ليس عند الحجازيين بنفس شروط \"ما\"، ويضاف إليها شرط خامس:\n</i> أن يكون اسمها وخبرها نكرتين (وعملها يكثر في الشعر).\n\n---\n\n### 3. الأمثلة والتطبيقات\n\n#### أمثلة \"كان\" وأخواتها:\n<i> </b>العمل بلا شرط:<b> {وكان الله غفوراً رحيماً}، {فأصبحتم بنعمته إخواناً}، {ليسوا سواءً}، {ظل وجهه مسوداً}.\n</i> </b>المسبوق بنفي:<b> {ولا يزالون مختلفين}، {لن نبرح عليه عاكفين}.\n<i> </b>المسبوق بنهي:<b> قول الشاعر: \"صاحِ شَمِّرْ وَلا تَزَلْ ذاكِرَ المَوتِ\" (الفعل تزل مجزوم، واسمه مستتر، وذاكر هو الخبر).\n</i> </b>المسبوق بدعاء:<b> قول الشاعر: \"وَلا زالَ مُنْهَلّاً بِجَرْعائِكَ القَطْرُ\" (القطرُ هو الاسم، ومنهلاً هو الخبر مقدم).\n<i> </b>المسبوق بـ ما المصدرية الظرفية:<b> {ما دمت حياً} (التاء اسم دام، وحياً خبرها، والتقدير: مدة دوامي حياً).\n\n#### أمثلة أحكام الترتيب والتصرف والتمام:\n</i> </b>توسط الخبر:<b> {وكان حقاً علينا نصرُ المؤمنين} (حقاً: خبر مقدم، نصرُ: اسم مؤخر).\n<i> </b>تقديم الخبر على الفعل:<b> \"عالماً كان زيدٌ\" (عالماً: خبر مقدم لـ كان).\n</i> </b>تصرف الأفعال:<b> {حتى يكونوا مؤمنين} (مضارع)، {قل كونوا حجارة} (أمر)، \"كونُك مجتهداً مطلوبٌ\" (مصدر عامل عمل الفعل).\n<i> </b>الأفعال التامة:<b> {وإن كان ذو عسرة} (كان هنا تامة بمعنى وُجد، وذو: فاعل مرفوع بالواو). {حين تمسون وحين تصبحون} (أفعال تامة بمعنى تدخلون في المساء والصباح، والواو فاعل).\n\n#### أمثلة خصائص \"كان\":\n</i> </b>زيادة كان:<b> \"ما كان أحسنَ زيداً\" (كان زائدة لا عمل لها إعرابياً).\n<i> </b>حذف كان مع اسمها:<b> \"التمس ولو خاتماً من حديد\" (التقدير: ولو كان الملتمس خاتماً). \"إن خيراً فخيراً\" (التقدير: إن كان عملهم خيراً فجزاؤهم خيراً).\n</i> </b>حذف نون المضارع المجزوم:<b> {ولم أكُ بغياً} (حُذفت النون تخفيفاً لتوفر الشروط).\n<i> </b>موانع حذف النون (التقاء ساكن أو ضمير نصب):<b> {لم يكنِ اللهُ} (لم تحذف النون لتقاطعها مع ساكن لفظ الجلالة)، وفي الحديث \"إن يكنْه\" (لم تحذف لاتصالها بضمير النصب الهاء).\n\n#### أمثلة الحروف المشبهة بـ \"ليس\":\n</i> </b>ما الحجازية العاملة:<b> {ما هذا بشراً}، {ما هن أمهاتهم}.\n<i> </b>بطلان عمل \"ما\" لاختلال الشروط:<b>\n  </i> اقتران الاسم بـ إن: \"ما إنْ زيدٌ قائمٌ\" (زيد: مبتدأ، قائم: خبر).\n  <i> اقتران الخبر بـ إلا: {وما محمدٌ إلا رسولٌ}.\n  </i> تقدم الخبر: \"ما قائمٌ زيدٌ\".\n  <i> تقدم معمول الخبر: \"ما طعامَك زيدٌ آكلٌ\" (يبطل عملها، إلا إذا كان ظرفاً مثل: \"ما عندك زيدٌ جالساً\" فيجوز الإعمال).\n</i> </b>إعمال \"لا\":<b> \"لا رجلٌ أفضلَ منك\". وقول المتنبي (شذوذاً لإعمالها في المعرفة): \"فلا الحمدُ مكسوباً ولا المالُ باقياً\".\n\n---\n\n### 4. الخلاصة: ما يجب حفظه وإتقانه\n\n1. </b>حكم الإعراب:<b> \"كان وأخواتها\" و\"الحروف المشبهة بليس\" ترفع المبتدأ اسماً لها وتنصب الخبر خيراً لها.\n2. </b>تقسيم الأفعال شروطاً:<b> احفظ الثمانية التي تعمل بلا شرط، والأربعة التي تشترط النفي وشبهه (زال، فتئ، برح، انفك)، والفعل الوحيد المرتبط بـ \"ما\" المصدرية الظرفية (دام).\n3. </b>معنى \"ما\" مع دام:<b> تذكر دائماً أنها تؤول بـ (مدة + المصدر).\n4. </b>التمام والنقصان:<b> كل أخوات كان يمكن أن تأتي تامة (تكتفي بفاعل) باستثناء: (ليس، زال، فتئ) فهي ناقصة دائماً.\n5. </b>شروط حذف نون \"يكن\" تخفيفاً:<b> أن تكون مضارعاً مجزوماً (لم يكُ)، وألا يليها ساكن، وألا يتصل بها ضمير نصب متصل.\n6. </b>شروط عمل \"ما\" الحجازية:<i></i> حفظ الشروط الأربعة بدقة (عدم وجود إن، عدم وجود إلا، عدم تقدم الخبر، عدم تقدم المعمول إلا لو كان ظرفاً أو جاراً ومجروراً). مع تذكر أن تميماً تهملها دائماً.",
    "full_text": "بسم الله الرحمن الرحيم، الحمد لله رب العالمين، وصلى الله وسلم وبارك على نبينا محمد وعلى آله وصحبه والتابعين، ومن تبعهم بإحسان إلى يوم الدين. بدأنا باباً متعلقاً بنواسخ الابتداء التي تدخل على المبتدأ والخبر وتغير بنية الجملة، وفي هذا الباب فصول؛ أولها الفصل المعقود لـ \"كَانَ\" وأخواتها. قال فصل: فأما كَانَ وأخواتها فإنها ترفع المبتدأ تشبيهاً بالفاعل ويُسمى اسمها، وتنصب الخبر تشبيهاً بالمفعول ويُسمى خبرها؛ فمثلاً في قول القائل: زَيْدٌ قَائِمٌ، بعد دخول \"كَانَ\" تصبح الجملة: كَانَ زَيْدٌ قَائِماً. فيكون اسم كَانَ مشبهاً بالفاعل الذي يكون مرفوعاً، ويكون \"قائماً\" الذي هو خبر كَانَ مشبهاً بالمفعول به الذي يكون منصوباً؛ فكَانَ هذه الأفعال تشبه الأفعال المتعدية التي تحتاج إلى فاعل ومفعول به، وما كان من قبل مبتدأً وخبراً يصبح كأنه فاعل ومفعول به لهذه الأفعال. وهذِه الأفعال على ثلاثة أقسام؛ أحدها ما يعمل هذا العمل من غير شرط، وهو: كَانَ، وأَمْسَى، وأَصْبَحَ، وأَضْحَى، وظَلَّ، وبَاتَ، وصَارَ، ولَيْسَ؛ هذِه كلها تعمل هذا العمل الذي نحن بصدد الحديث عنه دون شرط، نحو: {وَكَانَ اللَّهُ غَفُورًا رَّحِيمًا}؛ اللهُ: اسم كَانَ، غفوراً: خبرها. {فَأَصْبَحْتُم بِنِعْمَتِهِ إِخْوَانًا}؛ أَصْبَحَ من أخوات كَانَ، والتاء: ضمير متصل في محل رفع اسم أَصْبَحَ، إخواناً: خبر أَصْبَحَ. {لَيْسُوا سَوَاءً}؛ لَيْسَ من أخوات كَانَ، وواو الجماعة: في مبني يعني ضمير مبني ضمير متصل مبني في محل رفع اسم لَيْسَ، وسواءً: خبر لَيْسَ. {ظَلَّ وَجْهُهُ مُسْوَدًّا}؛ وجهُ: اسم ظَلَّ، مسوداً: خبر ظَلَّ. والثاني: ما يعمل هذا العمل بشرط أن يتقدمه نفي أو نهي أو دعاء، وهو أربعة: زَالَ، وفَتِئَ، وبَرِحَ، وانْفَكَّ؛ فهذِه لا بد لها لكي تعمل هذا العمل أن تُسبق بهذا الذي ذُكر؛ بالنفي أو النهي أو الدعاء، نحو: {وَلَا يَزَالُونَ مُخْتَلِفِينَ}؛ لاحظ لا هذِه النافية، إذن الشرط متحقق وهو وجود النفي، ثم إذاً يزالون هذِه تعمل هذا النسخ فهي إذن تكون من أخوات كَانَ. يزالون؛ واو الجماعة: اسم يَزَالُ، ومختلفين: خبر يَزَالُ، يعني منصوب وعلامة نصبه الياء النائبة عن الفتحة لأنه جمع مذكر سالم. {لَن نَّبْرَحَ عَلَيْهِ عَاكِفِينَ}؛ النفي إذن موجود وذلك في لَنْ، {لَنْ نَبْرَحَ}. منصوب بِلَنْ وعلامة نصبه الفتحة الظاهرة على آخره، عاكفين هو اسم نَبْرَحَ عفواً هو خبر نَبْرَحَ، اسمها ضمير متصل ضمير مستتر تقديره نحن؛ لن نبرح نحن عاكفين، عاكفين هو خبر نَبْرَحَ منصوب على منصوب به الياء النائبة عن الفتحة لأنه جمع مذكر سالم. وقول الشاعر: *\"صاحِ شَمِّرْ وَلا تَزَلْ ذاكِرَ المَوتِ فَنِسيانُهُ ضَلالٌ مُبينُ\"*، *\"فَنِسيانُهُ ضَلالٌ مُبينُ. صاحِ شَمِّرْ وَلا تَزَلْ ذاكِرَ المَوتِ\"*؛ هنا مثال على النهي، لأن لا هذِه ليست نافية كما في قوله تعالى {وَلَا يَزَالُونَ مُخْتَلِفِينَ}، وإنما هي ناهية. ولا الناهية كنا قد ذكرنا من قبل أنها إذا دخلت على الفعل المضارع فإنها تجزمه \"لا تكتب\"؛ فإذاً هنا \"تَزَالُ\" أنت تَزَالُ دخلت عليها لا الناهية فصارت: لا تَزلْ. هي في الحقيقة من جهة الصرف نقول صارت لا تزالُ، إذا جُزمت وكانت علامة الجزم السكون ثم التقى الساكنان اللذان أولهما حرف لين فحُذف، فتحولت لا تزالُ إلى لا تَزلْ. ثم الشرط متحقق فهي تعمل هذا العمل، فنقول اسمها: ضمير مستتر تقديره أنت، \"لا تزل أنت ذاكرَ\"، ذاكرَ: خبر تَزَلْ منصوب على من وعلامة نصبه الفتحة الظاهرة على آخره. وكذلك وقوله: *\"وَلا زالَ مُنْهَلّاً بِجَرْعائِكَ القَطْرُ\"*، *\"أَلا اسْلَمِي يا دارَ مَيَّ على البِلى ... وَلا زالَ مُنْهَلّاً بِجَرْعائِكَ القَطْرُ\"*؛ هنا مثال على الدعاء، أي على تقدم الدعاء على زَالَ؛ *\"وَلا زالَ مُنْهَلّاً بِجَرْعائِكَ القَطْرُ\"* أي يدعو بأن يدعو لهذا لهذه الدار دار ميّ يدعو بأن تصيبها يصيبها الغيث أو تصيبها السماء، وأن يستمر ذلك دائماً لكي يعني يبقى تبقى حية بنزول هذِه الأمطار عليها، فهذا دعاء ليس نفياً ولا نهياً. وقوله: *\"وَلا زالَ مُنْهَلّاً بِجَرْعائِكَ القَطْرُ\"*، زَالَ إذاً تعمل عمل كَانَ من أخوات كَانَ والشرط متحقق فيها؛ القطرُ: اسمها مرفوع وعلامة رفعه الضمة الظاهرة، منهلاً: خبرها منصوب وعلامة نصبه الفتحة الظاهرة على آخره. النوع الثالث قال: ما يعمل هذا العمل بشرط أن تتقدمه \"مَا\" المصدرية الظرفية وهو دَامَ، نحو: مَا دُمْتُ حَيّاً، وسُميت مَا هذِه مصدرية لأنها تُقدر بالمصدر وهو الدوام، وسُميت ظرفية للنيابة عن الظرف وهو المدة؛ مَا دُمْتُ حَيّاً أي مدة دوامي حياً، مدة دوامي حياً؛ فأنت ترى أن \"دُمْتُ\" مع مَا تتحول إلى مصدر وظرف. الظرف هو مدة، والمصدر هو دوام؛ فتأويل دَامَ مع مَا المصدرية الظرفية بمصدر وظرف، لأجله قلنا بأن مَا هذِه مصدرية ظرفية. فـ {مَا دُمْتُ حَيًّا} أي مدة دوامي حياً، هذا معنى قوله سُميت مصدرية لأنها تُقدر بالمصدر وهو الدوام وسُميت ظرفية لنيابتها عن الظرف وهو المدة. إذاً تحقق الشرط فنقول مَا دُمْتُ حَيّاً، التاء: هي ضمير متصل مبني في محل رفع اسم دَامَ، وحياً: خبر دَامَ منصوب وعلامة نصبه الفتحة الظاهرة. قال: ويجوز في خبر هذِه الأفعال أن يتوسط بينها وبين اسمها، نحو: {وَكَانَ حَقًّا عَلَيْنَا نَصْرُ الْمُؤْمِنِينَ}؛ كان نصرُ حقاً، إذاً النصرُ هو اسم كَانَ وحقاً: خبر كَانَ. فهنا تقدم الخبر على الاسم وتوسط بين كَانَ والاسم، {وَكَانَ حَقًّا} هو الخبر، نصرُ حقاً علينا نصرُ المؤمنين هو المبتدأ. وكذلك جاء قول الشاعر: *\"سَلِي إِنْ جَهِلْتِ النَّاسَ عَنَّا وَعَنْهُمُ ... فَلَيْسَ سَوَاءً عَالِمٌ وَجَهُولُ\"*، لَيْسَ، عالمٌ: هو اسم لَيْسَ وسواءً: خبر لَيْسَ؛ كما ترى توسط بين لَيْسَ واسمها، هذا على سبيل الجواز. ويجوز أن يتقدم أخبارهن عليهنَّ إلا لَيْسَ ودَامَ، كقولك: عَالِماً كَانَ زَيْدٌ؛ بمعنى في كَانَ وأخواتها كلها باستثناء لَيْسَ ودَامَ يمكن أن يتقدم الخبر ليس فقط على اسمها ولكن أن يتقدم على الأفعال نفسها، نحو: عَالِماً كَانَ زَيْدٌ، واضح؛ فزيدٌ: اسم كَانَ وعالماً: خبر كَانَ مقدم. لكن يقول يقول النحاة: لا يكون ذلك في لَيْسَ ولا في دَامَ على الصحيح، القضية فيها خلاف لكن على الصحيح أن ذلك ممتنع. قال: ولتصاريف هذِه الأفعال من المضارع والوالأمر والمصدر واسم الفاعل ما للماضي من العمل، نحو: {حَتَّىٰ يَكُونُوا مُؤْمِنِينَ}، {قُلْ كُونُوا حِجَارَةً}؛ يَكُونُوا مُؤْمِنِينَ هذا مضارع كَانَ يعمل مثل الماضي، فنقول يَكُونُوا مُؤْمِنِينَ؛ واو الجماعة هو اسم يَكُونُ ومؤمنين: خبر يَكُونُ منصوب علامة نصبه الياء النائبة عن الفتحة لأنه جمع مذكر سالم. {قُلْ كُونُوا حِجَارَةً أَوْ حَدِيدًا}، كُونُوا هذا فعل الأمر، الواو هي اسم كُونُوا، الخبر هو حجارةً وهو منصوب وعلامة نصبه الفتحة الظاهرة. وكذلك المصدر، مثلاً كأن تقول: كَوْنُكَ كَوْنُكَ مُجْتَهِداً مَطْلُوبٌ مِنْكَ، واضح؛ كَوْنُكَ مُجْتَهِداً مَطْلُوبٌ. فأنت ترى بأن قولك كَوْنُكَ مُجْتَهِداً، مجتهداً هذا خبر كَوْنُ؛ فالكَوْن الذي هو مصدر يعمل كما يعمل الفعل الماضي أو المضارع أو الأمر، وكَوْنُ: مبتدأ ومطلوبٌ: خبر المبتدأ. قال: وتُستعمل هذِه الأفعال تامة؛ أي مستغنية عن الخبر. لم نذكر بأن الأفعال التي تحدثنا عنها آنفاً وهي كَانَ وأخواتها تُسمى أفعالاً ناقصة، تُسمى أفعالاً ناقصة؛ لِمَ هي ناقصة؟ لأنها محتاجة إلى الخبر. لكن يفيدنا فائدة هنا فيقول إنها قد تُستعمل تامة لا ناقصة، ومعنى كونها تامة أي هي مستغنية عن الخبر، ومثَّل لذلك بقول الله سبحانه وتعالى: {وَإِن كَانَ ذُو عُسْرَةٍ}؛ كَانَ هناك تامة بمعنى وُجد، حصل، وقع؛ إن حصل ذو عسرة، إن وقع، إن وُجد ذو عسرة فنظرة. يعني هنا ذُو ماذا نقول فيه؟ نقول: فاعل كَانَ، فكَانَ هنا ليست من النواسخ وليست ناقصة بل هي تامة، وحينئذٍ فإنها تحتاج إلى فاعل فقط ولا تحتاج إلى خبر. وكذلك قول الله سبحانه وتعالى: {فَسُبْحَانَ اللَّهِ حِينَ تُمْسُونَ وَحِينَ تُصْبِحُونَ}؛ تُمْسُونَ وتُصْبِحُونَ كلاهما أفعال تامة، كلاهما فعل تام وليستا ناقصتين؛ فإذاً تُمْسُونَ لا نبحث عن اسمها وخبرها وإنما لها فاعل. تُمْسُونَ: فعل مضارع مرفوع لتجرده عن الناصب والجازم وعلامة رفعه ثبوت النون لأنه من الأفعال الخمسة، وواو الجماعة ضمير متصل مبني في محل رفع فاعل تُمْسُونَ، وكذلك نقول في تُصْبِحُونَ. فمعنى تُمْسُونَ: تدخلون في المساء، وتُصْبِحُونَ: تدخلون في الصباح. أما أَمْسَى وأَصْبَحَ التي هي من النواسخ فهي تدل على معنى الصيرورة؛ هي في الأصل راجعة إلى معنى المساء والصباح لكن يُراد بها معنى الصيرورة والتحول. قال: إلا زَالَ، وفَتِئَ، ولَيْسَ؛ فإنها ملازمة للنقص، أي لا تُستعمل قط تامة. الكلام عن زَالَ التي مضارعها يَزَالُ \"زَالَ يَزَالُ\"، وليست \"زَالَ يَزُولُ\"؛ إلا زَالَ يَزُولُ فعل آخر لا علاقة له بما نحن بصدده أصلاً، لكن الكلام عن زَالَ يَزَالُ وكذلك ولَيْسَ، فهذِه لا تكون تامة. قال: وتختص كَانَ بجواز زيادتها بشرط أن تكون بلفظ الماضي وأن تكون في حشو الكلام، نحو: مَا كَانَ أَحْسَنَ زَيْداً؛ بمعنى كَانَ قد يُؤتى بها زائدة، وذلك يكون بهذين الشرطين: أن تكون في الماضي فإذاً لا تُزاد إذا كانت في المضارع أو الأمر، وأن تكون في حشو الكلام كما في يعني بأن تقع ما معنى في حشو الكلام؟ أي أن تقع في وسط الكلام بين شيئين متلازمين، كأن تكون مثلاً بين مبتدأ وخبره؛ فمثال ذلك: مَا كَانَ أَحْسَنَ زَيْداً، وأكثر استعمالها زائدة هي في مثل هذا المثال يعني أن تكون بين مَا يعني في صيغة التعجب، بين مَا وأَحْسَنَ؛ فهنا كَانَ زائدة لأن أصل الكلام: مَا أَحْسَنَ زَيْداً. وحين تقول: مَا كَانَ أَحْسَنَ زَيْداً، أنت لا تزيد شيئاً ولا تغير شيئاً من الناحية الإعرابية؛ صحيح أنها تفيد معنى زائداً من جهة التوكيد ونحو ذلك، لكن من جهة علم النحو هي زائدة. مَا كَانَ أَحْسَنَ زَيْداً؛ إذن مَا هذِه تعجبية، وكَانَ زائدة لا فاعل لها، وأَحْسَنَ هذا فعل تعجب مبني على الفتح، والفاعل ضمير مستتر تقديره هو، زيداً: المفعول به؛ إذن نحو مَا كَانَ أَحْسَنَ زَيْداً هذِه زائدة، وكما قلنا تكون كثيراً هذِه الزائدة مع صيغة التعجب، أيضاً هذا من خصوصيات كَانَ. من خصوصياتها كذلك وتختص أيضاً بجواز حذفها مع اسمها وإبقاء خبرها، وذلك كثير بعد \"لَوْ\" و\"إِنْ\" الشرطيتين؛ كقول رسول الله صلى الله عليه وسلم: \"الْتَمِسْ وَلَوْ خَاتَماً مِنْ حَدِيدٍ\"؛ هنا كَانَ مع اسمها محذوفان، إذ تقدير الكلام في قوله \"الْتَمِسْ وَلَوْ خَاتَماً مِنْ حَدِيدٍ\" تقدير كذا: التمس ولو كان ما تلتمسه خاتماً من حديد؛ لكن لاختصار الكلام حُذف كل ذلك وبقي الخبر فقط \"ولو كان\"، حُذفت ما تلتمس أو الملتمس هذا اسمه، كَانَ واسمها حُذف وبقي الخبر وهو خاتماً من حديد. وكذلك في قولهم: \"الناس مجزيون بأعمالهم، إن خيراً فخيراً، وإن شراً فشرّاً\"؛ الناس مجزيون بأعمالهم إن خيراً فخيراً، أي إن كان عملهم خيراً فجزاؤهم خيراً، وإن كان عملهم شراً فجزاؤهم شرّاً. إذن حُذفت كَانَ وحُذف اسمها الذي هو عملهم وبقي الخبر فقط وهو خيراً، جميل أيضاً. إذاً تختص كَانَ بأمر أول قلنا هو يعني أن تكون زائدة، وتختص بشيء ثاني وهو جواز حذفها مع اسمها مع بقاء الخبر، وتختص ثالثاً بجواز حذف نون مضارعها المجزوم إن لم يلقَها ساكن ولا ضمير نصب. شروط؛ ما معنى هذا الكلام؟ معناه كما في قوله ربنا سبحانه وتعالى: {وَلَمْ أَكُ بَغِيًّا}، أصلها: أكونُ؛ إذاً ما الذي وقع؟ حُذفت النون، لكن لا بد من توفر هذِه الشروط: أولاً نون المضارع فلا تكون في الماضي ولا الأمر \"نون المضارع\"، ثانياً أن يكون هذا المضارع مجزوماً كما في \"وَلَمْ أَكُ\"، أكونُ هذِه مجزومة بِلَمْ، والشرط الثالث ألا يلتقي بها ساكن، إن لم يكن أو كما قال إن لم يلقَها ساكن كما هنا {أَكُ بَغِيًّا} لا يوجد ساكن بعدها، ولا ضمير نصب ولا ضمير نصب في قوله، ولا ضمير نصب أي متصل كان أو بالنون فلا تُحذف النون في مثلاً في قول رسول الله صلى الله عليه وسلم في حديث الدجال المعروف: \"إِنْ يَكُنْهُ فَلَنْ تُسَلَّطَ عَلَيْهِ\"، لا تُحذف النون هنا مع توفر الشروط الأخرى؛ لأنه \"يَكُنْهُ\" هو هذِه مجزومة لأنها فعل الشرط \"يَكُنْ\"، وهذا كَانَ المضارع إذاً المضارع مجزوم وليس بعدها ساكن \"يَكُنْهُ\"، ولكن الإشكال وجود ضمير نصب متصل بها لأن \"يَكُنْهُ\" هو على الهاء ضمير في محل نصب؛ فهنا لا يجوز حذف النون فلا تقول: \"إن يكه\". جميل، ومثال يعني قلنا الساكن \"حذفنا إن لم يلقَها ساكن\"، فإن لقيها ساكن لا تُحذف النون كذلك، كما في قول ربنا سبحانه وتعالى: {لَّمْ يَكُنِ اللَّهُ لِيَغْفِرَ لَهُمْ}؛ لا يقال \"لم يك الله ليغفر لهم\" بل تثبت النون وتُكسر لالتقاء الساكنين في مثل هذِه الحالة. عند التقاء الساكنين لا تحذف وتكسر، فيقال: {لَّمْ يَكُنِ اللَّهُ لِيَغْفِرَ لَهُمْ}، جميل. إذاً إذا توفرت هذِه الشروط الأربعة جاز حذف النون كما في {وَلَمْ أَكُ بَغِيًّا}؛ لَمْ: حرف نفي وجزم وقلب، أَكُ: فعل مضارع مجزوم بِلَمْ وعلامة جزمه السكون على النون، أين النون؟ المحذوفة تخفيفاً، السكون على النون المحذوفة تخفيفاً لأن أصله أكونُ، جُزم فصار \"لم أكنْ\" ثم حُذفت هذِه النون تخفيفاً. {وَلَا تَكُ فِي ضَيْقٍ}، {وَلَا تَكُ فِي ضَيْقٍ}؛ لا هذِه الناهية الجازمة، نفس الشيء أصلها تكونُ صارت \"ولا تكُ\". {وَإِن تَكُ حَسَنَةً يُضَاعِفْهَا}؛ الشيء نفسه، {وَإِن تَكُ} أصلها تكونُ، وهي فعل الشرط مجزوم فجاز حذف ماذا؟ حذف النون منها. انتهينا من كَانَ وأخواتها. الفصل الآخر متعلق بالحروف المشبهة بِلَيْسَ، قال: وأما الحروف المشبهة بِلَيْسَ فأربعة: مَا، ولَا، وإِنْ، ولَاتَ؛ فأما مَا فتعمل عمل لَيْسَ عند الحجازيين بشرط أن لا يقترن اسمها بِإِنْ، وأن لا يقترن خبرها بِإِلَّا، وأن لا يتقدم خبرها على اسمها، ولا معمول خبرها على اسمها إلا إذا كان المعمول ظرفاً أو جارّاً ومجروراً. فالمستوفية للشروط نحو: مَا زَيْدٌ ذَاهِباً عند الحجازيين؛ مَا: عاملة، زيدٌ: اسمها، ذاهباً: خبرها؛ فَمَا هذِه حرف يعمل عمل لَيْسَ، مَا زَيْدٌ ذَاهِباً كما لو قلت: لَيْسَ زَيْدٌ ذَاهِباً، لكن عند الحجازيين أما التميميون فيهملونها، واضح. وكقول الله سبحانه وتعالى: {مَا هَٰذَا بَشَرًا}؛ إذاً مَا عاملة عمل لَيْسَ، هذا: اسمها اسم إشارة مبني في محل رفع اسم مَا، بشراً: خبر مَا منصوب وعلامة نصبه الفتحة الظاهرة. {مَّا هُنَّ أُمَّهَاتِهِمْ}؛ هنَّ: ضمير منفصل مبني في محل رفع اسم مَا المشبهة بِلَيْسَ، أمهاتِ: خبر مَا منصوب وعلامة نصبه الكسرة النائبة عن الفتحة لأنه جمع مؤنث سالم وهو مضاف، والهاء: مضاف إليه، والميم: علامة الجمع. إذن هذِه أمثلة على مَا توفرت فيه الشروط التي ذُكر من قبل. الآن تلك الشروط؛ لأنه قال بشرط أن لا تقترن خبر وإلى غير ذلك، الآن سيذكر أمثلة على ما لم تتوفر فيه هذِه الشروط؛ فأول ذلك شرط إِنْ قال: فإن اقترنت بِإِنْ بطل عملها، نحو: مَا إِنْ زَيْدٌ قَائِمٌ؛ مَا إِنْ زَيْدٌ قَائِمٌ، إِنْ هذِه زائدة فليست نافية بل هي زائدة تكف مَا عن العمل. أصل الكلام \"مَا زَيْدٌ قَائِماً\"، حين تدخل إِنْ زائدة الكافة يصبح: مَا إِنْ زَيْدٌ قَائِمٌ فلا تعمل. كذلك عدم توفر الشرط الثاني، وكذا إن اقترن خبرها بِإِلَّا، نحو: {وَمَا مُحَمَّدٌ إِلَّا رَسُولٌ}؛ أصل ذلك لو أعملنا مَا أن نقول \"ما محمدٌ رسولاً\"، لكن \"رسولٌ\" وهو خبر مَا العاملة عمل لَيْسَ اقترن هذا الخبر بِإِلَّا، فحينئذٍ بطل عمل مَا ولم تعد تعمل عمل لَيْسَ، بل نقول محمدٌ: مبتدأ، ورسولٌ: خبر. ثالثاً: وكذا إن تقدم خبرها على اسمها، نحو: مَا قَائِمٌ زَيْدٌ؛ قائمٌ: الخبر، زيدٌ: مبتدأ. الأصل أن تقول \"ما زيدٌ قائماً\"، لكن لسبب من الأسباب قدمت الخبر؛ فإذا قدمت لا تقل \"ما قائماً زيدٌ\" ولكن قل: مَا قَائِمٌ زَيْدٌ فتبطل عمل مَا تصبح مهملة. رابعاً: وكذلك إن ماذا؟ تقدم معمول الخبر؛ معمول الخبر إن لم يتقدم الخبر كله وإنما معموله، أي شيء يعمل فيه الخبر؛ مثال ذلك: مَا طَعَامَكَ زَيْدٌ آكِلٌ، واضح. الأصل أصل الترتيب أن نقول: مَا زَيْدٌ آكِلاً طَعَامَكَ؛ زيدٌ: اسم مَا العاملة الحجازية، آكِلاً: خبر مَا، \"طعامَ\" معمول لِآكل لأن \"آكل\" اسم فاعل، وقد ذكرنا من قبل مراراً أن اسم الفاعل يعمل عمل الفعل؛ فطعامَ: مفعول به لِآكل. فلو قدمت معمول الخبر على الاسم، فقلت: مَا طَعَامَكَ زَيْدٌ آكِلٌ؛ فإنه يبطل عمل مَا، وتقول: مَا طَعَامُكَ زَيْدٌ آكِلٌ، فترفع \"طعامُك\" على أنه مبتدأ ثانٍ أو مفعول به مقدم لآكل؛ لكن الشاهد يبطل عمل مَا؛ إلا إذا كان هذا المعمول ظرفاً أو جاراً ومجروراً، كما قال من قبل: \"إلا إذا كان المعمول ظرفاً أو جاراً ومجروراً\"، نحو: مَا عِنْدَكَ زَيْدٌ جَالِساً؛ فـ \"عندَك\" هذا معمول لِجالساً، وقد تقدم على الاسم وهو زيد؛ فهل يبطل عمل مَا؟ لا يبطل، وإن قدمنا معمول الخبر لِمَا؟ لأن هذا المعمول ظرف؛ فإذاً يبقى العمل، فتقول: مَا عِنْدَكَ زَيْدٌ جَالِساً؛ خبر مَا العاملة التي عمل لَيْسَ. قال: وبنو تميم لا يعملونها وإن استوفت الشروط المذكورة؛ إذن كل ما سبق من شروط من عمل ومن شروط ذلك العمل إنما هو عند الحجازيين، فهي التي تُسمى مَا الحجازية وعليها القرآن يعني بها ورد القرآن فَمَا الحجازية العاملة. أما التميمية يعني إذا كان بنو تميم هم المتكلمون بِمَا فإنهم يهملونها في جميع الأحوال؛ إذن \"مَا زَيْدٌ قَائِمٌ\" التميمي دائماً يقول: مَا زَيْدٌ قَائِمٌ، زيدٌ: مبتدأ، وقائمٌ: الخبر. وأما لَا فتعمل عمل لَيْسَ أيضاً عند الحجازيين فقط بالشروط المتقدمة في مَا، وتزيد بشرط آخر وهو أن يكون اسمها وخبرها نكرتين، نحو: لَا رَجُلٌ أَفْضَلَ مِنْكَ. لَا هذِه أنواع كثيرة، لكن الكلام عن لَا معينة؛ لَا التي تعمل عمل لَيْسَ هذِه قليلة وتعمل على الخصوص في الشعر، يعني لن تجدها في الاستعمال العادي لكن ستجدها في الشعر على الخصوص. لَا هذِه تعمل عمل لَيْسَ بنفس الشروط السابقة التي ذكرنا بالنسبة لِمَا الحجازية، مع إضافة شرط آخر وهو أن يكون اسمها وخبرها نكرتين، نحو: لَا رَجُلٌ أَفْضَلَ مِنْكَ؛ رجلٌ: اسم لَا العاملة عمل لَيْسَ، أفضلَ: خبر لَا منصوب، واضح. فإذاً إذا قلنا إننا نشترط أن يكونا نكرتين، معنى ذلك أنها لا تعمل في معرفة؛ فلا تقول مثلاً: \"لا زيدٌ قائماً\". ووُجد من الشعراء من استعمل ذلك في المعارف مع المعارف، وفعله المتنبي من المتأخرين وليس ممن يُحتج بشعره حين قال: *\"فَلا الحَمْدُ مَكْسُوباً وَلا المالُ باقِياً ... إِذا الجُودُ لَمْ يُرْزَقْ خَلاصاً مِنَ الأَذى\"*، *\"إِذا الجُودُ لَمْ يُرْزَقْ\"* خلاصاً من الأذى؛ أي إذا لم يجتمع مع الجود مع الكرم خلاص من الأذى، *\"فَلا الحَمْدُ مَكْسُوباً وَلا المالُ باقِياً\"*. الحمدُ: اسم لَا، مكتوباً: خبرها؛ وكذلك في المالُ باقياً، فأعمل لَا مع أن الحمدَ معرفة وليس نكرة، واضح؛ لكن كما قلنا هذا نادر كما يقول النحاة قالوا أكثر عملها في الشعر. قال: وأما إِنْ فتعمل عمل لَيْسَ في لغة أهل العالية بالشروط المذكورة. نترك هذا إلى لقائنا المقبل بإذن الله سبحانه وتعالى، وأقول قولي هذا وأستغفر الله لي ولكم، والحمد لله رب العالمين.",
    "blocks_search_text": "أحكام كان وأخواتها وأقسامها فأما كَانَ وأخواتها فإنها ترفع المبتدأ تشبيهاً بالفاعل ويُسمى اسمها، وتنصب الخبر تشبيهاً بالمفعول ويُسمى خبرها شرح الشيخ عمل 'كان' وأخواتها في نسخ المبتدأ والخبر، وقسمها إلى ثلاثة أقسام: أفعال تعمل بلا شروط، وأفعال تشترط النفي أو النهي أو الدعاء، وأفعال تشترط 'ما' المصدرية الظرفية. توسط وتقدم خبر كان وأخواتها وتصرفاتها ويجوز في خبر هذِه الأفعال أن يتوسط بينها وبين اسمها، ويجوز أن يتقدم أخبارهن عليهنَّ إلا لَيْسَ ودَامَ بيّن الشيخ أحكام تقديم وتأخير الخبر في جملة 'كان'، وأشار إلى أن تصاريف هذه الأفعال (المضارع، الأمر، المصدر) تعمل عمل الماضي، وأنها قد تأتي تامة (لا تحتاج لخبر). خصوصيات كان (الزيادة والحذف) تختص كَانَ بجواز زيادتها بشرط أن تكون بلفظ الماضي وأن تكون في حشو الكلام تطرق الشيخ إلى الخصائص الحصرية لـ 'كان'، مثل زيادتها في الكلام، وجواز حذفها مع اسمها وإبقاء الخبر، وشروط حذف النون من مضارعها المجزوم. الحروف المشبهة بليس (ما، لا، إن) أما الحروف المشبهة بِلَيْسَ فأربعة: مَا، ولَا، وإِنْ، ولَاتَ؛ فأما مَا فتعمل عمل لَيْسَ عند الحجازيين تناول الشيخ الحروف التي تعمل عمل 'ليس' بشروط معينة عند الحجازيين، موضحاً حالات إهمالها، وخصائص 'لا' الحجازية التي تشترط تنكير اسمها وخبرها.",
