        "ts": "5:00",
        "sec": 300,
        "text": "على كل الأديان، فالعبرة الآن ليست بخصوص في هذا الحديث. فإذن الأصل في الإنسان أنه يولد موحداً ولا",
        "video_link": null
      },
      {
        "ts": "5:09",
        "sec": 309,
        "text": "يولد مشركاً؛ فالشرك شيء طارئ، الشيء الشرك شيء يطرأ على الإنسان. وحتى البشرية",
        "video_link": null
      },
      {
        "ts": "5:18",
        "sec": 318,
        "text": "لما نزل آدم عليه السلام، نزل طبعاً وهو نبي فكان موحداً بالطبع وذريته أيضاً، إذن الأصل",
        "video_link": null
      },
      {
        "ts": "5:26",
        "sec": 326,
        "text": "في البشرية أيضاً التوحيد؛ البشرية كانت على التوحيد.",
        "video_link": null
      },
      {
        "ts": "5:34",
        "sec": 334,
        "text": "والله تعالى يقول: {كَانَ النَّاسُ أُمَّةً وَاحِدًا فَبَعَثَ اللَّهُ النَّبِيِّينَ مُبَشِّرِينَ وَمُنذِرِينَ}، طبعاً",
        "video_link": null
      },
      {
        "ts": "5:40",
        "sec": 340,
        "text": "هنا ينبغي أن نقدر محذوفاً: \"كان الناس أمة واحدة فاختلفوا\".",
        "video_link": null
      },
      {
        "ts": "5:48",
        "sec": 348,
        "text": "دل ذلك، دل على ذلك قوله تعالى في آية أخرى في سورة يونس: {وَمَا كَانَ النَّاسُ إِلَّا أُمَّةً وَاحِدَةً",
        "video_link": null
      },
      {
        "ts": "5:55",
        "sec": 355,
        "text": "فَاخْتَلَفُوا}، يعني عند بعض قد يقول قائل مثلاً: {كَانَ النَّاسُ أُمَّةً وَاحِدَةً فَبَعَثَ اللَّهُ النَّبِيِّينَ",
        "video_link": null
      },
      {
        "ts": "6:04",
        "sec": 364,
        "text": "مُبَشِّرِينَ وَمُنذِرِينَ} لماذا بعث الله تعالى المبشرين والناس على أمة واحدة؟ فهناك محذوف ينبغي تقديره، أي: \"كان الناس أمة",
        "video_link": null
      },
      {
        "ts": "6:13",
        "sec": 373,
        "text": "واحدة فاختلفوا فبعث الله النبيين مبشرين ومنذرين وأنزل معهم الكتاب\" الآية، وهي في سورة البقرة.",
        "video_link": null
      },
      {
        "ts": "6:22",
        "sec": 382,
        "text": "المفسرون قالوا -في تفسير هذه الآية والآية الأخرى في سورة يونس- إن",
        "video_link": null
      },
      {
        "ts": "6:29",
        "sec": 389,
        "text": "الناس كانوا على، كانوا أمة واحدة على دين واحد وعلى ملة واحدة وهي التوحيد بالطبع.",
        "video_link": null
      },
      {
        "ts": "6:37",
        "sec": 397,
        "text": "وقال ابن كثير: الناس كانوا على ملة آدم عليه السلام ثم آلوا إلى أن عبدوا الأصنام.",
        "video_link": null
      },
      {
        "ts": "6:47",
        "sec": 407,
        "text": "وهؤلاء الأقوام الذين بدأوا في عبادة الأصنام هم أول من أشرك بالله، وهم الذين",
        "video_link": null
      },
      {
        "ts": "6:54",
        "sec": 414,
        "text": "بعث فيهم نوح عليه السلام، فكان نوح أول رسول إلى أهل الأرض لأن كل",
        "video_link": null
      },
      {
        "ts": "7:03",
        "sec": 423,
        "text": "من كان قبله كانوا أنبياء. وطبعاً سنذكر لاحقاً الفرق بين النبي والرسول.",
        "video_link": null
      },
      {
        "ts": "7:11",
        "sec": 431,
        "text": "روى الحاكم عن أبي أمامة الباهلي رضي الله عنه أن رسول الله صلى الله عليه",
        "video_link": null
      },
      {
        "ts": "7:18",
        "sec": 438,
        "text": "وسلم قال: \"كان بين آدم ونوح عشرة قرون،",
        "video_link": null
      },
      {
        "ts": "7:25",
        "sec": 445,
        "text": "كلهم على شريعة من الحق\"؛ كان بين آدم ونوح عشرة قرون كلهم على",
        "video_link": null
      },
      {
        "ts": "7:33",
        "sec": 453,
        "text": "شريعة من الحق. حين نقول -بالمناسبة- حين نقول قرن، فلا يُفهم منه مائة سنة؛ الآن الاصطلاح الذي",
        "video_link": null
      },
      {
        "ts": "7:43",
        "sec": 463,
        "text": "درج عليه الناس في أيامنا هذه أن القرن هو مائة سنة \"قرن\"، الحق أن القرن في نصوص",
        "video_link": null
      },
      {
        "ts": "7:51",
        "sec": 471,
        "text": "الشرع وفي أصل العربية هم طبقة من الناس؛ عشرة قرون أي عشر طبقات من الناس وطبعاً",
        "video_link": null
      },
      {
        "ts": "7:59",
        "sec": 479,
        "text": "هذا يعني يختلف باختلاف أعمار هؤلاء، فربما عاشوا مئات السنين خصوصاً يعني تعلم أن",
        "video_link": null
      },
      {
        "ts": "8:06",
        "sec": 486,
        "text": "نوحاً عليه السلام عاش أو بعث في قومه ألف سنة إلا خمسين عاماً بعث فيها، وربما عاش أكثر من ذلك. فالشاهد هو",
        "video_link": null
      },
      {
        "ts": "8:16",
        "sec": 496,
        "text": "أنه ينبغي يعني القرن حين يقول النبي عليه الصلاة والسلام: \"خير الناس قرني ثم الذين يلونهم ثم الذين",
        "video_link": null
      },
      {
        "ts": "8:24",
        "sec": 504,
        "text": "يلونهم\" فيقصد به الطبقة التي كانت موجودة آنذاك من الناس، هما الآن تقريباً",
        "video_link": null
      },
      {
        "ts": "8:31",
        "sec": 511,
        "text": "\"الجيل\" إن صح التعبير. {مَا بَالُ الْقُرُونِ الْأُولَىٰ}؛ أي الأقوام الذين كانوا في السابق.",
        "video_link": null
      },
      {
        "ts": "8:42",
        "sec": 522,
        "text": "إذن مبدأ الشرك والانحراف كان في القوم الذين بُعث فيهم",
        "video_link": null
      },
      {
        "ts": "8:49",
        "sec": 529,
        "text": "بعد ذلك نوح عليه السلام. روى البخاري عن ابن عباس رضي الله عنهما أنه قال -حديث",
        "video_link": null
      },
      {
        "ts": "8:59",
        "sec": 539,
        "text": "هذا أثر، حديث موقوف قال ابن عباس في تفسير قوله تعالى في سورة نوح: {وَقَالُوا لَا تَذَرُنَّ",
        "video_link": null
      },
      {
        "ts": "9:07",
        "sec": 547,
        "text": "آلِهَتَكُمْ وَلَا تَذَرُنَّ وَدًّا وَلَا سُوَاعًا وَلَا يَغُوثَ وَيَعُوقَ وَنَسْرًا}- قال ابن عباس رضي الله عنهما:",
        "video_link": null
      },
      {
        "ts": "9:16",
        "sec": 556,
        "text": "\"هذه أسماء رجال صالحين من قوم نوح، هذه أسماء رجال صالحين من قوم نوح، فلما هلكوا",
        "video_link": null
      },
      {
        "ts": "9:24",
        "sec": 564,
        "text": "أوحى الشيطان إلى قومهم أن ينصبوا إلى مجالسهم التي كانوا يجلسون فيها أنصاباً\".",
        "video_link": null
      },
      {
        "ts": "9:32",
        "sec": 572,
        "text": "هؤلاء هذه أسماء رجال صالحين؛ ود، وسواع، ويغوث، ويعوق، ونسر؛ هذه أسماء هذه أسماء",
        "video_link": null
      },
      {
        "ts": "9:41",
        "sec": 581,
        "text": "أعلام رجال كانوا صالحين في الأصل، وكانوا طبعاً قبل نوح عليه السلام.",
        "video_link": null
      },
      {
        "ts": "9:46",
        "sec": 586,
        "text": "فلما ماتوا جاء الشيطان فأوحى إلى أقوامهم، إلى قومهم بأن يجعلوا أنصاباً.",
        "video_link": null
      },
      {
        "ts": "9:55",
        "sec": 595,
        "text": "والأنصاب هذه تختلف عن علامات، وليس تمثالاً فقط، علامة مثلاً يأخذون أعواداً",
        "video_link": null
      },
      {
        "ts": "10:04",
        "sec": 604,
        "text": "مثلاً أو أشياء فيجعلونها علامة على المكان الذي كانوا أو الأمكنة التي كانوا يجلسون",
        "video_link": null
      },
      {
        "ts": "10:14",
        "sec": 614,
        "text": "فيها هؤلاء الأقوام الذين كانوا صالحين، ثم سموها بأسمائهم؛ يعني هناك كان يجلس نسر،",
        "video_link": null
      },
      {
        "ts": "10:21",
        "sec": 621,
        "text": "هناك كان يجلس يغوث، هناك يجلس يعوق، وهناك يجلس ود وغير ذلك،",
        "video_link": null
      },
      {
        "ts": "10:28",
        "sec": 628,
        "text": "فأُطلقت أسماؤهم على أسماء الأمكنة التي كانوا يجلسون فيها، ففعلوا. الشيطان",
        "video_link": null
      },
      {
        "ts": "10:35",
        "sec": 635,
        "text": "الذي أوحى لهم، والشيطان له حيل لا يعمل على في بعض الأحيان، في كل الأحيان لا يعمل",
        "video_link": null
      },
      {
        "ts": "10:42",
        "sec": 642,
        "text": "عاجلاً؛ الشيطان ربما يقصد يعني هدفه الأجيال القادمة، فلا يقصد مثلاً هذا الجيل،",
        "video_link": null
      },
      {
        "ts": "10:50",
        "sec": 650,
        "text": "هذا الجيل ربما متمسك بدينه لكن يكفيه أن",
        "video_link": null
      },
      {
        "ts": "10:56",
        "sec": 656,
        "text": "يحرفه أو يميل به ولو شيئاً قليلاً ولا يخرجه أبداً من الملة، ولكن ذلك الانحراف سيقع",
        "video_link": null
      },
      {
        "ts": "11:05",
        "sec": 665,
        "text": "أكثر في ذريتهم ثم سيزداد ثم سيزداد إلى أن يخرج الناس من الملة والعياذ بالله.",
        "video_link": null
      },
      {
        "ts": "11:12",
        "sec": 672,
        "text": "وهذا واضح؛ نرى أن في بعض الأقوام يكون هناك خير ثم ذلك يكون الانحراف قليلاً،",
        "video_link": null
      },
      {
        "ts": "11:19",
        "sec": 679,
        "text": "فيأتي جيل الجيل الذي يليهم فيكون الانحراف فيه أشد؛ يعني الأمر كالزاوية، الزاوية هذه كلما ابتعدت كلما يعني ابتعد",
        "video_link": null
      },
      {
        "ts": "11:29",
        "sec": 689,
        "text": "هذا الخط مع هذا الخط. قال: ففعلوا ولم تُعبد، في البداية لم تُعبد لأن الناس كانوا على الدين السليم والصحيح،",
        "video_link": null
      },
      {
        "ts": "11:38",
        "sec": 698,
        "text": "وقالوا فقط: نحن سنضع هذه الأنصاب فقط لكي نتذكر هؤلاء الناس ونترحم عليهم، كما يفعل الآن يعني",
        "video_link": null
      },
      {
        "ts": "11:48",
        "sec": 708,
        "text": "بعض التماثيل لكن فقط نقول: هذا تمثال لكي تذكار نتذكر به هؤلاء الناس ونترحم عليهم.",
        "video_link": null
      },
      {
        "ts": "11:55",
        "sec": 715,
        "text": "وربما ياتوك، ربما ياتونك بأدلة يعني شرعية تشجعهم على فعل هذا؛ نعم",
        "video_link": null
      },
      {
        "ts": "12:03",
        "sec": 723,
        "text": "هذا فيه مصلحة وهي أننا سنتذكرهم وسنتحدث عن أخبارهم وسنذكر أحاديثهم ومواعظهم، كل",
        "video_link": null
      },
      {
        "ts": "12:11",
        "sec": 731,
        "text": "هذا فيه خير، نعم. لذلك في بعض الأحيان لا ينبغي يعني فتح باب هكذا على مصراعيه أمام",
        "video_link": null
      },
      {
        "ts": "12:18",
        "sec": 738,
        "text": "كل من يزعم بأنه هناك مصلحة شرعية، قد تكون مفسدة تظهر الآن كالمصلحة ولكن يترتب عليها",
        "video_link": null
      },
      {
        "ts": "12:26",
        "sec": 746,
        "text": "المفسدة. وهنا هذا دور الراسخين في العلم للتمييز بين المصالح والمفاسد، وعندنا قاعدة مهمة جداً وهي سد الذرائع، وقد تُستعمل",
        "video_link": null
      },
      {
        "ts": "12:36",
        "sec": 756,
        "text": "كثيراً في باب العقائد أنه قد مثلاً قد يكون شيء جائزاً ولكن قد يفضي إلى",
        "video_link": null
      },
      {
        "ts": "12:44",
        "sec": 764,
        "text": "خلل، إلى مسألة، إلى مخالفة عقدية فنغلق هذا الباب حفاظاً على جناب التوحيد. إذن قال",
        "video_link": null
      },
      {
        "ts": "12:52",
        "sec": 772,
        "text": "ابن عباس: \"ففعلوا فلم تُعبد، حتى إذا هلك أولئك ونُسي العلم عُبدت\". أولئك الأقوام لما ماتوا الذين كانوا",
        "video_link": null
      },
      {
        "ts": "13:02",
        "sec": 782,
        "text": "معاصرين وكانوا قريبين من هؤلاء، لما انتهى هذا الجيل جاء الجيل الذي يليهم",
        "video_link": null
      },
      {
        "ts": "13:08",
        "sec": 788,
        "text": "فقلّ فيهم العلم، قال: \"ونُسي العلم عُبدت\". وهنا يشير إشارة مهمة جداً إلى أسباب انتشار",
        "video_link": null
      },
      {
        "ts": "13:16",
        "sec": 796,
        "text": "الشرك وهي انعدام العلم وغياب العلم، فقال: \"نُسي العلم\"،",
        "video_link": null
      },
      {
        "ts": "13:21",
        "sec": 801,
        "text": "أي أُهمل العلم وقلّ العلم، فُفتح باب الانحراف العقدي ووقع الناس في الشرك. هكذا",
        "video_link": null
      },
      {
        "ts": "13:31",
        "sec": 811,
        "text": "انتشرت أو بدأت عبادة الأصنام والأوثان. والشياطين يعني لم يكتفوا بهذا بل زينوا",
        "video_link": null
      },
      {
        "ts": "13:38",
        "sec": 818,
        "text": "للناس معبودات أخرى منها الجن؛ والجن هذا يعني لأنه مخلوق لا يُرى، ومخلوقات لا تُرى",
        "video_link": null
      },
      {
        "ts": "13:46",
        "sec": 826,
        "text": "بالعين ويعني لهم عالمهم، فالشيطان يعني انتهز هذا الغياب الذي يغيب",
        "video_link": null
      },
      {
        "ts": "13:57",
        "sec": 837,
        "text": "عن أنظار الناس فصار يخوف الناس منهم، قال تعالى: {وَيَوْمَ يَحْشُرُهُمْ جَمِيعًا ثُمَّ يَقُولُ",
        "video_link": null
      },
      {
        "ts": "14:05",
        "sec": 845,
        "text": "لِلْمَلَائِكَةِ أَهَٰؤُلَاءِ إِيَّاكُمْ كَانُوا يَعْبُدُونَ * قَالُوا سُبْحَانَكَ أَنتَ وَلِيُّنَا مِن دُونِهِم ۖ بَلْ كَانُوا",
        "video_link": null
      },
      {
        "ts": "14:12",
        "sec": 852,
        "text": "يَعْبُدُونَ الْجِنَّ ۖ أَكْثَرُهُم بِهِم مُّؤْمِنُونَ}؛ فكانوا يعبدون الجن وكانوا يستغيثون بهم",
        "video_link": null
      },
      {
        "ts": "14:19",
        "sec": 859,
        "text": "ويستعيذون بهم. وعبدوا كذلك الكواكب والنجوم، إذن فُتح باب الشرك على مصراعيه كما",
        "video_link": null
      },
      {
        "ts": "14:28",
        "sec": 868,
        "text": "في قوم إبراهيم عليه السلام الذي جاء لاحقاً بعد ذلك، قال تعالى يصف حاله؛ ما إن كان يعني هناك من كان هنا يناظر أم ينظر،",
        "video_link": null
      },
      {
        "ts": "14:37",
        "sec": 877,
        "text": "على كل حال أنه كان يعني أظهر أن قومه كانوا يعبدون الكواكب",
        "video_link": null
      },
      {
        "ts": "14:45",
        "sec": 885,
        "text": "والنجوم: {فَلَمَّا جَنَّ عَلَيْهِ اللَّيْلُ رَأَىٰ كَوْكَبًا ۖ قَالَ هَٰذَا رَبِّي ۖ فَلَمَّا أَفَلَ قَالَ لَا أُحِبُّ الْآفِلِينَ * فَلَمَّا",
        "video_link": null
      },
      {
        "ts": "14:52",
        "sec": 892,
        "text": "رَأَى الْقَمَرَ بَازِغًا قَالَ هَٰذَا رَبِّي ۖ فَلَمَّا أَفَلَ قَالَ لَئِن لَّمْ يَهْدِنِي رَبِّي لَأَكُونَنَّ مِنَ الْقَوْمِ الضَّالِّينَ *",
        "video_link": null
      },
      {
        "ts": "14:59",
        "sec": 899,
        "text": "فَلَمَّا رَأَى الشَّمْسَ بَازِغَةً قَالَ هَٰذَا رَبِّي هَٰذَا أَكْبَرُ ۖ فَلَمَّا أَفَلَتْ قَالَ يَا قَوْمِ إِنِّي بَرِيءٌ مِّمَّا",
        "video_link": null
      },
      {
        "ts": "15:07",
        "sec": 907,
        "text": "تُشْرِكُونَ}؛ إن قومه كانوا عبَدة للكواكب والنجوم والشمس. إذن هكذا",
        "video_link": null
      },
      {
        "ts": "15:14",
        "sec": 914,
        "text": "ظهر الشرك في البشرية؛ إذن الأصل في البشرية أنها كانت على التوحيد والشرك شيء طارئ، شيء حدث بعد أن كان التوحيد",
        "video_link": null
      },
      {
        "ts": "15:22",
        "sec": 922,
        "text": "والإيمان الحق. ثم نأتي إلى الجزيرة العربية؛ أول من أدخل الشرك إلى الجزيرة العربية هو عمرو بن",
        "video_link": null
      },
      {
        "ts": "15:30",
        "sec": 930,
        "text": "لحي الخزاعي، وهذا الرجل كان كان عُرف بفعل الخير وبالصدقة والحرص على",
        "video_link": null
      },
      {
        "ts": "15:39",
        "sec": 939,
        "text": "على أمور الدين والعبادات، فكان ديّناً خيراً فأحبه الناس",
        "video_link": null
      },
      {
        "ts": "15:46",
        "sec": 946,
        "text": "ويعني قدموه وصاروا يعني يستشيرونه ويسألونه، وصار",
        "video_link": null
      },
      {
        "ts": "15:52",
        "sec": 952,
        "text": "كالزعيم أو السيد الذي يوجه الناس في في",
        "video_link": null
      },
      {
        "ts": "15:59",
        "sec": 959,
        "text": "مكة ونواحيها، بل حتى إنهم قالوا صار الملك لمكة وولاية البيت كانت بيده. طبعاً",
        "video_link": null
      },
      {
        "ts": "16:07",
        "sec": 967,
        "text": "كان فيها الآن فيها عن الحقبة التي تلت إسماعيل عليه السلام، يعني لم يكن هناك",
        "video_link": null
      },
      {
        "ts": "16:14",
        "sec": 974,
        "text": "شرك؛ كان هؤلاء من ذرية إسماعيل عليه السلام كانوا على الحنيفية، كانوا مؤمنين",
        "video_link": null
      },
      {
        "ts": "16:21",
        "sec": 981,
        "text": "وموحدين. ثم يعني ما الذي وقع؟ هذا الرجل هو عمرو بن لحي الخزاعي سافر إلى الشام",
        "video_link": null
      },
      {
        "ts": "16:29",
        "sec": 989,
        "text": "فرأىهم يعبدون الأوثان فاستحسن هذا الأمر؛ لماذا؟ لأن الشام، الشام",
        "video_link": null
      },
      {
        "ts": "16:37",
        "sec": 997,
        "text": "هذه محل ومهبط الأنبياء والرسل ومحل الرسالات معروفة، يعني كثير من الأنبياء",
        "video_link": null
      },
      {
        "ts": "16:43",
        "sec": 1003,
        "text": "بُعثوا في هذه البقعة من الأرض لهم الفضل على غيرهم، فلما رأى هذا الأمر",
        "video_link": null
      },
      {
        "ts": "16:54",
        "sec": 1014,
        "text": "استحسنه. ولما عاد إلى مكة جاء بصنم وهو \"هبل\" المعروف،",
        "video_link": null
      },
      {
        "ts": "17:01",
        "sec": 1021,
        "text": "فجعله في جوف الكعبة ودعا أهل مكة إلى عبادته فأطاعوه، والله المستعان! إذن هنا بدأ",
        "video_link": null
      },
      {
        "ts": "17:08",
        "sec": 1028,
        "text": "الشرك في مكة. إن ربما يقول يعني: هذا البيت الذي",
        "video_link": null
      },
      {
        "ts": "17:15",
        "sec": 1035,
        "text": "بناه هذه الكعبة التي المشرفة التي بنى إبراهيم عليه السلام وإسماعيل عليه السلام، إذن هؤلاء كانوا على التوحيد؟ نقول: نعم،",
        "video_link": null
      },
      {
        "ts": "17:23",
        "sec": 1043,
        "text": "كانوا على التوحيد، وذريتهم كذلك كانت على التوحيد. ولكن طال الأمد فتقسو القلوب كما قلنا أيضاً حتى في لما",
        "video_link": null
      },
      {
        "ts": "17:31",
        "sec": 1051,
        "text": "وقع للأقوام الذين أو للقوم الذين بُعث فيهم نوح عليه السلام؛ قال ابن عباس تلك الإشارة المهمة وهي: \"نُسي العلم\".",
        "video_link": null
      },
      {
        "ts": "17:40",
        "sec": 1060,
        "text": "فلما يعني يطول الأمد ويطول المدد، ربما يضعف الحق أو صوت الحق.",
        "video_link": null
      },
      {
        "ts": "17:48",
        "sec": 1068,
        "text": "ولما ظهر الشرك في مكة ومكة أيضاً يعني أهل الحجاز",
        "video_link": null
      },
      {
        "ts": "17:57",
        "sec": 1077,
        "text": "والقبائل في الجزيرة العربية كانوا يعظمون مكة كما أن مكة كانت تعظم الشام؛ القبائل",
        "video_link": null
      },
      {
        "ts": "18:03",
        "sec": 1083,
        "text": "والمناطق في الجزيرة العربية يعظمون مكة لأن فيها البيت الذي بناه إبراهيم عليه السلام،",
        "video_link": null
      },
      {
        "ts": "18:10",
        "sec": 1090,
        "text": "فلما رأوهم، رأوا أنهم بدأوا يعبدون صنماً في في الكعبة ظنوا أن ذلك من الحق ومن",
        "video_link": null
      },
      {
        "ts": "18:18",
        "sec": 1098,
        "text": "الأمور المشروعة، فنصبوا أوثاناً أوثاناً في عدة مناطق من الجزيرة العربية؛",
        "video_link": null
      },
      {
        "ts": "18:26",
        "sec": 1106,
        "text": "بقديد مثلاً كان فيها \"مناة\" الذي ذكره الله تعالى، ثم",
        "video_link": null
      },
      {
        "ts": "18:35",
        "sec": 1115,
        "text": "ظهر \"اللات\" وظهر \"العزى\"، وهذه هي ثلاثة الأصنام الثلاثة التي اشتهرت، هي التي",
        "video_link": null
      },
      {
        "ts": "18:43",
        "sec": 1123,
        "text": "ذكرها الله تعالى في سورة النجم: {أَفَرَأَيْتُمُ اللَّاتَ وَالْعُزَّىٰ * وَمَنَاةَ الثَّالِثَةَ الْأُخْرَىٰ}. ثم كثر الشرك في الجزيرة العربية، ونصبت",
        "video_link": null
      },
      {
        "ts": "18:52",
        "sec": 1132,
        "text": "الأوثان في كل بقعة من هذه الجزيرة، بل في كل بيت حتى صار في كل بيت صنم بل أصنام في",
        "video_link": null
      },
      {
        "ts": "19:01",
        "sec": 1141,
        "text": "كل البيوت. وإذن كل هذا والله المستعان كان يرجع سببه إلى ذلك الرجل اللي هو عمرو بن لحي",
        "video_link": null
      },
      {
        "ts": "19:09",
        "sec": 1149,
        "text": "الخزاعي، ولا حول ولا قوة إلا بالله. عليه الصلاة والسلام شهد لهذا الرجل بالنار؛ رواه الشيخان عن أبي هريرة رضي",
        "video_link": null
      },
      {
        "ts": "19:17",
        "sec": 1157,
        "text": "الله عنه أن رسول الله صلى الله عليه وسلم قال: \"رأيت عمرو بن لحي يجر قصبه في النار\"،",
        "video_link": null
      },
      {
        "ts": "19:24",
        "sec": 1164,
        "text": "\"رأيت عمرو بن لحي يجر قصبه في النار\"، والقصب وهي الأمعاء، القُصْب الأمعاء.",
        "video_link": null
      },
      {
        "ts": "19:33",
        "sec": 1173,
        "text": "فهكذا ظهر الشرك في الجزيرة العربية؛ فأنتم ترون أن الأصل في الإنسان التوحيد، والأصل في",
        "video_link": null
      },
      {
        "ts": "19:40",
        "sec": 1180,
        "text": "البشرية التوحيد، فالشرك شيء طارئ. والدعوة للتوحيد إنما هي دعوة إلى الأصل، إلى البقاء على الأصل، إلى العودة إلى الأصل",
        "video_link": null
      },
      {
        "ts": "19:49",
        "sec": 1189,
        "text": "اللي هو التوحيد. وأن الأرضية التي ينبت فيها الشرك",
        "video_link": null
      },
      {
        "ts": "19:56",
        "sec": 1196,
        "text": "هي الأرضية التي يكثر فيها الجهل كما قلنا، بدليل ما قاله ابن عباس رضي الله، فقط قلنا",
        "video_link": null
      },
      {
        "ts": "20:03",
        "sec": 1203,
        "text": "إنه أشار إلى سبب مهم أو إلى الأرضية التي تكون يعني تعين على أن يظهر الشرك وهو الجهل، أرضية",
        "video_link": null
      },
      {
        "ts": "20:13",
        "sec": 1213,
        "text": "الجهل قال: \"ونُسي العلم\". بعض العلماء قال بالنظر إلى أسباب كل هذا،",
        "video_link": null
      },
      {
        "ts": "20:22",
        "sec": 1222,
        "text": "قال إن الشرك له سببان رئيسان بالإضافة طبعاً إلى الأرضية هي",
        "video_link": null
      },
      {
        "ts": "20:30",
        "sec": 1230,
        "text": "الجهل؛ قال هو الغلو في المخلوق، لأن لما، إذا تأملنا قصة قوم نوح فإنهم غلوا",
        "video_link": null
      },
      {
        "ts": "20:38",
        "sec": 1238,
        "text": "في أولئك الرجال الصالحين، هذاك التطرف هو مبالغة، مبالغة في التعظيم مبالغة في في",
        "video_link": null
      },
      {
        "ts": "20:47",
        "sec": 1247,
        "text": "المحبة قد توصل الإنسان إلى إلى مثل هذا، ولذلك",
        "video_link": null
      },
      {
        "ts": "20:54",
        "sec": 1254,
        "text": "قال النبي عليه الصلاة والسلام فيما رواه البخاري عن عمر بن الخطاب رضي الله عنه، قال: \"لا تطروني كما أطرت النصارى عيسى،",
        "video_link": null
      },
      {
        "ts": "21:03",
        "sec": 1263,
        "text": "فقولوا: أنا عبد الله ورسوله\". وهذا يشهد لما نحن الآن بصدده وهو",
        "video_link": null
      },
      {
        "ts": "21:11",
        "sec": 1271,
        "text": "المبالغة والغلو في المخلوق؛ النبي عليه الصلاة والسلام نهى أن يبالغ",
        "video_link": null
      },
      {
        "ts": "21:19",
        "sec": 1279,
        "text": "المسلمون في تعظيمه، نعم هو رجل معظم هو سيد الخلق ولكنه بشر. أما النصارى فإنها غلت",
        "video_link": null
      },
      {
        "ts": "21:28",
        "sec": 1288,
        "text": "في عيسى عليه السلام حتى ألّهته أو جعلته ابن الإله أو ثالث ثلاثة على يعني حسب",
        "video_link": null
      },
      {
        "ts": "21:35",
        "sec": 1295,
        "text": "الطوائف النصرانية، المهم أنها أخرجته من بشريته بسبب الغلو. فكان النبي عليه الصلاة",
        "video_link": null
      },
      {
        "ts": "21:42",
        "sec": 1302,
        "text": "والسلام ينهى عن هذا؛ لماذا؟ للدليل الذي ذكرناه هو الذي تقدم ذكره وهو سد الذرائع،",
        "video_link": null
      },
      {
        "ts": "21:48",
        "sec": 1308,
        "text": "ينبغي أن تسد الذرائع التي يمكن أن تفتح أبواب الانحراف العقدي. الأمر الثاني هو",
        "video_link": null
      },
      {
        "ts": "21:56",
        "sec": 1316,
        "text": "سوء الظن بالله؛ إذا اجتمع الغلو في المخلوق مع سوء الظن بالله في أرضية",
        "video_link": null
      },
      {
        "ts": "22:04",
        "sec": 1324,
        "text": "انتشر فيها الجهل، فإنها تفضي إلى ظهور الشرك. قال تعالى: {وَمَا قَدَرُوا اللَّهَ حَقَّ قَدْرِهِ}؛ لأن",
        "video_link": null
      },
      {
        "ts": "22:14",
        "sec": 1334,
        "text": "هؤلاء الناس الذين يسألون الأصنام فقد أساءوا الظن بالله؛ كيف تسأل أشياء صنعتها",
        "video_link": null
      },
      {
        "ts": "22:21",
        "sec": 1341,
        "text": "أنت بيدك ولا تثق في أفعال الله وفي قدرة الله وفي استجابة الله سبحانه وتعالى",
        "video_link": null
      },
      {
        "ts": "22:27",
        "sec": 1347,
        "text": "لك؟! لماذا تسأل ذلك الصنم؟ لأنك أسأت الظن بالله. والله تعالى قالها صراحة في القرآن الكريم، قال تعالى:",
        "video_link": null
      },
      {
        "ts": "22:36",
        "sec": 1356,
        "text": "{وَيُعَذِّبَ الْمُنَافِقِينَ وَالْمُنَافِقَاتِ وَالْمُشْرِكِينَ وَالْمُشْرِكَاتِ الظَّانِّينَ بِاللَّهِ ظَنَّ السَّوْءِ ۚ عَلَيْهِمْ",
        "video_link": null
      },
      {
        "ts": "22:43",
        "sec": 1363,
        "text": "دَائِرَةُ السَّوْءِ} دائرة، إذن السبب هو الظن، الظن بالسوء، {الظَّانِّينَ بِاللَّهِ ظَنَّ السَّوْءِ} هو ظن السوء",
        "video_link": null
      },
      {
        "ts": "22:52",
        "sec": 1372,
        "text": "هو السبب الذي إذا أُضيف إلى الغلو في المخلوق -كما قلت- في أرضية انتشر فيها الجهل، فإنها تفضي إلى الوقوع",
        "video_link": null
      },
      {
        "ts": "23:01",
        "sec": 1381,
        "text": "إلى ظهور الشرك والعياذ بالله. أقول قولي هذا وأستغفر الله لي ولكم، والسلام عليكم ورحمة الله تعالى وبركاته.",
        "video_link": null
      }
    ]
  },
  {
    "subject": "aqeeda",
    "subjectLabel": "العقيدة والتوحيد",
    "lesson": "الدرس 21",
    "lessonNum": 21,
    "title": "الدرس 21",
    "summary": "📚 <b>ملخص درس: الشرك في الربوبية - أكاديمية الباجي للعلوم الشرعية</b>\n\n🔹 <b>الخلاصة المحورية للدرس:</b>\n<blockquote>يُبين الدرس أن الشرك هو صرف شيء من خصائص الله لغيره، ويركز على \"الشرك في الربوبية\"، موضحاً أن المشركين قديماً لم ينكروا ربوبية الله بالكلية، بل أقروا بها إجمالاً، ولكن خللهم في هذا الجانب أدى بالضرورة إلى وقوعهم في الشرك في الألوهية. فالربوبية تستلزم الألوهية، وإصلاح العقيدة يبدأ بتصحيح الاعتقاد في ربوبية الله وحده.</blockquote>\n\n🔹 <b>الأحداث والوقائع والقواعد بالتفصيل:</b>\n<blockquote>\n• <b>تعريف الشرك وموقعه:</b> الشرك هو صرف شيء من خصائص الله لغير الله. ولأن التوحيد ثلاثة أقسام (ربوبية، ألوهية، أسماء وصفات)، فإن الشرك يتوزع على هذه الأقسام الثلاثة.\n• <b>إقرار المشركين بالربوبية:</b> كان مشركو العرب يُقرون بخصائص الربوبية (الخلق، الإحياء، الرزق، التدبير) لله تعالى، كما في الآيات: <i>{وَلَئِن سَأَلْتَهُم مَّنْ خَلَقَ السَّمَاوَاتِ وَالْأَرْضَ لَيَقُولُنَّ اللَّهُ}</i>. لكن إيمانهم كان إجمالياً غير سليم، فلو كان كاملاً لأنتج عبادة سليمة.\n• <b>الارتباط بين الربوبية والألوهية:</b> أي خلل في الألوهية (كدعاء غير الله) سببه اعتقاد فاسد في الربوبية، وهو ظنهم أن لغير الله قدرة أو تصرفاً أو نفعاً أو ضراً. لذا كان الأنبياء يبدأون بالدعوة إلى توحيد الربوبية.\n• <b>صور الشرك في الربوبية قديماً:</b>\n    • <b>طلب العزة من غير الله:</b> اعتقاد أن لغير الله قدرة على منح العزة.\n    • <b>الاستسقاء بالأنواء:</b> اعتقاد أن المطر ينزل بسبب النجوم والكواكب.\n    • <b>التمائم والتولة:</b> اعتقاد أن تعليق أشياء تجلب الحظ وتدفع الضرر (والتولة: نوع يُستخدم لتحبيب الزوج).\n    • <b>إتيان الكهنة والعرافين:</b> وتصديقهم في علم الغيب.\n    • <b>التطير:</b> التشاؤم بحركة الطيور.\n• <b>نماذج تاريخية للشرك في الربوبية:</b>\n    • <b>قوم عاد:</b> نسبوا الضرر لآلهتهم <i>{اعْتَرَاكَ بَعْضُ آلِهَتِنَا بِسُوءٍ}</i>.\n    • <b>النمروذ بن كنعان:</b> ادعى الإحياء والإماتة.\n    • <b>فرعون:</b> ادعى الربوبية <i>{أَنَا رَبُّكُمُ الْأَعْلَىٰ}</i>.\n    • <b>المجوس:</b> قالوا بوجود ربين (رب للخير ورب للشر).\n    • <b>الدهرية:</b> نسبوا التصرف للدهر والزمان.\n• <b>صور الشرك في العصر الحديث:</b> نسب الخلق أو التدبير للطبيعة (كنظرية التطور)، أو التوجه للأضرحة والمشعوذين طلباً للرزق أو الولد أو دفع الضر، ظناً منهم أن لهؤلاء تصرفاً في الكون.\n</blockquote>\n\n🔹 <b>الأسماء والمصطلحات الرئيسية:</b>\n<blockquote>\n• <b>ابن عباس:</b> صحابي أكد أن المشركين أقروا بالخالق ولكن أشركوا في العبادة.\n• <b>عكرمة ومجاهد:</b> من تلاميذ ابن عباس، أيدا تأصيله في إقرار المشركين بالخلق.\n• <b>عبد الرحمن بن زيد بن أسلم:</b> أوضح أن من يعبد غير الله غالباً ما يكون مؤمناً بوجود الله لكنه يشرك معه.\n• <b>الأنواء:</b> منازل النجوم التي كان الجاهليون يربطون نزول المطر بها.\n• <b>التمائم والتولة:</b> تمائم: ما يعلق لجلب الحظ ودفع الضر. التولة: ما يعلق للتحبيب.\n• <b>الطِّيَرَة:</b> التشاؤم، وهي شرك لربطهم الغيب بأفعال الطيور.\n</blockquote>\n\n🔹 <b>العِبر والأحكام المستفادة:</b>\n<blockquote>\n• لا يكفي الإيمان بوجود الله أو بكونه الخالق ليصير العبد موحداً، بل يجب توحيده في الألوهية أيضاً.\n• المنهج النبوي في الإصلاح هو إبطال خصائص الربوبية التي ينسبها المشركون لمعبوداتهم.\n• توحيد الربوبية يستلزم توحيد الألوهية، ولا يمكن أن يستقيم العبد في عبادته إلا إذا صحح عقيدته في ربوبية الله.\n• الحذر من الوسائل التي تؤدي للشرك، مثل الاعتقاد في النجوم، التمائم، أو التفاؤل والتشاؤم بغير شرع.\n</blockquote>\n\n🔹 <b>سؤال تدبر ومراجعة ذاتية:</b>\n<blockquote>\"على ضوء قاعدة (الربوبية تستلزم الألوهية)، كيف تفسر ذهاب بعض الناس إلى الأضرحة أو المشعوذين اليوم؟ وما هو المدخل العقدي الصحيح لمناصحتهم وتصحيح معتقدهم؟\"</blockquote>",
    "full_text": "بسم الله والحمد لله والصلاة والسلام على رسول الله وعلى آله وصحبه ومن والاه. أما بعد، فهذا درس جديد من دروس التوحيد شيء من خصائص الله لغير الله؛ الشرك هكذا بإجمال، وجعل أوصاف هو جعل والعقيدة للسنة الأولى في أكاديمية الباجي للعلوم الشرعية. قلنا في الدرس الماضي إن الشرك هو صرف شيء من خصائص الله لغير الله. ثم يمكن أن نفصل في هذه الخصائص انطلاقاً من تقسيم التوحيد؛ قلنا إن التوحيد يمكن أن نقسمه إلى أقسام ثلاثة: توحيد في الربوبية، وتوحيد في الألوهية، وتوحيد في الأسماء والصفات. فبالتالي الشرك يقع أيضاً في هذه الأقسام الثلاثة، فنجد: الشرك في الربوبية، والشرك في الألوهية، والشرك في الأسماء والصفات. ودرس اليوم سنتناول فيه الشرك في الربوبية، يعني بعض صوره وبعض الأقوام السابقين الذين وقعوا في هذا الشرك. قبل ذلك، عموماً كان المشركون في الجزيرة العربية وكثير من المشركين في المناطق المناطق الأخرى يثبتون الربوبية لله تعالى عموماً أو بإجمال، ويمكن نقول يثبتون كثيراً من خصائص الربوبية لله سبحانه وتعالى؛ يقول الله جل في علاه: {وَلَئِن سَأَلْتَهُم مَّنْ خَلَقَ السَّمَاوَاتِ وَالْأَرْضَ وَسَخَّرَ الشَّمْسَ وَالْقَمَرَ لَيَقُولُنَّ اللَّهُ}، وقال تعالى: {وَلَئِن سَأَلْتَهُم مَّن نَّزَّلَ مِنَ السَّمَاءِ مَاءً فَأَحْيَا بِهِ الْأَرْضَ مِن بَعْدِ مَوْتِهَا لَيَقُولُنَّ اللَّهُ}؛ هذه أفعال الربوبية؛ الخلق وإنزال الماء من السماء وإحياء الأرض. وقال تعالى: {وَلَئِن سَأَلْتَهُم مَّنْ خَلَقَ السَّمَاوَاتِ وَالْأَرْضَ لَيَقُولُنَّ اللَّهُ}، وقال تعالى: {وَلَئِن سَأَلْتَهُم مَّنْ خَلَقَ السَّمَاوَاتِ وَالْأَرْضَ لَيَقُولُنَّ خَلَقَهُنَّ الْعَزِيزُ الْعَلِيمُ}. وغيرها من الآيات، وقال تعالى: {قُلْ مَن يَرْزُقُكُم مِّنَ السَّمَاءِ وَالْأَرْضِ أَمَّن يَمْلِكُ السَّمْعَ وَالْأَبْصَارَ وَمَن يُخْرِجُ الْحَيَّ مِنَ الْمَيِّتِ وَيُخْرِجُ الْمَيِّتَ مِنَ الْحَيِّ وَمَن يُدَبِّرُ الْأَمْرَ ۚ فَسَيَقُولُونَ اللَّهُ}. كل هذه الآيات تتحدث عن الربوبية؛ الخلق والايجاد، وإنزال الماء، والإحياء، والتدبير، والرزق؛ هذه هي أفعال الربوبية التي بيّناها في دروس سابقة. هؤلاء الأقوام هؤلاء هم مشركون، ولكن إذا سُئلوا هذه الأسئلة المتعلقة بالربوبية أثبتوها لله؛ قال ابن عباس رضي الله عنهما: \"كان إذا قيل لهم: مَن خلق السماء؟ أو مَن خلق الأرض؟ ومَن خلق الجبال؟ قالوا: الله، وهم مشركون\"، مشركون كما سيأتي معنا في العبادة. وقال عكرمة ومجاهد وهما تلميذان لابن عباس رضي الله عنهما، قالوا يعني طبعاً نفس الكلام؛ اللي هو هم يعني تسألهم مَن خلقهم؟ مَن خلق المخلوقات؟ فيقولون: الله، وهم يعبدون غيره. وقال عبد الرحمن بن زيد بن أسلم: \"ليس أحد يعبد مع الله غيره إلا وهو مؤمن بالله، ويعرف أن الله ربه وأن الله خالقه وهو رازقه، وهو يشرك به\". إذاً أين الخلل؟ الخلل أن هذا هذا الإثبات وهذا الإيمان بربوبية الله تعالى كان بإجمال، ولم يكن سليماً مائة بالمائة؛ إذ لو كان سليماً بالمائة بالمائة لأنتج لنا عبادة سليمة، لأنه ما من خلل موجود في الألوهية إلا وسببه خلل موجود في الربوبية. لو صحت، لو صحت اعتقادات هؤلاء الناس في ربوبية الله ووحدوا الله تعالى كما ينبغي في ربوبيته، لما ظهر الشرك في الألوهية؛ لأن الشرك في الألوهية هؤلاء ما مقصده -وسنفصل لاحقاً- إن هؤلاء الناس يسألون غير الله، السؤال: لماذا سألوا غير الله؟ لماذا عبدوا غير الله؟ لأنهم اعتقدوا مسبقاً أن الله تعالى سيعطيهم، عفواً غير الله يعطيهم؛ هم عبدوا معبودات أخرى، لماذا عبدوا هذه المعبودات الأخرى؟ لأنهم اعتقدوا أنها تستجيب لهم، لها قوة، لها قدرة، لها تصرف، وهذا مرتبط بالربوبية؛ اعتقاد أن لهذه المعبودات تصرفات في الكون وقوة وقدرة على فعل أشياء، هذا خلل في الربوبية. ولذلك كان الأنبياء والرسل يبدأون بالربوبية ليصلوا إلى الألوهية، وهو المنهج الذي سار عليه العلماء؛ علماء العقيدة والعلماء ورثة الأنبياء. إذا أردت أن تحدث شخصاً وتنهاه عن عبادة غير الله، حدثه عن ربوبية هذا المعبود؛ هل له معانٍ من معاني الربوبية؟ هل يمكن أن، هل له تصرف؟ هل له قوة؟ وهل له قدرة؟ ولذلك الله تعالى بيّن أن هؤلاء المشركين وإن كانوا مقرين بربوبية الله كانت بإجمال، وبيّن الله تعالى أنهم كانت لهم مجموعة من الأمور المختلة في هذا الجانب، قال تعالى: {وَاتَّخَذُوا مِن دُونِ اللَّهِ آلِهَةً لِّيَكُونُوا لَهُمْ عِزًّا}، {وَاتَّخَذُوا مِن دُونِ اللَّهِ آلِهَةً لِّيَكُونُوا لَهُمْ عِزًّا}. فإذاً هم ابتغوا العزة من عند غير الله، لماذا؟ لأنهم اعتقدوا أن غير الله يعطي العزة، يعز؛ اعتقاد أن غير الله يعز هذا خلل في الربوبية ترتب عليه خلل في الألوهية، الأمر يعني الأمر مرتبط. لماذا سألوا غير الله؟ لأنهم اعتقدوا أن هذا المعبود غير الله يعطي ويعز فاتخذوه آلهة: {وَاتَّخَذُوا مِن دُونِ اللَّهِ آلِهَةً لِّيَكُونُوا لَهُمْ عِزًّا}. كذلك من صور الشرك في الربوبية عند المشركين في الجزيرة العربية: اعتقاد الأمطار من النجوم والأنواء، الأنواء هي منازل النجوم. روى الشيخان عن زيد بن خالد الجهني أنه قال: \"صلى لنا رسول الله صلى الله عليه وسلم صلاة الصبح بالحديبية على إثر سماء كانت من الليل\" أي على إثر مطر، \"فلما انصرف أقبل على الناس فقال: أتدرون ماذا قال ربكم؟ قالوا: الله ورسوله أعلم، قال: أصبح من عبادي مؤمن بي وكافر بي؛ فأما من قال مطرنا بفضل الله ورحمته فذلك مؤمن بي كافر بالكوكب، وأما من قال مطرنا بنوء كذا وكذا فذلك كافر بي مؤمن بالكوكب\". فهذا اعتقاد كان عند المشركين في الجزيرة العربية، وبقيت طبعاً بعض الرواسب عندهم فنبّههم النبي عليه الصلاة والسلام، وقد جاء طبعاً لتصفية المعتقدات. كانوا يعتقدون أن المطر إنما ينزله بعض النجوم والكواكب؛ فقال مَن اعتقد أن الأمطار هي التي تنزل المطر فهذا قد أشرك بأن النجوم هي التي تنزل المطر، هذا شرك بالله؛ فاعتقاد أن هذه المخلوقات لها هذا التصرف، هذا خلل في الربوبية وليس خللاً في الألوهية، بعد ذلك يترتب عليه خلل هو العبادة والدعاء. فما من خلل في الألوهية إلا وينبغي تتبعه لإصلاحه وسنجد أنه موجود في الربوبية؛ ما من خلل في الألوهية إلا ومرتبط بخلل في الربوبية، هذا هذا منهج الإصلاح الذي ينبغي اتباعه. بعض الناس مثلاً يقول تجدوه يذهب عند الضريح الفلاني ويسأله مثلاً الذرية، يسأله الصحة، امرأة تذهب وتسأله أن يعينها لكي تتزوج، وشاب يريد أن يعمل؛ هذه بعض الصور الموجودة مع كامل الأسف في زماننا. لماذا لجأ هؤلاء الناس لهذه الأضرحة ولهاته هاته مخلوقات وهذا وهذا وهؤلاء أموات أصلاً؟ لأنهم اعتقدوا أنها تعطي، واعتقادهم بأن هذه الأضرحة وهذه الأشياء تعطي، هذا خلل في الربوبية ترتب عليه خلل في الألوهية وهي التقرب إليها. فهناك ارتباط طبيعي بالطبع، لأن الربوبية مرتبطة بالألوهية بل الربوبية تستلزم الألوهية؛ توحيد الربوبية يستلزم توحيد الألوهية، وقد رأينا هذا في الفروق بين التوحيدين، بين هذين القسمين، بين الربوبية والألوهية؛ توحيد الربوبية يستلزم ويؤدي ويفضي إلى توحيد الألوهية، فهذا الارتباط يدفع المصلح والداعي إلى العقيدة السليمة إلى أن يربط الخلل الموجود في الألوهية بخلل موجود في الربوبية. ومرة أخرى ما نقولها ونؤكد عليها: ما من خلل وُجد في توحيد الألوهية إلا بسبب خلل موجود في توحيد الربوبية، لو سلم توحيد الربوبية لسلم توحيد الألوهية. كذلك من صور الشرك التي كانت موجودة في الجزيرة العربية -كل هذا لكي نبين بأن بعض الناس يقول بأن المشركين كانوا مقرين وموحدين توحيد الربوبية الصافي الكامل، وهذا خطأ؛ لأنه لو وُجد هذا الكمال في توحيد الربوبية لما وُجد خلل في توحيد الألوهية- قمت من الصور: الاعتقاد في التمائم، فما هي؟ كل شيء هي جمع تميمة، وما كان يحمل الإنسان لكي يعني يجلب له السلامة والعافية ويدفع ويدفع عنه الأضرار. روى أبو داود عن عبد الله بن مسعود رضي الله عنه أنه دخل على امرأته وفي عنقها شيء يعوذ به فجذبه وقطعه، ثم قال: \"لقد أصبح آل عبد الله\" يقصد عبد الله يحسد نفسه \"أغنياء عن أن يشركوا بالله ما لم ينزل به سلطاناً\"، ثم قال: سمعت رسول الله صلى الله عليه وسلم يقول: \"إن الرُّقَى وَالتَّمَائِمَ وَالتِّوَلَةَ شِرْكٌ\". إن التمائم والتولة شرك، الأمور التي ذكرت جمعتها؛ وهي الأمور التي تُعلق لكي تجلب الحظ وتدفع الأضرار، والتِوَلَة هي الأمور التي كانت تدفع تحمل، تفعلها النساء لكي يفضّل لكي يفضّلها زوجها لكي يحبها زوجها، يعني لأن كان عندهم طبعاً هذا التعدد وكانوا يعني أصحاب أصحاب زوجات ثلاثة وأربعة، فكانت الواحدة منها منهن تحمل شيئاً لكي تُحبَّب إلى زوجها لكي تُفضّل على غيرها. ابن مسعود رضي الله عنه جذب هذا من عنق زوجته فقال يعني إن كنت تفعلين هذا من باب التمائم أو من باب الشرك فهذه صورة صورة من صور الشرك في الربوبية التي ترتب عن هذا الفعل؛ اعتقاد بأن التمائم تجلب المنافع هذا شرك في الربوبية. إتيان الكهنة وتصديقهم هذا من الصور؛ أن المشركين في الجزيرة العربية كانوا يعتقدون أن الكهنة لهم قدرة على جلب المصالح ودفع المفاسد وهذا أيضاً من الشرك؛ قال عليه الصلاة والسلام: \"من أتى عرافاً أو كاهناً فصدقه بما يقول فقد كفر بما أُنزل على محمد\"، \"من أتى عرافاً أو كاهناً فصدقه\" طبعاً هذا الإتيان هذا يكون في الألوهية ولكن أين يكمن الشرك في الربوبية؟ هو التصديق، هو التصديق لأنه صدقه واعتقد أنه يعلم الغيب وينفع ويجلب الخير ونحو ذلك. كذلك من صور الشرك في الربوبية: التطير، وهذا كان مشهوراً أو معروفاً عنهم؛ روى أبو داود والترمذي عن عبد الله بن مسعود قال: قال عليه الصلاة والسلام: \"الطِّيَرَةُ شِرْكٌ\". التطير هذا من الطائر طبعاً، كانوا لهم أنواع من الطائر بعضها تُسمى صوانح وبوارح، ما الذي يفعلونه؟ يأتون فيضعون هذه الطيور إذا أرادوا أن يفعلوا شيئاً مستقبلاً في المستقبلي، يعني شيء لا يعرفون كيف سيكون بالطبع؛ مثلاً زواج، تجارة، رحلة، هجرة، يعني شراء شيء، أي شيء في المستقبل كانوا يأتون لهذه الطيور فيهيجونها، فإذا طارت يميناً قالوا: \"نعم، هذا فعل حسن سنفعله\"، وإذا طارت شمالاً تشاءموا وأحجموا عن فعله. فجاء النبي عليه الصلاة وأبطل هذا، وطبعاً البديل وطبعاً هو الاستشارة والاستخارة؛ يعني حتى عقلاً هذا باطل، كيف تربط يعني اتجاه الطيور شمالاً أو يميناً بأن هذا الفعل فيه خير وإذا اتجهت يساراً بأن هذا الفعل فيه شر؟! حتى عقلاً هذا الربط، ولذلك يعني هذه الفترة تُسمى الجاهلية من هذا الباب، من هذا الارتباط العقلي بين الأمور. ولكن كانوا مقرين كما قلنا رغم كل هذه الصور عموماً وإجمالاً من، في أمور الخلق وفي أمور الكبرى، في أمور الرزق كانوا مقرين بتوحيد الربوبية. أما في التاريخ القديم فقط يعني ظهر أيضاً هذا الخلل، الشرك في الربوبية عند القدامى؛ قال تعالى حكاية عن قوم عاد وهم يخاطبون نبيهم هوداً عليه السلام: {إِن نَّقُولُ إِلَّا اعْتَرَاكَ بَعْضُ آلِهَتِنَا بِسُوءٍ}، انظروا! وهم كانوا يعتقدون أن تلك الآلهة التي كانوا يعبدونها كانت يمكنها أن تسيء إلى الناس، فقالوا: {إِن نَّقُولُ إِلَّا اعْتَرَاكَ بَعْضُ آلِهَتِنَا بِسُوءٍ} فنسبوا الإساءة والضرر والضرر إلى آلهتهم أنها بإمكانها أن تسيء وتضر الناس. كذلك ما قاله النمروذ بن كنعان وهو الذي كان في عهد إبراهيم عليه السلام أنه نسب الإحياء والإماتة لنفسه، وهذا شرك في الربوبية لأنه اعتقد هو أنه هو الذي يميت، وكذلك هذا أمر واضح وجاء مصرحاً به في قصة فرعون قال: {أَنَا رَبُّكُمُ الْأَعْلَىٰ}. كذلك ما وقع فيه المجوس، وهذا أيضاً مهم لأن المجوس كانوا قريبين من الجزيرة العربية وهم اعتقدوا وجود ربين، تعالى الله عما يقولون؛ قالوا: يوجد في الكون ربان؛ رب خالق للخير ورب خالق للشر، والأول يسمونه رب النور والثاني يسمونه رب الظلام، يعني هناك من يقول إنه كان له أسماء \"يزدان\" واسم آخر لا يحضرني الآن؛ اعتقدوا أن هذين هما الربان المتصرفان في الكون. كذلك الدهرية أيضاً هؤلاء وقعوا في الشرك وإن قالوا بوجود الله، ولكن هم لم يلحدوا بالاصطلاح العصري ولكن هم مشركون من جهة الربوبية لأنهم نسبوا التصرف للدهر ومثل هؤلاء الذين يقولون الطبيعة تفعل كل شيء ونحو ذلك. فهؤلاء قال تعالى حكاية عنهم: {وَقَالُوا مَا هِيَ إِلَّا حَيَاتُنَا الدُّنْيَا نَمُوتُ وَنَحْيَا وَمَا يُهْلِكُنَا إِلَّا الدَّهْرُ}، هو الدهر هو الذي يتصرف في الكون؛ هذه كلها من صور الشرك في الربوبية في العصر القديم. ثم عندنا أيضاً صور من الشرك في الربوبية في هذا العصر كما قلنا قبل قليل؛ هؤلاء الذين نسبوا الخلق للطبيعة أو التصرف للطبيعة، وأصحاب نظرية التطور ونحو ذلك، هذا شرك في الربوبية لأنهم نسبوا الخلق والفعل وكل ما يقع للطبيعة؛ الطبيعة هي التي تفعل كل شيء. فاعتقاد هذا الأمر أيضاً من صور الشرك في الربوبية. وكذلك كما قلت قبل قليل قضية الأضرحة التي انتشرت في المجتمعات الإسلامية، ولا زالت مع كامل الأسف، أنهم كانوا يعني الناس يذهبون إليها ويقصدونها لجلب المصالح ودفع المفاسد؛ لماذا؟ لأنهم يعتقدون أن هذه الأضرحة، وأيضاً حتى يلحقوا بهم هؤلاء المشعوذين أنهم يذهبون يذهبون الناس إليهم ليسألوهم عن بعض الأمور الغيبية، ويسألون بعض الأمور التي تجلب لهم المنافع وتدفع عنهم المفاسد، كل هذا يدخل ويندرج تحت الشرك في الربوبية. وهذا طبعاً باطل في باطل، وإصلاحه هو إصلاح لما للعقيدة الصحيحة اللي هي عبادة الله وحده. المطلوب من الإنسان أنت لكي تعبد الله وحده لا بد أن تصحح عقيدة الربوبية؛ أن تكون، أن تبطل كل هذه الأمور عن غير الله، فلا فلا تجعل شيئاً من خصائص الربوبية لغير الله. هذا هذا التصرف يفضي بك إن شاء الله تعالى إلى سلامة العبادات، لأن قلنا ما هو الشرك؟ تعريفه العام: هو جعل شيء من خصائص الله لغير الله. ثم قلنا في التفصيل: جعل شيء من خصائص الربوبية لغير الله يفضي إلى جعل شيء من خصائص الله لغير الله في العبودية؛ فإصلاح هذا الخلل يفضي، يؤدي بتوفيق الله إلى إلى إصلاح العبادات فتكون عبادة الإنسان صحيحة وسليمة، ويسلم معتقده وتسلم عبادته لأنها هي الغاية من أجل خلق الإنسان: {وَمَا خَلَقْتُ الْجِنَّ وَالْإِنسَ إِلَّا لِيَعْبُدُونِ}. وبهذا نكون قد بيّنا هذا الشرك، ثم إن شاء الله تعالى في الدرس المقبل سنتحدث إن شاء الله تعالى عن الشرك في الألوهية. أقول قولي هذا وأستغفر الله لي ولكم، والسلام عليكم ورحمة الله تعالى وبركاته.",
    "blocks_search_text": "إقرار مشركي العرب بربوبية الله والربط بين توحيد الربوبية والألوهية عموماً كان المشركون في الجزيرة العربية وكثير من المشركين في المناطق المناطق الأخرى يثبتون الربوبية لله تعالى عموماً أو بإجمال بيّن الشيخ أن مشركي الجاهلية كانوا يقرّون بصفات الربوبية كالخلق والرزق إجمالاً، موضحاً المنهج الدعوي القائم على ربط توحيد الربوبية بالألوهية؛ إذ إن كل خلل في العبادة ينبع بالضرورة من خلل في اعتقاد الربوبية. صور الشرك في الربوبية عند مشركي الجزيرة العربية كذلك من صور الشرك في الربوبية عند المشركين في الجزيرة العربية: اعتقاد الأمطار من النجوم والأنواء، الأنواء هي منازل النجوم. فصّل الشيخ في بعض المظاهر الشركية السائدة في الجاهلية والتي تمس توحيد الربوبية، كنسبة نزول المطر للأنواء والكواكب، وتعليق التمائم لطلب السلامة، وإتيان الكهان وتصديقهم في علم الغيب، والتطير بالطيور. الشرك في الربوبية في التاريخ القديم والعصر الحديث أما في التاريخ القديم فقط يعني ظهر أيضاً هذا الخلل، الشرك في الربوبية عند القدامى استعرض الشيخ نماذج تاريخية للشرك في الربوبية كادعاء النمروذ وفرعون وعقائد المجوس والدهرية، وربطها بالانحرافات المعاصرة كنسبة الخلق للطبيعة، ونظرية التطور، واعتقاد النفع والضر في الأضرحة والمشعوذين.",
