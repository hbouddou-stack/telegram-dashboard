        "sec": 89,
        "text": "كرهوا؛ أي كره علماء المالكية رحمه الله عليهم، كرهوا البسمله. المكروه الأول:",
        "video_link": null
      },
      {
        "ts": "1:40",
        "sec": 100,
        "text": "البسملة؛ يقول إن العلماء كرهوا البسملة، والبسملة هي قول: \"بسم الله الرحمن",
        "video_link": null
      },
      {
        "ts": "1:48",
        "sec": 108,
        "text": "الرحيم\". وهي مكروهة كرهها المالكية في الصلوات المفروضة، لذا قال: \"وَكَرِهُوا بَسْمَلَةً تَعَوُّذَا فِي الْفَرْضِ\"؛ في الصلاة",
        "video_link": null
      },
      {
        "ts": "1:57",
        "sec": 117,
        "text": "المفروضة؛ فهم كرهوا البسملة في الصلاة المفروضة، هذا المكروه الأول. المكروه الثاني:",
        "video_link": null
      },
      {
        "ts": "2:05",
        "sec": 125,
        "text": "التعوذ؛ التعوذ قول المصلي: \"أعوذ بالله من الشيطان الرجيم\". وبالمناسبة لما تقول \"بسم",
        "video_link": null
      },
      {
        "ts": "2:15",
        "sec": 135,
        "text": "الله\" أي أستعين بالله، أستعين بالله الرحمن الرحيم؛",
        "video_link": null
      },
      {
        "ts": "2:23",
        "sec": 143,
        "text": "والتعوذ لما تقول \"أعوذ\"؛ أعوذ بالذال المعجمة، أعوذ بالله من",
        "video_link": null
      },
      {
        "ts": "2:30",
        "sec": 150,
        "text": "الشيطان الرجيم، معناها احتمي بالله احتمي بالله من الشيطان",
        "video_link": null
      },
      {
        "ts": "2:37",
        "sec": 157,
        "text": "الرجيم. كأنك تستعين بالله؛ إذا قلت \"بسم الله الرحمن الرحيم\" فأنت تستعين بالله",
        "video_link": null
      },
      {
        "ts": "2:43",
        "sec": 163,
        "text": "على أداء صلاتك حتى تؤديها على الوجه المطلوب، وعندما تقول \"أعوذ بالله\" أي احتمي",
        "video_link": null
      },
      {
        "ts": "2:52",
        "sec": 172,
        "text": "بالله من الشيطان الرجيم حتى لا يؤثر عليَّ في صلاتي. المالكية رحمه الله عليهم كرهوا",
        "video_link": null
      },
      {
        "ts": "3:00",
        "sec": 180,
        "text": "البسملة والتعوذ في الصلاة المفروضة،",
        "video_link": null
      },
      {
        "ts": "3:06",
        "sec": 186,
        "text": "واستحبوهما في الصلاة النافلة. لماذا كرهوهما في الصلاة المفروضة؟",
        "video_link": null
      },
      {
        "ts": "3:13",
        "sec": 193,
        "text": "كرهوهما لما ثبت في الصحيح وغيره من حديث أنس بن مالك رضي الله عنه، قال: \"صَلَّيْتُ خَلْفَ رَسُولِ اللَّهِ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ وَأَبِي بَكْرٍ وَعُمَرَ وَعُثْمَانَ، فَلَمْ أَسْمَعْ أَحَداً مِنْهُمْ يَقُولُ بِسْمِ اللَّهِ الرَّحْمَنِ الرَّحِيمِ\" (قال فلم أسمع أحداً منهم يقول بسم الله الرحمن الرحيم). وفي رواية:",
        "video_link": null
      },
      {
        "ts": "3:35",
        "sec": 215,
        "text": "\"فَكَانُوا يَفْتَتِحُونَ بِالْحَمْدُ لِلَّهِ رَبِّ الْعَالَمِينَ\". ا هذه في الواقع هذه المسألة (البسملة في",
        "video_link": null
      },
      {
        "ts": "3:42",
        "sec": 222,
        "text": "الصلاة) فيها كلام طويل جداً، لكن خلاصة الأمر أنه ثبت عنه صلى الله عليه وسلم أنه",
        "video_link": null
      },
      {
        "ts": "3:49",
        "sec": 229,
        "text": "كان يبسمل في الصلاة المفروضة، وإنما قال أنس بن مالك رضي الله عنه إنهم لم يسمع",
        "video_link": null
      },
      {
        "ts": "3:56",
        "sec": 236,
        "text": "أحداً منهم يقول \"بسم الله الرحمن الرحيم\" لأنهم لأن السنة الإسرار بالبسملة، السنة",
        "video_link": null
      },
      {
        "ts": "4:03",
        "sec": 243,
        "text": "الإسرار بالبسملة؛ أن الإنسان إذا صلى \"الله الرحمن الرحيم\" سراً، وهي التعوذ؛",
        "video_link": null
      },
      {
        "ts": "4:11",
        "sec": 251,
        "text": "ويكون في الركعة الأولى فقط يكون سراً، فالتعوذ يكون سراً والبسملة تكون سراً. على",
        "video_link": null
      },
      {
        "ts": "4:18",
        "sec": 258,
        "text": "هذا يُحمل قول أنس بن مالك رضي الله عنه \"لم أسمع أحداً منهم يقول بسم الله الرحمن الرحيم\" أو \"لم يكونوا يقولون بسم الله",
        "video_link": null
      },
      {
        "ts": "4:26",
        "sec": 266,
        "text": "الرحمن الرحيم\"؛ لأن البسملة تكون سراً، والله تعالى أعلى وأعلم. قال: \"وَكَرِهُوا",
        "video_link": null
      },
      {
        "ts": "4:36",
        "sec": 276,
        "text": "بَسْمَلَةً تَعَوُّذَا فِي الْفَرْضِ وَالسُّجُودَ فِي الثَّوْبِ\"؛ والسجود في الثوب. هذا المكروه الثالث من",
        "video_link": null
      },
      {
        "ts": "4:45",
        "sec": 285,
        "text": "مكروهات الصلاة التي ذكرها الناظم وهي: السجود في الثوب، السجود في الثوب يعني تضع",
        "video_link": null
      },
      {
        "ts": "4:51",
        "sec": 291,
        "text": "ثوباً تسجد عليه، تضع ثوباً فتسجد عليه؛ وهذا نُقل عن إمامنا مالك رحمه الله تعالى في",
        "video_link": null
      },
      {
        "ts": "4:58",
        "sec": 298,
        "text": "المدونة. والمالكية رحمه الله عليهم فسروا هذا بأنه ا يدعو إلى الرفاهية، كأنه يدعو",
        "video_link": null
      },
      {
        "ts": "5:06",
        "sec": 306,
        "text": "إلى الترفه، بينما الصلاة الأصل فيها أنها تذلل لله عز وجل وخضوع له؛",
        "video_link": null
      },
      {
        "ts": "5:14",
        "sec": 314,
        "text": "فلذلك كرهوا هذا. ا لكن الواقع أن النبي صلى الله عليه وسلم",
        "video_link": null
      },
      {
        "ts": "5:22",
        "sec": 322,
        "text": "ثبت عنه أنه صلى على الحصير وصلى على ثوب، والآن هذه المساجد",
        "video_link": null
      },
      {
        "ts": "5:30",
        "sec": 330,
        "text": "الآن مساجد مفروشة ففيها هذه الزرابي وفي هذا فلا يمكن أن نقول إنه يكره أن هذا",
        "video_link": null
      },
      {
        "ts": "5:38",
        "sec": 338,
        "text": "مما يكره لا، فالنبي صلى الله عليه وسلم صلى على الحصير وصلى على الثوب وصلى على",
        "video_link": null
      },
      {
        "ts": "5:45",
        "sec": 345,
        "text": "الفراش وكذلك أصحابه. قال: \"وَالسُّجُودَ فِي",
        "video_link": null
      },
      {
        "ts": "5:53",
        "sec": 353,
        "text": "الثَّوْبِ\"، ا ثم قال: \"كَذَا كَوْرِ",
        "video_link": null
      },
      {
        "ts": "6:01",
        "sec": 361,
        "text": "عِمَامَةٍ\"؛ لما قال \"كَذَا\" هنا المكروه الثالث اللي ذكره السجود في الثوب، كذا أي وأيضاً \"كَوْرِ",
        "video_link": null
      },
      {
        "ts": "6:10",
        "sec": 370,
        "text": "عِمَامَةٍ\"؛ أي هذا المكروه الرابع: السجود على كور العمامة، السجود على كور العمامة.",
        "video_link": null
      },
      {
        "ts": "6:20",
        "sec": 380,
        "text": "العمامة يُلف بها الرأس؛ فالإنسان لما يسجد تقدم معنا قوله صلى",
        "video_link": null
      },
      {
        "ts": "6:29",
        "sec": 389,
        "text": "الله عليه وسلم: \"أُمِرْتُ أَنْ أَسْجُدَ عَلَى سَبْعَةِ أَعْظُمٍ: عَلَى الْجَبْهَةِ -وَأَشَارَ بِيَدِهِ عَلَى أَنْفِهِ-\" إلى آخر الحديث؛",
        "video_link": null
      },
      {
        "ts": "6:42",
        "sec": 402,
        "text": "فالجبهة ينبغي أن تمس الأرض، وجود العمامة على",
        "video_link": null
      },
      {
        "ts": "6:50",
        "sec": 410,
        "text": "الجبهة يمنع من مماسة الجبهة",
        "video_link": null
      },
      {
        "ts": "6:56",
        "sec": 416,
        "text": "الأرض. كور العمامة (الكور يعني تكور العمامة على الرأس)؛ هذا الكور أحياناً ربما",
        "video_link": null
      },
      {
        "ts": "7:05",
        "sec": 425,
        "text": "يمنع الجبهة من مماسة الأرض، فهذا مكروه؛ هذا يكره لأنه ينبغي أن تمس الجبهة الأرض.",
        "video_link": null
      },
      {
        "ts": "7:14",
        "sec": 434,
        "text": "لذلك علماؤنا رحمه الله عليهم يقولون ينبغي أن أن يمس ولو جزء من الجبهة الأرض؛",
        "video_link": null
      },
      {
        "ts": "7:21",
        "sec": 441,
        "text": "يعني اعتمد الإنسان فينبغي أن يمس ولو جزء من الجبهة يمس",
        "video_link": null
      },
      {
        "ts": "7:29",
        "sec": 449,
        "text": "الأرض، وإذا لم يمس لم تمس الجبهة الأرض بسبب كور العمامة فيستحبون له أن يعيد",
        "video_link": null
      },
      {
        "ts": "7:37",
        "sec": 457,
        "text": "الصلاة، يستحبون له إعادة الصلاة في الوقت. قال: \"كَوْرِ",
        "video_link": null
      },
      {
        "ts": "7:45",
        "sec": 465,
        "text": "عِمَامَةٍ وَبَعْضِ كُمِّهِ\"؛ أي هذا المكروه الخامس: السجود على بعض",
        "video_link": null
      },
      {
        "ts": "7:54",
        "sec": 474,
        "text": "الكم، السجود على بعض الكم. أحياناً الإنسان يصلي ربما يكون الثوب",
        "video_link": null
      },
      {
        "ts": "8:01",
        "sec": 481,
        "text": "يكون الكم الـ الكم طويلاً؛ يعني ما قلناه فيما يتعلق بالسجود على كور العمامة يُقال في",
        "video_link": null
      },
      {
        "ts": "8:08",
        "sec": 488,
        "text": "السجود على بعض الكم؛ يكون الثوب سابغاً طويلاً.",
        "video_link": null
      },
      {
        "ts": "8:15",
        "sec": 495,
        "text": "فإذن اليد ماذا قلنا؟ بأن الجبهة ينبغي أن تمس الأرض كذلك اليدان ينبغي أن تمسا",
        "video_link": null
      },
      {
        "ts": "8:21",
        "sec": 501,
        "text": "الأرض وهو ساجد؛ إذا كان الثوب طويلاً فلم",
        "video_link": null
      },
      {
        "ts": "8:29",
        "sec": 509,
        "text": "يخرج يديه من كمه أبقى يده داخل كمه وسجد،",
        "video_link": null
      },
      {
        "ts": "8:36",
        "sec": 516,
        "text": "فهذا مكروه؛ هذا الذي يقصده بقوله:",
        "video_link": null
      },
      {
        "ts": "8:41",
        "sec": 521,
        "text": "\"وَبَعْضِ كُمِّهِ\" (وبعض كمه)؛ أي يسجد ويده",
        "video_link": null
      },
      {
        "ts": "8:51",
        "sec": 531,
        "text": "في كمه ولا تمس الأرض، هذا مكروه في الصلاة؛ لِمَا؟ لأنه ينبغي أن تمس أعضاء السجود",
        "video_link": null
      },
      {
        "ts": "9:02",
        "sec": 542,
        "text": "الأرض. ثم قال: \"وَحَمْلِ شَيْءٍ فِيهِ أَوْ فِي فَمِّهِ\". المكروه",
        "video_link": null
      },
      {
        "ts": "9:11",
        "sec": 551,
        "text": "السادس: حمل شيء في الكم؛ أحياناً بعض الناس بعض العادات بعض التقاليد يكون الكم واسعاً فربما يحمل الإنسان فيه شيئاً",
        "video_link": null
      },
      {
        "ts": "9:19",
        "sec": 559,
        "text": "وهو يصلي فيحمل شيئاً داخل. والمكروه الثامن أظن: حمل شيء في",
        "video_link": null
      },
      {
        "ts": "9:28",
        "sec": 568,
        "text": "الفم، ربما إنسان مثلاً (أو السابع) يكون الإنسان يحمل شيئاً في",
        "video_link": null
      },
      {
        "ts": "9:34",
        "sec": 574,
        "text": "فمه؛ ربما أكل شيئاً فبقي شيء في فمه فلا يريد أن يبتلعه حتى لا تبطل صلاته فيحمل",
        "video_link": null
      },
      {
        "ts": "9:43",
        "sec": 583,
        "text": "شيئاً في فمه، أو المهم شيء من هذا القبيل. فحمل شيء في الفم أثناء الصلاة أو حمل شيء في الكم أثناء",
        "video_link": null
      },
      {
        "ts": "9:51",
        "sec": 591,
        "text": "الصلاة هذا مكروه؛ لِمَا؟ لأن هذا",
        "video_link": null
      },
      {
        "ts": "9:59",
        "sec": 599,
        "text": "يشغل عن الخشوع في الصلاة، يشغل عن الخشوع في الصلاة. سيأتي معنى أن الخشوع في",
        "video_link": null
      },
      {
        "ts": "10:06",
        "sec": 606,
        "text": "الصلاة الخشوع في الصلاة مطلوب؛ فلما يحمل الإنسان شيئاً في كمه أو",
        "video_link": null
      },
      {
        "ts": "10:14",
        "sec": 614,
        "text": "في فمه فسيبقى منشغلاً معه، قد يسقط دعه أحذر أن يسقط فينشغل به عن",
        "video_link": null
      },
      {
        "ts": "10:22",
        "sec": 622,
        "text": "الخشوع فكُره هذا؛",
        "video_link": null
      },
      {
        "ts": "10:29",
        "sec": 629,
        "text": "مكروه. \"وَحَمْلِ شَيْءٍ فِيهِ أَوْ فِي فَمِّهِ\" ثم قال: قِرَاءَةٌ لَدَى السُّجُودِ وَالرُّكُوعْ *** تَفَكُّرُ الْقَلْبِ بِمَا فِيهِ خُشُوعْ",
        "video_link": null
      },
      {
        "ts": "10:38",
        "sec": 638,
        "text": "\"قِرَاءَةٌ لَدَى السُّجُودِ وَالرُّكُوعْ\". المكروه الثامن: القراءة أثناء السجود",
        "video_link": null
      },
      {
        "ts": "10:47",
        "sec": 647,
        "text": "أو أثناء الركوع؛ قراءة القرآن هذه من مكروهات",
        "video_link": null
      },
      {
        "ts": "10:54",
        "sec": 654,
        "text": "الصلاة. يقول النبي صلى الله عليه وسلم: \"أَلَا وَإِنِّي",
        "video_link": null
      },
      {
        "ts": "11:01",
        "sec": 661,
        "text": "نُهِيتُ أَنْ أَقْرَأَ الْقُرْآنَ رَاكِعاً أَوْ",
        "video_link": null
      },
      {
        "ts": "11:07",
        "sec": 667,
        "text": "سَاجِداً\" (إني نهيت أن أقرأ القرآن راكعاً أو",
        "video_link": null
      },
      {
        "ts": "11:13",
        "sec": 673,
        "text": "ساجداً)؛ لأن الركوع ركوع فيه تعظيم الرب جل جلاله في",
        "video_link": null
      },
      {
        "ts": "11:21",
        "sec": 681,
        "text": "التسبيح \"سبحان ربي العظيم\" كما مر معنا في المجلس الماضي، السجود فيه",
        "video_link": null
      },
      {
        "ts": "11:27",
        "sec": 687,
        "text": "التسبيح \"سبحان ربي الأعلى\" فيه الدعاء؛ قال صلى الله عليه وسلم: \"أَمَّا السُّجُودُ فَاجْتَهِدُوا فِي الدُّعَاءِ، فَقَمِنٌ أَنْ يُسْتَجَابَ لَكُمْ\"؛ أي حقيق أن",
        "video_link": null
      },
      {
        "ts": "11:36",
        "sec": 696,
        "text": "يستجاب لكم، فلذلك الركوع والسجود ليس محلاً لقراءة القرآن الكريم؛",
        "video_link": null
      },
      {
        "ts": "11:45",
        "sec": 705,
        "text": "فيكره للإنسان أن يقرأ القرآن راكعاً أو ساجداً. السجود يُستثنى؛ لا أقول استُثني قراءة",
        "video_link": null
      },
      {
        "ts": "11:54",
        "sec": 714,
        "text": "ولكن تكون أحياناً بعض الأدعية هي من القرآن الكريم، إذا ذكرها الإنسان على وجه الدعاء صح؛ مثلاً من القرآن",
        "video_link": null
      },
      {
        "ts": "12:03",
        "sec": 723,
        "text": "الكريم قول ربنا تبارك وتعالى: {رَبَّنَا لَا تُزِغْ قُلُوبَنَا بَعْدَ إِذْ هَدَيْتَنَا وَهَبْ لَنَا مِن لَّدُنْكَ رَحْمَةً ۚ إِنَّكَ أَنتَ الْوَهَّابُ}؛ لو الإنسان في سجوده",
        "video_link": null
      },
      {
        "ts": "12:13",
        "sec": 733,
        "text": "ا ذكر هذه الآية على وجه الدعاء لا على وجه القراءة يدعو ربه، فيقول: \"ربنا لا تزغ قلوبنا بعد إذ هديتنا وهب لنا من لدنك",
        "video_link": null
      },
      {
        "ts": "12:22",
        "sec": 742,
        "text": "رحمة\" يدعو دعاءً لا قراءة، هذا صح وجاز ولم يكره؛ لم",
        "video_link": null
      },
      {
        "ts": "12:30",
        "sec": 750,
        "text": "يكره لأن المنهي عن لأن المنهي عنه القراءة فقط،",
        "video_link": null
      },
      {
        "ts": "12:38",
        "sec": 758,
        "text": "فلذلك تكره قراءة القرآن في الركوع والسجود. ثم",
        "video_link": null
      },
      {
        "ts": "12:44",
        "sec": 764,
        "text": "قال: \"تَفَكُّرُ الْقَلْبِ بِمَا...\" في النظم: \"بِمَا فِيهِ خُشُوعْ\" والشيخ صححها في الشرح: \"بِمَا يُنَافِي الْخُشُوعْ\"، هذا المكروه",
        "video_link": null
      },
      {
        "ts": "12:55",
        "sec": 775,
        "text": "السابع أو التاسع؛ الخشوع روح",
        "video_link": null
      },
      {
        "ts": "13:02",
        "sec": 782,
        "text": "الصلاة، الصلاة دون خشوع جسد بلا",
        "video_link": null
      },
      {
        "ts": "13:11",
        "sec": 791,
        "text": "روح. ربنا جل جلاله امتدح أهل الخشوع فقال: {قَدْ أَفْلَحَ",
        "video_link": null
      },
      {
        "ts": "13:19",
        "sec": 799,
        "text": "الْمُؤْمِنُونَ * الَّذِينَ هُمْ فِي صَلَاتِهِمْ خَاشِعُونَ}.",
        "video_link": null
      },
      {
        "ts": "13:28",
        "sec": 808,
        "text": "والخشوع سكون النفس والقلب والجوارح؛",
        "video_link": null
      },
      {
        "ts": "13:37",
        "sec": 817,
        "text": "فتكون جوارح العبد ساكنة خاشعة لربها جل جلاله أثناء",
        "video_link": null
      },
      {
        "ts": "13:45",
        "sec": 825,
        "text": "الصلاة، وفي داخله خشوع وسكون",
        "video_link": null
      },
      {
        "ts": "13:53",
        "sec": 833,
        "text": "وخضوع لله رب العالمين. تفكر",
        "video_link": null
      },
      {
        "ts": "14:02",
        "sec": 842,
        "text": "القلب بما ينافي الخشوع من أمور الدنيا",
        "video_link": null
      },
      {
        "ts": "14:09",
        "sec": 849,
        "text": "وغيرها هذا من مكروهات الصلاة؛ لأنه ينافي الغرض من",
        "video_link": null
      },
      {
        "ts": "14:18",
        "sec": 858,
        "text": "الصلاة. كان بعض الصالحين إذا دخل الصلاة -بل هذا دأب",
        "video_link": null
      },
      {
        "ts": "14:25",
        "sec": 865,
        "text": "الصالحين- الواحد منهم الواحد منهم إذا دخل الصلاة ينسى كل ما",
        "video_link": null
      },
      {
        "ts": "14:33",
        "sec": 873,
        "text": "حوله، يغـ يغيب عن العالم الخارجي إن صح هذا التعبير. أحد الصالحين كان إذا دخل",
        "video_link": null
      },
      {
        "ts": "14:42",
        "sec": 882,
        "text": "بيته يتوقف الأطفال عن اللعب وتقل الحركة في",
        "video_link": null
      },
      {
        "ts": "14:48",
        "sec": 888,
        "text": "المنزل احتراماً له وهيبةً منه، فإذا دخل في الصلاة أخذوا حريتهم فقر عادوا إلى لهوهم",
        "video_link": null
      },
      {
        "ts": "14:58",
        "sec": 898,
        "text": "ولعبهم، وأهل الكلام إلى كلامهم؛ لأنه حين يدخل في الصلاة يغيب عن عن غيره عن عن ما",
        "video_link": null
      },
      {
        "ts": "15:06",
        "sec": 906,
        "text": "حوله. ا كان عبد الله بن الزبير رضي الله عنه",
        "video_link": null
      },
      {
        "ts": "15:13",
        "sec": 913,
        "text": "وأرضاه كان يصلي في الحرم فيقف كأنه خشبة، حتى إن الحمام (حمام الحرم) يأتي ويحط",
        "video_link": null
      },
      {
        "ts": "15:20",
        "sec": 920,
        "text": "عليه يظنه جذع شجرة أو عوداً، من شدة خشوعه وسكونه. أفتح قوساً يسيراً من الأسئلة التي",
        "video_link": null
      },
      {
        "ts": "15:29",
        "sec": 929,
        "text": "تُطرح كثيراً أن البعض يقول: \"كيف أحصل الخشوع في الصلاة؟\" الجواب أيها الأفاضل الفضلاء",
        "video_link": null
      },
      {
        "ts": "15:38",
        "sec": 938,
        "text": "والفضليات: الخشوع عمل القلب؛ كلما كان القلب حياً",
        "video_link": null
      },
      {
        "ts": "15:44",
        "sec": 944,
        "text": "حاضراً، كلما أسرع إليه الخشوع. فلتحصيل",
        "video_link": null
      },
      {
        "ts": "15:52",
        "sec": 952,
        "text": "الخشوع هناك ا ما يُفعل قبل",
        "video_link": null
      },
      {
        "ts": "15:59",
        "sec": 959,
        "text": "الصلاة، وهناك ما يُفعل أثناء أثناء الصلاة من أجل تحقيق",
        "video_link": null
      },
      {
        "ts": "16:09",
        "sec": 969,
        "text": "الخشوع. قبل الصلاة: أن تحافظ على حياة قلبك، أن يبقى القلب",
        "video_link": null
      },
      {
        "ts": "16:17",
        "sec": 977,
        "text": "حياً؛ يبقى القلب حياً بذكر الله؛ \"مَثَلُ الَّذِي يَذْكُرُ رَبَّهُ وَالَّذِي لَا يَذْكُرُ رَبَّهُ مَثَلُ الْحَيِّ",
        "video_link": null
      },
      {
        "ts": "16:24",
        "sec": 984,
        "text": "وَالْمَيِّتِ\" كما قال صلى الله عليه وسلم. بالإكثار من ذكر الله؛ أذكار الصباح والمساء، أذكار الدخول الخروج، أذكار",
        "video_link": null
      },
      {
        "ts": "16:34",
        "sec": 994,
        "text": "الأكل والنوم والوضوء وغيرها، والذكر المطلق؛ يحيا",
        "video_link": null
      },
      {
        "ts": "16:40",
        "sec": 1000,
        "text": "القلب بتلاوة القرآن يومياً بتدبر: {أَفَلَا يَتَدَبَّرُونَ الْقُرْآنَ أَمْ عَلَىٰ قُلُوبٍ",
        "video_link": null
      },
      {
        "ts": "16:49",
        "sec": 1009,
        "text": "أَقْفَالُهَا}. يحيا القلب بحضور مجالس العلماء",
        "video_link": null
      },
      {
        "ts": "16:56",
        "sec": 1016,
        "text": "والصالحين، حضور والاستماع إلى كلامهم؛ يحيا القلب بتذكر الموت ولقاء الله جل",
        "video_link": null
      },
      {
        "ts": "17:06",
        "sec": 1026,
        "text": "جلاله؛ يحيا القلب برحمة اليتيم وزيارة",
        "video_link": null
      },
      {
        "ts": "17:12",
        "sec": 1032,
        "text": "المريض، وهكذا الإنسان يبقي قلبه حياً. يحيا القلب بترك",
        "video_link": null
      },
      {
        "ts": "17:19",
        "sec": 1039,
        "text": "المعاصي فإنها قاتلة للقلوب سموم قاتلة، ومَن أذنب يستغفر يستغفر كما قال صلى",
        "video_link": null
      },
      {
        "ts": "17:28",
        "sec": 1048,
        "text": "الله عليه وسلم: \"إِذَا أَذْنَبَ الْعَبْدُ ذَنْباً نُكِتَ فِي قَلْبِهِ نُكْتَةٌ سَوْدَاءُ، فَإِنْ تَابَ وَنَزَعَ وَاسْتَغْفَرَ صُقِلَ",
        "video_link": null
      },
      {
        "ts": "17:35",
        "sec": 1055,
        "text": "قَلْبُهُ، وَإِنْ زَادَ زَادَتْ\" يعني إذا استغفر الإنسان وتاب يُصقل",
        "video_link": null
      },
      {
        "ts": "17:43",
        "sec": 1063,
        "text": "القلب يُنقى القلب ويزول أثر تلك النكتة السوداء أثر الذنب؛ لكن من زاد الذنب زاد السواد حتى",
        "video_link": null
      },
      {
        "ts": "17:53",
        "sec": 1073,
        "text": "يعلو السواد القلب ويطغى عليه الران، فأنَّى ينفذ إليه نور الإيمان وكيف سينبثق",
        "video_link": null
      },
      {
        "ts": "18:02",
        "sec": 1082,
        "text": "منه الخشوع؟! فلذلك بهذا يحيا القلب؛ إذا بقي القلب حياً، إذا ذهبت للصلاة مع تكبيرك تذكر",
        "video_link": null
      },
      {
        "ts": "18:12",
        "sec": 1092,
        "text": "ربك عز وجل فيسرع حضور القلب يسرع إليك حضور قلبك؛ أما القلب إذا كان في",
        "video_link": null
      },
      {
        "ts": "18:21",
        "sec": 1101,
        "text": "قسوة وشدة ا يقل",
        "video_link": null
      },
      {
        "ts": "18:27",
        "sec": 1107,
        "text": "خشوعه. ثم قبيل الصلاة مثلاً للرجال يستحب للإنسان أن يبكر إلى",
        "video_link": null
      },
      {
        "ts": "18:34",
        "sec": 1114,
        "text": "المسجد، يصلي تحية المسجد، يذكر ربه عز وجل حتى يتهيأ القلب",
        "video_link": null
      },
      {
        "ts": "18:41",
        "sec": 1121,
        "text": "للدخول في الفرض مع مع التأمل في الأذان وفي الإقامة وما إلى ذلك. وللمرأة كذلك",
        "video_link": null
      },
      {
        "ts": "18:48",
        "sec": 1128,
        "text": "تتأمل في الأذان في الإقامة ترددد مع المؤذن، تصلي النافلة قبل الصلاة فيتهيأ",
        "video_link": null
      },
      {
        "ts": "18:55",
        "sec": 1135,
        "text": "قلبها للدخول في الفريضة لأن لأن الفرض نعم؛ ثم حين تدخل في الصلاة تستحضر أنك بين",
        "video_link": null
      },
      {
        "ts": "19:02",
        "sec": 1142,
        "text": "يدي ملك الملوك جل جلاله، أنك بين يدي خالقك خالق السماوات والأرض فتجتهد في",
        "video_link": null
      },
      {
        "ts": "19:09",
        "sec": 1149,
        "text": "استحضار هذا وتسكن أعضاءك وتجتهد في إحضار قلبك تجتهد. فإذا",
        "video_link": null
      },
      {
        "ts": "19:16",
        "sec": 1156,
        "text": "جاء ما يصرف قلبك عن تركيزه وعن خشوعه تطرده وترجع إلى تركيزك وإلى خشوعك ا في",
        "video_link": null
      },
      {
        "ts": "19:26",
        "sec": 1166,
        "text": "صلاتك؛ فبذلك يعظم الأجر ويحصل الأثر أثر الأثر.",
        "video_link": null
      },
      {
        "ts": "19:33",
        "sec": 1173,
        "text": "إنما يحصل من الصلاة بقدر خشوع العبد في صلاته؛ ربنا تبارك وتعالى قال: {سِيمَاهُمْ فِي وُجُوهِهِم مِّنْ أَثَرِ السُّجُودِ} (من اثر الصلاة)، يعني لما يصلي",
        "video_link": null
      },
      {
        "ts": "19:42",
        "sec": 1182,
        "text": "الإنسان بخُشوع وبطمأنينة حين ينتهي من الصلاة يبقى الأثر بادياً عليه. نسأل الله تعالى أن يرزقنا",
        "video_link": null
      },
      {
        "ts": "19:50",
        "sec": 1190,
        "text": "وإياكم قلباً سليماً خاشعاً. قال رحمه الله عليه وهو يعدد",
        "video_link": null
      },
      {
        "ts": "19:59",
        "sec": 1199,
        "text": "مكروهات الصلاة؛ قال: وَعَبَثٌ وَالِالْتِفَاتُ وَالدُّعَاءْ *** أَثْنَاءَ قِرَاءَةٍ كَذَا إِنْ رَكَعَا تَشْبِيكُ أَوْ فَرْقَعَةُ الْأَصَابِعِ *** تَخَصُّرٌ تَغْمِيضُ عَيْنٍ تَابِعِ",
        "video_link": null
      },
      {
        "ts": "20:06",
        "sec": 1206,
        "text": "\"وَعَبَثٌ\"؛ من مكروهات الصلاة: العبث، العبث الإنسان العبث في الصلاة؛ الإنسان يعبث بثوبه، يعبث بساعته،",
        "video_link": null
      },
      {
        "ts": "20:14",
        "sec": 1214,
        "text": "يعبث بقبعته، بشعر لحيته، تعبث المرأة بثيابها؛ هذا العبث وكثرة الحركة في الصلاة",
        "video_link": null
      },
      {
        "ts": "20:21",
        "sec": 1221,
        "text": "هي مكروهة. النبي صلى الله عليه وسلم قال: \"اسْكُنُوا فِي الصَّلَاةِ\" (اسكنوا في",
        "video_link": null
      },
      {
        "ts": "20:28",
        "sec": 1228,
        "text": "الصلاة)؛ الحركة تنبغي في ينبغي أن يكون ساكنا في صلاته خاشعاً مطمئناً، أما كثرة العبث",
        "video_link": null
      },
      {
        "ts": "20:36",
        "sec": 1236,
        "text": "وهذا هذا يكره في الصلاة؛ بل لو كثر العبث جداً لو كثرت الحركة والعبث جداً لدرجة أن الرائي",
        "video_link": null
      },
      {
        "ts": "20:46",
        "sec": 1246,
        "text": "إذا رأى الرجل وهو يصلي ما ظنه يصلي لكثرة عبثه، هذا تبطل صلاته عليه أن يعيد الصلاة؛ لكن",
        "video_link": null
      },
      {
        "ts": "20:54",
        "sec": 1254,
        "text": "العبث اليسير هذا يكره في الصلاة؛ يعبث بخاتمه، يعبث بشعره، يعبث",
        "video_link": null
      },
      {
        "ts": "21:01",
        "sec": 1261,
        "text": "بثيابه يعبث؛ من الخشوع هذا من مكروهات الصلاة، لقوله صلى الله عليه وسلم: \"اسكنوا في",
        "video_link": null
      },
      {
        "ts": "21:09",
        "sec": 1269,
        "text": "الصلاة\". \"وَعَبَثٌ وَالِالْتِفَاتُ\"؛ المكروه الحادي عشر: الالتفات، الإنسان يلتفت في",
        "video_link": null
      },
      {
        "ts": "21:16",
        "sec": 1276,
        "text": "صلاته يلتفت يمنة ويلتفت يسرة، رفع بصره إلى السماء؛ أحياناً تكون",
        "video_link": null
      },
      {
        "ts": "21:24",
        "sec": 1284,
        "text": "داخلاً إلى المسجد فـ تجد الرجل يصلي في يتبعك",
        "video_link": null
      },
      {
        "ts": "21:29",
        "sec": 1289,
        "text": "ببصره، ثالثاً يصلي وهو يرفع بصره إلى",
        "video_link": null
      },
      {
        "ts": "21:36",
        "sec": 1296,
        "text": "السماء ويتأمل في في نقش المسجد؛ ربما تجد ربما إنسان وإنسانة يصلي بجانب التلفاز فـ",
        "video_link": null
      },
      {
        "ts": "21:45",
        "sec": 1305,
        "text": "بين الفينة والأخرى يرمي ببصره إلى التلفاز يخطف بعض النظرات. سُئلت عائشة أم المؤمنين رضي الله",
        "video_link": null
      },
      {
        "ts": "21:52",
        "sec": 1312,
        "text": "عنها عن الالتفات في صلاة سألـ عفواً سألت هي سألت رسول الله صلى الله عليه وسلم سألته عن الالتفات في الصلاة، فقال لها",
        "video_link": null
      },
      {
        "ts": "22:01",
        "sec": 1321,
        "text": "عليه الصلاة والسلام: \"هُوَ اخْتِلَاسٌ يَخْتَلِسُهُ الشَّيْطَانُ مِنْ صَلَاةِ الْعَبْدِ\" (هو",
        "video_link": null
      },
      {
        "ts": "22:08",
        "sec": 1328,
        "text": "اختلاس يختلسه الشيطان من الشيطان من صلاة العبد)؛ اختلاس، الاختلاس هو",
        "video_link": null
      },
      {
        "ts": "22:15",
        "sec": 1335,
        "text": "يعني الاختطاف بسرعة، هذا الاختلاس يختطف بسرعة الاختلاس فهو يختطف فالشيطان يختطف",
        "video_link": null
      },
      {
        "ts": "22:22",
        "sec": 1342,
        "text": "من الإنسان ا شيئاً من صلاته. ويقول صلى الله عليه وسلم: \"إِنَّ اللَّهَ يَنْصِبُ وَجْهَهُ",
        "video_link": null
      },
      {
        "ts": "22:29",
        "sec": 1349,
        "text": "لِوَجْهِ عَبْدِهِ فِي صَلَاتِهِ مَا لَمْ يَلْتَفِتْ\" (ما لم يلتفت)؛ فالإنسان يقبل على ربه عز وجل، فلِمَا",
        "video_link": null
      },
      {
        "ts": "22:36",
        "sec": 1356,
        "text": "يلتفت يلتفت؟ ما الهدف من هذا؟ فالإنسان لا يرفع بصره إلى السماء والسقف وإلى يمنة",
        "video_link": null
      },
      {
        "ts": "22:43",
        "sec": 1363,
        "text": "ويسرة، هذا من مكروهات الصلاة. \"وَعَبَثٌ وَالِالْتِفَاتُ وَالدُّعَاءْ\"؛ الدعاء",
        "video_link": null
      },
      {
        "ts": "22:52",
        "sec": 1372,
        "text": "قال: \"وَالدُّعَاءْ أَثْنَاءَ قِرَاءَةٍ\"؛ والدعاء (أي والدعاء، حُذفت الهمزة للوزن)؛ والدعاء أي",
        "video_link": null
      },
      {
        "ts": "23:00",
        "sec": 1380,
        "text": "والدعاء أثناء أي أثناء أي أثناء قراءة قراءة؛ أي الدعاء أثناء",
        "video_link": null
      },
      {
        "ts": "23:09",
        "sec": 1389,
        "text": "القراءة، الدعاء أثناء القراءة أثناء القراءة؛ هذا يكره أو يكره نعم هذا مكروه.",
        "video_link": null
      },
      {
        "ts": "23:19",
        "sec": 1399,
        "text": "لكن الواقع أن هذا يكره كُره أثناء الصلاة المفروضة، أثناء الصلاة المفروضة؛ كيف يكون",
        "video_link": null
      },
      {
        "ts": "23:27",
        "sec": 1407,
        "text": "هذا الدعاء؟ مثلاً إنسان يصلي صلاة العشاء",
        "video_link": null
      },
      {
        "ts": "23:33",
        "sec": 1413,
        "text": "مثلاً قرأ الفاتحة، طيب هو يقرا الفاتحة لو قال: {اهْدِنَا الصِّرَاطَ الْمُسْتَقِيمَ} ثم قال: \"اللهم",
        "video_link": null
      },
      {
        "ts": "23:42",
        "sec": 1422,
        "text": "اهدنا\" لا يكره هذا، لماذا؟ لأن الفاتحة لأن الفاتحة ركن، الفاتحة ركن فكيف تنشغل عن",
        "video_link": null
      },
      {
        "ts": "23:51",
        "sec": 1431,
        "text": "الركن بالدعاء الذي هو مستحب؟ الركن أهم.",
        "video_link": null
      },
      {
        "ts": "23:59",
        "sec": 1439,
        "text": "طيب أنهيت قراءة الفاتحة دخلت في السورة، تقرأ السورة وأثناءها دعوت الله عز",
        "video_link": null
      },
      {
        "ts": "24:08",
        "sec": 1448,
        "text": "وجل؛ السورة سنة مؤكدة، الدعاء مستحب، فكيف تترك السنة المؤكدة للمستحب؟ لذلك هاد",
        "video_link": null
      },
      {
        "ts": "24:17",
        "sec": 1457,
        "text": "القراءة هذه الكراهة تُقيد بالصلاة المفروضة؛ إذاً من مكروهات",
        "video_link": null
      },
      {
        "ts": "24:24",
        "sec": 1464,
        "text": "الصلاة: الدعاء أثناء القراءة في الصلاة",
        "video_link": null
      },
      {
        "ts": "24:31",
        "sec": 1471,
        "text": "المفروضة. أما الصلاة المستحبة فهذه أو عفواً أما الصلاة النافلة",
        "video_link": null
      },
      {
        "ts": "24:39",
        "sec": 1479,
        "text": "(يعني نعم المستحبة النافلة)، فهذه يُشرع الدعاء أو يستحب الدعاء أثناء القراءة",
        "video_link": null
      },
      {
        "ts": "24:45",
        "sec": 1485,
        "text": "فيها؛ ثبت ذلك عن رسول الله صلى الله عليه وسلم. مثلاً أنت تقرأ فـ قرأت آية مرت بآية",
        "video_link": null
      },
      {
        "ts": "24:56",
        "sec": 1496,
        "text": "آية نعيم: {إِنَّ الْمُتَّقِينَ فِي جَنَّاتٍ وَنَهَرٍ} فقلت: \"اللهم اجعلني من أهل الجنة\" مثلاً؛ قرأت قول الله",
        "video_link": null
      },
      {
        "ts": "25:05",
        "sec": 1505,
        "text": "تعالى: {وَرَحْمَتِي وَسِعَتْ كُلَّ شَيْءٍ} توقفت وقلت: \"اللهم اجعل اللهم اشملني بواسع رحمتك\" وأنت تصلي، هذا مشروع جائز؛ ثبت عنه صلى الله",
        "video_link": null
      },
      {
        "ts": "25:15",
        "sec": 1515,
        "text": "عليه وسلم أنه كان مر إذا مر بآية رحمة سأل، وإذا مر بآية عذاب استعاذ بالله منه؛",
        "video_link": null
      },
      {
        "ts": "25:21",
        "sec": 1521,
        "text": "أو ما وردت بآية عذاب: {إِنَّ الْمُجْرِمِينَ فِي عَذَابِ جَهَنَّمَ خَالِدُونَ} فتقول: \"اللهم إني أعوذ بك",
        "video_link": null
      },
      {
        "ts": "25:28",
        "sec": 1528,
        "text": "من نارك\"، هذا يجوز في النافلة يجوز؛ لكن في الصلاة المفروضة",
        "video_link": null
      },
      {
        "ts": "25:36",
        "sec": 1536,
        "text": "يكره. قال رحمه الله عليه: \"وَالدُّعَاءْ أَثْنَاءَ قِرَاءَةٍ كَذَا إِنْ",
        "video_link": null
      },
      {
        "ts": "25:44",
        "sec": 1544,
        "text": "رَكَعَا\"؛ إن ركعا أي الدعاء أثناء القراءة أثناء الركوع، الدعاء أثناء الركوع هذا كذلك يكره؛",
        "video_link": null
      },
      {
        "ts": "25:52",
        "sec": 1552,
        "text": "ا ليتقدم معنا قوله صلى الله عليه وسلم: \"أَمَّا الرُّكُوعُ فَعَظِّمُوا فِيهِ الرَّبَّ\" (أما الركوع فعظموا فيه",
        "video_link": null
      },
      {
        "ts": "26:01",
        "sec": 1561,
        "text": "الرب)؛ فالركوع ليس محلاً للدعاء إلا مثلاً بعض الأذكار التي وردت عن رسول الله صلى الله عليه وسلم فيها شيء من",
        "video_link": null
      },
      {
        "ts": "26:08",
        "sec": 1568,
        "text": "الدعاء؛ مثلاً: \"سُبْحَانَكَ اللَّهُمَّ رَبَّنَا وَبِحَمْدِكَ اللَّهُمَّ اغْفِرْ لِي\"، فـ من غير هذا أما غير هذا يدعو لا، الركوع",
        "video_link": null
      },
      {
        "ts": "26:16",
        "sec": 1576,
        "text": "ليس محلاً للدعاء وإنما هو في الدعاء يكون في السجود. ثم قال رحمه الله عليه: \"تَشْبِيكُ أَوْ",
        "video_link": null
      },
      {
        "ts": "26:25",
        "sec": 1585,
        "text": "فَرْقَعَةُ الْأَصَابِعِ\". المكروه الرابع عشر: تشبيك الأصابع هكذا في الصلاة؛ إنسان يصلي فيشبك أصابعه",
        "video_link": null
      },
      {
        "ts": "26:32",
        "sec": 1592,
        "text": "أحياناً مثلاً في وضع اليدين؛ قدما ذكرنا في في المجلس الماضي ذكرنا وضع اليمنى على",
        "video_link": null
      },
      {
        "ts": "26:40",
        "sec": 1600,
        "text": "اليسرى، قلنا الناظم رحمه الله مشى على منهاج على المشهور من المالكية أن",
        "video_link": null
      },
      {
        "ts": "26:47",
        "sec": 1607,
        "text": "المشهور هو الإرسال وهو السدل؛ قلنا الصواب أن المستحب هو وضع",
        "video_link": null
      },
      {
        "ts": "26:54",
        "sec": 1614,
        "text": "اليد على الصدر (اليمنى على اليسرى). بعض الناس يفعل هكذا يعمل هكذا يعني يضع ا أو",
        "video_link": null
      },
      {
        "ts": "27:02",
        "sec": 1622,
        "text": "يشبك بين أصابعه هكذا، لا؛ هذا مكروه. ا دليل",
        "video_link": null
      },
      {
        "ts": "27:10",
        "sec": 1630,
        "text": "كراهته قوله صلى الله عليه وسلم: \"إِذَا صَلَّى أَحَدُكُمْ فَلَا يُشَبِّكَنَّ بَيْنَ أَصَابِعِهِ، فَإِنَّ التَّشْبِيكَ",
        "video_link": null
      },
      {
        "ts": "27:17",
        "sec": 1637,
        "text": "مِنَ الشَّيْطَانِ\" (إذا صلى أحدكم فلا يشبكن بين",
        "video_link": null
      },
      {
        "ts": "27:24",
        "sec": 1644,
        "text": "أصابعه فإن التشبيك من الشيطان)؛ ليس لا يشبك بين أصابعه في الصلاة هكذا ورد؛ حتى في المسجد، حتى في المسجد ما يشبك الإنسان",
        "video_link": null
      },
      {
        "ts": "27:32",
        "sec": 1652,
        "text": "بين أصابعه، فلا تشبك بين أصابعك هكذا سواء في وضع اليد على الصدر أو نحو ذلك لا تشبك",
        "video_link": null
      },
      {
        "ts": "27:39",
        "sec": 1659,
        "text": "بين أصابعك. بالمناسبة أنا تذكرت الآن حتى مثلاً الوضع (بدأ استطراداً بس) الوضع اليمنى على اليسرى؛",
        "video_link": null
      },
      {
        "ts": "27:46",
        "sec": 1666,
        "text": "بعض الناس يعمل هكذا لا هذا فيمسك العضد لا هذا غير مشروع، وبعضهم ربما يعمل هكذا",
        "video_link": null
      },
      {
        "ts": "27:53",
        "sec": 1673,
        "text": "لا، وإنما تضع اليمنى على اليسرى هكذا، وربما يقبض الإنسان؛ هذا حق رجوع إلى ما كان ينبغي الإشارة إليه في المجلس الماضي،",
        "video_link": null
      },
      {
        "ts": "28:02",
        "sec": 1682,
        "text": "وأما تمسك هذا يُسمى القبض؛ هذا يُسمى القبض، أنك تقبض على الساعد هذا القبض، والوضع",
        "video_link": null
      },
      {
        "ts": "28:09",
        "sec": 1689,
        "text": "هكذا تضع اليمنى على اليسرى هكذا. طيب فالتشبيك مكروه؛ قال: \"تَشْبِيكُ",
        "video_link": null
      },
      {
        "ts": "28:16",
        "sec": 1696,
        "text": "أَوْ فَرْقَعَةُ الْأَصَابِعِ\". الإنسان يصلي ويفرقع أصابعه فهذا ينافي الصلاة وينافي",
        "video_link": null
      },
      {
        "ts": "28:24",
        "sec": 1704,
        "text": "الخشوع المنبغي، فهذا وذاك ابن عباس رضي الله عنه رأى مولاه شعبة يفرقع أصابعه في الصلاة",
        "video_link": null
      },
      {
        "ts": "28:34",
        "sec": 1714,
        "text": "فزجره قال: \"لا أُمَّ لَكَ! تُفَرْقِعُ أَصَابِعَكَ وَأَنْتَ فِي الصَّلَاةِ\"؟! يعني ما هذا العمل؟ هذا لا يقبل ولا يليق. ثم قال:",
        "video_link": null
      },
      {
        "ts": "28:44",
        "sec": 1724,
        "text": "\"تَخَصُّرٌ\"؛ المكروه أظن الخامس عشر أو السادس عشر: التخصر، التخصر وضع اليد على الخاصرة؛ الخاصرة هي",
        "video_link": null
      },
      {
        "ts": "28:52",
        "sec": 1732,
        "text": "هذه جنب الإنسان فهو إنسان يصلي ويضع، إذا صلى الإنسان ووضع يده هكذا على الخاصرة هذا مكروه؛",
        "video_link": null
      },
      {
        "ts": "29:00",
        "sec": 1740,
        "text": "ينافي مقام الأدب مع الله عز وجل، وإنسان واقف بين يدي مولاه سبحانه وتعالى لا يليق",
        "video_link": null
      },
      {
        "ts": "29:07",
        "sec": 1747,
        "text": "به هذا، فلا تضع يديك هكذا؛ فالتخصر هذا منهي عنه. ا يقول أبو هريرة رضي الله عنه",
        "video_link": null
      },
      {
        "ts": "29:16",
        "sec": 1756,
        "text": "كما في صحيح البخاري: \"نُهِيَ أَنْ يُصَلِّيَ الرَّجُلُ مُتَخَصِّراً\" (نهي أن يصلي الرجل متخصراً)؛",
        "video_link": null
      },
      {
        "ts": "29:26",
        "sec": 1766,
        "text": "أي يضع يديه على خاصرته. ثم المكروه الأخير الذي ذكره الناظم",
        "video_link": null
      },
      {
        "ts": "29:33",
        "sec": 1773,
        "text": "رحمه الله: \"تَغْمِيضُ عَيْنٍ تَابِعِ\"؛ تغميض عين، تابع تغميض العين في الصلاة يغمض عينيه هكذا، لا؛ هذا",
        "video_link": null
      },
      {
        "ts": "29:41",
        "sec": 1781,
        "text": "يكره أن يـ أن يغمض الإنسان عينيه في الصلاة، لا داعي لإغماض العينين. ا البعض",
        "video_link": null
      },
      {
        "ts": "29:47",
        "sec": 1787,
        "text": "يقول: \"طيب أنا أريد أن أغمض عيني حتى أجلب الخشوع\"، لا؛ خير الهدي هدي محمد صلى الله",
        "video_link": null
      },
      {
        "ts": "29:54",
        "sec": 1794,
        "text": "عليه وسلم، الحبيب صلى الله عليه وسلم ما كان يغمض عينيه في الصلاة وهو سيد الخاشعين، تدريب تتدرب على هذا فلذلك لا.",
        "video_link": null
      },
      {
        "ts": "30:03",
        "sec": 1803,
        "text": "وقال بعض العلماء إن لأن تغميض العين حركة زائدة في الصلاة غير مشروعة، حركة زائدة بالعين وهي غير مشروعة فلا داعي",
        "video_link": null
      },
      {
        "ts": "30:12",
        "sec": 1812,
        "text": "لإغماض العينين؛ إلا لو افترضنا إن كان يعني إنسان وجد نفسه يصلي على ثوب كثير",
        "video_link": null
      },
      {
        "ts": "30:19",
        "sec": 1819,
        "text": "الزخرفة فشغله جداً ما ممكن، لكن الإنسان يغمض عينيه دائماً في الصلاة لا؛ هذا من",
        "video_link": null
      },
      {
        "ts": "30:26",
        "sec": 1826,
        "text": "مكروهات الصلاة، والله تعالى أعلى وأعلم. هذا الحديث هذا نهاية الحديث عن مكروهات الصلاة، وإلى",
        "video_link": null
      },
      {
        "ts": "30:35",
        "sec": 1835,
        "text": "المجلس المقبل إن شاء الله تعالى؛ سبحانك اللهم وبحمدك أشهد أن لا إله إلا أنت أستغفرك وأتوب إليك، وصلى الله وسلم وبارك",
        "video_link": null
      },
      {
        "ts": "30:42",
        "sec": 1842,
        "text": "على سيدنا محمد وعلى آله، والحمد لله رب العالمين. السلام عليكم ورحمة الله وبركاته.",
        "video_link": null
      }
    ]
  },
  {
    "subject": "fiqh",
    "subjectLabel": "الفقه الإسلامي",
    "lesson": "الدرس 20",
    "lessonNum": 20,
    "title": "الدرس 20",
    "summary": "📚 <b>الملخص الشامل للدرس: أنواع الصلوات وأحكام الجنازة</b>\n\n🔹 <b>الخلاصة المحورية للدرس:</b>\n<blockquote>يتناول هذا الدرس شرحاً لمنظومة \"ابن عاشر\" فيما يتعلق بأنواع الصلوات، مبيناً تقسيمها إلى صلوات مفروضة (عين وكفاية) وصلوات مسنونة، مع تفصيل أحكام صلاة الجنازة وتوابعها، والتطرق لأحكام صلاة الوتر والكسوف بأسلوب فقهي مؤصل.</blockquote>\n\n🔹 <b>الأحداث والوقائع / القواعد والمسائل بالتفصيل:</b>\n\n<blockquote>\n• <b>تقسيم الصلوات:</b> تنقسم الصلاة إلى فرض (عيني وهو الصلوات الخمس، وكفائي كصلاة الجنازة) ونفل (سنة، رغيبة، ونافلة مطلقة).\n• <b>فرضية الصلوات الخمس:</b> تجب على كل مكلف ومكلفة، ودليلها من السنة حديث الأعرابي الذي سأل النبي ﷺ عن الإسلام، وقصة فرضها ليلة الإسراء والمعراج.\n• <b>صلاة الجنازة:</b> هي فرض كفاية (إذا قام بها البعض سقطت عن الباقين)، ولا يصلى على الكافر، أما شهيد المعركة فلا يصلى عليه إلا استحباباً.\n• <b>فرائض صلاة الجنازة:</b> أربعة: <b>التكبير</b> (أربع تكبيرات)، <b>الدعاء</b> للميت (وهو المقصود الأعظم)، <b>النية</b>، و<b>السلام</b> (تسليمة واحدة سراً عند المالكية).\n• <b>مستحبات الجنازة:</b> قراءة الفاتحة بعد التكبيرة الأولى، والصلاة على النبي ﷺ بعد الثانية، والدعاء بعد الثالثة والرابعة.\n• <b>توابع الجنازة:</b> الغسل (كغسل الجنابة)، التكفين (ثلاثة أثواب للرجل)، والدفن؛ كلها فروض كفاية وتجب للميت المسلم.\n• <b>صلاة الوتر:</b> سنة مؤكدة، وقتها من بعد صلاة العشاء إلى طلوع الفجر، وحكمها \"صلاة الليل مثنى مثنى، ثم ركعة توتر له ما قد صلى\".\n• <b>صلاة الكسوف:</b> سنة مؤكدة، تصلى عند رؤية كسوف الشمس (أو خسوف القمر)، وهي ركعتان في كل ركعة ركوعان وقراءتان.\n</blockquote>\n\n🔹 <b>الأسماء والمصطلحات الرئيسية:</b>\n\n<blockquote>\n• <b>الإمام عبد الواحد بن عاشر:</b> صاحب المنظومة الفقهية التي يُشرح منها الدرس.\n• <b>النجاشي:</b> الصحابي الذي صلى عليه النبي ﷺ صلاة الغائب، وهو دليل على مشروعية صلاة الجنازة.\n• <b>الفرض العيني:</b> ما يُطلب من كل مكلف بعينه ولا ينوب فيه أحد عن أحد.\n• <b>الفرض الكفائي:</b> ما يُطلب حصوله من الأمة، فإذا قام به البعض سقط عن الباقين.\n• <b>المرفوع حكماً:</b> قول الصحابي \"من السنة كذا\" أو \"أمرنا\"، وهو في حكم كلام النبي ﷺ.\n</blockquote>\n\n🔹 <b>العِبر والأحكام المستفادة:</b>\n\n<blockquote>\n• وجوب إخلاص الدعاء للميت، فكما ندعو لغيرنا اليوم، سيأتي من يدعو لنا غداً.\n• الحرص على أدب الدعاء بتقديم الثناء على الله (الفاتحة) والصلاة على النبي ﷺ.\n• أن الكسوف آية من آيات الله تذكير بقدرته، وليست مرتبطة بموت أحد أو حياته.\n• أهمية ستر الميت وتكريمه بالغسل والتكفين والدفن.\n</blockquote>\n\n🔹 <b>سؤال تدبر ومراجعة ذاتية:</b>\n\n<blockquote>بناءً على ما ذكره الشيخ حول \"فرض الكفاية\" في صلاة الجنازة وتوابعها، لماذا اعتبر الإسلام صلاة الجنازة وتغسيل الميت والدفن من فروض الكفاية وليس من فروض العين؟ وما هي الحكمة من وراء ذلك في ترابط المجتمع المسلم؟</blockquote>",
    "full_text": "بسم الله الرحمن الرحيم، الحمد لله رب العالمين، والصلاة والسلام الأتمان الأكملان على سيدنا محمد الصادق الأمين، وعلى آله وصحبه أجمعين. أما بعد، السلام عليكم ورحمة الله وبركاته. وصلنا إلى قول المصنف الإمام عبد الواحد بن عاشر رحمه الله تعالى، أنواع الصلوات؛ قال رحمه الله: فَصْلٌ وَخَمْسُ صَلَوَاتٍ فَرْضُ عَيْنْ *** وَهْيَ كِفَايَةٌ لِمَيْتٍ دُونَ مَيْنْ فَرْضُهَا التَّكْبِيرُ أَرْبَعاً دُعَاءْ *** وَنِيَّةٌ سَلَامٌ سِرٍّ تَابَعَا انتقل بنا الناظم رحمه الله تعالى إلى الحديث عن أنواع الصلوات. أنواع الصلوات؛ الصلوات يمكن تقسيمها أو هي تقسم إلى فرض ونفل؛ هناك صلوات مفروضة وصلوات نافلة غير مفروضة. يقول ربنا تبارك وتعالى في الحديث القدسي: \"وَمَا تَقَرَّبَ إِلَيَّ عَبْدِي بِشَيْءٍ أَحَبَّ إِلَيَّ مِمَّا افْتَرَضْتُهُ عَلَيْهِ، وَمَا يَزَالُ عَبْدِي يَتَقَرَّبُ إِلَيَّ بِالنَّوَافِلِ حَتَّى أُحِبَّهُ\"؛ هناك الفرض وهناك النفل. طيب الصلوات المفروضة تنقسم أيضاً إلى قسمين: صلوات مفروضة فرضاً عينياً، وصلوات مفروضة فرضاً كفائياً؛ هناك فرض فرض عين، هناك فرض كفاية. وسبق لنا في المقدمة الأصولية شرح هذه المصطلحات؛ فرض العين هو الذي يُطلب من كل مكلف بعينه، لا ينوب فيه أحد عن أحد. أما فرض الكفاية هو فرض يُطلب حصوله بغض النظر عن مَن قام به، فإذا إذا قام به البعض يكفي وتسقط المطالبة به عن الباقين. إذاً الصلوات المفروضة قسمان: فرض عين وفرض كفاية؛ مثال فرض الكفاية مما سيذكره: صلاة الجنازة، والفرض العين: الصلوات الخمس. النفل يقسّمه المالكية إلى أقسام؛ الآن نتحدث عن النفل بصفة عامة، النفل الذي هو في مقابل الفرض؛ هناك منه ما هو سنة، ومنه ما يسمونه رغيبة، ومنه ما يُسمى النافلة؛ في هذا الإطار ديال النفل هناك السنة مثل صلاة الكسوف مثلاً، هناك الرغيبة، هناك النافلة المطلقة؛ هذه أنواع سيذكرها الناظم رحمه الله تعالى. فبدأ فقال: \"فَصْلٌ وَخَمْسُ صَلَوَاتٍ فَرْضُ عَيْنْ\"؛ وخمس صلوات فرض عين. الصلوات الصلوات المفروضة فرضاً عينياً -بمعنى أنها تجب على كل مسلم بعينه، وعلى كل مسلمة بعينها- هي خمس صلوات؛ هي الصلوات المعروفة: صلاة الصبح، والظهر، والعصر، والمغرب، والعشاء؛ خمس صلوات. دليلها الكتاب والسنة والإجماع؛ مما يدل عليها أنه لما جاء أعرابي (أو تحديداً السنة والإجماع، الكتاب بالإشارة)؛ مما يدل عليها من السنة حديث الأعرابي الذي جاء إلى رسول الله صلى الله عليه وسلم يسأله عن الإسلام، فقال له صلى الله عليه وسلم: \"خَمْسُ صَلَوَاتٍ فِي الْيَوْمِ وَاللَّيْلَةِ\" (خمس صلوات في اليوم والليلة)؛ قال الرجل: \"هل عليَّ غيرها؟\" قال صلى الله عليه وسلم: \"لَا، إِلَّا أَنْ تَطَّوَّعَ\" (أي إلا إذا أردت أن تتطوع)؛ ففهم منها أو فأُخذ من هذا الحديث بصريح اللفظ النبوي أن الصلوات المفروضة خمس. وكذلك تعلمون قصة فرض الصلاة ليلة الإسراء والمعراج، حيث فُرضت الصلاة أولاً خمسين، وأشار كليم الله موسى عليه السلام أشار على الحبيب صلى الله عليه وسلم أن يراجع ربه جل جلاله وهو الكريم سبحانه أن يراجعه في هذه المسألة، فبقي ربنا عز وجل يضع بعض الصلوات عن أمة الإسلام حتى بقيت خمس صلوات؛ \"فَصْلٌ وَخَمْسُ صَلَوَاتٍ فَرْضُ عَيْنْ\". ثم قال: \"وَهْيَ كِفَايَةٌ لِمَيْتٍ دُونَ مَيْنْ\"؛ وهي (أي الصلوات) كفاية (أي فرض كفاية) لِميت؛ أي لِميت دون مين (أي دون شك)؛ أي أن الصلاة على الجنازة فرض كفاية. المسلم إذا مات، المسلم -الكافر لا يُصلى عليه- المسلم إذا مات تجب الصلاة عليه، الصلاة على الميت المسلم فريضة؛ هل هي فريضة عينية؟ لا، هي فريضة كفائية؛ إذا قام بها بعض المسلمين سقطت المطالبة بها عن الباقين. فالمسلم تجب الصلاة عليه إلا ما كان من الشهيد؛ شهيد المعركة فهذا لا يُصلى عليه إلا استحباباً. قال: \"وَهْيَ كِفَايَةٌ لِمَيْتٍ دُونَ مَيْنْ\". لما مات النجاشي، قال النبي صلى الله عليه وسلم: \"إِنَّ أَخاً لَكُمْ قَدْ مَاتَ، فَقُومُوا فَصَلُّوا عَلَيْهِ\"؛ فصلى عليه النبي صلى الله عليه وسلم والصحابة الكرام رضوان الله عليهم. وصلاته صلى الله عليه وسلم لعدد من الجنائز هذا مشهور مستفيض متواتر؛ فالصلاة على الجنازة فريضة كفائية. لما ذكر رحمه الله صلاة الجنازة استطرد ليتحدث عن بعض ما يتعلق بها، ما يتعلق بالجنازة، فذكر فروضها؛ أي فروض صلاة الجنازة. ما هي فرائض صلاة الجنازة التي لا تصح صلاة الجنازة إلا بها؟ قال رحمه الله: \"فَرْضُهَا التَّكْبِيرُ أَرْبَعاً\"؛ التكبير أربعاً؛ أي أن يكبر المصلي على الجنازة أربع تكبيرات. أبو هريرة رضي الله عنه لما ذكر الحديث حديث صلاة النبي صلى الله عليه وسلم على النجاشي، قال: \"فَصَفَّ بِهِمْ فَكَبَّرَ أَرْبَعاً\" (كبر أربعاً). صلاة الجنازة -كما لا يخفى عليكم إن شاء الله- صلاة الجنازة ليس فيها ركوع وليس فيها سجود؛ يكبر المصلي على الجنازة أربع تكبيرات، كما دل على ذلك حديث أبي هريرة رضي الله عنه آنفاً قال: \"فصفَّ بهم وكبَّر أربع تكبيرات\". ماذا يقول بين التكبيرات؟ قال الناظم رحمه الله تعالى: \"فَرْضُهَا التَّكْبِيرُ أَرْبَعاً دُعَاءْ *** وَنِيَّةٌ سَلَامٌ سِرِّ تَابَعَا\"؛ الناظم رحمه الله ذكر أن فرائض صلاة صلاة الجنازة أربعة: التكبير ويكون أربعاً، الدعاء، والنية، والسلام. الدعاء؛ يُدعى للميت، يُدعى للميت، وأصل هذا المقصد الأهم من الصلاة على الجنازة: الدعاء للميت؛ كان الذين يصلون على الميت يتوجهون إلى الله عز وجل أن يرحم هذا الميت الذي بين أيديهم، وسيورونه في التراب بعد قليل، كأنهم يشفعون له عند ربه فيسألون ربهم أن يغفر له. من الأدعية التي استحبها المالكية ما رواه مالك رحمه الله في الموطأ عن أبي هريرة رضي الله عنه، وفيه: \"اللَّهُمَّ إِنَّهُ عَبْدُكَ وَابْنُ عَبْدِكَ وَابْنُ أَمَتِكَ، كَانَ يَشْهَدُ أَنْ لَا إِلَهَ إِلَّا اللَّهُ وَأَنَّ مُحَمَّداً عَبْدُكَ وَرَسُولُكَ وَأَنْتَ أَعْلَمُ بِهِ، اللَّهُمَّ إِنْ كَانَ مُحْسِناً فَزِدْ فِي إِحْسَانِهِ، وَإِنْ كَانَ مُسِيئاً فَتَجَاوَزْ عَنْ سَيِّئَاتِهِ، اللَّهُمَّ اغْفِرْ لَنَا وَلَهُ، وَلَا تَفْتِنَّا بَعْدَهُ وَلَا تَحْرِمْنَا أَجْرَهُ، اللَّهُمَّ مَنْ أَحْيَيْتَهُ مِنَّا فَأَحْيِهِ عَلَى الْإِيمَانِ، وَمَنْ تَوَفَّيْتَهُ مِنَّا فَتَوَفَّهُ عَلَى الْإِسْلَامِ\"؛ فيستحبون هذا الدعاء. وأي دعاء مطلق الدعاء للميت مشروع؛ ومما ثبت عن النبي صلى الله عليه وسلم في ذلك أنه صلى على ميت فدعا له، فقال: \"اللَّهُمَّ اغْفِرْ لَهُ وَارْحَمْهُ، وَعَافِهِ وَاعْفُ عَنْهُ، وَأَكْرِمْ نُزُلَهُ، وَوَسِّعْ مُدْخَلَهُ، وَاغْسِلْهُ بِالْمَاءِ وَالثَّلْجِ وَالْبَرَدِ، وَنَقِّهِ مِنَ الْخَطَايَا كَمَا نَقَّيْتَ الثَّوْبَ الْأَبْيَضَ مِنَ الدَّنَسِ، وَأَبْدِلْهُ دَاراً خَيْراً مِنْ دَارِهِ، وَأَهْلاً خَيْراً مِنْ أَهْلِهِ، وَزَوْجاً خَيْراً مِنْ زَوْجِهِ، وَأَدْخِلْهُ الْجَنَّةَ، وَأَعِذْهُ مِنْ عَذَابِ الْقَبْرِ...\" وغيرها من الأدعية التي وردت بعض الأدعية عن رسول الله صلى الله عليه وسلم، والإنسان يدعو. المهم أن يخلص الإنسان الدعاء للميت؛ قال صلى الله عليه وسلم كما في سنن أبي داوود من حديث أبي هريرة رضي الله عنه: \"إِذَا صَلَّيْتُمْ عَلَى الْمَيِّتِ فَأَخْلِصُوا لَهُ الدُّعَاءَ\" (إذا صليتم على الميت فأخلصوا له الدعاء). الإنسان يدعو للميت بقلب خالص، لأن الإنسان اليوم نحن نصلي على ميت وغداً سيُصلى علينا؛ فنصلي على الميت ونخلص الدعاء، لعل ربنا تعالى أن ييسر لنا مَن إذا صلى علينا يخلص لنا الدعاء؛ فلعله يصلي علينا رجل صالح يخلص الدعاء فيستجيب الله عز وجل له فيرحمنا سبحانه. نسأل الله تعالى رحمته، وكرمه، وحلمه، ومغفرته، وعفوه. قال: \"فَرْضُهَا\"؛ إذاً ذكر الناظم رحمه الله، قال: \"فَرْضُهَا التَّكْبِيرُ أَرْبَعاً دُعَاءْ\"، ثم قال: \"وَنِيَّةٌ\". النية؛ النية هذه خلاص، يقول النبي صلى الله عليه وسلم: \"إِنَّمَا الْأَعْمَالُ بِالنِّيَّاتِ\"؛ ينوي أنه يصلي صلاة الجنازة. \"سَلَامٌ سِرٍّ تَبَعَا\"؛ الفرض الرابع من فرائض صلاة الجنازة: السلام؛ لأن كل صلاة كما مر معنا غير مرة: \"الصَّلَاةُ الطُّهُورُ، وَتَحْرِيمُهَا التَّكْبِيرُ، وَتَحْلِيلُهَا التَّسْلِيمُ\"؛ فيدخل في الصلاة بالتكبير ويخرج بالتسليم. قال الناظم رحمه الله: \"سَلَامٌ سِرٍّ\" أي يُستحب الإسرار بالسلام، يستحب؛ اختار المالكية رحمهم الله تعالى في المشهور عندهم أن المصلي على الجنازة يسلم تسليمة واحدة ويسر بها؛ الإمام يُسمع يسر فيسمع الإمام مَن يليه، وهكذا حتى يسلم الجميع. فقال لذلك قال: \"سَلَامٌ سِرٍّ تَبَعَا\". انتبه هذه الهيئة هيئة الصلاة هذه التي ذكرها الناظم معناها أن الإنسان يكبر \"الله أكبر\" ويدعو للميت التكبيرة الأولى، ثم يقول \"الله أكبر\" يكبر التكبيرة الثانية ويدعو للميت، ثم يكبر التكبيرة الثالثة ويدعو للميت، ثم يكبر التكبيرة الرابعة ثم يسلم. ا الواقع أن في صفة صلاة الجنازة المنقولة عن رسول الله صلى الله عليه وسلم، نُقل شيء لم يشر إليه الناظم رحمه الله ولم لم يختاروه المالكية، وهو قراءه الفاتحة؛ قراءة الفاتحة. المالكية رحمه الله عليهم لم يروا قراءة الفاتحة في صلاة الجنازة، وقالوا إن صلاة الجنازة كلها دعاء. والواقع أن قراءة الفاتحة في صلاة الجنازة ثابتة عن رسول الله صلى الله عليه؛ ثبتت في صحيح البخاري، ففي صحيح البخاري أن عبد الله بن عباس رضي الله عنهما صلى صلاة الجنازة فقرأ الفاتحة وجهر بها، فلما سلّم سُئل عن ذلك لِمَ قرأت الفاتحة؟ فقال رضي الله عنه وأرضاه: \"لِتَعْلَمُوا أَنَّهَا سُنَّةٌ\". \"لِتَعْلَمُوا أَنَّهَا سُنَّةٌ\"؛ قوله تعلموا أنها سنة، يقصد سنة مَن؟ يقصد سنة النبى صلى الله عليه وسلم؛ الصحابي إذا قال \"من السنة كذا\" فهو يقصد سنة الرسول صلى الله عليه. الحافظ زين الدين العراقي في ألفيته في الحديث يقول: قَوْلُ الصَّحَابِيِّ مِنَ السُّنَّةِ أَوْ *** نَحْوُ أُمِرْنَا حُكْمُهُ الرَّفْعُ وَلَوْ بَعْدَ النَّبِيِّ قَالَهُ بِأَعْصُرِ *** إلى آخر الحديث. قال رحمه الله عليه الحافظ العراقي: قول الصحابي من السنة أو نحو \"أُمِرنا\"، هذا له حكم الرفع. ولعلكم درستم في مصطلح الحديث \"البيقونية\" أن المرفوع هو ما نُسب إلى النبي صلى الله عليه وسلم؛ يقول البيقوني رحمه الله عليه: \"وَمَا أُضِيفَ لِلنَّبِيِّ الْمَرْفُوعُ\"؛ أو ما أدري المهم... ما أضيف للرسول في المصطلح المهم أنه المرفوع هو ما نُسب إلى النبي صلى الله عليه وسلم. والمرفوع قسمان: مرفوع صريح ومرفوع حكمي؛ هناك ما رُفع إلى رسول الله صلى الله عليه وسلم صريحاً وهناك ما رُفع حكماً. المرفوع الصريح هو أنك تجد: \"قال رسول الله صلى الله عليه وسلم\"، \"فعل رسول الله صلى الله عليه وسلم\" هذا مرفوع صريح. المرفوع حكماً هو من من هذا القبيل، منه ما ذكرنا من هذا القبيل: \"من السنة كذا\"، \"أُمِرنا\"، \"كانوا يؤمرون\"؛ كما رأينا في في أظن في المجلس قبل الماضي حديث أنس: \"كانوا يؤمرون أن يضع الرجل يده اليمنى على اليسرى في الصلاة\"؛ كانوا يؤمرون، مَن الذي كان يأمرهم؟ الرسول صلى الله عليه وسلم. مَن هم الذين كانوا يؤمرون؟ الصحابة؛ ده صحابي يتحدث عن أصحاب رسول الله صلى الله عليه وسلم، يبعد أن يتحدث عن التابعين ويتحدث عن الصحابة كانوا يؤمرون. فلذلك هنا فقول عمر قول عبد الله بن عباس رضي الله عنهما: \"لتعلموا أنها سنة\"، فإنما يقصد سنة رسول الله صلى الله عليه وسلم؛ فلذلك تشرع قراءة الفاتحة بعد التكبيرة الأولى. ففي صلاة الجنازة تقول \"الله أكبر\" ثم تقرأ الفاتحة، تقرأ الفاتحة. بعد التكبيرة الثانية أيضاً ثبت عن رسول الله صلى الله عليه وسلم الصلاة على رسول الله صلى الله عليه وسلم في صلاة الجنازة، وإن كان المالكية لم يختاروا هذه أيضاً؛ لكن ثبت أظن كـ في سنن أبي داوود وغيره الصلاة على رسول الله صلى الله عليه وسلم، فلذلك يستحب أن الإنسان يقرأ الفاتحة بعد التكبيرة الأولى، ثم يصلي على رسول الله صلى الله عليه وسلم بعد التكبيرة بعد التكبيرة الثانية، وبعد التكبيرة الثالثة والرابعة يدعو للميت، يدعو للميت ولعموم المسلمين. وفي الواقع هذا هذا هذا من أدب الدعاء أصلاً؛ الفاتحة فيها ثناء على الله تعالى وتمجيد له، ومن آداب الدعاء تقديم الثناء والتمجيد بين يدي ربنا جل جلاله؛ هذا من آداب الدعاء، ومن أدب الدعاء أن نقدم بالصلاة على رسول الله صلى الله عليه وسلم كما ورد من أدب في أدب الدعاء هذا. طيب. إذاً هذه فرائض صلاة الجنازة؛ قال رحمه الله: \"فَرْضُهَا التَّكْبِيرُ أَرْبَعاً دُعَاءْ *** وَنِيَّةٌ سَلَامٌ سِرٍّ تَبَعَا\". استطراد الناظم أيضاً استطراد، ما دام ذكر صلاة الجنازة فهو استطراد فقال: وَكَالصَّلَاةِ الْغُسْلُ دَفْنٌ وَكَفَنْ *** \"وَكَالصَّلَاةِ الْغُسْلُ دَفْنٌ وَكَفَنْ\"؛ كـ الصلاة الكاف كاف التشبيه، كالصلاة الغسل؛ الغسل يشبه الصلاة في ماذا؟ في الفرضية؛ يقصد الناظم رحمه الله تعالى أن غسل الميت أو أن تغسيل الميت المسلم فرض أيضاً واجب، وهو أيضاً فرض كفاية؛ لا يجوز أن يُدفن المسلم دون غسل إلا ما كان من الشهيد؛ الشهيد لا يُغسل. في زمن رسول الله صلى الله عليه وسلم رجل وقصته ناقة، كان واقفاً بعرفة فوقصته ناقته فمات؛ فقال صلى الله عليه وسلم: \"اغْسِلُوهُ بِمَاءٍ وَسِدْرٍ، وَكَفِّنُوهُ فِي ثَوْبَيْهِ\"؛ فقال اغسلوه، اغسلوه فعل أمر، والأمر يفيد الوجوب كما رأيتم في الأصول؛ فيُؤمر فالمسلمون مأمرون بتغسيل الميت المسلم. لما ماتت زينب بنت رسول الله صلى الله عليه وسلم، قال صلى الله عليه وسلم للنساء: \"اغْسِلْنَهَا ثَلَاثاً أَوْ خَمْساً أَوْ أَكْثَرَ مِنْ ذَلِكَ إِنْ رَأَيْتُنَّ ذَلِكَ بِمَاءٍ وَسِدْرٍ\"؛ فقال اغسلنها، فتغسيل الميت واجب. تغسيل الميت بالمناسبة، تغسيل الميت غسل الميت هو كغسل الجنابة، غسل الميت هو كغسل الجنابة؛ يُغسل الميت يُعصر بطنه عصراً رفيقاً، ثم يُغسل فرجه وما حوله من الأذى بعد أن يضع الغاسل يلف على يده على يده خرقة حتى يغسله يغسله بها باب الاستنجاء تنقية، ثم يوضئه الوضوء الأصغر للصلاة؛ يعني يبلل إصبعه أو قطنة ونحو ذلك فيمرها على أسنانه محل المضمضة، وكذلك أنفه محل الاستنشاق، بعد أن يكون قد غسل يديه ثم يغسل وجهه ويديه اليمنى ثم اليسرى للمرفق، ثم قدميه، ثم يغسل سائر الجسد؛ يبدأ بالشق الأيمن، طبعاً بعد ثم يغسل الرأس قبل ذلك، يغسل رأسه ثم يفيض الماء عليه؛ يغسل الشق الأيمن ثم الشق الأيسر كغـ كالغسل من الجنابة. ويستحب أن يكون تكون عدد الغسلات ثلاثاً ثلاثاً أي أو خمساً أو سبعاً أو أكثر؛ كما قال صلى الله عليه وسلم للنساء اللواتي كن يغسلن زينب رضي الله عنها: \"اغْسِلْنَهَا ثَلَاثاً أَوْ خَمْساً أَوْ أَكْثَرَ مِنْ ذَلِكَ إِنْ رَأَيْتُنَّ ذَلِكَ بِمَاءٍ وَسِدْرٍ\"؛ يعني إذا كانت الحاجة تدعو إلى تكرار عدد الغسلات أكثر من ثلاث. هذا باختصار شديد، الوقت لا يكفي للتوسع في قضية تغسيل الميت. قال رحمه الله تعالى: \"وَكَالصَّلَاةِ الْغُسْلُ\" \"دَفْنٌ\"؛ الدفن أيضاً الدفن أيضاً كالغسل في ماذا؟ في في الفرضية، فيجب دفن الميت المسلم؛ بل الواقع الدفن هذا الجاري به العمل عند البشر عند البشر كلهم، وقد امتن الله تعالى على الإنسان بمسألة الدفن؛ قال تعالى: {ثُمَّ أَمَاتَهُ فَأَقْبَرَهُ}؛ فلو لم يُدفن الإنسان لبقي فوق على ظهر الأرض جيفة تستقذر، وربما تتـ ـتناولها الكلاب والسباع والهوام والطيور؛ وفي هذا من التنقيص من كرامة الإنسان ما فيه، الحمد لله على ستره. قال: \"وَكَالصَّلَاةِ الْغُسْلُ دَفْنٌ وَكَفَنْ\"؛ أيضاً التكفين أيضاً هذا واجب، التكفين واجب؛ \"وَكَالصَّلَاةِ الْغُسْلُ دَفْنٌ وَكَفَنْ\". ذاك الذي وقصته ناقته، قال صلى الله عليه وسلم: \"وَكَفِّنُوهُ فِي ثَوْبَيْهِ\"؛ فيُكفن. وكُفن رسول الله صلى الله عليه وسلم في ثلاث؛ كما تقول أم المؤمنين عائشة رضي الله عنها: \"كُفِّنَ رَسُولُ اللَّهِ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ فِي ثَلَاثَةِ أَثْوَابٍ بِيضٍ سَحُولِيَّةٍ لَيْسَ فِيهَا قَمِيصٌ وَلَا عِمَامَةٌ\"؛ فيُكفن الرجل في ثلاثة أثواب؛ يوضع الثوب الأول ثم الثوب الثاني ثم الثوب الثالث ويدرج في الكفن درجاً. والمرأة مثل الرجل، وبعض العلماء استحبوا للمرأة أن يُزاد الخمار والدرع زيادة في الستر؛ يعني المهم هو لف الميت وستره بثوب قبل دفنه. قال: \"وَكَالصَّلَاةِ الْغُسْلُ دَفْنٌ وَكَفَنْ\". ثم قال الناظم رحمه الله: وِتْرٌ كُسُوفٌ عِيدٌ اسْتِسْقَا سُنَنْ *** كأنه يقول لك: \"أنا أنهيت الآن أنهيت لك حديثي عن الصلوات المفروضة؛ المفروضة فرضاً عينياً والمفروضة فرضاً كفائياً، الآن تعال لأحدثك عن الصلوات المسنونة وهي في الواقع السنة المؤكدة\"؛ قال: \"وِتْرٌ كُسُوفٌ عِيدٌ اسْتِسْقَا سُنَنْ\". صلاة الوتر، صلاة الكسوف، صلاة العيد، صلاة الاستسقاء. بالنسبة لـ الوتر، الوتر هذه؛ الوتر هو الوتر ضد الشفع، والعدد الفردي إن صح التعبير؛ العدد العدد الفردي يُسمى وتراً، كاين عدد فردي وعدد زوجي فالفردي يُسمى وتراً. شرع ربنا عز وجل لعباده أن يختموا صلاة يومهم وليلتهم بالوتر، بالوتر؛ وهذا الوتر سنة مؤكدة، أكد عليها النبي صلى الله عليه وسلم بفعله وبقوله وحث عليها وحض عليها؛ قال صلى الله عليه وسلم: \"صَلَاةُ اللَّيْلِ مَثْنَى مَثْنَى، فَإِذَا خَشِيَ أَحَدُكُمُ الصُّبْحَ صَلَّى رَكْعَةً وَاحِدَةً تُوتِرُ لَهُ مَا قَدْ صَلَّى\" (توتر له ما قد صلى)؛ مثلاً صليت ثمان ركعات تصلي ركعة واحدة فتوتر لك ما صليت فتصبح تسع ركعات. ونبينا صلى الله عليه وسلم يقول: \"إِنَّ اللَّهَ وِتْرٌ يُحِبُّ الْوِتْرَ\"؛ إن الله وتر يحب الوتر. النبي صلى الله عليه وسلم يقول: \"اجْعَلُوا آخِرَ صَلَاتِكُمْ بِاللَّيْلِ وِتْراً\" (اجعلوا آخر صلاتكم بالليل وتراً). قال النبي صلى الله عليه وسلم: \"يَا أَهْلَ الْقُرْآنِ أَوْتِرُوا، فَإِنَّ اللَّهَ وِتْرٌ يُحِبُّ الْوِتْرَ\"؛ يا أهل القرآن أوتروا فإن الله وتر يحب الوتر. هذا الوتر السنة المؤكدة وقته من بعد صلاة العشاء إلى انبلاج الفجر، إلى طلوع الفجر؛ هذا كله وقت للوتر، من بعد أن تصلي صلاة العشاء إلى طلوع الفجر كله وقت للوتر. طيب إذا أذن الفجر وأنت لم توتر بعد، لم تصلِّ الوتر بعد؛ توتر قبل أن تصلي صلاة الصبح، وهذا يسميه فقهاؤنا الوقت الضروري للوتر، الوقت الضروري للوتر؛ من أذان الفجر إلى أن تصلي صلاة الصبح. مثلاً كنت عازماً على القيام لتصلي صلاة الوتر في آخر الليل، لكن غلبك النوم فلم تستيقظ إلا مع أذان الفجر؛ تتوضأ وتصلي الوتر قبل أن تصلي صلاة الصبح. قال: \"وِتْرٌ\"، ثم قال: \"كُسُوفٌ\"؛ صلاة الكسوف. السنة المؤكدة الثانية: صلاة الكسوف، صلاة الكسوف. المقصود بالكسوف هنا -بالكاف- المقصود بالكسوف هنا: كسوف الشمس؛ ما معنى كسوف الشمس؟ ذهاب ضوئها، ذهاب ضوء الشمس؛ وذلك حين يأتي القمر بين الشمس وبيننا في الأرض، فـ يذهب ضوء الشمس فيقال: كسفت الشمس؛ هذه آية من آيات الله. إذا وقع هذا الكسوف، شُرع للمسلم أن يفزع إلى الصلاة. بالمناسبة، بغض النظر عن كيف يتم الكسوف؛ الطريقة التي ذكرناها ياتي القمر بين الشمس وبين الأرض، يبقى هذا من آيات الله؛ ربنا عز وجل يذكرنا به نعمته علينا وأنه قادر على أن يفعل في كونه ما يشاء؛ مثل الجسم تراه سليماً صحيحاً معافى فيدخله فيروس أو بسيط فيبعثه الجسم ويحدث فيه الحمى والآلام ونحو ذلك، فتتذكر أن سلامتك بأمن الله عز وجل وفضل من الله عز وجل، وربك قادر على أن يفعل في جسمك كما شاء كذلك في كونه؛ فشرع لنا أن نفزع إلى الصلاة. قال النبي صلى الله عليه وسلم كما في الصحيحين في البخاري ومسلم وغيرهما: \"إِنَّ الشَّمْسَ وَالْقَمَرَ آيَتَانِ مِنْ آيَاتِ اللَّهِ لَا يَنْكَسِفَانِ لِمَوْتِ أَحَدٍ وَلَا لِحَيَاتِهِ، فَإِذَا رَأَيْتُمُوهُمَا فَقُومُوا فَصَلُّوا\" (فإذا رأيتموهما فقوموا فصلوا) أو كما قال صلى الله عليه وسلم؛ لأن كان العرب قديماً كانوا إذا كسفت إذا كسفت الشمس يقولون: \"مات اليوم عظيم\" أو \"يُولد عظيم\"، ووافق أن انكسفت الشمس في عهد رسول الله صلى الله عليه وسلم وافق ذلك موت إبراهيم ابن رسول الله صلى الله عليه وسلم، فقال بعضهم: \"كسفت الشمس لموت إبراهيم ابن رسول الله صلى الله عليه وسلم\"؛ فقال لهم النبي عليه الصلاة والسلام: \"إِنَّ الشَّمْسَ وَالْقَمَرَ آيَتَانِ مِنْ آيَاتِ اللَّهِ لَا يَنْكَسِفَانِ لِمَوْتِ أَحَدٍ وَلَا لِحَيَاتِهِ\". ا الكسوف السنة المؤكدة، كيف تؤدى صلاة الكسوف؟ صلاة الكسوف ركعتان، في كل ركعة ركوعان؛ صلاة الكسوف ركعتان في كل ركعة ركوعان. بمعنى يكبر الإنسان، صفتها كالاتي: يكبر الإنسان \"الله أكبر\"؛ طبعاً بالمناسبة تشرع لها صلاة الجماعة، تشرع لها صلاة الجماعة في المسجد. الله أكبر، تقرأ الفاتحة ثم تقرأ سورة وتطيل؛ الكسوف النبي صلى الله عليه وسلم صلّى الكسوف قالوا: \"قدرنا قراءته الأولى بقدر سورة البقرة\"؛ بقدر خمسة أحزاب، فقرأ طويلاً صلى الله عليه وسلم بعد الفاتحة، ثم ركع؛ ركع ركوعاً طويلاً قريباً من قراءته، يعني ركوعه قريب من من تلك القراءة التي قرأها والتي قُدّرت بالبقرة؛ ركع ركوعاً طويلاً هذا الركوع الأول. لما تقوم من الركوع تقول: \"سمع الله لمن حمده، ربنا ولك لك الحمد\"؛ تقرأ الفاتحة مرة أخرى، ثم تقرأ سورة تقرأ القرآن مرة أخرى. وهذه القراءة الثانية كانت قريبة من الركوع؛ يعني الركوع أنقص قليلاً من من القراءة الأولى، والقراءة الثانية أنقص قليلاً من الركوع؛ ثم تركع، ثم ترفع، ثم تسجد سجدتين. إذاً الركعة الأولى فيها ركوعان اثنان وقراءتان اثنتان؛ تقرأ الفاتحة مرتين، وتقرأ السورة أو ما بعد الفاتحة مرتين؛ ثم تقوم للركعة الثانية وتفعل فيها مثل ما فعلت في الأولى أيضاً، وكانت كل قراءة أنقص من سابقتها؛ مثلاً القراءة الركوع الركوع الثاني في الركعة الأولى قريب من القراءة قريب من الفاتحة\"، فقالوا لو لو صلى جهراً لعُلم بما قرأ صلى الله عليه وسلم؛ لكن الثانية، والقراءة في الركعة الثانية القراءة الأولى في الركعة الثانية قريبة من الركوع الثاني في الركعة الأولى، وهكذا. الواقع أنه في صحيح البخاري عن عائشة رضي الله عنها: \"أَنَّ رَسُولَ اللَّهِ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ جَهَرَ فِي صَلَاةِ الْكُسُوفِ بِقِرَاءَتِهِ\"؛ فصرحت عائشة رضي الله فـ طبعاً هذا حتى تطول الصلاة؛ حتى إذا أنهى الإنسان صلاته يكاد يعني ما ينتهـ ما تنتهي عنها أنه صلى الله عليه وسلم صلاها جهراً. ولعل لعل أدائها جهراً يساعد بالأخص في الصلاة حتى ينجلي ما وقع وترجع الشمس إلى ضيائها؛ فهذه صفة صلاة صلاة الجماعة، يساعد المأموم على على الإطالة فيها وعلى البقاء متخشعاً فيها؛ الكسوف. وهذه الصفة، أو صفة صلاة الكسوف، طبعاً هي ركعتان في كل ركعة ركوعان. لأنه لو أسرَّ الإمام الإمام صلاة الكسوف وأطال كما أطال صلى الله عليه وسلم وصلى سراً، وقد يكون في المأمومين مَن المالكية رحمه الله عليهم ومن وافقهم اختاروا أن أو رجحوا أنها تُصلى سراً، ورجح لا مَن لا يحفظ القران أو لا غيرهم أنها تُصلى جهراً. ا المالكية رحمه الله عليهم حتى رجحوا أنها تُصلى سراً لأن يحـ... ما يقرأ بعض ما يحفظه فيبقى ساكتاً فيلهو وربما يمل ونحو ذلك؛ فلعله يترجح أن أن لهذا الحديث الذي ذكرت لكم وفيه أن الذي روى صلاة صلاة رسول الله صلى الله عليه وسلم الكسوف، قال: \"إن القراءة الأولى تُقرأ أن تُصلى جهراً، والله تعالى أعلى وأعلم. طبعاً وقتها وقتها تكون عندما يظهر الكسوف، عندما يظهر الكسوف هنا تشرع الصلاة؛ تشرع الصلاة لا بعض الناس أحياناً في بعض الأوقات يكون مثلاً يخبر أهل الفلك بأن الكسوف سيقع في اليوم الفلاني في الصباح في الوقت الفلاني مع الصباح، فتجد بعض الناس في الصباح بدأ صلاة الكسوف وربما الكسوف لم يبدأ بعد أو ربما يكون كسوفاً جزئياً لا يظهر فيصلي الإنسان؛ لا، الكسوف إنما يُصلى حينما ترى الكسوف، إذا رأيت الشمس قد كسفت حينها تصلي، إذا لم ترَ فلا تصلي. وما يُقال في كسوف الشمس يُقال في كسوف القمر أيضاً، فيُقال الكسوف ويُقال الخسوف أيضاً؛ فصلاة الكسوف هي للشمس وللقمر أيضاً. قال رحمه الله تعالى: \"وِتْرٌ كُسُوفٌ\"، وما زال الكلام على العيد والاستسقاء وما عداهما من أنواع الصلوات طويلاً؛ فنتوقف عند هذا القدر ونكمل في المجلس المقبل إن شاء الله تعالى. سبحانك اللهم وبحمدك أشهد أن لا إله إلا أنت أستغفرك وأتوب إليك، وصلى الله وسلم وبارك على سيدنا محمد وعلى آله، والحمد لله رب العالمين. السلام عليكم ورحمة الله وبركاته.",
    "blocks_search_text": "تقسيم الصلوات وفرضية الصلوات الخمس الصلوات يمكن تقسيمها أو هي تقسم إلى فرض ونفل... والفرض العين: الصلوات الخمس شرح الشيخ تقسيم الصلوات إلى فرض ونفل، وتفصيل الفروض إلى فرض عين وفرض كفاية، مع بيان الأدلة على أن الصلوات المفروضة عيناً هي خمس صلوات. أحكام الجنائز: صلاة الجنازة وفرائضها وتجهيز الميت أن الصلاة على الجنازة فرض كفاية... فرائض صلاة الجنازة أربعة: التكبير ويكون أربعاً، الدعاء، والنية، والسلام... وكالصلاة الغسل دفن وكفن بيّن الشيخ أحكام صلاة الجنازة وفرائضها الأربعة مع مناقشة حكم قراءة الفاتحة فيها، ثم فصّل الأحكام والسنن المتعلقة بتغسيل الميت وتكفينه ودفنه. الصلوات المسنونة: صلاة الوتر وصلاة الكسوف الآن تعال لأحدثك عن الصلوات المسنونة وهي في الواقع السنة المؤكدة؛ قال: وِتْرٌ كُسُوفٌ عِيدٌ اسْتِسْقَا سُنَنْ شرح الشيخ صلاة الوتر مبيناً فضلها ووقتها الاختياري والضروري، ثم فصّل في صلاة الكسوف من حيث صفتها وهيئتها وحكم الجهر والإسرار بالقراءة فيها.",
