        "citation": "أَنَّهُ يَجِبُ تَأْنِيثُ الْفِعْلِ... إِذَا كَانَ الْفَاعِلُ مُؤَنَّثاً حَقِيقِيَّ التَّأْنِيثِ... وَيَجُوزُ تَرْكُ التَّاءِ إِنْ كَانَ الْفَاعِلُ مَجَازِيَّ التَّأْنِيثِ... وَقَدْ يَتَأَخَّرُ الْفَاعِلُ وَيَتَقَدَّمُ الْمَفْعُولُ جَوَازاً وَوُجُوباً.",
        "explanation": "فصّل الشيخ في وجوب تأنيث الفعل مع المؤنث الحقيقي وجوازه مع المجازي، وبيّن أحكام الترتيب بين الفاعل والمفعول به، موضحاً حالات التقديم والتأخير بينهما.",
        "video_link": null,
        "search_text": "تأنيث الفعل وتأخير الفاعل أَنَّهُ يَجِبُ تَأْنِيثُ الْفِعْلِ... إِذَا كَانَ الْفَاعِلُ مُؤَنَّثاً حَقِيقِيَّ التَّأْنِيثِ... وَيَجُوزُ تَرْكُ التَّاءِ إِنْ كَانَ الْفَاعِلُ مَجَازِيَّ التَّأْنِيثِ... وَقَدْ يَتَأَخَّرُ الْفَاعِلُ وَيَتَقَدَّمُ الْمَفْعُولُ جَوَازاً وَوُجُوباً. فصّل الشيخ في وجوب تأنيث الفعل مع المؤنث الحقيقي وجوازه مع المجازي، وبيّن أحكام الترتيب بين الفاعل والمفعول به، موضحاً حالات التقديم والتأخير بينهما."
      }
    ],
    "video_url": null,
    "segments": [
      {
        "ts": "0:00",
        "sec": 0,
        "text": "بسم الله الرحمن الرحيم، الحمد لله رب العالمين، وصلى الله وسلم وبارك على نبينا محمد وعلى آله وصحبه والتابعين، ومن تبعهم",
        "video_link": null
      },
      {
        "ts": "0:09",
        "sec": 9,
        "text": "بإحسان إلى يوم الدين. هذا باب جديد هو باب المرفوعات من الأسماء،",
        "video_link": null
      },
      {
        "ts": "0:16",
        "sec": 16,
        "text": "بدأ بسرد هذه المرفوعات قبل أن يفصل فيها لاحقاً، فقال: الْمَرْفُوعَاتُ عَشَرَةٌ؛",
        "video_link": null
      },
      {
        "ts": "0:24",
        "sec": 24,
        "text": "وَهِيَ: الْفَاعِلُ، وَالْمَفْعُولُ الَّذِي لَمْ يُسَمَّ فَاعِلُهُ، وَالْمُبْتَدَأُ وَخَبَرُهُ، وَاسْمُ كَانَ وَأَخَوَاتِهَا،",
        "video_link": null
      },
      {
        "ts": "0:33",
        "sec": 33,
        "text": "وَاسْمُ أَفْعَالِ الْمُقَارَبَةِ، وَاسْمُ الْحُرُوفِ الْمُشَبَّهَةِ بِـ \"لَيْسَ\"، وَخَبَرُ إِنَّ وَأَخَوَاتِهَا، وَخَبَرُ لَا الَّتِي لِنَفْيِ",
        "video_link": null
      },
      {
        "ts": "0:43",
        "sec": 43,
        "text": "الْجِنْسِ، وَالتَّابِعُ لِلْمَرْفُوعِ؛ وَهُوَ أَرْبَعَةُ أَشْيَاءَ: النَّعْتُ، وَالْعَطْفُ، وَالتَّوْكِيدُ، وَالْبَدَلُ. هذا سرد لا",
        "video_link": null
      },
      {
        "ts": "0:52",
        "sec": 52,
        "text": "نحتاج إلى الإطالة في الحديث عنه. المرفوع الأول هو الفاعل.",
        "video_link": null
      },
      {
        "ts": "0:58",
        "sec": 58,
        "text": "بَابُ الْفَاعِلِ؛ قال: هُوَ الِاسْمُ الْمَرْفُوعُ الْمَذْكُورُ قَبْلَهُ فِعْلُهُ، أو ما في تأويل الفعل.",
        "video_link": null
      },
      {
        "ts": "1:07",
        "sec": 67,
        "text": "وهو على قسمين ظاهر، إذن كل اسم مرفوع قبله، يعني حين نقول اسم مرفوع قد يكون هذا",
        "video_link": null
      },
      {
        "ts": "1:17",
        "sec": 77,
        "text": "الاسم صريحاً وقد يكون مؤولاً.",
        "video_link": null
      },
      {
        "ts": "1:22",
        "sec": 82,
        "text": "وسيأتينا أن الفعل قد يشبك مع حرف مصدري،",
        "video_link": null
      },
      {
        "ts": "1:30",
        "sec": 90,
        "text": "يعني حرف مصدري ومعه صلته فيكون ما ما هو كالاسم، فيكون اسماً مؤولاً",
        "video_link": null
      },
      {
        "ts": "1:39",
        "sec": 99,
        "text": "كما في قول الله سبحانه وتعالى: {أَلَمْ يَأْنِ لِلَّذِينَ آمَنُوا أَن تَخْعَشَعَ}،",
        "video_link": null
      },
      {
        "ts": "1:47",
        "sec": 107,
        "text": "كما لو قيل: ألم يأنِ خشوع قلوبهم، {أَن تَخْشَعَ قُلُوبُهُمْ} خشوع قلوبهم، فإذن هذا الفاعل هو",
        "video_link": null
      },
      {
        "ts": "1:57",
        "sec": 117,
        "text": "اسم، قلنا صريح أو مؤول، اسم مرفوع مذكور قبله فعل، وهذا الفعل هو العامل في",
        "video_link": null
      },
      {
        "ts": "2:08",
        "sec": 128,
        "text": "الفاعل هو الذي يرفعه، أو ما هو في تأويل الفعل أي ما يشبه",
        "video_link": null
      },
      {
        "ts": "2:15",
        "sec": 135,
        "text": "الفعل في عمله وهو اسم الفاعل،",
        "video_link": null
      },
      {
        "ts": "2:22",
        "sec": 142,
        "text": "والصفة المشبهة، والمصدر، واسم الفعل، إلى غير ذلك،",
        "video_link": null
      },
      {
        "ts": "2:27",
        "sec": 147,
        "text": "فهذه الأشياء أيضاً تقتضي فاعلاً.",
        "video_link": null
      },
      {
        "ts": "2:35",
        "sec": 155,
        "text": "ثم وهذا سيأتينا في موضعه بإذن الله عز وجل، ثم هذا الفاعل على قسمين: إما أن يكون",
        "video_link": null
      },
      {
        "ts": "2:45",
        "sec": 165,
        "text": "ظاهراً أو أن يكون مضمراً. فَالظَّاهِرُ نحو: قَالَ اللَّهُ، قَالَ: فعل ماضٍ مبني",
        "video_link": null
      },
      {
        "ts": "2:53",
        "sec": 173,
        "text": "على الفتح، واسم الجلالة فاعل، اللَّهُ: فاعل. قَالَ رَجُلَانِ،",
        "video_link": null
      },
      {
        "ts": "2:59",
        "sec": 179,
        "text": "رَجُلَانِ: فاعل مرفوع وعلامة رفعه الالف نيابة عن الضمة لأنه مثنى. {جَاءَ الْمُعَذِّرُونَ}، الْمُعَذِّرُونَ:",
        "video_link": null
      },
      {
        "ts": "3:08",
        "sec": 188,
        "text": "فاعل مرفوع علامة رفعه الواو النائبة عن الضمة لأنه جمع مذكر سالم. {يَوْمَ يَقُومُ النَّاسُ}،",
        "video_link": null
      },
      {
        "ts": "3:17",
        "sec": 197,
        "text": "هنا يَقُومُ: فعل مضارع، النَّاسُ: فاعل مرفوع.",
        "video_link": null
      },
      {
        "ts": "3:23",
        "sec": 203,
        "text": "{يَوْمَئِذٍ يَفْرَحُ الْمُؤْمِنُونَ}، الْمُؤْمِنُونَ: فاعل مرفوع وعلامة رفعه الواو النائبة عن الضمة لأنه",
        "video_link": null
      },
      {
        "ts": "3:31",
        "sec": 211,
        "text": "جمع مذكر سالم. {قَالَ أَبُوهُمْ}، أَبُو: فاعل مرفوع وعلامة رفعه الواو النائبة عن الضمة لأنه",
        "video_link": null
      },
      {
        "ts": "3:39",
        "sec": 219,
        "text": "من الأسماء الستة. هذه كلها أمثلة مختلفة كطريقة المصنف في هذا المتن متنوعة، أمثلة",
        "video_link": null
      },
      {
        "ts": "3:48",
        "sec": 228,
        "text": "على الفاعل حين يكون اسماً ظاهراً. ثم هذا الفاعل قد يكون مضمراً أي ضميراً،",
        "video_link": null
      },
      {
        "ts": "3:56",
        "sec": 236,
        "text": "كقولك: ضَرَبْتُ، التاء هنا",
        "video_link": null
      },
      {
        "ts": "4:02",
        "sec": 242,
        "text": "ضمير متصل مبني في محل رفع فاعل، ضَرَبْنَا كذلك ضمير متصل مبني في محل رفع فاعل، إلى",
        "video_link": null
      },
      {
        "ts": "4:12",
        "sec": 252,
        "text": "آخره كما تقدم في فصل المضمر فلا نحتاج إلى إعادة الكلام عنه.",
        "video_link": null
      },
      {
        "ts": "4:19",
        "sec": 259,
        "text": "والذي في تأويل الفعل، إذن هذا الفعل واضح عندنا، الذي في تأويل الفعل نحو: أَقَائِمٌ",
        "video_link": null
      },
      {
        "ts": "4:27",
        "sec": 267,
        "text": "الزَّيْدَانِ؟ وقوله تعالى: {مُخْتَلِفٌ أَلْوَانُهُ}. ففي نحو أَقَائِمٌ الزَّيْدَانِ؟ قَائِمٌ هذا",
        "video_link": null
      },
      {
        "ts": "4:37",
        "sec": 277,
        "text": "اسم ولكنه في صيغته الصرفية هو اسم فاعل،",
        "video_link": null
      },
      {
        "ts": "4:44",
        "sec": 284,
        "text": "فقائم الزيدان في قوة قولك أو في تأويل قولك: أيقوم الزيدان؟ أَقَائِمٌ الزَّيْدَانِ، يقوم",
        "video_link": null
      },
      {
        "ts": "4:53",
        "sec": 293,
        "text": "الزيدان. قَائِمٌ: مبتدأ ومبتدأ مرفوع علامة رفعه الضمة ظاهرة على",
        "video_link": null
      },
      {
        "ts": "5:02",
        "sec": 302,
        "text": "آخره، وقائم اسم فاعل، واسم الفاعل يعمل عمل الفعل فيرفع فاعلاً",
        "video_link": null
      },
      {
        "ts": "5:10",
        "sec": 310,
        "text": "وينصب مفعولاً. هذه كلها أشياء ستأتينا في موضعها، لكن نحن نذكرها هنا من باب البيان.",
        "video_link": null
      },
      {
        "ts": "5:19",
        "sec": 319,
        "text": "الزَّيْدَانِ: فاعل، أنت ما تعرفه في الأصل هو أن يكون الفاعل",
        "video_link": null
      },
      {
        "ts": "5:27",
        "sec": 327,
        "text": "لفعل، يكون الفعل هو الذي يرفع الفاعل، لكن قلنا إن هنالك أشياء أخرى غير الفعل تعمل",
        "video_link": null
      },
      {
        "ts": "5:38",
        "sec": 338,
        "text": "عمل الفعل منها اسم الفاعل في هذه الصورة، فإذن الزيدان فاعل لاسم",
        "video_link": null
      },
      {
        "ts": "5:46",
        "sec": 346,
        "text": "الفاعل، ونقول عنه فاعل سد مسد الخبر، أو أغنى عن",
        "video_link": null
      },
      {
        "ts": "5:53",
        "sec": 353,
        "text": "الخبر. هذا سنأخذه إن شاء الله تعالى في بحث المبتدأ والخبر.",
        "video_link": null
      },
      {
        "ts": "6:00",
        "sec": 360,
        "text": "وكذلك قوله تعالى: {مُخْتَلِفٌ أَلْوَانُهُ}، فهو في قوة أو في تأويل: يختلف أو تختلف",
        "video_link": null
      },
      {
        "ts": "6:09",
        "sec": 369,
        "text": "ألوانه، واضح؟ {مُخْتَلِفٌ أَلْوَانُهُ}، مُخْتَلِفٌ:",
        "video_link": null
      },
      {
        "ts": "6:17",
        "sec": 377,
        "text": "مبتدأ وألوانه، وهو اسم اسم فاعل، مُخْتَلِفٌ اسم فاعل",
        "video_link": null
      },
      {
        "ts": "6:24",
        "sec": 384,
        "text": "يعمل عمل الفعل فيرفع الفاعل وينصب المفعول، وإذن ألوانُ: فاعل له،",
        "video_link": null
      },
      {
        "ts": "6:33",
        "sec": 393,
        "text": "وهو مرفوع علامة رفعه الضمة الظاهرة على آخره، جميل.",
        "video_link": null
      },
      {
        "ts": "6:42",
        "sec": 402,
        "text": "إذن نحن فهمنا الآن أن الفاعل يكون العامل فيه فعلاً، هذا معروف لديكم لا",
        "video_link": null
      },
      {
        "ts": "6:49",
        "sec": 409,
        "text": "جديد فيه، لكن ربما الذي قد يكون جديداً عند كثير من المبتدئين هو أن اسم الفاعل أيضاً",
        "video_link": null
      },
      {
        "ts": "6:57",
        "sec": 417,
        "text": "وما أشبهه من هذه الصفات يمكنه كذلك أن يعمل عمل الفعل فيكون عندنا فاعل لاسم",
        "video_link": null
      },
      {
        "ts": "7:06",
        "sec": 426,
        "text": "الفاعل. قال: وَلِلْفَاعِلِ أَحْكَامٌ؛ مِنْهَا: أَنَّهُ لَا يَجُوزُ حَذْفُهُ،",
        "video_link": null
      },
      {
        "ts": "7:14",
        "sec": 434,
        "text": "لأنه عمدة؛ فيما سنذكره انطلاقاً من الآن هنالك أشياء",
        "video_link": null
      },
      {
        "ts": "7:23",
        "sec": 443,
        "text": "نقول عنها إنها عمدة في الكلام، وأشياء أخرى نقول عنها إنها فضلة في",
        "video_link": null
      },
      {
        "ts": "7:29",
        "sec": 449,
        "text": "الكلام. عمدة: أي يقوم الكلام عليها لا سبيل إلى ماذا؟ إلى حذفها من الكلام، إذا حُذفت من",
        "video_link": null
      },
      {
        "ts": "7:38",
        "sec": 458,
        "text": "الكلام يعني لم يصح لم يستقم الكلام. والأشياء التي هي فضلة لا شك أنها تفيد",
        "video_link": null
      },
      {
        "ts": "7:44",
        "sec": 464,
        "text": "معنى ولكنها لو حُذفت من الكلام يبقى مع ذلك كلاماً مستقيماً صالحاً،",
        "video_link": null
      },
      {
        "ts": "7:51",
        "sec": 471,
        "text": "فالفاعل عمدة لا يجوز حذفه، واضح؟ فَإِنْ ظَهَرَ فِي اللَّفْظِ نحو: قَامَ زَيْدٌ، وَالزَّيْدَانِ",
        "video_link": null
      },
      {
        "ts": "8:00",
        "sec": 480,
        "text": "قَامَا، فذاك؛ وَإِلَّا فَهُوَ ضَمِيرٌ مُسْتَتِرٌ. بمعنى كأنه",
        "video_link": null
      },
      {
        "ts": "8:08",
        "sec": 488,
        "text": "يتوقع سؤالاً يسأله من يقرأ هذا الكلام؛ حين تقول له، حين يقول إن الفاعل عمدة فلا يجوز",
        "video_link": null
      },
      {
        "ts": "8:18",
        "sec": 498,
        "text": "حذفه، كأن سائلاً يسأل: طيب ولكن في نحو زَيْدٌ قَامَ، زيدٌ مبتدأ، قامَ فعل، أين فاعله؟ فإذن هل",
        "video_link": null
      },
      {
        "ts": "8:27",
        "sec": 507,
        "text": "حُذف فاعله؟ لا، يقول لك: لا، إذا كان الفاعل ظاهراً في اللفظ هذا لا إشكال فيه؛",
        "video_link": null
      },
      {
        "ts": "8:35",
        "sec": 515,
        "text": "قَامَ زَيْدٌ، قام فعل زيد فاعله، الزَّيْدَانِ قَامَا، قَامَا الفاعل هو الألف هذا الضمير.",
        "video_link": null
      },
      {
        "ts": "8:45",
        "sec": 525,
        "text": "إن كان كذلك فلا إشكال، وإلا",
        "video_link": null
      },
      {
        "ts": "8:50",
        "sec": 530,
        "text": "إذا لم يكن الفاعل ظاهراً في اللفظ فحينئذٍ نحتاج إلى أن نقول إنه ضمير مستتر، وهذا",
        "video_link": null
      },
      {
        "ts": "9:00",
        "sec": 540,
        "text": "كله لأجل عدم إمكان حذف الفاعل؛ فنقول في نحو زَيْدٌ قَامَ، قَامَ: فعل ماضٍ مبني على الفتح،",
        "video_link": null
      },
      {
        "ts": "9:08",
        "sec": 548,
        "text": "والفاعل ضمير مستتر جوازاً تقديره هو، والجملة من الفعل والفاعل",
        "video_link": null
      },
      {
        "ts": "9:16",
        "sec": 556,
        "text": "في محل رفع خبر المبتدأ، جميل. هذا الحكم الأول من أحكام الفاعل.",
        "video_link": null
      },
      {
        "ts": "9:24",
        "sec": 564,
        "text": "الحكم الثاني: أَنَّهُ لَا يَجُوزُ تَقَدُّمُهُ عَلَى الْفِعْلِ، فَإِنْ وَجَدَ مَا ظَاهِرُهُ أَنَّهُ فَاعِلٌ مُقَدَّمٌ وَجَبَ تَقْدِيرُ",
        "video_link": null
      },
      {
        "ts": "9:33",
        "sec": 573,
        "text": "الْفَاعِلِ ضَمِيراً مُسْتَتِراً، وَيَكُونُ الْمُقَدَّمُ إِمَّا مُبْتَدَأً نحو:",
        "video_link": null
      },
      {
        "ts": "9:39",
        "sec": 579,
        "text": "زَيْدٌ، وَإِمَّا فَاعِلاً بِفِعْلٍ مَحْذُوفٍ نحو: {وَإِنْ أَحَدٌ مِّنَ الْمُشْرِكِينَ اسْتَجَارَكَ}، لِأَنَّ أَدَاةَ الشَّرْطِ لَا تَدْخُلُ",
        "video_link": null
      },
      {
        "ts": "9:48",
        "sec": 588,
        "text": "عَلَى الْمُبْتَدَأِ، جميل. هنا الحكم الذي، الحكم",
        "video_link": null
      },
      {
        "ts": "9:55",
        "sec": 595,
        "text": "الثاني من أحكام الفاعل هو أن الترتيب بين الفعل والفاعل دائماً هكذا: فعل أولاً وفاعل",
        "video_link": null
      },
      {
        "ts": "10:03",
        "sec": 603,
        "text": "بعده، بمعنى أن الفاعل دائماً يأتي بعد الفعل ولا",
        "video_link": null
      },
      {
        "ts": "10:08",
        "sec": 608,
        "text": "يتقدم عليه. ستقول لي: في نحو زَيْدٌ قَامَ،",
        "video_link": null
      },
      {
        "ts": "10:15",
        "sec": 615,
        "text": "هل يمكنك أن تقول زَيْدٌ فاعل مقدم وقَامَ فعل جاء بعد الفاعل؟ لا، لا يصح ذلك ولا يجوز، بل",
        "video_link": null
      },
      {
        "ts": "10:26",
        "sec": 626,
        "text": "تقول: زَيْدٌ مبتدأ كما قلنا في الإعراب، قَامَ فعل،",
        "video_link": null
      },
      {
        "ts": "10:32",
        "sec": 632,
        "text": "فاعله ضمير مستتر، والجملة الفعلية خبر المبتدأ. وكذلك في قول ربنا سبحانه وتعالى: {وَإِنْ أَحَدٌ",
        "video_link": null
      },
      {
        "ts": "10:41",
        "sec": 641,
        "text": "مِّنَ الْمُشْرِكِينَ اسْتَجَارَكَ فَأَجِرْهُ حَتَّىٰ يَسْمَعَ كَلَامَ اللَّهِ}، هنا",
        "video_link": null
      },
      {
        "ts": "10:51",
        "sec": 651,
        "text": "لو فرضنا أن \"إن\" غير موجودة، \"أحدٌ من المشركين استجارك\"، أحدٌ استجارك، لو كان الكلام هكذا",
        "video_link": null
      },
      {
        "ts": "10:58",
        "sec": 658,
        "text": "لصح لنا أن نقول مثل ما في زيد قامه، نقول: أحدٌ مبتدأ واستجار فعل وفاعله ضمير مستتر والجملة",
        "video_link": null
      },
      {
        "ts": "11:08",
        "sec": 668,
        "text": "الفعلية خبر المبتدأ، لكن الإشكال هنا ما الذي وقع؟ هو أن \"إن\" هذه الشرطية موجودة،",
        "video_link": null
      },
      {
        "ts": "11:17",
        "sec": 677,
        "text": "وأداة الشرط هذه تدخل على جملة فعلية ولا تدخل على الجمل الاسمية، لا يمكن أن تدخل على المبتدأ.",
        "video_link": null
      },
      {
        "ts": "11:26",
        "sec": 686,
        "text": "فلأجل ذلك يعني أن لا بد بعدها من فعل هو فعل الشرط كما سيأتي في موضعه، فإذاً حينئذٍ",
        "video_link": null
      },
      {
        "ts": "11:35",
        "sec": 695,
        "text": "نقدر فعلاً محذوفاً تقديره: وإن استجارك أحدٌ من المشركين",
        "video_link": null
      },
      {
        "ts": "11:44",
        "sec": 704,
        "text": "استجارك، واضح؟ لأجل ذلك نقدر",
        "video_link": null
      },
      {
        "ts": "11:52",
        "sec": 712,
        "text": "فعلاً محذوفاً، ولذلك قال: وَإِمَّا فَاعِلاً بِفِعْلٍ مَحْذُوفٍ نحو: {وَإِنْ أَحَدٌ مِّنَ الْمُشْرِكِينَ اسْتَجَارَكَ}،",
        "video_link": null
      },
      {
        "ts": "12:00",
        "sec": 720,
        "text": "وعلل عدم إمكان إعراب \"أحد\" مبتدأ بقوله:",
        "video_link": null
      },
      {
        "ts": "12:07",
        "sec": 727,
        "text": "لِأَنَّ أَدَاةَ الشَّرْطِ لَا تَدْخُلُ عَلَى الْمُبْتَدَأِ. هذا الحكم الثاني. الحكم الثالث قال: وَمِنْهَا أَنَّ فِعْلَهُ يُوَحَّدُ مَعَ",
        "video_link": null
      },
      {
        "ts": "12:17",
        "sec": 737,
        "text": "تَثْنِيَتِهِ وَجَمْعِهِ كَمَا يُوَحَّدُ مَعَ إِفْرَادِهِ، فَتَقُولُ: قَامَ الزَّيْدَانِ، وَقَامَ الزَّيْدُونَ، كَمَا تَقُولُ: قَامَ",
        "video_link": null
      },
      {
        "ts": "12:27",
        "sec": 747,
        "text": "زَيْدٌ. قال الله تعالى: {قَالَ رَجُلَانِ}، و {جَاءَ الْمُعَذِّرُونَ}، و {وَقَالَ الظَّالِمُونَ}، و {وَقَالَ نِسْوَةٌ}، واضح؟",
        "video_link": null
      },
      {
        "ts": "12:37",
        "sec": 757,
        "text": "إذن هذا هو الأصل، هذه هي الجادة، هذه لغة القرآن، هذه هي اللغة المطردة عند العرب،",
        "video_link": null
      },
      {
        "ts": "12:43",
        "sec": 763,
        "text": "وهي أن الفعل يكون موحداً، ما معنى موحد؟ يكون على صيغة الواحد \"قَامَ\"",
        "video_link": null
      },
      {
        "ts": "12:52",
        "sec": 772,
        "text": "مثلاً، مع كون الفاعل قد يكون مثنى قد يكون مفرداً وقد يكون",
        "video_link": null
      },
      {
        "ts": "13:01",
        "sec": 781,
        "text": "مثنى وقد يكون جماعة؛ فتقول: قام الزيدون كما تقول قام الزيدان وقام الزيدان. ومثّل من القرآن: {قَالَ رَجُلَانِ}،",
        "video_link": null
      },
      {
        "ts": "13:10",
        "sec": 790,
        "text": "إذن \"قال\" هذا مفرد موحد يعني ورجلان مثنى، {جَاءَ الْمُعَذِّرُونَ} نفس الشيء المعذرون جمع، {قَالَ",
        "video_link": null
      },
      {
        "ts": "13:18",
        "sec": 798,
        "text": "الظَّالِمُونَ}، {وَقَالَ نِسْوَةٌ} جمع إناث لكن \"قال\" قلنا هذه هي اللغة المطردة. لكن",
        "video_link": null
      },
      {
        "ts": "13:26",
        "sec": 806,
        "text": "هنالك لغة أخرى لبعض العرب قال: وَمِنَ الْعَرَبِ مَنْ يُلْحِقُ الْفِعْلَ عَلَامَةَ التَّثْنِيَةِ وَالْجَمْعِ إِذَا",
        "video_link": null
      },
      {
        "ts": "13:36",
        "sec": 816,
        "text": "كَانَ الْفَاعِلُ مُثَنًّى أَوْ مَجْمُوعاً، فَتَقُولُ: قَامَا الزَّيْدَانِ،",
        "video_link": null
      },
      {
        "ts": "13:42",
        "sec": 822,
        "text": "وَقَامُوا الزَّيْدُونَ، وَقُمْنَ الْهِنْدَاتُ، وتسمى لغة",
        "video_link": null
      },
      {
        "ts": "13:49",
        "sec": 829,
        "text": "\"أَكَلُونِي الْبَرَاغِيثُ\" لأن هذا اللفظ سُمع من بعضهم، ومنه الحديث: \"يَتَعَاقَبُونَ فِيكُمْ مَلَائِكَةٌ",
        "video_link": null
      },
      {
        "ts": "13:56",
        "sec": 836,
        "text": "بِاللَّيْلِ وَمَلَائِكَةٌ بِالنَّهَارِ\". إذن هذه اللغة المسماة عند أكثر النحاة لغة \"أكلوني",
        "video_link": null
      },
      {
        "ts": "14:06",
        "sec": 846,
        "text": "البراغيث\" لأن ذلك سُمع من بعض العرب، يعني بعض العرب قال هذه الكلمة قال: \"أكلوني البراغيث\" فاشتهرت عند النحاة بهذا اللفظ.",
        "video_link": null
      },
      {
        "ts": "14:13",
        "sec": 853,
        "text": "وابن مالك وأشباهه من النحاة الذين يعظمون الحديث النبوي يقولون: الأفضل أن نسميها",
        "video_link": null
      },
      {
        "ts": "14:21",
        "sec": 861,
        "text": "لغة \"يتعاقبون الملائكة\" أخذاً من هذا الحديث: \"يَتَعَاقَبُونَ فِيكُمْ مَلَائِكَةٌ",
        "video_link": null
      },
      {
        "ts": "14:28",
        "sec": 868,
        "text": "بِاللَّيْلِ وَمَلَائِكَةٌ بِالنَّهَارِ\". هذه اللغة فيها إثبات علامة التثنية والجمع في",
        "video_link": null
      },
      {
        "ts": "14:37",
        "sec": 877,
        "text": "الفعل إذا كان الفاعل مثنى أو مجموعاً، في لغة أكلوني البراغيث يقولون هكذا، لكن",
        "video_link": null
      },
      {
        "ts": "14:46",
        "sec": 886,
        "text": "في اللغة الأصلية الجادة كيف نقول؟ نقول: أكلني البراغيث، ويتعاقبون ملائكة كيف نقول؟ نقول: يتعاقب",
        "video_link": null
      },
      {
        "ts": "14:55",
        "sec": 895,
        "text": "فيكم ملائكة، لكن ورد الحديث بهذه الرواية على هذا",
        "video_link": null
      },
      {
        "ts": "15:03",
        "sec": 903,
        "text": "أو على هذه اللغة، وحتى يعني يوجد في القرآن ما حمل ما حمله بعضهم على هذه",
        "video_link": null
      },
      {
        "ts": "15:11",
        "sec": 911,
        "text": "اللغة قول الله سبحانه وتعالى: {وَأَسَرُّوا النَّجْوَى الَّذِينَ ظَلَمُوا}،",
        "video_link": null
      },
      {
        "ts": "15:17",
        "sec": 917,
        "text": "قالوا على لغة أكلوني البراغيث، لأنه الأصل أن يقال: وأسرّ النجوى الذين ظلموا، لكن",
        "video_link": null
      },
      {
        "ts": "15:24",
        "sec": 924,
        "text": "هنالك طرق أخرى لإعراب الآية وتخريجها على لغة أخرى، لأن لغة أكلوني البراغيث ليست",
        "video_link": null
      },
      {
        "ts": "15:32",
        "sec": 932,
        "text": "لغة يعني فصيحة، فالأفضل أن لا يحمل عليها شيء من القرآن الكريم. أما الحديث فإنكم",
        "video_link": null
      },
      {
        "ts": "15:42",
        "sec": 942,
        "text": "تعرفون أن الحديث يمكن أن يروى بالمعنى، يمكن أن يكون الراوي هو الذي أورد",
        "video_link": null
      },
      {
        "ts": "15:48",
        "sec": 948,
        "text": "الحديث بهذه على هذه اللغة، ولا يكون ذلك بالضرورة من كلام رسول الله صلى الله عليه وسلم، ويمكن",
        "video_link": null
      },
      {
        "ts": "15:57",
        "sec": 957,
        "text": "أن يكون رسول الله صلى الله عليه وسلم قد حدث قوماً بلغتهم وما أشبه ذلك، جميل.",
        "video_link": null
      },
      {
        "ts": "16:06",
        "sec": 966,
        "text": "قال: وَالصَّحِيحُ أَنَّ الْأَلِفَ وَالْوَاوَ وَالنُّونَ أَحْرُفٌ",
        "video_link": null
      },
      {
        "ts": "16:12",
        "sec": 972,
        "text": "دَالَّةٌ عَلَى التَّثْنِيَةِ وَالْجَمْعِ، وَأَنَّ الْفَاعِلَ مَا بَعْدَهَا. بمعنى الذي يريد أن يقوله المصنف هنا أن",
        "video_link": null
      },
      {
        "ts": "16:22",
        "sec": 982,
        "text": "الصحيح أن هذه اللغة في نحو مثلاً \"يتعاقبون الملائكة\"،",
        "video_link": null
      },
      {
        "ts": "16:31",
        "sec": 991,
        "text": "أن تكون الواو هنا مجرد حرف دال على الجمع",
        "video_link": null
      },
      {
        "ts": "16:37",
        "sec": 997,
        "text": "والفاعل هو ملائكة، في نحو نفس الشيء في أكلوني البراغيث ومثلاً",
        "video_link": null
      },
      {
        "ts": "16:45",
        "sec": 1005,
        "text": "في قَامَا الزَّيْدَانِ الألف حرف دال على التثنية والفاعل هو الزيدان",
        "video_link": null
      },
      {
        "ts": "16:53",
        "sec": 1013,
        "text": "وهكذا، وَأَنَّ الْفَاعِلَ مَا بَعْدَهَا.",
        "video_link": null
      },
      {
        "ts": "17:00",
        "sec": 1020,
        "text": "وهذا هو الصحيح الذي اختاره المصنف، والقول الآخر أن هذه اللواحق نفسها ليست",
        "video_link": null
      },
      {
        "ts": "17:08",
        "sec": 1028,
        "text": "مجرد حروف وإنما هي ضمائر وإنها هي الفاعل،",
        "video_link": null
      },
      {
        "ts": "17:14",
        "sec": 1034,
        "text": "والمرفوع بعدها مثلاً يمكنك أن تعربه بدلاً منه؛ فتقول مثلاً في يتعاقبون ملائكة: الواو",
        "video_link": null
      },
      {
        "ts": "17:23",
        "sec": 1043,
        "text": "واو الجماعة فاعل على الأصل، وملائكة بدل من واو الجماعة، جميل.",
        "video_link": null
      },
      {
        "ts": "17:31",
        "sec": 1051,
        "text": "وَمِنْهَا -أي من أحكام الفاعل- قال: وَمِنْهَا أَنَّهُ يَجِبُ تَأْنِيثُ الْفِعْلِ",
        "video_link": null
      },
      {
        "ts": "17:39",
        "sec": 1059,
        "text": "بِتَاءٍ سَاكِنَةٍ فِي آخِرِ الْمَاضِي، وَبِتَاءِ الْمُضَارَعَةِ فِي أَوَّلِ الْمُضَارِعِ إِذَا كَانَ",
        "video_link": null
      },
      {
        "ts": "17:48",
        "sec": 1068,
        "text": "الْفَاعِلُ مُؤَنَّثاً حَقِيقِيَّ التَّأْنِيثِ، نحو: قَامَتْ هِنْدٌ، وَتَقُومُ هِنْدٌ.",
        "video_link": null
      },
      {
        "ts": "17:57",
        "sec": 1077,
        "text": "إذا كان الفاعل حقيقي التأنيث، يعني امرأة أو أنثى من مثلاً حتى من النساء أو من غير",
        "video_link": null
      },
      {
        "ts": "18:06",
        "sec": 1086,
        "text": "النساء لكن أنثى حقيقية، إذا كان الفاعل مؤنثاً حقيقي التأنيث كهند",
        "video_link": null
      },
      {
        "ts": "18:16",
        "sec": 1096,
        "text": "وزينب وغير ذلك، فالفعل يجب أن يؤنث؛ إذا كان ماضياً يؤنث",
        "video_link": null
      },
      {
        "ts": "18:25",
        "sec": 1105,
        "text": "بتاء التأنيث الساكنة في آخره فتقول: قَامَتْ هِنْدٌ، وإذا كان الفعل مضارعاً يؤنث",
        "video_link": null
      },
      {
        "ts": "18:33",
        "sec": 1113,
        "text": "بالتاء في أوله تاء المضارعة فتقول: تَقُومُ هِنْدٌ. هذا بالنسبة لـ",
        "video_link": null
      },
      {
        "ts": "18:42",
        "sec": 1122,
        "text": "الفاعل إذا كان حقيقياً، يقولون حقيقي التأنيث: ما له فرج، ومجازي التأنيث: ما لا فرج له، جميل.",
        "video_link": null
      },
      {
        "ts": "18:51",
        "sec": 1131,
        "text": "مجازي التأنيث قال: وَيَجُوزُ تَرْكُ التَّاءِ إِنْ كَانَ",
        "video_link": null
      },
      {
        "ts": "18:57",
        "sec": 1137,
        "text": "الْفَاعِلُ مَجَازِيَّ التَّأْنِيثِ، نحو: طَلَعَ الشَّمْسُ. الشمس",
        "video_link": null
      },
      {
        "ts": "19:08",
        "sec": 1148,
        "text": "حقيقة ليست أنثى حقيقة وإنما أنثى على جهة المجاز أو مؤنثة،",
        "video_link": null
      },
      {
        "ts": "19:17",
        "sec": 1157,
        "text": "فتقول: طلعت الشمس، وييجوز أن تقول: طلع الشمس.",
        "video_link": null
      },
      {
        "ts": "19:23",
        "sec": 1163,
        "text": "وكما في قوله تعالى: {وَمَا كَانَ صَلَاتُهُمْ عِندَ الْبَيْتِ إِلَّا مُكَاءً وَتَصْدِيَةً}،",
        "video_link": null
      },
      {
        "ts": "19:33",
        "sec": 1173,
        "text": "الشاهد قوله سبحانه: {وَمَا كَانَ صَلَاتُهُمْ}، كان الصلاة؛ الصلاة مجازي التأنيث،",
        "video_link": null
      },
      {
        "ts": "19:42",
        "sec": 1182,
        "text": "فيجوز أن تقول: كانت صلاتهم، أو أن تقول: كان صلاتهم.",
        "video_link": null
      },
      {
        "ts": "19:49",
        "sec": 1189,
        "text": "قال: وَحُكْمُ الْمُثَنَّى وَالْمَجْمُوعِ جَمْعَ تَصْحِيحٍ حُكْمُ الْمُفْرَدِ؛ فَتَقُولُ: قَامَ الزَّيْدَانِ، وَقَامَ الزَّيْدُونَ،",
        "video_link": null
      },
      {
        "ts": "19:59",
        "sec": 1199,
        "text": "وَقَامَتِ الْمُسْلِمَتَانِ، وَقَامَتِ الْمُسْلِمَاتُ، واضح؟",
        "video_link": null
      },
      {
        "ts": "20:07",
        "sec": 1207,
        "text": "وَأَمَّا جَمْعُ التَّكْسِيرِ فَحُكْمُهُ حُكْمُ الْمَجَازِيِّ التَّأْنِيثِ.",
        "video_link": null
      },
      {
        "ts": "20:14",
        "sec": 1214,
        "text": "جمع التكسير مثل مجازي التأنيث، مثل الشمس والصلاة ونحو ذلك؛ تقول: قَامَ الرِّجَالُ،",
        "video_link": null
      },
      {
        "ts": "20:22",
        "sec": 1222,
        "text": "وَقَامَتِ الرِّجَالُ يجوز ذلك، وقام الهنود وقامت الهنود (هنود جمع هند).",
        "video_link": null
      },
      {
        "ts": "20:31",
        "sec": 1231,
        "text": "فهنا جمع التكسير ليس جمع المذكر السالم أو جمع المؤنث السالم،",
        "video_link": null
      },
      {
        "ts": "20:40",
        "sec": 1240,
        "text": "لا، جمع التكسير يعامل معاملة مجازي التأنيث فلأجل ذلك يصح لك أن تقول قامت",
        "video_link": null
      },
      {
        "ts": "20:48",
        "sec": 1248,
        "text": "الرجال كما تقول قام الرجال. اشتهر عند بعضهم قولهم: \"كل جمع مؤنث\"،",
        "video_link": null
      },
      {
        "ts": "20:54",
        "sec": 1254,
        "text": "وذكروا عن الزمخشري أنه من ضمن أبيات له أنه قال: \"إن قومي تجمعوا وبقتلي تحدثوا، لا أبالي بجمعهم كل جمع مؤنث\" فالمقصود جمع التكسير يعني كالرجال ونحو",
        "video_link": null
      },
      {
        "ts": "21:13",
        "sec": 1273,
        "text": "ذلك. حكم آخر من أحكام الفاعل قال: وَمِنْهَا أَنَّ",
        "video_link": null
      },
      {
        "ts": "21:19",
        "sec": 1279,
        "text": "الْأَصْلَ فِيهِ أَنْ يَلِيَ فِعْلَهُ ثُمَّ يُذْكَرُ الْمَفْعُولُ",
        "video_link": null
      },
      {
        "ts": "21:24",
        "sec": 1284,
        "text": "بهذا الترتيب: فعل فاعل مفعول، نحو: {وَوَرِثَ",
        "video_link": null
      },
      {
        "ts": "21:30",
        "sec": 1290,
        "text": "سُلَيْمَانُ دَاوُودَ}؛ وَوَرِثَ: فعل ماضٍ مبني على الفتح، سُلَيْمَانُ: فاعل مرفوع وعلامة رفعه الضمة",
        "video_link": null
      },
      {
        "ts": "21:39",
        "sec": 1299,
        "text": "الظاهرة على آخره ولم ينون لأنه ممنوع من الصرف للعالمية والعجمة، دَاوُودَ:",
        "video_link": null
      },
      {
        "ts": "21:46",
        "sec": 1306,
        "text": "مفعول به منصوب وعلامة نصبه الفتحة الظاهرة على آخره ولم ينون كذلك لأنه",
        "video_link": null
      },
      {
        "ts": "21:55",
        "sec": 1315,
        "text": "ممنوع من الصرف العالمية والعجمة. لكن قد يعاد قد",
        "video_link": null
      },
      {
        "ts": "22:03",
        "sec": 1323,
        "text": "يقدم ويؤخر، قال: وَقَدْ يَتَأَخَّرُ الْفَاعِلُ وَيَتَقَدَّمُ الْمَفْعُولُ جَوَازاً،",
        "video_link": null
      },
      {
        "ts": "22:12",
        "sec": 1332,
        "text": "نحو: {وَلَقَدْ جَاءَ آلَ فِرْعَوْنَ النُّذُرُ}.",
        "video_link": null
      },
      {
        "ts": "22:19",
        "sec": 1339,
        "text": "جَاءَ: فعل ماضٍ مبني على الفتح، آلَ: مفعول به منصوب مقدم وعلامة نصبه",
        "video_link": null
      },
      {
        "ts": "22:28",
        "sec": 1348,
        "text": "الفتحة الظاهرة على آخره وهو مضاف، فِرْعَوْنَ: مضاف إليه مجرور وعلامة جره الفتحة النائبة عن",
        "video_link": null
      },
      {
        "ts": "22:36",
        "sec": 1356,
        "text": "الكسرة لأنه ممنوع من الصرف للعالمية، النُّذُرُ: فاعل",
        "video_link": null
      },
      {
        "ts": "22:44",
        "sec": 1364,
        "text": "مؤخر مرفوع وعلامة رفعه الضمة الظاهرة على آخره. لكن هذا",
        "video_link": null
      },
      {
        "ts": "22:50",
        "sec": 1370,
        "text": "التقديم والتأخير جائز وليس واجباً، لأنه يمكن أن يقال في غير القرآن: ولقد جاء النذر آل فرعون، كما",
        "video_link": null
      },
      {
        "ts": "22:59",
        "sec": 1379,
        "text": "قيل: ولقد جاء آل فرعون النذر، يجوز التقديم والتأخير. وقد يكون هذا التقديم والتأخير واجباً قال:",
        "video_link": null
      },
      {
        "ts": "23:08",
        "sec": 1388,
        "text": "وَوُجُوباً، ما معنى وجوباً؟ أي لسبب اقتضى ذلك،",
        "video_link": null
      },
      {
        "ts": "23:16",
        "sec": 1396,
        "text": "نحو: {شَغَلَتْنَا أَمْوَالُنَا}، واضح؟ شَغَلَتْنَا أَمْوَالُنَا؛ شَغَلَ: فعل ماضٍ مبني",
        "video_link": null
      },
      {
        "ts": "23:25",
        "sec": 1405,
        "text": "على الفتح، التاء: تاء التأنيث الساكنة، نا: ضمير متصل مبني",
        "video_link": null
      },
      {
        "ts": "23:34",
        "sec": 1414,
        "text": "في محل نصب مفعول به مقدم، أَمْوَالُ: فاعل مؤخر مرفوع وعلامة رفعه الضمة الظاهرة على",
        "video_link": null
      },
      {
        "ts": "23:43",
        "sec": 1423,
        "text": "آخره وهو مضاف، نا: ضمير متصل مبني في محل جر مضاف إليه، جميل. فهنا",
        "video_link": null
      },
      {
        "ts": "23:52",
        "sec": 1432,
        "text": "لما قلنا بأن التقديم والتأخير هنا واجب، لأنه لو قدمنا",
        "video_link": null
      },
      {
        "ts": "24:00",
        "sec": 1440,
        "text": "الفاعل حينئذٍ، لو قلنا: شغلت أموالنا نا،",
        "video_link": null
      },
      {
        "ts": "24:07",
        "sec": 1447,
        "text": "حينئذٍ نحتاج إلى أن نأتي يعني الضمير الذي هو",
        "video_link": null
      },
      {
        "ts": "24:15",
        "sec": 1455,
        "text": "المفعول به أن نأتي به متأخراً في مكانه الأصلي، لكن حينئذٍ بما أنه ضمير متصل",
        "video_link": null
      },
      {
        "ts": "24:24",
        "sec": 1464,
        "text": "سنحتاج إلى فصله واضح، فيلزم انفصال الضمير الذي هو مفعول فنقول:",
        "video_link": null
      },
      {
        "ts": "24:32",
        "sec": 1472,
        "text": "شغلت أموالنا إيانا، هكذا نقول.",
        "video_link": null
      },
      {
        "ts": "24:40",
        "sec": 1480,
        "text": "والقاعدة التي ذكرناها من قبل أنه لا يؤتى بالضمير منفصلاً متى أمكن الإتيان به متصلاً،",
        "video_link": null
      },
      {
        "ts": "24:48",
        "sec": 1488,
        "text": "هذا ذكرناه في فصل الضمير، والإتيان بالضمير هنا متصلاً ممكن، يكفي أن",
        "video_link": null
      },
      {
        "ts": "24:56",
        "sec": 1496,
        "text": "نأتي به مقدماً متصلاً، فلأجل ذلك نقول هنا يجب",
        "video_link": null
      },
      {
        "ts": "25:05",
        "sec": 1505,
        "text": "أن يكون الترتيب هكذا؛ يجب تقديم المفعول على الفاعل، لأنه السبب في هذه الحالة،",
        "video_link": null
      },
      {
        "ts": "25:12",
        "sec": 1512,
        "text": "السبب أنه لو جيء بالمفعول مؤخراً لوجب",
        "video_link": null
      },
      {
        "ts": "25:19",
        "sec": 1519,
        "text": "انفصال الضمير، والحال أنه لا يؤتى بالضمير منفصلاً إذا كان بالإمكان أن يؤتى به متصلاً.",
        "video_link": null
      },
      {
        "ts": "25:27",
        "sec": 1527,
        "text": "وقد يكون هناك أسباب أخرى نعم،",
        "video_link": null
      },
      {
        "ts": "25:34",
        "sec": 1534,
        "text": "نعم في مثل: {وَإِذِ ابْتَلَىٰ إِبْرَاهِيمَ رَبُّهُ}، ابْتَلَى:",
        "video_link": null
      },
      {
        "ts": "25:40",
        "sec": 1540,
        "text": "فعل ماضٍ مبني على الفتح المقدر،",
        "video_link": null
      },
      {
        "ts": "25:49",
        "sec": 1549,
        "text": "إِبْرَاهِيمَ: مفعول به منصوب مقدم، رَبُّ: فاعل مرفوع مؤخر، واضح؟",
        "video_link": null
      },
      {
        "ts": "25:59",
        "sec": 1559,
        "text": "فهنا أيضاً التقديم والتأخير واجب، لمَ؟ لأنه لو أُخر المفعول",
        "video_link": null
      },
      {
        "ts": "26:07",
        "sec": 1567,
        "text": "فقيل: ابتلى ربه إبراهيم، حينئذٍ ما الذي يقع؟",
        "video_link": null
      },
      {
        "ts": "26:14",
        "sec": 1574,
        "text": "ابتلى ربه إبراهيم، الهاء في \"ربه\" ترجع على إبراهيم،",
        "video_link": null
      },
      {
        "ts": "26:21",
        "sec": 1581,
        "text": "فيكون الضمير حينئذٍ -الذي هو الهاء- يكون هذا الضمير عائداً على متأخر لفظاً ورتبة،",
        "video_link": null
      },
      {
        "ts": "26:32",
        "sec": 1592,
        "text": "متأخر لفظاً، هذا يتكرر كثيرا في كلام النحاة: العود عود الضمير على متأخر لفظاً",
        "video_link": null
      },
      {
        "ts": "26:39",
        "sec": 1599,
        "text": "ورتبة. ما معنى متأخر لفظاً؟ أي الضمير هنا وهو يعود على شيء يأتي بعده متأخر",
        "video_link": null
      },
      {
        "ts": "26:48",
        "sec": 1608,
        "text": "يأتي بعده في اللفظ، هذا هو معنى عائد على متأخر في اللفظ.",
        "video_link": null
      },
      {
        "ts": "26:55",
        "sec": 1615,
        "text": "ومتأخر رتبة لمَ؟ لأننا قلنا إن إبراهيم مفعول به،",
        "video_link": null
      },
      {
        "ts": "27:03",
        "sec": 1623,
        "text": "فهذا الضمير يعود على متأخر؛ الضمير الموجود مع الفاعل يرجع على المفعول،",
        "video_link": null
      },
      {
        "ts": "27:11",
        "sec": 1631,
        "text": "والمفعول متأخر في المرتبة بالمقارنة مع الفاعل، والقاعدة عندهم أن الأصل -قد يعدل عن هذا الأصل- لكن الأصل أن الضمير لا يعود على متأخر لفظاً ورتبة؛ لذلك لا يمكنك أن تقول:",
        "video_link": null
      },
      {
        "ts": "27:29",
        "sec": 1649,
        "text": "ابتلى ربه إبراهيم، لا بد يجب أن تقول: {وَإِذِ ابْتَلَىٰ إِبْرَاهِيمَ رَبُّهُ} فتقدم المفعول على",
        "video_link": null
      },
      {
        "ts": "27:38",
        "sec": 1658,
        "text": "الفاعل. قال: وَقَدْ يَتَقَدَّمُ الْمَفْعُولُ عَلَى الْفِعْلِ وَالْفَاعِلِ مَعاً. ما سبق هو في تقدم المفعول على الفاعل",
        "video_link": null
      },
      {
        "ts": "27:46",
        "sec": 1666,
        "text": "وحده، الآن تقدم المفعول على الفعل والفاعل معاً جَوَازاً وَأَيْضاً وُجُوباً. جَوَازاً نحو: {فَرِيقًا كَذَّبُوا وَفَرِيقًا يَقْتُلُونَ}؛",
        "video_link": null
      },
      {
        "ts": "27:54",
        "sec": 1674,
        "text": "فَرِيقًا: مفعول به منصوب مقدم، كَذَّبُوا: كَذَّبَ فعل ماضٍ مبني على الضم",
        "video_link": null
      },
      {
        "ts": "28:04",
        "sec": 1684,
        "text": "لاتصاله بواو الجماعة، وواو الجماعة فاعل. فإذن الفعل والفاعل، وجاء",
        "video_link": null
      },
      {
        "ts": "28:12",
        "sec": 1692,
        "text": "المفعول به مقدماً عليهما، ولكن هذا تقديم جائز لأنه يمكن أن يقال في غير القرآن:",
        "video_link": null
      },
      {
        "ts": "28:19",
        "sec": 1699,
        "text": "كذبوا فريقاً، ونفس الشيء {وَفَرِيقًا يَقْتُلُونَ} (يقتلون فريقاً)، هذا تقديم جائز. وَوُجُوباً نحو:",
        "video_link": null
      },
      {
        "ts": "28:28",
        "sec": 1708,
        "text": "{فَأَيَّ آيَاتِ اللَّهِ تُنكِرُونَ}، أَيَّ: مفعول به مقدم،",
        "video_link": null
      },
      {
        "ts": "28:37",
        "sec": 1717,
        "text": "تُنكِرُونَ: فعل وفاعله. لمَ هذا التقديم واجب؟ إذن هنا تقدم",
        "video_link": null
      },
      {
        "ts": "28:44",
        "sec": 1724,
        "text": "المفعول على الفعل والفاعل، لكن لمَ هو تقديم واجب؟ لأن \"أَيَّ\" اسم استفهام، وأسماء",
        "video_link": null
      },
      {
        "ts": "28:51",
        "sec": 1731,
        "text": "الاستفهام كما يقولون لها صدر الكلام. قال: لِأَنَّ الِاسْتِفْهَامَ لَهُ صَدْرُ الْكَلَامِ، ما معنى له صدر الكلام؟ يعني اسم الاستفهام يكون في",
        "video_link": null
      },
      {
        "ts": "29:00",
        "sec": 1740,
        "text": "بداية الكلام دائماً؛ فلا يمكنك أن تقول: تنكرون أيَّ آيات الله، لا، اسم الاستفهام له صدر الكلام",
        "video_link": null
      },
      {
        "ts": "29:09",
        "sec": 1749,
        "text": "فلأجل ذلك يقدم، لأن تأخير المفعول حينئذٍ ينافي هذه",
        "video_link": null
      },
      {
        "ts": "29:16",
        "sec": 1756,
        "text": "الصدارة التي تحدثنا عنها. فإذن هذا هذه بعض الأحكام",
        "video_link": null
      },
      {
        "ts": "29:23",
        "sec": 1763,
        "text": "الجميلة عن الفاعل والترتيب، خاصة هذا الحكم الأخير المتعلق بالترتيب بين الفعل",
        "video_link": null
      },
      {
        "ts": "29:31",
        "sec": 1771,
        "text": "والفاعل والمفعول. انتهينا من باب الفاعل، وبعده يأتي باب المفعول الذي لم يسمى",
        "video_link": null
      },
      {
        "ts": "29:41",
        "sec": 1781,
        "text": "فاعله. أقول قولي هذا وأستغفر الله لي ولكم، والحمد لله رب العالمين.",
        "video_link": null
      }
    ]
  },
  {
    "subject": "nahw",
    "subjectLabel": "علم النحو والصرف",
    "lesson": "الدرس 16",
    "lessonNum": 16,
    "title": "الدرس 16",
    "summary": "إليك \"الملخص الشامل للدرس\" (Fiche de Révision Intégrale) بناءً على تفريغ كلام الشيخ، مُنسقاً وفق المعايير المطلوبة:\n\n📚 <b>الملخص الشامل: أحكام نائب الفاعل والمبتدأ</b>\n\n🔹 <b>الخلاصة المحورية للدرس (في أسطر):</b>\n<blockquote>يتناول الدرس مبحثين أساسيين من \"المرفوعات\" في النحو العربي؛ الأول: <b>نائب الفاعل</b> (تعريفه، تغييره لصيغة الفعل، وما ينوب عن الفاعل)، والثاني: <b>المبتدأ</b> (تعريفه، أقسامه، مسوغات الابتداء بالنكرة، ومكانة المصدر المؤول).</blockquote>\n\n🔹 <b>الأحداث والوقائع / القواعد والمسائل بالتفصيل:</b>\n\n<blockquote>\n• <b>تعريف نائب الفاعل:</b> هو الاسم المرفوع الذي حُذف فاعله وأُقيم هو مقامه، فصار مرفوعاً بعد أن كان منصوباً (في الأصل مفعولاً به)، وأصبح \"عمدة\" بعد أن كان \"فضلة\"، مما يمنع حذفه أو تقديمه على الفعل.\n• <b>أحكام الفعل مع نائب الفاعل:</b> يجب تأنيث الفعل إذا كان نائب الفاعل مؤنثاً (حقيقي أو مجازي كالأرض)، ولا تلحق الفعل علامة تثنية أو جمع إذا كان النائب مثنى أو مجموعاً (يُقال: <code>ضُرِبَ الزَّيْدَانِ</code>).\n• <b>تغيير صيغة الفعل (بناء الفعل للمفعول):</b>\n- الماضي: يُضم أوله ويُكسر ما قبل آخره (<code>ضُرِبَ</code>).\n- المضارع: يُضم أوله ويُفتح ما قبل آخره (<code>يُضْرَبُ</code>).\n- الماضي المبدوء بتاء زائدة: يُضم أوله وثانيه (<code>تُعُلِّمَ</code>).\n- الماضي المبدوء بهمزة وصل: يُضم أوله وثالثه (<code>أُسْتُخْرِجَ</code>).\n- الماضي معتل العين (الأجوف): فيه ثلاث لغات (كسر فائه مع قلب عينه ياءً <code>قِيلَ</code>، الإشمام، أو ضم فائه مع قلب عينه واواً <code>قُولَ</code>).\n• <b>ما ينوب عن الفاعل:</b> ينوب عن الفاعل (1) المفعول به، (2) الظرف، (3) الجار والمجرور، (4) المصدر.\n• <b>المبتدأ:</b> هو الاسم المرفوع العاري عن العوامل اللفظية، وعامله \"معنوي\" هو الابتداء.\n• <b>أقسام المبتدأ:</b> (1) مبتدأ له خبر، (2) مبتدأ له مرفوع سد مسد الخبر (يحدث إذا كان المبتدأ اسم فاعل أو اسم مفعول معتمداً على نفي أو استفهام).\n• <b>مسوغات الابتداء بالنكرة:</b> الأصل في المبتدأ المعرفة، ولا يُبتدأ بالنكرة إلا بمسوغ مثل: (تقدم نفي أو استفهام، وصف النكرة، إضافتها، أو تقدم الخبر الظرف/الجار والمجرور).\n• <b>المصدر المؤول:</b> قد يقع المبتدأ مصدراً مؤولاً من \"أن\" والفعل، مثل: <code>{وَأَن تَصُومُوا خَيْرٌ لَّكُمْ}</code>.\n</blockquote>\n\n🔹 <b>الأسماء والمصطلحات الرئيسية:</b>\n\n<blockquote>\n• <b>المبني للمفعول:</b> هو الفعل الذي حُذف فاعله وأُسند إلى مفعوله أو ما يقوم مقامه.\n• <b>العمدة والفضلة:</b> العمدة (كالنائب عن الفاعل والمبتدأ) لا يصح الاستغناء عنه، والفضلة (كالمفعول قبل النيابة) هو ما يمكن حذفه.\n• <b>الإشمام:</b> خلط الكسرة بصوت الضمة عند نطق الفعل معتل العين (مثل <code>قِيلَ</code>).\n• <b>العامل المعنوي:</b> هو العامل الذي لا نلفظ به (مثل الابتداء في المبتدأ).\n</blockquote>\n\n🔹 <b>العِبر والأحكام المستفادة:</b>\n\n<blockquote>\n• أهمية \"البلاغة\" في النحو، حيث يكون حذف الفاعل لغرض بلاغي وليس عبثاً.\n• التيسير في اللغة العربية؛ فوجود أكثر من لغة في تصريف الفعل (كـ <code>قِيلَ</code> و <code>قُولَ</code>) يدل على سعة اللسان العربي.\n• الربط بين علمي النحو والصرف من خلال الميزان الصرفي وتغيير حركات الأفعال.\n</blockquote>\n\n🔹 <b>سؤال تدبر ومراجعة ذاتية:</b>\n\n<blockquote>لماذا لا يجوز -في رأي النحاة- الابتداء بالنكرة في الجملة التامة دون مسوغ؟ وكيف تُحول النكرة إلى ما يشبه المعرفة في المسوغات التي ذكرها الشيخ (الوصف والإضافة)؟</blockquote>",
    "full_text": "بسم الله الرحمن الرحيم، الحمد لله رب العالمين، وصلى الله وسلم، أعيد. بسم الله الرحمن الرحيم، الحمد لله رب العالمين، وصلى الله وسلم وبارك على نبينا محمد وعلى آله وصحبه والتابعين، ومن تبعهم بإحسان إلى يوم الدين. في باب المرفوعات أو في القسم الخاص بالمرفوعات من الأسماء، ذكرنا الأول منها وهو الفاعل، ثم نذكر اليوم الثاني وهو المفعول الذي لم يُسمَّ فاعله، والذي قد يُسمى عند الكثير من الناس من النحاة وغيرهم: نائب الفاعل. قال: وهو الاسم المرفوع الذي لم يُذكر معه فاعله، وأُقيم هو مقامه فصار مرفوعاً بعد أن كان منصوباً، وعمدة بعد أن كان فضلة؛ مثلاً: ضَرَبَ زَيْدٌ عَمْراً، لا أريد إذاً ضرب: فعل، زيد: فاعل، عمرو: مفعول به. هذا الفاعل لسبب من الأسباب وهي أسباب مختلفة يذكرها البلاغيون لا أريد ذكرها، فأحذف هذا الفاعل. حينئذٍ ما الذي يقع؟ يصبح هذا المفعول قائماً مقام الفاعل وتُغيّر صيغة الفعل، فأقول بدلاً من ضَرَبَ زَيْدٌ عَمْراً، أقول: ضُرِبَ عَمْرٌو. هذا معنى قولنا: هو الاسم المرفوع \"عمرو\" الذي لم يُذكر معه فاعله، لأننا حذفنا الفاعل الذي هو زيد؛ فاعل الضرب محذوف لا ندري من فعل هذا الضرب، وأُقيم هو مقامه؛ أي أُقيم مقامه أي أُقيم عمرو مقام زيد فصار مرفوعاً بعد أن كان منصوباً، هذا واضح \"عمراً\" صارت \"عمرو\"، وصار عمدة بعد أن كان فضلة؛ لأنه يمكن أن تقول: ضرب زيد، يعني كان المفعول فضلة في الكلام، لكن بعد ذلك صار عمدة لأنك لا يمكنك أن تحذف \"عمرو\" من جملة ضُرِبَ عَمْرٌو، فصار عمدة بعد أن كان فضلة. لأنه صار عمدة، ينبني على ذلك أنه لا يجوز حذفه ولا تقديمه على الفعل، لا يمكن حذفه لأنه عمدة ولا تقديمه على الفعل. فلا يمكنك أن تقول: عَمْرٌو ضُرِبَ، لأنه في هذه الحالة يمكنك أن تقول ذلك لكن في هذه الحالة لا يمكنك أن تعرب عمرو نائباً عن الفاعل، بل تقول: عمروٌ مبتدأ، وضُرِبَ فعل والنائب عن الفاعل ضمير مستتر، والجملة الفعلية خبر المبتدأ، كما قلنا في الفاعل بالضبط. قال: ويجب تأنيث الفعل إن كان مؤنثاً، نحو: ضُرِبَتْ هِنْدٌ، ونحو: {إِذَا زُلْزِلَتِ الْأَرْضُ}. إذن لا بد من أن تقول: ضُرِبَتْ هِنْدٌ، فتؤنث الفعل حين يكون نائب الفاعل مؤنثاً حقيقياً، نحو: ضُرِبَتْ هِنْدٌ، أو أيضاً إذا كان نائب الفاعل مثل الأرض، إذا كان نائب الفاعل إذاً مجازي التأنيث، نحو الأرض في قول ربنا سبحانه وتعالى: {إِذَا زُلْزِلَتِ الْأَرْضُ}؛ فهمت مثال حقيقي التأنيث، والأرض مثال على مجازي التأنيث. ويجب أن لا يلحق الفعل علامة تثنية أو جمع إن كان مثنى أو مجموعاً، نحو: ضُرِبَ الزَّيْدَانِ وضُرِبَ الزَّيْدُونَ؛ ويُسمى هذا ذكرناه من قبل في الفاعل حين ذكرنا أنك تقول إن الفعل يبقى لا يتغير بل يبقى على أصله، على أصله فلا تلحقه علامة تثنية ولا علامة جمع إذا كان الفاعل مثنى أو مجموعاً، كذلك الشيء نفسه نقوله هنا. ويُسمى أيضاً النائب عن الفاعل ماذا؟ كما ذكرنا أولاً: النائب عن الفاعل، قال: وهذه العبارة أحسن وأخصر. \"أحسن\" هذا محل نقاش عند النحاة، وإن كان يعني يمكن أن تقول إنها أحسن لأنها أوضح، وأخصر لا شيء كأنها أكثر اختصاراً، لكن بعض النحاة ينازع في هذا ويقول: بل المفعول الذي لم يسم فاعله أو لا، فعلى كل حال هذه مسألة اصطلاحية لا ينبني عليها كبير شيء؛ إذا قلت نائب الفاعل أو النائب عن الفاعل فالكلام واضح. ويُسمى فعله: الفعل المبني للمفعول، والفعل المجهول، والفعل الذي لم يسم فاعله، نحو: ضُرِبَ. الآن سيتكلم عن هذا الفعل، لأنك حين تحذف الفاعل وتقيم المفعول مقامه، الفعل يتغير؛ هذا الفعل يُسمى فعلاً مبنياً للمفعول ويُسمى فعلاً مجهولاً، الفعل المجهول، أليس كذلك؟ ما معنى المجهول؟ أي المجهول فاعله، ويُسمى الفعل الذي لم يسم فاعله، جميل. فإن كان الفعل ماضياً ضُمَّ أوله وكُسِر ما قبل آخره، ضَرَبَ هذا فعل ماضي \"ضَرَبَ\"، إذا أردت المبني للمفعول منه فأنت تقول: ضُرِبَ؛ إذاً تضم أوله وتكسر ما قبل آخره: ضُرِبَ. كذلك مثلاً دَحْرَجَ تصبح: دُحْرِجَ، دُحْرِجَتِ الكُرَةُ مثلاً استَخْرَجَ؛ استخرج العامل الذهب، أُسْتُخْرِجَ الذَّهَبُ، جميل. وإن كان مضارعاً ضُمَّ أوله وفُتِحَ ما قبل آخره، نحو: أوله وفُتِح ما قبل آخره؛ نحو: ضُرِبَ زَيْدٌ هذا للماضي، ويُضْرَبُ زَيْدٌ هذا للمضارع. إذن يُضْرَبُ تصبح: يُضْرَبُ، يُضم أوله ويُفتح ما قبل آخره. فإن كان الماضي مبدوءاً بتاء زائدة ضُمَّ أوله وثانيه، نحو: تَعَلَّمَ وتَدَرَّبَ؛ تَعَلَّمَ زَيْدٌ النَّحْوَ، هذا فعل ماضي مبدوء بالتاء هاته تاء زائدة، فعند الإتيان بالمبني للمفعول تقول: تُعُلِّمَ النَّحْوُ أو تُعُلِّمَ الدَّرْسُ، فلا تكتفي بضم التاء بل تضم التاء وتضم معها الحرف الثاني أيضاً \"تُدُرِّبَ\" كذلك. وإن كان مبدوءاً بهمزة وصل، نحو: اِنْطَلَقَ واِسْتَخْرَجَ، ضُمَّ أوله وثالثه؛ فتقول: أُونْطُلِقَ، أُسْتُخْرِجَ؛ فيُضم أوله ولكن يُضم كذلك الثالث. اِنْطَلَقَ؛ الطاء هي الثالثة تصبح: أُونْطُلِقَ، اِسْتَخْرَجَ: أُسْتُخْرِجَ، يُضم الأول وهو همزة الوصل ويُضم الثالث أيضاً، أما الآخر فهذا قد ذكرناه من قبل قلنا إنه يُكسر ما قبل آخره. وإن كان الماضي معتل العين فلك كسر فائِه فتصير عينه ياءً، نحو: قِيلَ وبِيعَ. هذا الماضي \"قَالَ\" و\"بَاعَ\" معتل العين، ما معنى معتل العين؟ أي معتل الحرف الثاني. في علم الصرف حين يذكرون الميزان الصرفي، يذكرون لك أن الكلمات كلها توزن بما يُسمى الميزان الصرفي، وهذا الميزان الصرفي مبني على الفاء والعين واللام، على \"فَعَلَ\"؛ فاء الكلمة هو المقصود بها حرفها الأول، وعين الكلمة الحرف الثاني، ولام الكلمة الحرف الثالث. فإذا قال عينها، هي هذه الألف الوسط الحرف الثاني. فإذا كان الماضي معتل العين، فإذاً هذه العين التي هي الحرف الثاني معتلة لأنها هنا ألف \"قَالَ\" \"بَاعَ\"، فإن كان الماضي معتل العين فلك يعني عندك خيارات؛ الخيار الأول: فلك كسر فائِه (الفاء هو الحرف الأول كما قلنا) فتصير عينه ياءً؛ إذاً قال: تكسر فاء الكلمة وهي القاف فتصبح: قِـ، وحينئذٍ الكسرة هذه لا بد لها من ياء بعدها فتقول: قِيلَ، أو بِيعَ؛ إذاً باع زيد سلعةً: بِيعَتِ السِّلْعَةُ. ولك إشمام الكسرة الضمة، وهو خلط الكسرة بشيء من صوت من صوت الضمة؛ بمعنى تقول: قِيلَ، فتشم الكسرة ضمة، تزيد مع الضمة مع الكسرة شيئاً من الضمة. القُرّاء يقولون: ضم الشفتين، يعني من قرأ في علم التجويد يقول الإشمام هو ضم الشفتين بحيث تقول قِيلَ قِيلَ، تضم الشفتين عند النطق بالفاء، فلأجل ذلك يعني هذا هو الإشمام كما يقوله النحاة. وبطبيعة الحال هناك من يسميه بغير ذلك، فالمقصود أن حركة قِيلَ وبِيعَ تكون بين الضمة والكسرة؛ قِيلَ بِيعَ. ولك ضم الفاء فتصير عينه واواً ساكنة، هذا الخيار الثالث فتصبح: قُولَ وبُوعَ، يعني تصبح ضمة خالصة، وهذا هذه لغة لبعض العرب؛ *\"ليت وهل ينفع شيئاً ليت ... ليت شباباً بُوعَ فاشتريت\"*، *\"ليت شباباً بُوعَ\"* هي بمعنى لكن هي لغة لبعض العرب. إذن لك هذه الخيارات الثلاثة. ثم قال: والنائب عن الفاعل على قسمين: ظاهر ومضمر؛ فالظاهر نحو: {وَإِذَا قُرِئَ الْقُرْآنُ}، قُرِئَ: فعل ماض مبني للمفعول أو مبني لما لم يسم فاعله مبني على الفتح الظاهر على آخره، القرآنُ: نائب الفاعل. ضُرِبَ مِثْلٌ نفس الشيء، {قُضِيَ الْأَمْرُ}، {قُتِلَ الْخَرَّاصُونَ}؛ الخرّاصون: نائب الفاعل مرفوع وعلامة رفعه الواو النائبة عن الضمة لأنه جمع مذكر سالم، كذلك {يُعْرَفُ الْمُجْرِمُونَ}، هذه كلها أمثلة على الاسم الظاهر. والمضمر نحو: ضُرِبْتُ، ضُرِبْنَا، ضُرِبْتَ، إلى آخر ما تقدم؛ فتقول في \"ضُرِبْتُ\": فعل ماض مبني للمفعول مبني على السكون لاتصاله بالتاء المتحركة، والتاء المتحركة ضمير متصل مبني في محل رفع نائب الفاعل. لكن يبنى الفعل للمفعول وينوب عن الفاعل واحد من أربعة، واضح؟ لما قال \"لكن\" هذه للاستدراك لكي يرفع عن قارئ هذا الكتاب ما يمكن أن يتوهمه من أن النائب عن الفاعل هو المفعول فقط، فيقول له: لا، ليس كذلك النائب عن الفاعل؛ صحيح أن الغالب والمستعمل كثيراً هو المفعول لكن قد ينوب عن الفاعل شيء آخر. لكن يبنى الفعل المفعول وينوب عن الفاعل واحد من أربعة؛ الأول: المفعول به، كما تقدم في الأمثلة السابقة أن المفعول به هو الذي ينوب عن الفاعل فيصبح نائباً عن الفاعل. الثاني: الظرف، نحو: جُلِسَ أَمَامَكَ، وصِيمَ رَمَضَانُ. جُلِسَ أَمَامَكَ، أصل الكلام مثلاً: جَلَسَ زَيْدٌ أَمَامَكَ؛ زيد هو الفاعل حُذف بغرض بلاغي، فينوب عنه لأن \"جَلَسَ\" هذه ليست متعدية، ليست فعلاً متعدياً لا لا مفعول لها، فنأتي بالظرف هو الذي يعوض الفاعل: جُلِسَ أَمَامَكَ. صِيمَ رَمَضَانُ؛ صَامَ العَابِدُ رَمَضَانَ، رمضانَ هذا ظرف، حُذف الفاعل وهو العابد فصارت: صِيمَ رَمَضَانُ. الثالث: الجار والمجرور، نحو: {وَلَمَّا سُقِطَ فِي أَيْدِيهِمْ}، {وَلَمَّا سُقِطَ فِي أَيْدِيهِمْ} يعني بنو إسرائيل حين ندموا على عبادتهم العجل، فَسُقِطَ في أيديهم؛ نقول سُقِطَ هذه فعل ماض مغير الصيغة، في أيديهم جار ومجرور واضح، في: حرف جر، وأيدي: مجرور، والشاهد من هذا هو أن جملة الجار والمجرور \"في أيديهم\" في محل جر في محل رفع نائب الفاعل، جميل. {وَلَمَّا سُقِطَ}، ثم قال الرابع: المصدر، نحو: {فَإِذَا نُفِخَ فِي الصُّورِ نَفْخَةٌ وَاحِدَةٌ}، {فَإِذَا نُفِخَ فِي الصُّورِ نَفْخَةٌ وَاحِدَةٌ}؛ نُفِخَ: فعل ماض مغير الصيغة مبني على الفتح الظاهر في آخره، في الصور: جار ومجرور، نفخةٌ: نائب الفاعل وهو مصدر. وأصل الكلام مثلاً يعني مثلاً: فإذا نفخ الملك نفخةً، إذا نفخ الملك في الصور نفخةً واحدةً، فـ \"نفخةٌ\" هنا ليس مفعولاً به وإنما هو مصدر يعني هو الذي صار نائباً عن الفاعل، جميل. المقصود بالمصدر هنا المفعول المطلق، سياتينا في باب منصوبات الأسماء المفاعيل ومنها المفعول المطلق؛ يمكن أن يُقال مفعول مطلق ويمكن الناس تقول مصدر، جميل؛ {فَإِذَا نُفِخَ فِي الصُّورِ نَفْخَةٌ وَاحِدَةٌ}. قال: ولا ينوب غير المفعول به مع وجوده غالباً؛ أي إذا كان المفعول موجوداً فهو الأحق، المفعول به إذا كان موجوداً فهو الأحق بأن ينوب عن الفاعل حين يُحذف الفاعل، يأتي المفعول به هو الذي يقوم مقامه؛ هذا في الغالب وفي المسألة خلاف عند النحاة. قال: وإذا كان الفعل متعدياً لِاثنين جُعل أحدهما نائباً عن الفاعل ويُنصب الثاني، نحو: أُعْطِيَ زَيْدٌ دِرْهَماً. \"أَعْطَى\" هذه من الأفعال التي تتعدى لِمفعولين، فتقول: أَعْطَى عَمْرٌو زَيْداً دِرْهَماً؛ أعطى: فعل ماضي، عَمْرٌو: فاعل، زيداً: مفعول أول، درهماً: مفعول ثاني. حين حذفنا عمرو، حين حذفنا عمرو أُقيم المفعول الأول مقامه وهو زيد فصار: أُعْطِيَ زَيْدٌ دِرْهَماً، واضح؟ فإذاً يُجعل الأول نائباً عن الفاعل ويُنصب الثاني منهما، أليس كذلك؟ طيب، أُعْطِيَ زَيْدٌ دِرْهَماً، جميل. إذاً بهذا ننهي ماذا؟ هذا المبحث المتعلق بنائب الفاعل. باب المبتدأ والخبر، وفيه نوعان من المرفوعات: المبتدأ والخبر كلاهما. يبدأ بالمبتدأ، يقول: المبتدأ هو الاسم المرفوع العاري عن العوامل اللفظية. المبتدأ إذا أردت الاختصار تقول: المبتدأ هو الاسم المرفوع الذي يبدأ به الكلام، لكن هذا بطبيعة الحال ليس ليس تعريفاً صحيحاً، لكن إذا أردنا الاختصار هو كذلك؛ فهو اسم مرفوع عارٍ أي مجرد عن العوامل اللفظية. فمثلاً حين أقول: كَانَ زَيْدٌ قَائِماً، زيدٌ صحيح أنه اسم مرفوع لكن فيه عامل لفظي يعمل فيه وهو \"كَانَ\". قَامَ زَيْدٌ، زيدٌ فاعل للفعل قام فـ \"قَامَ\" هو الفاعل الذي يعمل فيه، فإذاً هذه الأسماء ليست مجردة عن العوامل اللفظية؛ الأسماء المرفوعة تجد لها عوامل تعمل فيها عوامل لفظية، يعني مُتلفظاً بها. لكن المبتدأ حين تقول: زَيْدٌ قَائِمٌ، زيدٌ هذا مبتدأ مرفوع، ما الذي رفعه؟ أين العامل اللفظي الذي عمل فيه؟ يقولون: لا يوجد عامل لفظي عامل فيه، ولكن يوجد عامل معنوي؛ ما هذا العامل المعنوي؟ قالوا: هو الابتداء، مبتدأ مرفوع بالابتداء، واضح، وقائمٌ خبر والعامل فيه هو المبتدأ؛ إذن المبتدأ يعمل في الخبر هو الذي يرفع الخبر، لكن ما الذي يرفع المبتدأ؟ قالوا: الابتداء؛ ما معنى الابتداء؟ هذا عامل معنوي يعني كونه مبتدأً به، جميل. وهو قسمان: ظاهر ومضمر؛ فالمضمر \"أَنَا\" وأخواتها التي تقدمت في فصل المضمر وهي ضمائر الرفع المنفصلة؛ تقول: أَنَا قَائِمٌ، نَحْنُ قَائِمُونَ، أَنْتُمَا قَائِمَانِ، إلى غير ذلك؛ ضمائر الرفع المنفصلة كلها يمكن أن تقع مبتدأً، هذه هي الضمائر. قال: والظاهر قسمان: مبتدأ له خبر، ومبتدأ له مرفوع سد مسد الخبر؛ وهذا ربما شيء جديد عند الكثيرين. فالمبتدأ الذي له خبر، نحو: اللَّهُ رَبُّنَا؛ اللهُ: مبتدأ، ربُّ: خبر مرفوع وهو مضاف، ونا: مضاف إليه. مُحَمَّدٌ رَسُولُ اللَّهِ؛ محمدٌ: مبتدأ، رسولُ: خبر مرفوع وهو مضاف، لفظ الجلالة: مضاف إليه. والثاني، هذا هو الذي نحتاج إلى أن نقف عنده: مبتدأ له مرفوع سد مسد الخبر، ما معنى ذلك؟ معنى أنه قد يقع المبتدأ، قد يكون المبتدأ اسم فاعل أو اسم مفعول، ونحن قد ذكرنا من قبل أن اسم الفاعل واسم المفعول يعملان عمل الفعل، بمعنى يكون لهما مرفوع؛ اسم الفاعل يرفع مرفوعاً كما أن الفعل يرفع مرفوعاً هو فاعله، جميل. إذن الثاني يقول: هو اسم الفاعل واسم المفعول إذا تقدم عليهما نفي أو استفهام؛ بمعنى يُشترط لتحقق هذا الذي نذكره أن يتقدم على هذا المبتدأ استفهام أو نفي، فنقول إن هذا هذا المبتدا معتمد على النفي أو على الاستفهام؛ نحو: أَقَائِمٌ الزَّيْدَانِ؟ همزة الاستفهام إذاً الاستفهام موجود، قائمٌ: مبتدأ وأنت ترى أنه على صيغة اسم الفاعل، الزيدان: فاعل لِاسم الفاعل \"قائم\" سد مسد الخبر؛ بمعنى أن هذا المبتدأ، هذا المبتدأ حين رفع فاعلاً لم يحتج بعد ذلك إلى خبر، فإن ذلك الفاعل يقوم مقام الخبر أو يسد مسد الخبر. وكذلك: مَا قَائِمٌ الزَّيْدَانِ؛ هنا حالة الاعتماد على النفي لا الاستفهام، ما: نافية، قائمٌ: مبتدأ، الزيدان: فاعل لِاسم الفاعل لأن اسم الفاعل وهو قائمٌ يعمل عمل الفعل؛ إذاً الزيدان فاعل لاسم الفاعل يسد مسد الخبر. وكذلك: هَلْ مَضْرُوبٌ الْعُمْرَانِ؟ هل: أداة استفهام حرف استفهام، مضروبٌ: مبتدأ وهو على صيغة اسم المفعول، وحينئذٍ نقول: العِمران مضروب العِمران؛ العِمران هذا نائب فاعل لِمضروب، واضح؛ نائب فاعل سد مسد الخبر. لاحظ أنه في في اسم الفاعل أقول إنه يرفع فاعلاً، واسم المفعول يرفع نائباً عن الفاعل، وهذا مفهوم جداً يعني لا تحتاج إلى التفكير فيه كثيراً؛ لأنك حين تقول: أَقَائِمٌ الزَّيْدَانِ؟ كما لو قلت: أَيَقُومُ الزَّيْدَانِ؟ حينئذٍ فعل وزيدان فاعله. لكن هَلْ مَضْرُوبٌ الْعُمْرَانِ؟ في المعنى كما لو قلت: هل ضُرِبَ العِمران؟ هل يُضرب أو هل ضُرِبَ العِمران؟ وحينئذٍ العِمران نائب فاعل، لأن الفعل هنا يكون مبنياً لما لم يسم فاعله؛ فأنت ترى إذاً مع اسم الفاعل يكون هنالك فاعل، ومع اسم المفعول يكون عندنا نائب عن الفاعل، وفي الصورتين سواء أكان عندك فاعل أو نائب عن الفاعل فإنه يسد مسد الخبر. وكذلك في: وَمَا مَضْرُوبٌ الْعُمْرَانِ نفس الشيء، إنما هنا الاستناد على نفي لا على استفهام؛ ما: نافية، مضروبٌ: مبتدأ يعمل عمل الفعل مبتدأ يعمل عمل الفعل لأنه مفعول، العمران: نقول فيه إنه نائب عن الفاعل يسد مسد الخبر. ابن مالك يقول: *\"مبتدأ زيد وعاذر خبر إن قلت زيد عاذر من اعتذر ... وأول مبتدأ والثاني فاعل فاعل فاعل أغنى في أسار ذان\"*، يعني في نحو أسارٍ ذان تقول إن الثاني منهما من الاسمين تقول إنه فاعل أغنى، أي أغنى عن الخبر أو سد مسد الخبر: *\"فاعل أغنى أسار ذان\"*. وبطبيعة الحال الأصل هو الاعتماد على استفهام أو نفي، لكن قد يوجد يعني هذا هاته الصيغة دون هذا الاعتماد، كما قال في الألفية: نحو *\"فائز أولو الرشاد\"*، لكن الأصل هو هذا؛ الأصل أن يؤتى أن يكون ذلك معتمداً على استفهام أو على نفي، جميل. ولا يكون المبتدأ نكرة إلا بمسوغ، والمسوغات كثيرة؛ منها أن يتقدم على النكرة نفي أو استفهام، ومنها أن تكون موصوفة، إلى غير ذلك؛ هذه هي مسوغات الابتداء بالنكرة. فالاصل أن المبتدأ لا يكون نكرة وإنما يكون معرفة، ولا يجوز الابتداء بنكرة ما لم تفد؛ كـ *\"عند زيد نمرة وهل فتى فيكم وما خل لنا ... رجل من الكرام عندنا ورغبة في الخير خير وعمل بر يزين\"* وليقس ما لم يقل، كما يقول ابن مالك. ولا يكون المبتدأ نكرة إلا بمسوغ، سبب؛ المسوغات كثيرة ابن عقيل مثلاً في شرحه على ألفية ابن مالك ذكر أربعين من هذه المسوغات، سيذكر منها بعضها؛ قال: منها أن يتقدم على النكرة نفي أو استفهام، نحو: مَا رَجُلٌ قَائِماً، وَهَلْ رَجُلٌ جَالِسٌ. ما: نافية، رجلٌ: نكرة مبتدأ، ما الذي سوغ الابتداء بالنكرة؟ تقدم النفي أو الاستفهام. وهل رجل جالس نفس الشيء تقدم يعني في حالة \"ما رجل\" تقدم النفي، في حالة \"هل رجل جالس\" تقدم الاستفهام. وقوله تعالى: {أَإِلَٰهٌ مَّعَ اللَّهِ}، الهمزة استفهامية، إلهٌ: مبتدأ وهو نكرة لكن سوغ الابتداء بالنكرة تقدم الاستفهام. ومنها من المسوغات: أن تكون موصوفة، نحو: {وَلَعَبْدٌ مُّؤْمِنٌ خَيْرٌ}؛ أن تكون موصوفة أن يكون المبتدأ متبوعاً بنعت بصفة، نحو: وَلَعَبْدٌ مُّؤْمِنٌ، عبدٌ: مبتدأ هو نكرة، ما الذي سوغ الابتداء بالنكرة؟ وجود النعت \"مؤمن\"، ولعبد مؤمن خيرٌ؛ خيرٌ هو الخبر. ومنها: أن تكون مضافة، نحو حديث: \"خَمْسُ صَلَوَاتٍ كَتَبَهُنَّ اللَّهُ\"؛ خمسُ: مبتدأ وهو نكرة مضاف، صلواتٍ: مضاف إليه مجرور، مسوغ الابتداء بالنكرة وجود هذه الإضافة. \"كَتَبَهُنَّ اللَّهُ\" جملة فعلية هي في محل الخبر. وأنت يمكن أن تفهم هذا؛ فحين يكون حين تكون النكرة موصوفة أو حين تكون مضافة، فالوصف والإضافة قيد؛ النكرة قلنا هي شيء شائع في جنسه، حين نأتي بالإضافة فأنت تقيد هذا الشيوع، حين تأتي بالصفة كذلك أنت تقيد هذا الشيوع فتقترب النكرة من المعرفة حينئذٍ. ومنها أي من المسوغات: أن يكون الخبر ظرفاً أو جاراً ومجروراً مقدمين على النكرة، يعني تبدأ بالظرف أو بالجار والمجرور؛ نحو: عِنْدَكَ رَجُلٌ، فِي الدَّارِ امْرَأَةٌ؛ امرأةٌ: مبتدأ مؤخر وهو نكرة، ما الذي سوغ ذلك؟ تقدم الجار والمجرور، ونفس الشيء في عندك رجل. ومثله قوله تعالى: {وَلَدَيْنَا مَزِيدٌ}، مزيدٌ يعني مبتدأ مؤخر، لدينا: ظرف، لدى ظرف وهو مضاف ونا مضاف إليه؛ هذه شبه الجملة هاته هي المقدمة متعلقة بالخبر، ولأجل تقدمها سوغ ذلك أن يكون المبتدأ نكرة. وكذلك: {وَعَلَىٰ أَبْصَارِهِمْ غِشَاوَةٌ}، غشاوةٌ: مبتدأ مؤخر وهو نكرة، وسوغ ذلك تقدم الجار والمجرور عليه. قال: وقد يكون المبتدأ مصدراً مؤولاً من \"أَنْ\" والفعل، نحو: {وَأَن تَصُومُوا خَيْرٌ لَّكُمْ}؛ أي صومُكم خير لكم. وأن تصوموا؛ أن: حرف نصب ومصدر، حرف مصدري، تصوموا: فعل مضارع منصوب بأن وعلامة نصبه حذف النون لأنه من الأمثلة الخمسة، وواو الجماعة ضمير متصل في محل رفع فاعل. والمصدر المنسبك من أن والفعل المضارع بعدها في محل رفع المبتدأ، وتقدير الكلام: صومُكم خير لكم؛ خيرٌ: خبر مرفوع، ولكم: مجرور. فإذاً {وَأَن تَصُومُوا خَيْرٌ لَّكُمْ}، أن تصوموا هذا مصدر مسبوك، أن تصوموا عفواً المصدر المؤول من هذا الحرف ومن الفعل هو المبتدأ. ثم قال: والخبر هو الجزء المتم الفائدة؛ إذن في لقائنا المقبل نكمل حديثنا في هذا الباب باب المبتدأ والخبر، لكن بعد أن أنهينا المبتدأ نذكر بعد ذلك الخبر. أقول قولي هذا وأستغفر الله لي ولكم، والحمد لله رب العالمين.",
    "blocks_search_text": "نائب الفاعل: تعريفه وتغيير صيغة الفعل هو الاسم المرفوع الذي لم يُذكر معه فاعله، وأُقيم هو مقامه فصار مرفوعاً بعد أن كان منصوباً، وعمدة بعد أن كان فضلة شرح الشيخ ماهية نائب الفاعل وكيفية تحويل الجملة الفعلية بحذف الفاعل وإقامة المفعول به مقامه، مع توضيح التغيرات النحوية التي تطرأ على الجملة. قواعد بناء الفعل للمجهول (المبني للمفعول) فإن كان الفعل ماضياً ضُمَّ أوله وكُسِر ما قبل آخره، وإن كان مضارعاً ضُمَّ أوله وفُتِحَ ما قبل آخره فصل الشيخ الأحكام الصرفية المتعلقة بتغيير صيغة الفعل (الماضي والمضارع) عند بناء الجملة للمجهول، بما في ذلك حالات الأفعال المعتلة والمبدوءة بتاء زائدة أو همزة وصل. ما ينوب عن الفاعل ومسائل متفرقة يبنى الفعل للمفعول وينوب عن الفاعل واحد من أربعة: المفعول به، الظرف، الجار والمجرور، والمصدر بيّن الشيخ أن النائب عن الفاعل ليس محصوراً في المفعول به، بل قد ينوب عنه الظرف أو الجار والمجرور أو المصدر، مع توضيح كيفية التعامل مع الأفعال المتعدية لمفعولين. المبتدأ: تعريفه، أقسامه، ومسوغات الابتداء بالنكرة المبتدأ هو الاسم المرفوع العاري عن العوامل اللفظية، والظاهر قسمان: مبتدأ له خبر، ومبتدأ له مرفوع سد مسد الخبر شرح الشيخ حقيقة المبتدأ كاسم مرفوع بعامل معنوي، وأوضح الحالة التي يغني فيها فاعل اسم الفاعل (أو نائب فاعل اسم المفعول) عن الخبر، مع سرد مسوغات الابتداء بالنكرة.",
