      },
      {
        "ts": "5:24",
        "sec": 324,
        "text": "الخبث؛ أي النجاسة. ونحن ذكرنا في بداية هذه الدروس المباركة لما تحدثنا عن الطهارة،",
        "video_link": null
      },
      {
        "ts": "5:34",
        "sec": 334,
        "text": "قلنا الطهارة قسمان: طهارة خبث وطهارة حدث.",
        "video_link": null
      },
      {
        "ts": "5:41",
        "sec": 341,
        "text": "طهارة الخبث؛ أي من النجاسة، وهذه الطهارة تكون في الثوب، وفي البدن، وفي المكان.",
        "video_link": null
      },
      {
        "ts": "5:53",
        "sec": 353,
        "text": "المصلي يُشترط لصحة صلاته أن يكون ثوبه طاهراً ليس فيه نجاسة،",
        "video_link": null
      },
      {
        "ts": "6:03",
        "sec": 363,
        "text": "وبدنه طاهراً ليس فيه نجاسة، والمكان الذي يصلي فيه طاهراً ليس فيه نجاسة؛ نجاسة مثل:",
        "video_link": null
      },
      {
        "ts": "6:12",
        "sec": 372,
        "text": "البول، والغائط، ودم الحيض؛ الأمور التي التي حكم الشرع بنجاستها.",
        "video_link": null
      },
      {
        "ts": "6:20",
        "sec": 380,
        "text": "مثلاً طهارة البدن من أدلتها قول النبي صلى الله عليه وسلم:",
        "video_link": null
      },
      {
        "ts": "6:27",
        "sec": 387,
        "text": "\"اسْتَنْزِهُوا مِنَ الْبَوْلِ، فَإِنَّ عَامَّةَ عَذَابِ الْقَبْرِ مِنْهُ\"؛ وذكرنا هذا الحديث سابقاً:",
        "video_link": null
      },
      {
        "ts": "6:35",
        "sec": 395,
        "text": "\"اسْتَنْزِهُوا مِنَ الْبَوْلِ، فَإِنَّ عَامَّةَ عَذَابِ الْقَبْرِ مِنْهُ\". فيجب تطهير البدن، فمن كان على بدنه",
        "video_link": null
      },
      {
        "ts": "6:44",
        "sec": 404,
        "text": "نجاسة وجب عليه إزالتها قبل أن يصلي. طهارة الثوب؛",
        "video_link": null
      },
      {
        "ts": "6:53",
        "sec": 413,
        "text": "روى البخاري في صحيحه من حديث خولة بنت يسار رضي الله عنها أنها قالت: يا رسول",
        "video_link": null
      },
      {
        "ts": "6:59",
        "sec": 419,
        "text": "الله، ليس لي إلا ثوب واحد وأنا أحيض فيه؛ فقال لها النبي صلى الله عليه وسلم: \"إِذَا طَهُرْتِ",
        "video_link": null
      },
      {
        "ts": "7:08",
        "sec": 428,
        "text": "فَاغْسِلِي مَوْضِعَ الدَّمِ ثُمَّ صَلِّي فِيهِ\"؛ إذا طهرت فاغسلي",
        "video_link": null
      },
      {
        "ts": "7:15",
        "sec": 435,
        "text": "موضع الدم ثم صلي فيه. فدل هذا على وجوب غـ",
        "video_link": null
      },
      {
        "ts": "7:23",
        "sec": 443,
        "text": "تطهير الثوب من النجاسة ودم الحيض. والنبي صلى الله عليه وسلم كان يصلي في في",
        "video_link": null
      },
      {
        "ts": "7:32",
        "sec": 452,
        "text": "في نعليه؛ فمرة كان يصلي والصحابة يصلون خلفه في نعالهم، ففجأة رأوه خلع نعليه",
        "video_link": null
      },
      {
        "ts": "7:40",
        "sec": 460,
        "text": "فخلعوا نعالهم، فلما سلّم قال: \"مَا بَالُكُمْ أَلْقَيْتُمْ نِعَالَكُمْ؟\" قالوا: يا رسول الله رأيناك ألقيت فألقينا؛ فقال صلى الله عليه وسلم: \"إِنَّ",
        "video_link": null
      },
      {
        "ts": "7:49",
        "sec": 469,
        "text": "جِبْرِيلَ أَتَانِي فَأَخْبَرَنِي أَنَّ فِيهِمَا قَذَراً\" (يعني فهو كان يصلي في نعليه، فلما جاء",
        "video_link": null
      },
      {
        "ts": "7:55",
        "sec": 475,
        "text": "جبريل أخبره بأن نعله فيه نجاسة نزع نعله)؛",
        "video_link": null
      },
      {
        "ts": "8:00",
        "sec": 480,
        "text": "إذاً لا بد من طهارة الثوب. طهارة المكان أيضاً؛ المكان يصلي فيه لا بد أن يكون طاهراً،",
        "video_link": null
      },
      {
        "ts": "8:09",
        "sec": 489,
        "text": "ودليل هذا الحديث المتفق عليه المخرّج في البخاري ومسلم؛ حديث ذلك الأعرابي الذي جاء إلى",
        "video_link": null
      },
      {
        "ts": "8:17",
        "sec": 497,
        "text": "المسجد ثم بال في طائفة المسجد، فزجره الناس؛ فقال النبي صلى الله عليه وسلم: \"دَعُوهُ لَا تُزْرِمُوهُ\"؛ فلما انتهى قال صلى الله عليه",
        "video_link": null
      },
      {
        "ts": "8:25",
        "sec": 505,
        "text": "وسلم: \"دَعُوهُ وَأَهْرِيقُوا عَلَى بَوْلِهِ سَجْلاً مِنْ مَاءٍ\" أو قال: \"ذَنُوباً مِنْ مَاءٍ\". إذاً فهذا الرجل الأعرابي",
        "video_link": null
      },
      {
        "ts": "8:34",
        "sec": 514,
        "text": "كان يجهل أن المساجد لها حرمة فبال في المسجد، فالنبي صلى الله عليه وسلم قال: \"أهريقوا على بوله سجلاً من ماء\" يعني لِمَا؟ حتى",
        "video_link": null
      },
      {
        "ts": "8:41",
        "sec": 521,
        "text": "يتطهر هذا المكان الذي يصلي فيه الناس. إذاً طهارة الخبث شرط لصحة الصلاة.",
        "video_link": null
      },
      {
        "ts": "8:54",
        "sec": 534,
        "text": "ثم قال رحمه الله: \"وَسَتْرُ عَوْرَةٍ\"؛ وستر عورة.",
        "video_link": null
      },
      {
        "ts": "9:01",
        "sec": 541,
        "text": "ستر العورة أيضاً شرط لصحة الصلاة. سبحان الله هذا من أهمية الصلاة؛ شوف",
        "video_link": null
      },
      {
        "ts": "9:08",
        "sec": 548,
        "text": "الكلام على الصلاة، نحن حاولنا أن نقدم مقدمة يسيرة في أول ما بدأنا نتحدث عن الصلاة، لكن الكلام على الصلاة كلام طويل جداً؛ هذه",
        "video_link": null
      },
      {
        "ts": "9:17",
        "sec": 557,
        "text": "العبادة خصها الله بخصائص عجيبة جداً، منها أن هذا الذي يصلي شرط الله عز وجل له أن",
        "video_link": null
      },
      {
        "ts": "9:25",
        "sec": 565,
        "text": "أن يكون على أكمل الهيئات والصفات، فلا يقف بين يدي ربه عز وجل كذا كما شاء وإنما",
        "video_link": null
      },
      {
        "ts": "9:31",
        "sec": 571,
        "text": "على أكمل هيئة؛ متوضئ يكون يقف متوضئاً متطهراً، مستقبل القبلة، متطهراً طهارة خبث",
        "video_link": null
      },
      {
        "ts": "9:40",
        "sec": 580,
        "text": "وطهارة حدث، ساتراً عورته. وسبحان الله يعني ا",
        "video_link": null
      },
      {
        "ts": "9:47",
        "sec": 587,
        "text": "ستر العورة دليلها قول الله عز وجل: {يَا بَنِي آدَمَ خُذُوا زِينَتَكُمْ عِندَ كُلِّ مَسْجِدٍ}، {يَا بَنِي آدَمَ",
        "video_link": null
      },
      {
        "ts": "9:54",
        "sec": 594,
        "text": "خُذُوا زِينَتَكُمْ عِندَ كُلِّ مَسْجِدٍ}. وأيضاً قول النبي صلى الله عليه وسلم -كما عند أبي",
        "video_link": null
      },
      {
        "ts": "10:01",
        "sec": 601,
        "text": "داوود والترمذي من حديث عائشة رضي الله عنها- قال صلى الله عليه وسلم: \"لَا يَقْبَلُ اللَّهُ",
        "video_link": null
      },
      {
        "ts": "10:08",
        "sec": 608,
        "text": "صَلَاةَ حَائِضٍ إِلَّا بِخِمَارٍ\"؛ لا يقبل الله صلاة حائض (أي التي بلغت، أي إن بلغت سن الحيض",
        "video_link": null
      },
      {
        "ts": "10:17",
        "sec": 617,
        "text": "يعني أصبحت مكلفة): \"لَا يَقْبَلُ اللَّهُ صَلَاةَ حَائِضٍ إِلَّا بِخِمَارٍ\". ليس المقصود هنا صلاة حائض التي هي",
        "video_link": null
      },
      {
        "ts": "10:26",
        "sec": 626,
        "text": "يعني في مدة الحيض وفي أيام الحيض، إنما التي من شأنها أن تحيض (المرأة البالغة)؛ المقصود: لا يقبل الله صلاة حائض إلا بخمار.",
        "video_link": null
      },
      {
        "ts": "10:35",
        "sec": 635,
        "text": "عورة الرجل: ما بين السرة إلى الركبة، ما بين السرة إلى الركبة عورة؛ لا تصح صلاة",
        "video_link": null
      },
      {
        "ts": "10:43",
        "sec": 643,
        "text": "الرجل الذي صلى كاشفاً عورته عامداً. المرأة عورتها في الصلاة... وجهها",
        "video_link": null
      },
      {
        "ts": "10:53",
        "sec": 653,
        "text": "وكفاها، وجهها وكفاها الصلاة",
        "video_link": null
      },
      {
        "ts": "11:03",
        "sec": 663,
        "text": "عفواً عفواً عفواً؛ عورة الصلاة ما عدا الوجه والكفين، عفوـ؛ هذا الذي قصدته. عورة المرأة في",
        "video_link": null
      },
      {
        "ts": "11:10",
        "sec": 670,
        "text": "الصلاة: ما عدا الوجه والكفين؛ عورة المرأة في الصلاة",
        "video_link": null
      },
      {
        "ts": "11:18",
        "sec": 678,
        "text": "سائر جسدها ما عدا الوجه والكفان، فهما فقط اللذان يُباح",
        "video_link": null
      },
      {
        "ts": "11:28",
        "sec": 688,
        "text": "للمرأة أو هما فقط اللذان تظهرهما المرأة في الصلاة، ما عدا الوجه والكفين يجب ستره. إذاً عورة",
        "video_link": null
      },
      {
        "ts": "11:38",
        "sec": 698,
        "text": "المرأة في الصلاة كل جسدها ما عدا",
        "video_link": null
      },
      {
        "ts": "11:45",
        "sec": 705,
        "text": "الوجه والكفان، هذان فقط يظهران الباقي يستر؛ وذاك من هنا ننبه أخواتنا",
        "video_link": null
      },
      {
        "ts": "11:53",
        "sec": 713,
        "text": "المسلمات إلى ضرورة تغطية القدم أيضاً، فإن بعض المسلمات تتهاون بشأن القدم فتتركه",
        "video_link": null
      },
      {
        "ts": "12:02",
        "sec": 722,
        "text": "مكشوفاً أثناء الصلاة وهذا لا ينبغي ولا يصح، بل لا بد من من",
        "video_link": null
      },
      {
        "ts": "12:08",
        "sec": 728,
        "text": "من ستر القدم أيضاً. ا",
        "video_link": null
      },
      {
        "ts": "12:12",
        "sec": 732,
        "text": "إذاً قال رحمه الله: \"وَسَتْرُ عَوْرَةٍ\"، ثم قال:",
        "video_link": null
      },
      {
        "ts": "12:19",
        "sec": 739,
        "text": "\"وَطُهْرُ الْحَدَثِ\"؛ طهر الحدث. وهذا تكلمنا عن دليله غير مرة؛ قال النبي صلى الله عليه",
        "video_link": null
      },
      {
        "ts": "12:25",
        "sec": 745,
        "text": "وسلم كما في حديث ابن عمر: \"لَا تُقْبَلُ صَلَاةٌ بِغَيْرِ طُهُورٍ\" (لا تقبل صلاة بغير طهور). ومن",
        "video_link": null
      },
      {
        "ts": "12:32",
        "sec": 752,
        "text": "حديث أبي هريرة رضي الله عنه قال صلى الله عليه وسلم: \"لَا يَقْبَلُ اللَّهُ صَلَاةَ أَحَدِكُمْ إِذَا",
        "video_link": null
      },
      {
        "ts": "12:40",
        "sec": 760,
        "text": "أَحْدَثَ حَتَّىٰ يَتَوَضَّأَ\"؛ إذاً فـ",
        "video_link": null
      },
      {
        "ts": "12:45",
        "sec": 765,
        "text": "طهارة الحدث شرط. ثم قال رحمه الله: \"بِالذِّكْرِ وَالْقُدْرَةِ فِي غَيْرِ الْأَخِيرْ\"؛ تقييد مهم جداً.",
        "video_link": null
      },
      {
        "ts": "13:00",
        "sec": 780,
        "text": "هذه الشروط الأربعة هي شروط بشرطين اثنين:",
        "video_link": null
      },
      {
        "ts": "13:09",
        "sec": 789,
        "text": "الذكر والقدرة في غير الأخير؛ في غير طهارة الحدث. يعني",
        "video_link": null
      },
      {
        "ts": "13:16",
        "sec": 796,
        "text": "طهارة الخبث، واستقبال القبلة، وستر العورة هي شروط تـ تبطل",
        "video_link": null
      },
      {
        "ts": "13:24",
        "sec": 804,
        "text": "الصلاة بتركها بشرط الذكر والقدرة؛ الذكر",
        "video_link": null
      },
      {
        "ts": "13:32",
        "sec": 812,
        "text": "ضده النسيان، القدرة ضدها العجز. بمعنى",
        "video_link": null
      },
      {
        "ts": "13:41",
        "sec": 821,
        "text": "مثلاً قلنا طهارة الخبث شرط؛ لو أن إنساناً",
        "video_link": null
      },
      {
        "ts": "13:48",
        "sec": 828,
        "text": "في ثوبه نجاسة، قال: \"حين أصلي سـ أغير الثوب\"،",
        "video_link": null
      },
      {
        "ts": "13:54",
        "sec": 834,
        "text": "ثم صلى ولم يتذكر، أنه لم يتذكر أن على ثوبه نجاسة إلا بعد أن",
        "video_link": null
      },
      {
        "ts": "14:03",
        "sec": 843,
        "text": "سلّم؛ نسيه، ما حكم صلاته؟ صحيحة، صحيحة.",
        "video_link": null
      },
      {
        "ts": "14:11",
        "sec": 851,
        "text": "قال: بالذكر. لو أن إنساناً مريض، لو أن إنساناً مريض",
        "video_link": null
      },
      {
        "ts": "14:20",
        "sec": 860,
        "text": "عاجز عن الحركة أصاب ثوبه نجاسة (مثلاً أصابه بول، أكرمكم",
        "video_link": null
      },
      {
        "ts": "14:27",
        "sec": 867,
        "text": "الله، أسأل الله أن يسترنا وأن يحسن عاقبتنا) ولم يجد من يساعده على تغيير ثيابه، أو كان",
        "video_link": null
      },
      {
        "ts": "14:37",
        "sec": 877,
        "text": "في تغيير ثيابه مشقة، أو مثلاً كان في المستشفى ولم يجد من من يقوم عليه فيغيّر ثوبه وحان وقت الصلاة؛ هل يترك الصلاة؟ لا",
        "video_link": null
      },
      {
        "ts": "14:46",
        "sec": 886,
        "text": "يترك الصلاة أبداً، يصلي بثوبه. طيب فيه نجاسة؟ نعم، ولكنه غير قادر على تغييرها، غير",
        "video_link": null
      },
      {
        "ts": "14:53",
        "sec": 893,
        "text": "قادر على تغييرها، عاجز عن تغييرها؛ يكون فعـ عاجز لا يكون عجزاً متوهماً، فعلاً عاجز",
        "video_link": null
      },
      {
        "ts": "15:01",
        "sec": 901,
        "text": "لا يستطيع تغيير ثوبه؛ هذا يصلي في ثوبه رغم أن فيه نجاسة،",
        "video_link": null
      },
      {
        "ts": "15:08",
        "sec": 908,
        "text": "واضح؛ هكذا. مثلاً استقبال القبلة؛ إنسان يعرف أن القبلة في هذا الاتجاه مثلاً هذا،",
        "video_link": null
      },
      {
        "ts": "15:17",
        "sec": 917,
        "text": "أن يصلي؛ نسي وصلى لِـ لغير اتجاه القبلة نسياناً، الصلاة صحيحة؟ صـ صحيحة. أو كان عاجزاً",
        "video_link": null
      },
      {
        "ts": "15:26",
        "sec": 926,
        "text": "عن استقبال القبلة؛ مثلاً إنسان يكون مريضاً في مستشفى، المستشفى في سرير يعني في غير اتجاه القبلة، وإنسان ربما على سريره",
        "video_link": null
      },
      {
        "ts": "15:36",
        "sec": 936,
        "text": "ومجموعة من الأجهزة مركبة عليه وحان وقت الصلاة، ولا يستطيع أن أن ينحرف ليستقبل",
        "video_link": null
      },
      {
        "ts": "15:43",
        "sec": 943,
        "text": "القبلة؛ يصلي على حاله ولو إلى غير القبلة. شوف سبحان الله أهمية الصلاة! إنسان ا",
        "video_link": null
      },
      {
        "ts": "15:50",
        "sec": 950,
        "text": "في في حرب في معركة والقتال قائم، والصلاة قرب خرج وقتها؛ قال تعالى: {فَإِنْ خِفْتُمْ فَرِجَالًا أَوْ رُكْبَانًا}؛ يصلي على حاله رغم أنه غير مسلـ",
        "video_link": null
      },
      {
        "ts": "15:58",
        "sec": 958,
        "text": "يستقبل القبله؛ يصلي على حاله: العجز، العجز؛ وهكذا. قال: إذاً",
        "video_link": null
      },
      {
        "ts": "16:07",
        "sec": 967,
        "text": "مثلاً ستر العورة أيضاً؛ إنسان نسي أو عجز عن ستر عورته، فكذلك نفس الأمر؛ فـ ذ قال رحمه",
        "video_link": null
      },
      {
        "ts": "16:16",
        "sec": 976,
        "text": "الله: \"بِالذِّكْرِ وَالْقُدْرَةِ فِي غَيْرِ الْأَخِيرْ\". معنى هذا أن الشروط الثلاثة الأولى التي هي",
        "video_link": null
      },
      {
        "ts": "16:25",
        "sec": 985,
        "text": "التي هي: الاستقبال، وطهارة الخبث، وستر العورة هي شروط ابتداء ودوام مع الذكر والقدرة،",
        "video_link": null
      },
      {
        "ts": "16:35",
        "sec": 995,
        "text": "وتسقط مع العجز والنسيان كما بينا الآن.",
        "video_link": null
      },
      {
        "ts": "16:43",
        "sec": 1003,
        "text": "فـ الإنسان الصلاة لا بد أن تؤدى الصلاة.",
        "video_link": null
      },
      {
        "ts": "16:50",
        "sec": 1010,
        "text": "ثم قال قال قال: \"بِالذِّكْرِ وَالْقُدْرَةِ فِي غَيْرِ الْأَخِيرْ\"؛ في غير الأخير الذي هو",
        "video_link": null
      },
      {
        "ts": "16:59",
        "sec": 1019,
        "text": "طهارة الحدث؛ أه هاد طهارة الحدث لا بد منها يعني \"فِي غَيْرِ الْأَخِيرْ\" يعني طهارة الحدث لو أن",
        "video_link": null
      },
      {
        "ts": "17:06",
        "sec": 1026,
        "text": "إنساناً، طبعاً الأمور الأخرى دليلها: {فَاتَّقُوا",
        "video_link": null
      },
      {
        "ts": "17:13",
        "sec": 1033,
        "text": "اللَّهَ مَا اسْتَطَعْتُمْ}، ويعني هذا بالنسبة لِشرط القدرة، وبالنسبة لِشرط الذكر قول النبي",
        "video_link": null
      },
      {
        "ts": "17:20",
        "sec": 1040,
        "text": "صلى الله عليه وسلم: \"إِنَّ اللَّهَ وَضَعَ عَنْ أُمَّتِي الْخَطَأَ وَالنِّسْيَانَ\" (إن الله وضع عن أمتي الخطأ",
        "video_link": null
      },
      {
        "ts": "17:28",
        "sec": 1048,
        "text": "والنسيان) وما استُكرهوا عليه؛ لكن طهارة الحدث هذه: \"لا تقبل صلاة بغير طهور\"، نص واضح",
        "video_link": null
      },
      {
        "ts": "17:38",
        "sec": 1058,
        "text": "قاطع: \"لَا تُقْبَلُ صَلَاةٌ بِغَيْرِ طُهُورٍ\"؛ فلا يسقط هذا الشرط",
        "video_link": null
      },
      {
        "ts": "17:47",
        "sec": 1067,
        "text": "حتى مع النسيان؛ مع النسيان مع النسيان لا يسقط، حتى نكون أكثر دقة حتى يكون كلامنا دقيقاً وواضحاً إن",
        "video_link": null
      },
      {
        "ts": "17:56",
        "sec": 1076,
        "text": "شاء الله مع النسيان لا يسقط؛ يعني لو أن إنساناً نسي وصلى على غير طهارة، ماذا ما",
        "video_link": null
      },
      {
        "ts": "18:04",
        "sec": 1084,
        "text": "الذ ماذا عليه أن يفعل؟ يعيد الصلاة؛ يتطهر ويعيد الصلاة، لا يسقط",
        "video_link": null
      },
      {
        "ts": "18:11",
        "sec": 1091,
        "text": "بالنسيان هذا؛ \"لَا تُقْبَلُ صَلَاةٌ بِغَيْرِ طُهُورٍ\"، \"لَا يَقْبَلُ اللَّهُ صَلَاةَ أَحَدِكُمْ إِذَا أَحْدَثَ حَتَّىٰ يَتَوَضَّأَ\"؛",
        "video_link": null
      },
      {
        "ts": "18:19",
        "sec": 1099,
        "text": "نسي؛ يتوضأ ويعيد الصلاة.",
        "video_link": null
      },
      {
        "ts": "18:28",
        "sec": 1108,
        "text": "لكن هذا مع النسيان، لكن مع العجز؛ لأن قال: \"بِالذِّكْرِ وَالْقُدْرَةِ فِي غَيْرِ الْأَخِيرْ *** تَفْرِيعُ نَاسِيهَا وَعَاجِزٍ كَثِيرْ\"؛ يعني كاين فروع مهمـ كثيرة في في هادو لعله ترجأ إن شاء",
        "video_link": null
      },
      {
        "ts": "18:42",
        "sec": 1122,
        "text": "الله إلى دراسة متن الرسالة بإذن الله عز وجل. قال العاجز؛ العاجز عن طهارة الحدث،",
        "video_link": null
      },
      {
        "ts": "18:52",
        "sec": 1132,
        "text": "مثلاً إنسان مريض ولا يجد",
        "video_link": null
      },
      {
        "ts": "19:01",
        "sec": 1141,
        "text": "من يناوله الماء ليتوضأ، أو لا يستطيع أن يتوضأ ولم يجد من يناوله ما يتيمم به.",
        "video_link": null
      },
      {
        "ts": "19:11",
        "sec": 1151,
        "text": "إنسان طريح فراش في مستشفى في كذا مثلاً ا لم يـ لا يمكنه أن يتوضأ كما قلنا؛ مثال نحن",
        "video_link": null
      },
      {
        "ts": "19:20",
        "sec": 1160,
        "text": "نعطي مثالاً ويُقاس ما لم يقل؛ الأجهزة مركبة عليه إلى آخره، لا يستطيع أن",
        "video_link": null
      },
      {
        "ts": "19:27",
        "sec": 1167,
        "text": "يتوضأ، تيمم لا يجد من يأتي ويمم",
        "video_link": null
      },
      {
        "ts": "19:34",
        "sec": 1174,
        "text": "في وجهه وكفيه، لم يجد من يممه؛ ماذا يفعل واقترب",
        "video_link": null
      },
      {
        "ts": "19:45",
        "sec": 1185,
        "text": "خروج وقت الصلاة، هل يصلي أم لا يصلي؟ هذه اختلف فيها علماؤنا رحمه الله عليهم، وفي",
        "video_link": null
      },
      {
        "ts": "19:51",
        "sec": 1191,
        "text": "خلاف بين بين المالكية أنفسهم حتى خارج المذهب.",
        "video_link": null
      },
      {
        "ts": "19:59",
        "sec": 1199,
        "text": "هذا الخلاف عبر عنه بعضهم بقوله: وَمَنْ لَمْ يَجِدْ مَاءً وَلَا مُتَيَمَّمًا *** فَأَرْبَعَةُ الْأَقْوَالِ يَحْكِينَ مَذْهَبَا يُصَلِّي وَيَقْضِي عَكْسُ مَا قَالَ مَالِكٌ *** وَأَشْهَبُ يَقْضِي وَالْأَدَاءُ لِأَشْهَبَا يعني أربعة أقوال؛ بعض فقهائنا -وهو رأي ابن القاسم",
        "video_link": null
      },
      {
        "ts": "20:24",
        "sec": 1224,
        "text": "علماء المالكية ومن تلاميذ الإمام مالك المشهورين الأماثل الأفذاذ- قال لك:",
        "video_link": null
      },
      {
        "ts": "20:31",
        "sec": 1231,
        "text": "يصلي ويقضي؛ يصلي على حاله بغير طهارة، ولكن الوقت اللي تيسرت الطهارة يقضي؛",
        "video_link": null
      },
      {
        "ts": "20:40",
        "sec": 1240,
        "text": "يصلي ويقضي. \"عَكْسُ مَا قَالَ مَالِكٌ\"؛ والإمام مالك رحمه الله قال لهم لا لا تسقط الصلاة عنه، قال لك من عجز عن من لم يجد ماء ولا متيمماً",
        "video_link": null
      },
      {
        "ts": "20:49",
        "sec": 1249,
        "text": "ما يستطيع لا يتيمم ولا يتوضأ، هذا قال الإمام مالك رحمهـ تسقط عنه الصلاة.",
        "video_link": null
      },
      {
        "ts": "20:55",
        "sec": 1255,
        "text": "\"وَأَشْهَبُ يَقْضِي\"؛ أشهب كذلك من من من أئمة المالكية، أشهب رحمه الله عليه قال لك:",
        "video_link": null
      },
      {
        "ts": "21:04",
        "sec": 1264,
        "text": "لا يصلي، ينتظر حتى تتيسر له طهارة الحدث ثم يقضي.",
        "video_link": null
      },
      {
        "ts": "21:12",
        "sec": 1272,
        "text": "و\"وَالْأَدَاءُ لِأَشْهَبَا\" الإمام أشهب رحمه الله عليه تقول لك:",
        "video_link": null
      },
      {
        "ts": "21:18",
        "sec": 1278,
        "text": "يؤدي (يعني يصلي على حاله)، يصلي على حاله ولا يحتاج إلى قضاء؛ ورأي أشهب أقوى رأي",
        "video_link": null
      },
      {
        "ts": "21:26",
        "sec": 1286,
        "text": "أشهب أرجح، أرجح وأقوى. ا",
        "video_link": null
      },
      {
        "ts": "21:35",
        "sec": 1295,
        "text": "يعني أن من عجز عن ا",
        "video_link": null
      },
      {
        "ts": "21:43",
        "sec": 1303,
        "text": "عن طهارة الحدث، من عجز عن طهارة الحدث فإنه",
        "video_link": null
      },
      {
        "ts": "21:50",
        "sec": 1310,
        "text": "يصلي على حاله ولا شيء عليه؛ هذه. ثم قال رحمه الله قال: أي",
        "video_link": null
      },
      {
        "ts": "21:59",
        "sec": 1319,
        "text": "\"نَدْبٌ يُعِيدَانِ بِوَقْتٍ\"؛ ندب يعيدان بوقت.",
        "video_link": null
      },
      {
        "ts": "22:06",
        "sec": 1326,
        "text": "يعني أن ذلك العاجز أو الناسي؛ \"نَدْبٌ يُعِيدَانِ بِوَقْتٍ\". وقلنا",
        "video_link": null
      },
      {
        "ts": "22:16",
        "sec": 1336,
        "text": "غير مرة أن المالكية لما يقولون \"يعيد في الوقت\" أي أن هذه الإعادة مستحبة؛",
        "video_link": null
      },
      {
        "ts": "22:24",
        "sec": 1344,
        "text": "فقال لك من نسي أو عجز، إذا تذكر أو زال عجزه",
        "video_link": null
      },
      {
        "ts": "22:34",
        "sec": 1354,
        "text": "يستحب له أن يعيد؛ هذا طبعاً لِشرط الاستقبال وطهارة الخبث وشرط العورة، يستحب له",
        "video_link": null
      },
      {
        "ts": "22:42",
        "sec": 1362,
        "text": "أن يعيد: \"نَدْبٌ يُعِيدَانِ بِوَقْتٍ\". مثل ماذا؟ قال: \"كَالْخَطَا\"؛ كالخطأ أي كـ",
        "video_link": null
      },
      {
        "ts": "22:49",
        "sec": 1369,
        "text": "الخطأ في قبلة لا عجزها، يعني إنسان أخطأ في استقبال",
        "video_link": null
      },
      {
        "ts": "22:57",
        "sec": 1377,
        "text": "القبلة، فقال يستحب له أن يعيد: \"كَالْخَطَا *** فِي قِبْلَةٍ لَا عَجْزِهَا أَوِ الْغِطَا\"؛ أي الستر.",
        "video_link": null
      },
      {
        "ts": "23:06",
        "sec": 1386,
        "text": "ثم قال: \"وَمَا عَدَا وَجْهَ وَكَفَّ الْحُرَّةِ *** يَجِبُ سَتْرُهُ كَمَا فِي الْعَوْرَةِ\"؛",
        "video_link": null
      },
      {
        "ts": "23:12",
        "sec": 1392,
        "text": "وهذا الذي ذكرناه آنفاً؛ وما عدا، لأن قلنا عورة المرأة في الصلاة كلها",
        "video_link": null
      },
      {
        "ts": "23:21",
        "sec": 1401,
        "text": "ما عدا الوجه والكفان:",
        "video_link": null
      },
      {
        "ts": "23:27",
        "sec": 1407,
        "text": "\"وَمَا عَدَا وَجْهَ وَكَفَّ الْحُرَّةِ *** يَجِبُ سَتْرُهُ كَمَا فِي الْعَوْرَةِ *** لَكِنْ لَدَى كَشْفٍ لِصَدْرٍ أَوْ شَعَرْ *** أَوْ طَرْفٍ تَعِيدُ فِي الْوَقْتِ الْمُقَرْ\".",
        "video_link": null
      },
      {
        "ts": "23:36",
        "sec": 1416,
        "text": "أحياناً المرأة تصلي وهي ساترة جسمها،",
        "video_link": null
      },
      {
        "ts": "23:44",
        "sec": 1424,
        "text": "ربما يبدو منه شيء دون قصد، دون قصد؛ فـ يظهر",
        "video_link": null
      },
      {
        "ts": "23:51",
        "sec": 1431,
        "text": "شيء من شعرها، أو دون قصد شيء من صدرها، أو من رجلها أو نحو ذلك؛",
        "video_link": null
      },
      {
        "ts": "24:00",
        "sec": 1440,
        "text": "هذا لا يؤثر صلاتها صحيحة لأنها لم تقصد.",
        "video_link": null
      },
      {
        "ts": "24:07",
        "sec": 1447,
        "text": "فإذا تنبهت تستر،",
        "video_link": null
      },
      {
        "ts": "24:11",
        "sec": 1451,
        "text": "إذا تنبهت تستر ما ظهر وتكمل صلاتها، ولا",
        "video_link": null
      },
      {
        "ts": "24:19",
        "sec": 1459,
        "text": "شيء عليها. وإذا تسترت بالشكل المطلوب الكامل في بداية الصلاة -وهذا هو الواجب، تستر بشكل كامل- ثم",
        "video_link": null
      },
      {
        "ts": "24:29",
        "sec": 1469,
        "text": "ظهر شيء منها دون قصد صلاتها صحيحة.",
        "video_link": null
      },
      {
        "ts": "24:35",
        "sec": 1475,
        "text": "قال يستحب لها أن تعيد في الوقت؛ قال: \"لَكِنْ لَدَى كَشْفٍ لِصَدْرٍ أَوْ شَعَرْ *** أَوْ طَرْفٍ تَعِيدُ فِي الْوَقْتِ الْمُقَرْ\". هذه شروط الصحة.",
        "video_link": null
      },
      {
        "ts": "24:50",
        "sec": 1490,
        "text": "ثم انتقل يبين شرطين آخرين،",
        "video_link": null
      },
      {
        "ts": "24:56",
        "sec": 1496,
        "text": "هما شرطا وجوب، وفي الواقع شرطا صحة أيضاً؛ شروط وجوب شروط صحة. شروط الوجوب اللي هي",
        "video_link": null
      },
      {
        "ts": "25:05",
        "sec": 1505,
        "text": "شروط الوجوب فقط راه تقدمت معنا لما لما شرحنا قوله: \"وَكُلُّ تَكْلِيفٍ بِشَرْطِ الْعَقْلِ مَعْ *** الْبُلُوغِ بِدَمٍ أَوْ حَمْلِ\" إلى آخر الأبيات هاد. هذان الشرطان اللذان ذكرهما الآن هما شرطا",
        "video_link": null
      },
      {
        "ts": "25:21",
        "sec": 1521,
        "text": "وجوب وصحة؛ في أن قال: شَرْطُ وُجُوبِهَا النَّقَا مِنَ الدَّمِ *** بِقَصَّةٍ أَوِ الْجُفُوفِ فَاعْلَمِ فَلَا قَضَا أَيَّامِهِ ثُمَّ دُخُولْ *** وَقْتٍ فَأَدَاهَا بِهِ حَتْمًا يُقُولْ",
        "video_link": null
      },
      {
        "ts": "25:40",
        "sec": 1540,
        "text": "الشرط الأول من شروط الوجوب والصحة: النقاء من الدم، النقاء من الدم؛ أي دم؟ دم",
        "video_link": null
      },
      {
        "ts": "25:49",
        "sec": 1549,
        "text": "الحيض والنفاس، دم الحيض والنفاس؛ النقاء من الدم أيضاً من الحيض والنفاس.",
        "video_link": null
      },
      {
        "ts": "25:56",
        "sec": 1556,
        "text": "الدليل قول النبي صلى الله عليه وسلم: \"أَلَيْسَ إِذَا حَاضَتْ لَمْ تُصَلِّ وَمَمْ تَصُمْ؟\" (أليس إذا حاضت",
        "video_link": null
      },
      {
        "ts": "26:06",
        "sec": 1566,
        "text": "لم تصلِّ ولم تصم؟) فدل هذا على أن الحائض",
        "video_link": null
      },
      {
        "ts": "26:11",
        "sec": 1571,
        "text": "لا تصلي لا تصلي الحائض؛ لكن بمجرد",
        "video_link": null
      },
      {
        "ts": "26:19",
        "sec": 1579,
        "text": "تطهرها وانقطاع حيضها تجب عليها الصلاة.",
        "video_link": null
      },
      {
        "ts": "26:30",
        "sec": 1590,
        "text": "النقاء من دم الحيض والنفاس؛ النقاء قال: \"شَرْطُ وُجُوبِهَا النَّقَا مِنَ الدَّمِ\"؛ النقاء من",
        "video_link": null
      },
      {
        "ts": "26:40",
        "sec": 1600,
        "text": "دم الحيض والنفاس شرط لوجوب الصلاة؛ المرأة أثناء حيضها وأثناء نفاسها لا تجب عليها",
        "video_link": null
      },
      {
        "ts": "26:48",
        "sec": 1608,
        "text": "الصلاة، الصلاة لا تجب عليها؛ فإذا طهرت من حيضها ونفاسها وجبت عليها الصلاة.",
        "video_link": null
      },
      {
        "ts": "26:59",
        "sec": 1619,
        "text": "فهو فهذا شرط وجوب وشرط صحة أيضاً، لأنها إذا صلت أثناء حيضها صلاتها باطلة لا تصح.",
        "video_link": null
      },
      {
        "ts": "27:08",
        "sec": 1628,
        "text": "إذاً: \"شَرْطُ وُجُوبِهَا النَّقَا مِنَ الدَّمِ\".",
        "video_link": null
      },
      {
        "ts": "27:15",
        "sec": 1635,
        "text": "أيضاً يدل على هذا حديث فاطمة بنت أبي حبيش وسبق أن ذكرناه سابقاً؛ قال قال لها النبي صلى",
        "video_link": null
      },
      {
        "ts": "27:22",
        "sec": 1642,
        "text": "الله عليه وسلم: \"فَإِذَا أَقْبَلَتِ الْحَيْضَةُ فَاتْرُكِي الصَّلَاةَ\" (فإذا أقبلت الحيضة فاتركي الصلاة)،",
        "video_link": null
      },
      {
        "ts": "27:29",
        "sec": 1649,
        "text": "\"فَإِذَا ذَهَبَ قَدْرُهَا فَاغْسِلِي عَنْكِ الدَّمَ وَصَلِّي\"؛ وكنا رأينا سابقاً رواية: \"فاغتسلي وصلي\".",
        "video_link": null
      },
      {
        "ts": "27:39",
        "sec": 1659,
        "text": "هذا النقاء بما يعرف؟ يعرف بأحد أمرين اثنين؛",
        "video_link": null
      },
      {
        "ts": "27:46",
        "sec": 1666,
        "text": "قال: \"بِقَصَّةٍ أَوِ الْجُفُوفِ فَاعْلَمِ\".",
        "video_link": null
      },
      {
        "ts": "27:53",
        "sec": 1673,
        "text": "القصة؛ أي ما يسميه العلماء القصة البيضاء، القصة البيضاء. ما هي القصة البيضاء؟",
        "video_link": null
      },
      {
        "ts": "28:02",
        "sec": 1682,
        "text": "القصة البيضاء هي ماء أبيض كالجير يخرج عقب الانتهاء من الحيض؛ وكانت النساء تبعث إلى أم المؤمنين عائشة رضي الله عنها",
        "video_link": null
      },
      {
        "ts": "28:10",
        "sec": 1690,
        "text": "بالدَّرَجة فيها فيها يعني شيء من القطن (الكرسف)، الكرسف أي شيء من القطن؛ يعني المرأة",
        "video_link": null
      },
      {
        "ts": "28:19",
        "sec": 1699,
        "text": "كانت تحار هل انتهت عادتها أم لا، فتأخذ شيئاً من القطن فتتتبع به في الموضع أثر",
        "video_link": null
      },
      {
        "ts": "28:26",
        "sec": 1706,
        "text": "الدم ثم تبعث بهذا القطن إلى أم المؤمنين تقول لها: انظري هل طهرتُ أم لا؟ فكانت تقول لهن: \"لا تعجلن حتى ترين القصة البيضاء\"؛ هاد",
        "video_link": null
      },
      {
        "ts": "28:36",
        "sec": 1716,
        "text": "هذه العلامة الأولى، إذا رأت هذا الماء الأبيض فقد طهرت. العلامة الثانية: الجفوف؛ بعض النساء قد لا تنزل معها القصة البيضاء،",
        "video_link": null
      },
      {
        "ts": "28:45",
        "sec": 1725,
        "text": "لكن تجف ويتوقف دم الحيض نهائياً فتعلم أن عادتها قد انتهت؛ قال:",
        "video_link": null
      },
      {
        "ts": "28:52",
        "sec": 1732,
        "text": "\"بِقَصَّةٍ أَوِ الْجُفُوفِ فَاعْلَمِ\". لذلك ينبغي للمرأة",
        "video_link": null
      },
      {
        "ts": "28:59",
        "sec": 1739,
        "text": "أن تنتبه لهذا الأمر؛ فبمجرد ما تنتهي عادتها تجب عليها الصلاة. وكنت قد نبهت في",
        "video_link": null
      },
      {
        "ts": "29:06",
        "sec": 1746,
        "text": "مجلس سابق إلى خطأ الخطأ الذي تقع فيه بعض النسوة، أنهن يؤخرن",
        "video_link": null
      },
      {
        "ts": "29:13",
        "sec": 1753,
        "text": "الاغتسال وبالتالي يؤخرن الصلاة بعد انقطاع دم الحيض، وهذا لا يجوز أبداً. فلو",
        "video_link": null
      },
      {
        "ts": "29:19",
        "sec": 1759,
        "text": "-كما قلت- لو أن مثلاً طهرت قبل قبل الصبح بدقائق،",
        "video_link": null
      },
      {
        "ts": "29:26",
        "sec": 1766,
        "text": "تغتسل تصلي الصبح؛ ولكن لو انقطع دم الحيض بعد الأذان بين",
        "video_link": null
      },
      {
        "ts": "29:33",
        "sec": 1773,
        "text": "أذان الصبح وشروق الشمس، يجب أن تغتسل لكي تصلي صلاة الصبح فلا ينبغي أن تؤخر. تغتسل؛",
        "video_link": null
      },
      {
        "ts": "29:41",
        "sec": 1781,
        "text": "بعض الناس تقول بعض النساء تقول: \"لا، حتى يطلع الصباح وأذهب للحمام\"، الآن البيوت أغلب المنازل الآن فيها حمامات فتغتسل في",
        "video_link": null
      },
      {
        "ts": "29:50",
        "sec": 1790,
        "text": "حمام بيتها. لو افترضنا أن بيتها ليس فيه حمام -كانت قديماً البيوت لم تكن فيها حمامات،",
        "video_link": null
      },
      {
        "ts": "29:58",
        "sec": 1798,
        "text": "وكان النساء يغتسلن في حتى في بيت النوم أو نحو ذلك في جفنة أو نحوها- لو افترضنا أن هذه المرأة مريضة بالربو أو نحو ذلك من",
        "video_link": null
      },
      {
        "ts": "30:07",
        "sec": 1807,
        "text": "الأمراض عافانا الله وإياكم وإذا اغتسلت ستمرض، تتيمم؛ تتيمم وتصلي. وسقنا حديث عمرو بن العاص",
        "video_link": null
      },
      {
        "ts": "30:16",
        "sec": 1816,
        "text": "في غزوة ذات السلاسل ذكرناه في المجلس الخاص بالتيمم، المهم لا بد من تطهر والصلاة؛ تتيمم",
        "video_link": null
      },
      {
        "ts": "30:23",
        "sec": 1823,
        "text": "وتصلي حتى يطلع النهار ويدفأ الجو ثم تغتسل، لكن لا بد من الصلاة. وأقول مثل هذا",
        "video_link": null
      },
      {
        "ts": "30:31",
        "sec": 1831,
        "text": "في سائر الأوقات؛ فلذلك فـ النقاء من دم الحيض والنفاس شرط لوجوب",
        "video_link": null
      },
      {
        "ts": "30:39",
        "sec": 1839,
        "text": "الصلاة؛ قال: \"شَرْطُ وُجُوبِهَا النَّقَا مِنَ الدَّمِ *** بِقَصَّةٍ أَوِ الْجُفُوفِ فَاعْلَمِ *** فَلَا قَضَا أَيَّامِهِ\". فلا قضا",
        "video_link": null
      },
      {
        "ts": "30:47",
        "sec": 1847,
        "text": "أيامه؛ أي أن أن الصلاة لا تقضى، وذكرنا كذلك سابقاً حديث عمرة بنت عبد الرحمن وهي",
        "video_link": null
      },
      {
        "ts": "30:55",
        "sec": 1855,
        "text": "من التابعيات الجليلات من تلميذات عائشة رضي الله عنها، أنها قالت: يا أم المؤمنين ما بال الحائض تقضي الصوم ولا تقضي الصلاة؟",
        "video_link": null
      },
      {
        "ts": "31:03",
        "sec": 1863,
        "text": "فقالت لها: \"أَحَرُورِيَّةٌ أَنْتِ؟\" الحرورية هاد فرقة من الخوارج وكانوا يعترضون على الأحكام",
        "video_link": null
      },
      {
        "ts": "31:10",
        "sec": 1870,
        "text": "الشرعية بعقولهم، كما ترى بعض الناس اليوم لا تعجبه بعض الأحكام فيبقى يسأل: ولماذا",
        "video_link": null
      },
      {
        "ts": "31:16",
        "sec": 1876,
        "text": "الحكم كذا؟ ولماذا لا يكون كذا؟ حتى سمعنا بعض بعض بعض الناس ممن زلت أقدامهم بعد",
        "video_link": null
      },
      {
        "ts": "31:24",
        "sec": 1884,
        "text": "ثبات -نسأل الله السلامة والعافية في هذا الزمن- الذين ممن بدأ يقول يقول: \"لا، المرأة الحائض",
        "video_link": null
      },
      {
        "ts": "31:29",
        "sec": 1889,
        "text": "تصلي وتصوم\"، وهذا في في مصادمة صريحة للنص",
        "video_link": null
      },
      {
        "ts": "31:36",
        "sec": 1896,
        "text": "النبوي الصريح والواضح لإجماع العلماء، نعوذ بالله من الحَوْرِ بَعْدَ الْكَوْرِ ونعوذ",
        "video_link": null
      },
      {
        "ts": "31:43",
        "sec": 1903,
        "text": "بالله من من الزلل ا بعد الثبات. فقالت: \"لا، أحرورية أنتِ؟\" قالت لها:",
        "video_link": null
      },
      {
        "ts": "31:50",
        "sec": 1910,
        "text": "\"لستُ حرورية ولكن أسأل\"؛ يعني أسأل سؤال متعلمة لا سؤال معترضة، فقالت لها: \"كَانَ يُصِيبُنَا ذَلِكَ عَلَى عَهْدِ رَسُولِ اللَّهِ صَلَّى",
        "video_link": null
      },
      {
        "ts": "31:59",
        "sec": 1919,
        "text": "اللَّهُ عَلَيْهِ وَسَلَّمَ فَنُؤْمَرُ بِقَضَاءِ الصَّوْمِ وَلَا نُؤْمَرُ بِقَضَاءِ الصَّلَاةِ\"؛ هذه القصة ا فيها، ولذلك قال:",
        "video_link": null
      },
      {
        "ts": "32:05",
        "sec": 1925,
        "text": "إذاً فقال: \"فَلَا قَضَا أَيَّامِهِ ثُمَّ دُخُولْ *** وَقْتٍ\". ثُمَّ دخول وقت فأدَّاها به حتماً؛ أقول هذا شرط الوجوب الثاني وهو",
        "video_link": null
      },
      {
        "ts": "32:14",
        "sec": 1934,
        "text": "أيضاً شرط وجوب وشرط صحة، وهو دخول الوقت؛ قال ربنا جل جلاله: {إِنَّ الصَّلَاةَ كَانَتْ عَلَى",
        "video_link": null
      },
      {
        "ts": "32:21",
        "sec": 1941,
        "text": "الْمُؤْمِنِينَ كِتَابًا مَّوْقُوتًا}؛ {إِنَّ الصَّلَاةَ كَانَتْ عَلَى الْمُؤْمِنِينَ كِتَابًا",
        "video_link": null
      },
      {
        "ts": "32:28",
        "sec": 1948,
        "text": "مَّوْقُوتًا}. فالصلاة لها أوقات محددة، كل وقت كل صلاة لها وقت",
        "video_link": null
      },
      {
        "ts": "32:36",
        "sec": 1956,
        "text": "بداية ووقت نهاية؛ وهذه الأوقات سوف تأتي معكم إن شاء الله عز وجل في متن الرسالة",
        "video_link": null
      },
      {
        "ts": "32:42",
        "sec": 1962,
        "text": "بإذن الله عز وجل فـ نرجئ الحديث عنها إلى ذلك الحين.",
        "video_link": null
      },
      {
        "ts": "32:49",
        "sec": 1969,
        "text": "المهم هنا هو أن نعلم أن الصلاة لا تجب إلا إذا دخل وقتها؛ صلاة المغرب قبل غروب الشمس غير واجبة، وبالتالي من صلى صلاة",
        "video_link": null
      },
      {
        "ts": "32:59",
        "sec": 1979,
        "text": "المغرب قبل غروب الشمس صلاته باطلة؛ لِمَا؟ الصلاة غير واجبة لم تجب عليه صلاة المغرب",
        "video_link": null
      },
      {
        "ts": "33:06",
        "sec": 1986,
        "text": "أصلاً، لم تجب عليه صلاة المغرب فماذا يصلي هذا أصلاً؟ لاجـ لا وجود لشيء اسمه المغرب؛",
        "video_link": null
      },
      {
        "ts": "33:13",
        "sec": 1993,
        "text": "فمن يصلي فالصلاة لا تجب عليه، والشمس لا تجب عليه صلاة المغرب والشمس لم",
        "video_link": null
      },
      {
        "ts": "33:22",
        "sec": 2002,
        "text": "تغرب، لم تغرب، ولو صلى فصلاته باطلة لأن لأن دخول الوقت شرط",
        "video_link": null
      },
      {
        "ts": "33:31",
        "sec": 2011,
        "text": "في وجوب الصلاة وشرط في صحتها أيضاً. ولو صلى أحد",
        "video_link": null
      },
      {
        "ts": "33:39",
        "sec": 2019,
        "text": "الصبح قبل بزوغ الفجر فصلاته باطلة، لأن الصبح",
        "video_link": null
      },
      {
        "ts": "33:48",
        "sec": 2028,
        "text": "لَمَّا يجب عليه بعد، وقد أدى الصلاة قبل دخول وقتها فالصلاة باطلة. يقول علماؤنا: لو دخل",
        "video_link": null
      },
      {
        "ts": "33:56",
        "sec": 2036,
        "text": "في الصلاة قبل الـ وقتها ولو بتكبيرة الإحرام فالصلاة باطلة، الصلاة باطلة؛ فلذلك",
        "video_link": null
      },
      {
        "ts": "34:03",
        "sec": 2043,
        "text": "لا ينبغي الإنسان أن يؤدي الصلاة قبل دخول وقتها. هذا الحديث عن شروط أداء الصلاة",
        "video_link": null
      },
      {
        "ts": "34:11",
        "sec": 2051,
        "text": "وشروط وجوبها. والله تعالى أعلى وأعلم؛ سبحانك اللهم وبحمدك أشهد أن لا إله إلا أنت أستغفرك وأتوب",
        "video_link": null
      },
      {
        "ts": "34:18",
        "sec": 2058,
        "text": "إليك، وصلى الله وسلم وبارك على سيدنا محمد وعلى آله، والحمد لله رب العالمين.",
        "video_link": null
      }
    ]
  },
  {
    "subject": "fiqh",
    "subjectLabel": "الفقه الإسلامي",
    "lesson": "الدرس 16",
    "lessonNum": 16,
    "title": "الدرس 16",
    "summary": "📚 <b>الملخص الشامل للدرس: سنن الصلاة في نظم ابن عاشر</b>\n\n🔹 <b>الخلاصة المحورية للدرس:</b>\n<blockquote>يتناول هذا المجلس شرحاً تفصيلياً لسنن الصلاة في \"نظم ابن عاشر\"، حيث قسّمها الناظم إلى سنن مؤكدة وسنن خفيفة (مندوبات)، موضحاً أحكامها، أدلتها من السنة النبوية، وكيفية أدائها، مع التنبيه على ما يترتب على تركها من سجود للسهو.</blockquote>\n\n🔹 <b>الأحداث والقواعد والمسائل بالتفصيل:</b>\n\n<blockquote>\n• <b>قراءة السورة بعد الفاتحة:</b> هي سنة مؤكدة تُقرأ في الركعتين الأوليين من الصلوات المفروضة والنافلة. استدل الشيخ بحديث أبي سعيد الخدري \"أمرنا أن نقرأ بفاتحة الكتاب وما تيسر\"، وبفعل النبي ﷺ في الصحيحين.\n• <b>القيام لقراءة السورة:</b> القيام للسورة سنة مرتبطة بسنيّة السورة نفسها، اقتداءً بهدي النبي ﷺ في صلاته.\n• <b>الجهر والسر:</b> الجهر سنة في الصلوات الجهرية (الصبح، أوليتا المغرب والعشاء، الجمعة). والسر سنة في الصلوات السرية (الظهر، العصر، الأخيرة من المغرب، الأخيرتان من العشاء). أدنى مراتب الجهر أن يسمع نفسه ومن يليه، وأدنى مراتب السر تحريك اللسان بالقراءة.\n• <b>التكبيرات (ما عدا تكبيرة الإحرام):</b> تكبيرة الإحرام ركن، وما عداها من تكبيرات الانتقال (الخفض والرفع والقيام) فهي سنة مؤكدة، لحديث ابن مسعود: \"كان النبي ﷺ يكبر في كل خفض ورفع\".\n• <b>التشهد والجلوس له:</b> التشهد الأول والتشهد الثاني سنة مؤكدة، وكذلك الجلوس لكل منهما. استدل الشيخ بحديث عبد الله بن بحينة حين ترك النبي ﷺ التشهد الأول وسجد للسهو، وأكد أن الجلوس للتشهد الثاني الذي هو سنة لا يختلط بجلوس السلام الذي هو ركن.\n• <b>التسميع (سمع الله لمن حمده):</b> سنة مؤكدة للإمام والمنفرد (الفذ) عند الرفع من الركوع، أما المأموم فيقتصر على قول \"ربنا ولك الحمد\".\n• <b>سجود الأعضاء السبعة:</b> السجود على الجبهة والأنف (عظم واحد)، واليدين، والركبتين، وأطراف القدمين سنة، مع مراعاة عدم افتراش الذراعين كافتراش السبع.\n• <b>إنصات المأموم:</b> وجوب إنصات المأموم في الصلاة الجهرية لإمامه لقوله تعالى: {وإذا قُرئ القرآن فاستمعوا له وأنصتوا}.\n• <b>رد السلام:</b> التسليمة الأولى ركن للخروج من الصلاة، والتسليمة الثانية سنة (رد على الإمام).\n• <b>زيادة الطمأنينة:</b> الطمأنينة ركن، والزيادة عليها فوق حد الاستقرار سنة.\n• <b>اتخاذ السترة:</b> سنة للإمام والمنفرد لمنع المرور بين يديهم. أما المأموم فسترته هي سترة إمامه.\n• <b>كلام التشهد والصلاة على النبي ﷺ:</b> صيغة التشهد (واختار المالكية صيغة عمر بن الخطاب) والصلاة على النبي ﷺ في التشهد من السنن الخفيفة.\n</blockquote>\n\n🔹 <b>الأسماء والمصطلحات الرئيسية:</b>\n\n<blockquote>\n• <b>الإمام ابن عاشر:</b> صاحب النظم الفقهي الذي يُشرح في المجلس.\n• <b>الفذ:</b> هو المصلي المنفرد الذي لا يصلي خلف إمام.\n• <b>السنة المؤكدة:</b> السنن التي يترتب على تركها غالباً سجود السهو (عند المالكية).\n• <b>السنن الخفيفة (المندوبات):</b> هي ما دون السنن المؤكدة في الفضيلة، ولا يترتب على تركها ما يترتب على السنن المؤكدة.\n• <b>الأتان:</b> أنثى الحمار (ورد ذكرها في حديث ابن عباس كدليل على سترة الإمام).\n</blockquote>\n\n🔹 <b>العبر والأحكام المستفادة:</b>\n\n<blockquote>\n• أهمية اتباع هدي النبي ﷺ في الصلاة بقوله: \"صلوا كما رأيتموني أصلي\".\n• الفرق الفقهي الدقيق بين الركن والسنن المؤكدة والسنن الخفيفة.\n• ضرورة تحريك اللسان في القراءة، فبدونه لا تسمى قراءة شرعاً.\n• حفظ حرمة المصلي من خلال اتخاذ السترة وعدم المرور بين يديه.\n• فضل الالتزام بالأذكار الواردة عن النبي ﷺ وصحابته الكرام.\n</blockquote>\n\n🔹 <b>سؤال تدبر ومراجعة ذاتية:</b>\n<blockquote>لماذا لا يرجع المصلي إذا نسي التشهد الأول وقام إلى الركعة الثالثة؟ وما الحكمة الفقهية في تفريق المالكية بين \"السجود لترك السنة المؤكدة\" و\"السجود لترك المندوب\"؟</blockquote>",
    "full_text": "بسم الله الرحمن الرحيم، الحمد لله رب العالمين، والصلاة والسلام الأتمان الأكملان على سيدنا محمد الصادق الأمين، وعلى آله وصحبه أجمعين. أما بعد، السلام عليكم ورحمة الله وبركاته. مع مجلس جديد من مجالسنا الفقهية المباركة في شرح نظم الإمام العلامة سيدي عبد الواحد بن عاشر رحمه الله تعالى عليه. في المجلس الماضي أنهينا الحديث عن شروط الصلاة؛ الناظم رحمه الله تعالى ذكر لنا أركان الصلاة ثم ذكر شروطها، وهذه أمور لا بد منها لتصح الصلاة؛ فالصلاة لا تصح إلا بتوفر الشروط كلها وإقامة الأركان كلها. بعد ذلك انتقل الشيخ الإمام رحمه الله تعالى للحديث عن سنن الصلاة، فقال رحمه الله: سُنَنُهَا السُّورَةُ بَعْدَ الْوَاقِيَهْ *** مَعَ الْقِيَامِ أَوَّلًا وَالثَّانِيَهْ جَهْرٌ وَسِرٌّ بِمَحَلِّ لَهُمَا *** تَكْبِيرُهُ إِلَّا الَّذِي تَقَدَّمَا ذكر سنن الصلاة، وسنن الصلاة قسمها إلى قسمين: منها سنن مؤكدة، ومنها سنن سماها سنناً خفيفة. ثم هذه السنن الخفيفة أو هذه السنن عموماً، منها ما له تعلق بذات الصلاة، ومنها ما هو خارج عن ذات الصلاة وله تعلق بها فذكرها كلها رحمه الله عليه. أول سنة بدأ بها هي قراءة السورة بعد فاتحة الكتاب؛ فقال رحمه الله تعالى: \"سُنَنُهَا السُّورَةُ بَعْدَ الْوَاقِيَهْ\"، ورُويت: \"بَعْدَ الْوَافِيَهْ\" والوافية هذه من أسماء الفاتحة. قراءة الفاتحة ركن في الصلاة، قراءة السورة التي بعد الفاتحة سنة مؤكدة. وهذه السورة التي تُقرأ بعد الفاتحة تُقرأ في الركعتين الأوليين من صلاة صلاة الظهر، وصلاة العصر، وصلاة المغرب، وصلاة العشاء، وطبعاً أيضاً في ركعتي صلاة الصبح وركعتي صلاة الجمعة؛ وهذا في حديثنا عن الصلوات المفروضة، وقل مثل ذلك في الصلوات في التطوعات الأخرى. دليل هذه قراءة هذه السورة قول قول أبي سعيد الخدري رضي الله عنه وأرضاه: \"أُمِرْنَا أَنْ نَقْرَأَ بِفَاتِحَةِ الْكِتَابِ وَمَا تَيَسَّرَ\" (أمرنا أن نقرأ بالفاتحة وما تيسر). وفي صحيح البخاري من حديث أبي قتادة رضي الله عنه: \"أن رسول الله صلى الله عليه وسلم كان يقرأ في الأوليين من الظهر بفاتحة الكتاب وسورةٍ\" (وسورتين)؛ فهو صلى الله عليه وسلم كان يقرأ سورة مع الفاتحة، فقراءة السورة بعد الفاتحة سنة من سنن الصلاة. قال رحمه الله: \"سُنَنُهَا السُّورَةُ بَعْدَ الْوَاقِيَهْ *** مَعَ الْقِيَامِ أَوَّلًا وَالثَّانِيَهْ\"؛ السنة الثانية هي القيام لـ القيام لقراءة هذه السورة؛ القيام لقراءة هذه السورة هذا من السنن، لأن كما يقول فقهاؤنا هناك ارتباط بين الظرف والمظروف؛ فالسورة سنة والقيام لها أيضاً سنة، القيام لها أيضاً سنة؛ وهذا ما فعله رسول الله صلى الله عليه وسلم وقد قال: \"صَلُّوا كَمَا رَأَيْتُمُونِي أُصَلِّي\". ثم قال: \"جَهْرٌ وَسِرٌّ بِمَحَلِّ لَهُمَا\". السنة الثالثة: الجهر في محله. طبعاً يعني الصلوات التي يُجهر فيها، الجهر فيها سنة؛ وهذه الصلوات كما لا يخفى هي صلاة الصبح -وأقصد صلاة الصبح فريضة الفجر- والركعتان الركعتان الأوليان من المغرب، والركعتان الأوليان من العشاء، وركعتا صلاة الجمعة؛ هذا الجهر سنة. يقول أبو هريرة رضي الله عنه وأرضاه: \"فِي كُلِّ صَلَاةٍ يَقْرَأُ؛ فَمَا أَسْمَعَنَا رَسُولُ اللَّهِ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ أَسْمَعْنَاكُمْ، وَمَا أَخْفَى عَنَّا أَخْفَيْنَا مِنْكُمْ\" (يعني أنه صلى الله عليه وسلم كان بعض الصلوات يجهر فيها وبعض الصلوات يسر فيها). فالصلوات التي أسرَّ فيها، نقل لنا الصحابة الكرام رضوان الله عليهم جهر رسول الله صلى الله عليه وسلم في تلك الصلوات؛ مثلاً جبير بن مطعم رضي الله عنه يحكي أنه ذهب إلى رسول الله صلى الله عليه وسلم فوجده يقرأ في صلاة المغرب بسورة الطور، سمعه يقرأ سورة الطور؛ فهذا جهر في المغرب. وكـ فهذا الجهر سنة. قد يقول قائل: ما حد الجهر؟ الجهر أدنى مراتبه، أدنى مراتبه: أن يسمع القارئ نفسه ومن يليه، أن يسمع نفسه هو ومن يليه؛ هذا أدنى مراتب الجهر، أما حده فلا أما أكثره فلا حد له؛ لأن كل إنسان وصوته يعني وحدة صوته فلا فلا حد لأكثره. قال رحمه الله: \"جَهْرٌ وَسِرٌّ بِمَحَلِّ لَهُمَا\". السنة الرابعة: السر، السر فيما يُسر فيه؛ وهي الصلوات المفروضة: صلاة الظهر، صلاة العصر، والركعة الأخيرة من صلاة المغرب، والركعتان الأخيرتان من صلاة العشاء. أحد التابعين (أبو معمر) سأل خباب بن الأرت رضي الله تعالى عنه وأرضاه، فقال له: \"أكان النبي صلى الله عليه وسلم يقرأ في الظهر والعصر؟\" قال: نعم؛ قال له: \"بما كنتم تعرفون قراءته؟\" قال: \"بِاضْطِرَابِ لِحْيَتِهِ\" (باضطراب لحيته)، صلوات الله وسلامه عليه؛ لأنهم يصلون خلفه وهو صلى الله عليه وسلم إمامهم، فكيف يعرفون أنه يقرأ؟ باضطراب لحيته صلوات الله وسلامه عليه؛ فكان يُرى اضطرابها من خلفه. فـ هذا السر كذلك، ما قلناه في الجهر نقوله في السر؛ ما حد ما ضابط هذا السر؟ وحده قالوا: السر أدناه تحريك اللسان بالقراءة، تحريك اللسان بالقراءة؛ هذا أدناه. أعلاه: أن يسمع نفسه، أن يسمع نفسه؛ هذا أسياسي للسر. بعض الناس ربما يصلي سراً فلا يحرك لسانه وهذه ليست قراءة؛ ربما يقرأ سورة الفاتحة أو سورة من السور دون تحريك اللسان، هذا لا يسمى قراءة؛ فالقراءة لا بد فيها من تحريك اللسان. إذاً أدنى مراتب السر: أن تحرك لسانك بالقراءة، أعلى المراتب: أن تسمع نفسك، أن تسمع نفسك؛ هذا أساسي للسر. السنة الخامسة؛ قال رحمه الله: \"تَكْبِيرُهُ إِلَّا الَّذِي *** تَقَدَّمَا\". ما هو التكبير الذي تقدم معنا في هذا النظم؟ تكبيرة الاحرام، تكبيرة الاحرام هذه ركن من أركان الصلاة؛ باقي التكبيرات سنة، باقي التكبيرات سنة؛ قال رحمه الله: \"تَكْبِيرُهُ إِلَّا الَّذِي *** تَقَدَّمَا\". التكبيرات الأخرى؛ مثلاً: تكبيرة النزول إلى الركوع، تكبيرة النزول إلى السجود، الرفع من السجود، القيام للركعة الثالثة فهذه، والقيام لـ من أجل أو التكبير من أجل في الرفع من أجل الجلوس للتشهد فهذا السنـ سنة. يقول ابن مسعود رضي الله عنه: \"كَانَ رَسُولُ اللَّهِ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ يُكَبِّرُ فِي كُلِّ خَفْضٍ وَرَفْعٍ وَقِيَامٍ وَقُعُودٍ\" (كان رسول الله صلى الله عليه وسلم يكبر في كل خفض ورفع وقيام وقعود)؛ فهذا التكبير سنة. قال رحمه الله: كُلُّ تَشَهُّدٍ جُلُوسٌ أَوَّلُ *** وَالثَّانِي لَا مَا لِلسَّلَامِ يَحْصُلُ لما قال: \"كُلُّ تَشَهُّدٍ\" هنا ذكر السنتين السادسة والسابعة وهما: التشهد الأول، والتشهد الثاني (التشهد الأول والتشهد الثاني). تقول عائشة رضي الله عنها عن وهي تحكي صفة رسول الله صلى الله عليه وسلم: \"وَكَانَ يَقُولُ فِي كُلِّ رَكْعَتَيْنِ التَّحِيَّةَ\" (وكان يقول في كل ركعتين التحية)؛ هذا التشهد. ففقهاؤنا يقولون هو أن تقول: \"أشهد أن لا إله إلا الله، أشهد أن محمداً رسول الله\"؛ هذا هو التشهد المقصود في كلام الناظم هنا، أما صيغة التشهد كلها سيأتي ذكرها بعد بعد قليل إن شاء الله عز وجل. قال رحمه الله: \"كُلُّ تَشَهُّدٍ\"؛ إذاً التشهد الأول والتشهد الثاني هذا السنتان السادسة والسابعة. قال رحمه الله: \"كُلُّ تَشَهُّدٍ جُلُوسٌ أَوَّلُ *** وَالثَّانِي لَا مَا لِلسَّلَامِ يَحْصُلُ\"؛ السنة الثامنة والسنة التاسعة: الجلوس للتشهد؛ الجلوس للتشهد الأول، والجلوس للتشهد الثاني؛ هذا من السنة من سنن الصلاة. ما الدليل؟ قالوا الدليل حديث عبد الله بن بحينة رضي الله عنه؛ في هذا الحديث يحكي أن رسول الله صلى الله عليه وسلم صلّى إما الظهر أو العصر، فقام من الركعتين ولم يجلس للتشهد الأوسط (التشهد الأول لم يجلس له النبي صلى الله عليه وسلم) فسبَّح الناس به، فلم يرجع، حتى إذا قضى صلاته وانتظر الناس تسليمه، سجد سجدتين وتشهد سجد سجدتين ثم سلم؛ يعني أنه سجد سجدتي السهو (سجود السهو الذي سجده صلى الله عليه وسلم) من أجل ماذا؟ من أجل تلك السنة التي تركها وهي الجلوس للتشهد. قالوا: لو لم يكن الجلوس للتشهد سنة، لأتى صلى الله عليه وسلم بالتشهد وهو قائم؛ لما قام للركعة الثالثة وذكروه بأنه لم يجـ التشهد، كان بإمكانه أن يتشهد وهو قائم؛ لكن لما لم يفعل وأتى بسجود السهو بعده، فُهم منه أن أن الجلوس للتشهد سنة، وكونه وأيضاً استُدل بهذا الحديث على أنه سنة؛ لأنه صلى الله عليه وسلم لم يرجع للجلوس أيضاً لما؟ لأنه كما يقول فقهاؤنا: لا نرجع من فرض إلى إلى سنة (من ركن إلى سنة)؛ القيام لقراءة الفاتحة ركن، فلم يرجع صلى الله عليه وسلم لم يقطع هذا الركن ليرجع من أجل الجلوس للتشهد وهو سنة. إذن فإذا قال رحمه الله: \"كُلُّ تَشَهُّدٍ جُلُوسٌ أَوَّلُ وَالثَّانِي\" أي الجلوس الأول هذا التشهد الأوسط، ثم الجلوس الثاني \"لَا مَا لِلسَّلَامِ يَحْصُلُ\"؛ أي يقول لك أن هذا الجلوس للتشهد الثاني الذي ذكرت لك أنه سنة، لا تخلطه بالجلوس الذي يكون من أجل السلام؛ لأن السلام والتسليم من أجل الخروج من الصلاة هذا ركن، والجلوس له أيضاً ركن كما تقدم معنا؛ فهذا ليس داخلاً، وإنما الجلوس للتشهد هذا الذي يُعتبر من السنن. قال رحمه الله: وَسَمِعَ اللَّهُ لِمَنْ حَمِدَهُ *** فِي الرَّفْعِ مِنْ رُكُوعِهِ أَوْرَدَهُ الْفَذُّ وَالْإِمَامُ هَذَا أَكَّدَا *** وَالْبَاقِي كَالْمَنْدُوبِ فِي الْحُكْمِ بَدَا السنة العاشرة: التسميع، التسميع يعني: \"سمع الله لمن حمده\"، \"سمع الله لمن حمده\" هذه سنة. النبي صلى الله عليه وسلم لما بيّن لنا أن ذكر أموراً ينبغي أن يقوم بها المأموم، قال صلى الله عليه وسلم: \"فَإِذَا كَبَّرَ فَكَبِّرُوا، وَإِذَا رَكَعَ فَارْكَعُوا، وَإِذَا قَالَ: سَمِعَ اللَّهُ لِمَنْ حَمِدَهُ، فَقُولُوا: رَبَّنَا وَلَكَ الْحَمْدُ\"؛ وإذا قال: \"سمع الله لمن حمده\" فقولوا: \"ربنا ولك الحمد\". التسميع: \"سمع الله لمن حمده\"؛ هنا قال رحمه الله: \"وَسَمِعَ اللَّهُ لِمَنْ حَمِدَهُ *** فِي الرَّفْعِ مِنْ رُكُوعِهِ أَوْرَدَهُ\"؛ هذا يكون عند الرفع من الركوع، فتقوم من ركوعك وأنت تسمّع تقول: \"سمع الله لمن حمده\". \"فِي الرَّفْعِ مِنْ رُكُوعِهِ أَوْرَدَهُ مَنْ؟\" أورده قال رحمه الله: \"الْفَذُّ وَالْإِمَامُ\" (الفذ الفذ والامام)؛ الفذ يعني المنفرد (المنفرد والامام خلاص معروف). يُفهم من هذا أن المأموم لا يقول: \"سمع الله لمن حمده\"، المأموم لا يقول: \"سمع الله لمن حمده\"؛ وإنما يكتفي بقول: \"ربنا ولك الحمد\"، لقوله صلى الله عليه وسلم: \"وَإِذَا قَالَ: سَمِعَ اللَّهُ لِمَنْ حَمِدَهُ، فَقُولُوا: رَبَّنَا وَلَكَ الْحَمْدُ\"؛ يقول الإمام: \"سمع الله لمن حمده\" فيقول المأموم: \"ربنا ولك الحمد\" ولا يقول: \"سمع الله لمن حمده\". ذا قال: \"الْفَذُّ وَالْإِمَامُ فِي الرَّفْعِ مِنْ رُكُوعِهِ أَوْرَدَهُ الْفَذُّ وَالْإِمَامُ\". ثم قال رحمه الله: \"هَذَا أَكَّدَا\"؛ ماذا يقصد بقوله \"هَذَا أَكَّدَا\"؟ يقصد هذه السنن العشر التي ذكرها لك الآن، يقول لك: هذه سنن مؤكدة؛ والباقي؟ الباقي من السنن يقول لك: الباقي من السنن التي سأذكر لك: \"وَالْبَاقِي كَالْمَنْدُوبِ فِي الْحُكْمِ بَدَا\"؛ أي أنها هي كـ المندوبات، لأن المندوبات سيتحدث عنها بعد انتهائه من الحديث عن السنن إن شاء الله عز وجل، وقال هي كل مندوب أو كما يعبر العلماء يقول هي سنن خفيفة (سنن خفيفة). قد يقول قائل: ما الفرق بين السنن المؤكدة والسنن الخفيفة؟ أولاً التفاوت في في الأجر والفضيلة، ثم أمر آخر مهم جداً وهو قضية السجود؛ المالكية رحمه الله عليهم عندهم أن سجود السهو يكون لترك يعني السنن المؤكدة باستثناء التكبير والتسميع؛ وهذا سوف يأتي معنا بإذن الله عز وجل حين حديثنا عن سجود السهو، فحينها حينها سنحتاج أن نستذكر هذه السنن المؤكدة التي ذكرناها الآن. قال رحمه الله وهو يعدد السنن الخفيفة: إِقَامَةٌ سُجُودُهُ عَلَى الْيَدَيْنْ *** وَطَرَفِ الرِّجْلَيْنِ مِثْلَ الرُّكْبَتَيْنْ أول سنة من السنن الخفيفة ذكرها قال: \"إِقَامَةٌ\"، ويقصد بذلك إقامة الصلاة؛ وهذه سأرجئها للمجلس المقبل إن شاء الله لما نتحدث عن الأذان نتحدث عن الإقامة بإذن الله عز وجل. قال: \"سُجُودُهُ عَلَى *** الْيَدَيْنْ وَطَرَفِ الرِّجْلَيْنِ مِثْلَ الرُّكْبَتَيْنْ\"؛ كيفيه السجود الآن، السجود. السجود ركن من أركان الصلاة؛ هذه الأطراف التي ذكرها هنا، يقول رحمه الله إن السجود عليها سنة؛ ما هي؟ قال: \"سُجُودُهُ عَلَى *** الْيَدَيْنْ\" (اليدين) و\"طَرَفِ الرِّجْلَيْنِ\" والركبتين. لما يقول اليدين، يقول علماؤنا غير مفترشهما لا يفترش اليدين، لـ نهي النبي صلى الله عليه وسلم عن افتراش كافتراش السَّبُع أو كافتراش الكلب؛ فيضع يديه هكذا، يضع يديه مستقبلاً بأصابعه بأصابع يديه القبلة. فهنا قال رحمه الله: \"سُجُودُهُ عَلَى الْيَدَيْنْ وَطَرَفِ الرِّجْلَيْنِ\"؛ يعني أطراف الرجلين القدمين ينصبهما هكذا ينصبهما، والركبتين. ودليل هذا حديث ابن عباس رضي الله عنه الذي يقول فيه (حديث ابن عباس عن رسول الله صلى الله عليه وسلم أنه قال): قال \"أُمِرْتُ أَنْ أَسْجُدَ عَلَى سَبْعَةِ أَعْظُمٍ: عَلَى الْجَبْهَةِ -وَأَشَارَ بِيَدِهِ عَلَى أَنْفِهِ- وَالْيَدَيْنِ، وَالرُّكْبَتَيْنِ، وَأَطْرَافِ الْقَدَمَيْنِ\" (وأطراف القدمين)؛ فهذا الحديث يبين هذه السبعة الأعظم التي أُمرنا أن نسجد عليها: الجبهة مع الأنف هذا عظم واحد (واحد)، ثم اليدان (ثلاثة)، الركبتان (خمسة)، والقدمان (سبعة). فقال رحمه الله تعالى: \"سُجُودُهُ عَلَى الْيَدَيْنْ وَطَرَفِ الرِّجْلَيْنِ *** مِثْلَ الرُّكْبَتَيْنْ\". ثم قال: إِنْصَاتُ مُقْتَدٍ بِجَهْرٍ ثُمَّ رَدّ *** عَلَى الْإِمَامِ وَالْيَسَارِ وَاحِدٌ بِهْ شَدّ \"إِنْصَاتُ مُقْتَدٍ بِجَهْرٍ\"؛ هذه السنة الثالثة التي يذكرها، السنة الخفيفة الثالثة وهي: إنصات مقتدٍ؛ المقتدي هو المأموم، إنصات المأموم في الصلاة الجهرية؛ إنصات المأموم في الصلاة الجهرية. قال رحمه الله: \"إِنْصَاتُ مُقْتَدٍ\" اللي هو المأموم \"بِجَهْرٍ\"؛ فـ المأموم في الصلاة الجهرية ينصت لإمامه؛ قال رسول الله صلى الله عليه وسلم: \"وَإِذَا قَرَأَ فَأَنْصِتُوا\" (وإذا قرأ فانصتوا)؛ أي إذا قرأ الإمام فانصتوا. وقال سبحانه: {وَإِذَا قُرِئَ الْقُرْآنُ فَاسْتَمِعُوا لَهُ وَأَنصِتُوا لَعَلَّكُمْ تُرْحَمُونَ}. \"إِنْصَاتُ مُقْتَدٍ بِجَهْرٍ ثُمَّ رَدّ *** عَلَى الْإِمَامِ وَالْيَسَارِ وَاحِدٌ بِهْ\"؛ هذه السنة الرابعة من من السنن الخفيفة التي ذكرها وهي: رد السلام على الإمام والمأموم. الخروج من الصلاة يكون بالتسليم؛ التسليم ركن، لكن التسليم الذي هو ركن هو التسليمة الأولى، التسليمة الأولى التي بها يخرج الإنسان من الصلاة؛ هذه التسليمة ركن من أركان الصلاة كما تقدم معنا. والنبي صلى الله عليه وسلم يقول: \"مِفْتَاحُ الصَّلَاةِ الطُّهُورُ، وَتَحْرِيمُهَا التَّكْبِيرُ، وَتَحْلِيلُهَا التَّسْلِيمُ\"؛ فالتسليمة الأولى ركن تخرج من الصلاة. يقول رحمه الله عليهم: التسليمة الثانية هي رد على سلام الإمام، التسليمة الثانية يرد على سلام الإمام (طبعاً حديثنا عن المأموم) فيقولون: رد على الإمام؛ كان الإمام لما يقول \"السلام عليكم\" نرد عليه ونقول: \"السلام عليكم\". وبعض المالكية يزيد تسليمة ثالثة، يقول تزيد تسليمة ثالثة ترد بها على من يوجد عن يسارك هو أيضاً سلّم تسلّم عليه؛ لهذا قال الناظم رحمه الله تعالى: \"ثُمَّ رَدّ *** عَلَى الْإِمَامِ وَالْيَسَارِ وَاحِدٌ بِهْ\" (إن كان به أحد)، ولكن الراجح والمشهور أنهما تسليمتان فقط؛ تسليمتان فقط لا ثلاث تسليمات، فالمأموم يسلم تسليمتين فقط (تسليمتين فقط). قال رحمه الله تعالى: \"إِنْصَاتُ مُقْتَدٍ بِجَهْرٍ ثُمَّ رَدّ *** عَلَى الْإِمَامِ وَالْيَسَارِ وَاحِدٌ بِهْ\"؛ وَزَائِدُ السُّكُونِ لِلْحُضُورِ سِرْ *** غَيْرُ مُقْتَدٍ خَافَ الْمُرُورْ السنة السادسة التي ذكرها من السنن الخفيفة؛ قال رحمه الله قال: \"وَزَائِدُ السُّكُونِ لِلْحُضُورِ\"؛ أي الزيادة في الطمأنينة، الزيادة في الطمأنينة. طبعاً على الطمأنينة، الطمأنينة تقدم معنا أنها ركن من أركان الصلاة له لها حد أدنى وهو استقرار الأعضاء (استقرار الأعضاء كما تقدم معنا)؛ لكن ما زاد على هذا، السنة أن الإنسان يطمئن طويلاً فهذا سنة. كان رسول الله صلى الله عليه وسلم أحياناً أو كان صلى الله عليه وسلم يطيل الصلاة أحـ كان يطيل الصلاة؛ يحكون عن أنس رضي الله عنه أنه كان أحياناً إذا رفع رأسه من الركوع يبقى حتى يقول القائل قد نسي، من كثرة ما ما يبقى منتصباً بعد قيامه من الركوع؛ فالزيادة على الحد الأدنى من الطمأنينة هذا مستحب، هذا سنة (سنة خفيفة)؛ قال رحمه الله: \"وَزَائِدُ السُّكُونِ لِلْحُضُورِ\". ثم قال: \"سُتْرَةُ عَيْنِ *** غَيْرِ مُقْتَدٍ خَافَ الْمُرُورْ\"؛ السنة السابعة من السنن الخفيفة: اتخاذ السترة، اتخاذ السترة، اتخاذ السترة لغير المأموم، أو اتخاذ السترة للإمام والمنفرد (اتخاذ السترة للإمام والمنفرد). يقول صلى الله عليه وسلم: \"إِذَا صَلَّى أَحَدُكُمْ فَلْيُصَلِّ إِلَى سُتْرَةٍ وَلْيَدْنُ مِنْهَا\" (فليصلِّ إلى سترة وليدن منها). السترة يعني شيء يضعه الإنسان أمامه وهو يصلي، يضع شيئاً أمامه حتى يمنع أحداً أن يمر بين يديه، لأن الإنسان وهو يصلي وهو يصلي له حرمة ولا يجوز لأحد أن يمر بين يديه. والنبي صلى الله عليه وسلم يقول: \"لَوْ يَعْلَمُ الْمَارُّ بَيْنَ يَدَيِ الْمُصَلِّي مَاذَا عَلَيْهِ، لَكَانَ أَنْ يَقِفَ أَرْبَعِينَ خَيْرًا لَهُ\"؛ وعيد شديد. لو يعلم المار بين يدي المصلي (إنسان يصلي بين يديه يعني ممكن إنسان يمر بين يديه بحيث إن ممكن أن تعترض وهكذا): \"لو يعلم المار بين يدي المصلي ماذا عليه لكان أن يقف أربعين خير لا\"، يقول الراوي: \"لا أدري أربعين يوماً ولا أربعين شهراً أربعين سنة أربعين ماذا\"؛ لكن لو لو قلنا فقط أربعين دقيقة الأمر ليس هيناً، ليس هيناً؛ فللمصلي حرمة. لكن ما يساعد المصلي على منع الناس من المرور بين يديه ويصلي: أن يضع سترة أمامه ويصلي؛ هذه السترة تكون يكون بينه بينها من المسافة بحيث إذا سجد، إذا سجد يبقى حوالي شبر بينه وبين السترة مثلاً، يضعها بعيداً عن موضع سجوده بحوالي شبر؛ هذا موضع السترة. قال صلى الله عليه وسلم: \"إِذَا صَلَّى أَحَدُكُمْ فَلْيُصَلِّ إِلَى سُتْرَةٍ وَلْيَدْنُ مِنْهَا\". وكان صلى الله عليه وسلم إذا خرج يحمل معه عنزة أو حربة؛ عنزة يعني حربة يعني التي يحملها المحارب، فكان يضعها أمامه ينصبها أمامه ثم يصلي، حتى إذا جاء من يريد أن يمر، يمر خلف خلف السترة فلا إشكال، فلا إشكال إن شاء الله. قال رحمه الله: \"سُتْرَةُ عَيْنِ *** غَيْرِ مُقْتَدٍ\"؛ غير مقتدٍ يعني غير المأموم، ففُهم من هذا أن الإمام يسن له أن يصلي إلى سترة، والفذ (من يصلي لوحده) هذا أيضاً يصلي إلى سترة؛ قلنا حتى يكف من يمكن أن يمر بين يديه. طيب، لماذا استثنى المأموم لما قال \"سُتْرَةُ عَيْنِ غَيْرِ مُقْتَدٍ\"؟ لأن المأموم سترته أمامه، سترة له سترة الإمام؛ سترة الإمام سترة للمأموم. لو أن إنساناً يصلي مأموماً وجاء إنسان مر بين يديه، ما لا يؤثر هذا، لا يؤثر؛ لِمَا؟ لأن سترة الإمام سترة له. وفي هذا حديث ابن عباس في صحيح مسلم أنه يقول: \"أَقْبَلْتُ وَأَنَا غُلَامٌ عَلَى أَتَانٍ لِي، فَمَرَرْتُ بَيْنَ يَدَيْ بَعْضِ الصَّفِّ، ثُمَّ أَرْسَلْتُ الْأَتَانَ تَرْتَعُ، وَرَسُولُ اللَّهِ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ يُصَلِّي بِمِنًى إِلَى غَيْرِ جِدَارٍ\" فـ هنا قال: \"فَلَمْ يُنْكِرْ ذَلِكَ عَلَيَّ أَحَدٌ\"؛ فابن عباس رضي الله عنه مر بـ الأتان هي أنثى الحمار، مر بها بين يدي بعض الصفوف ولم ينكر عليه أحد، لم ينكر عليه أحد؛ لماذا؟ لأن سترة الإمام سترة لِـمَن معه. ثم قال رحمه الله تعالى: جَهْرُ السَّلَامِ كَلِمُ التَّشَهُّدِ *** صَلَاتُنَا فِيهِ عَلَى مُحَمَّدِ \"جَهْرُ السَّلَامِ\"؛ أي الجهر بالسلام، لما يسلم يقول: \"السلام عليكم\"؛ جهر السلام. تقول عائشة رضي الله عنها في صفة صلاة رسول الله صلى الله عليه وسلم: \"ثُمَّ يُسَلِّمُ تَسْلِيمًا يُسْمِعُنَا\" (ثم يسلم تسليماً يسمعنا)، فـ الجهر بالسلام. قال رحمه الله: \"جَهْرُ السَّلَامِ *** كَلِمُ التَّشَهُّدِ\"؛ هذه السنة العاشرة من من السنن الخفيفة: كلام التشهد. قال: \"كَلِمُ التَّشَهُّدِ\"؛ قبل قليل ذكرنا بأن التشهد الذي ذكر الناظم رحمه الله أنه من السنن المؤكدة هو أن تقول: \"أشهد أن لا إله إلا الله، أشهد أن محمداً رسول الله\"، لكن قال هنا: \"كَلِمُ التَّشَهُّدِ\" أي صيغة التشهد كلها؛ صيغة التشهد كلها، هذه الصيغة: \"التحيات لله...\"؛ هذه الصيغة هذه الصيغة وردت مجموعة من الصيغ عن رسول الله صلى الله عليه وسلم في التشهد، وكلها ثابتة. المالكية رحمه الله عليهم اختاروا صيغة عمر بن الخطاب رضي الله عنه التي رواها مالك في الموطأ، وفيها أن عمر بن الخطاب رضي الله عنه كان يعلم الناس التشهد على المنبر يقول: \"التحيات لله، الزاكيات لله، الطيبات لله، الصلوات لله، السلام عليك أيها النبي ورحمة الله وبركاته، السلام علينا وعلى عباد الله الصالحين، أشهد أن لا إله إلا الله، وأشهد أن محمداً رسول الله\"؛ هذه صيغة عمر بن الخطاب رضي الله عنه، هذه صيغة ثابتة صحيحة، فـ هذه التي اختارها المالكية؛ لماذا؟ قال لأنه علمها الناس بمحضر من الصحابة وبالمسجد النبوي وفي المدينة ولم ينكر عليه أحد، فرأوا أن هذا يعطيها قوة. وهناك صيغة أخرى: صيغة ابن مسعود رضي الله عنه مخرجة في الصحيحين: \"التحيات لله والصلوات والطيبات، السلام عليك أيها النبي ورحمة الله وبركاته...\"؛ تختلف فقط في البداية: \"التحيات لله والصلوات والطيبات...\"، المهم هذا يعني هذه صيغ؛ أية صيغة أتى بها الإنسان أجزأته إن شاء الله. قال: \"كَلِمُ التَّشَهُّدِ\"، ثم قال: \"صَلَاتُنَا *** فِيهِ عَلَى مُحَمَّدِ\"؛ أي الصلاة على سيدنا رسول الله صلى الله عليه وسلم في التشهد، هذه الصلاة كذلك سنة. قال رحمـ وهذه الصيغة هذه الصلاة أيضاً وردت فيها صيغ عن سيدنا رسول الله صلى الله عليه وسلم؛ أية صيغة صحيحة أتت الإنسان أجزأت مثل: \"اللهم صل على محمد وعلى آل محمد كما صليت على آل إبراهيم، وبارك على محمد وعلى آل محمد كما باركت على آل إبراهيم إنك حميد مجيد\" أو غيرها من الصيغ إن شاء الله. وأنا أنصح إخواني وأخواتي من الطلبة والطالبات أن يقتنوا كتاباً من كتب الأذكار، ولعلي أشرت إلى هذا سابقاً: كتاب الأذكار للإمام النووي رحمه الله تعالى، أو كتاب حصن المسلم؛ كتاب صغير كتيب صغير مبارك بحمد الله عز وجل فيه أذكار مختصرة تخص الصلاة وغيرها، وهذا الحمد لله يعني يفيد يفيد الإنسان. هذه سنن ذكرها الناظم رحمه الله تعالى. بقيت سنتان فيهما الكلام يحتاج إلى بسط: سنة الأذان وسنة القصر؛ نرجئها للمجلس المقبل إن شاء الله تعالى. سبحانك اللهم وبحمدك أشهد أن لا إله إلا أنت أستغفرك وأتوب إليك، وصلى الله وسلم وبارك على سيدنا محمد وعلى آله، والحمد لله رب العالمين. السلام عليكم ورحمة الله وبركاته.",
    "blocks_search_text": "قراءة السورة والقيام لها تعد قراءة **السورة بعد الفاتحة** سنة مؤكدة في الركعتين الأوليين من الصلوات المفروضة والنوافل، لقول أبي سعيد الخدري: «أمرنا أن نقرأ بفاتحة الكتاب وما تيسر». ويرتبط بها **القيام لها**، وهو سنة أيضاً اقتداءً بالنبي ﷺ في قوله: «صلوا كما رأيتموني أصلي» <b>اتباعاً للسنة</b>. 💡 التفسير التربوي: يبين هذا الجزء أن الصلاة ليست مجرد حركات، بل هي نظام متكامل من الأركان والسنن. قراءة السورة بعد الفاتحة تعزز الخشوع وتزيد من تدبر القرآن في صلاتك، والقيام لها هو تأدب مع كلام الله. أحكام الجهر والسر في الصلاة الجهر في محله سنة في الصبح والمغرب والعشاء والجمعة، وأدنى مراتب الجهر أن **يسمع القارئ نفسه ومن يليه**. أما السر في الظهر والعصر، فأدناه **تحريك اللسان بالقراءة**، وأعلاه أن يسمع المصلي نفسه، ولا تعتبر القراءة صحيحة دون تحريك اللسان <b>ليتحقق شرط القراءة</b>. 💡 التفسير التربوي: الجهر والسر في الصلاة يربطان المصلي ببيئته (الجماعة) أو بصلته الخاصة مع الله. تعلم الضوابط الدقيقة، مثل تحريك اللسان، يصحح العبادة ويخرجها من حيز التمني إلى حيز العمل الشرعي. سنن التكبير والجلوس للتشهد ما عدا **تكبيرة الإحرام** التي هي ركن، فإن سائر التكبيرات عند الخفض والرفع سنة. كما أن **التشهد الأول والجلوس له** يعدان من السنن المؤكدة، والجلوس للتشهد لا يشمل الجلوس للسلام لأنه ركن مستقل؛ فالتشهد سنة، والجلوس له سنة <b>يُجبر تركها بسجود السهو</b>. 💡 التفسير التربوي: التكبيرات الانتقالية وسيلة لربط جسد المصلي بحركاته، وهي تذكر بقدسية الانتقال بين أركان الصلاة. التفرقة بين سنن الجلوس وأركان السلام تظهر عمق الفقه في التفريق بين ما هو كمالي وما هو أساسي في الصلاة. حكم التسميع وفضل السنن المؤكدة قول **«سمع الله لمن حمده»** سنة للإمام والمنفرد عند الرفع من الركوع، أما المأموم فيكتفي بـ **«ربنا ولك الحمد»**. هذه السنن العشر المذكورة مؤكدة، يترتب على تركها سجود السهو، بخلاف السنن الخفيفة التي تشبه المندوبات <b>في الحكم والأجر</b>. 💡 التفسير التربوي: التسميع يحقق مبدأ الترتيب الوظيفي في صلاة الجماعة، حيث يوزع المهام بين الإمام والمأموم؛ فالإمام يفتح بالذكر والمأموم يجيب بالحمد، وهو تجسيد لروح التعاون في العبادة. سنن الصلاة الخفيفة وسجودها من السنن الخفيفة: السجود على **سبعة أعظم** (الجبهة والأنف، اليدين، الركبتين، وأطراف القدمين)، وتكون اليدان مبسوطتين غير مفترشتين. ومنها **الإنصات للمأموم** في الجهرية، ورد السلام على الإمام، والزيادة في الطمأنينة، و**اتخاذ السترة** لغير المأموم <b>لحفظ حرمة الصلاة</b>. 💡 التفسير التربوي: السنن الخفيفة كـ \"السترة\" أو \"زيادة الطمأنينة\" ليست كماليات فقط، بل هي حماية للعبادة من التشويش أو الاستعجال، وهي تدرب المسلم على الاهتمام بالتفاصيل التي ترفع من جودة صلاته. صيغ التشهد والصلاة على النبي يُسن الجهر بالسلام الأول، كما يُسن الإتيان بصيغ التشهد الثابتة كـ **صيغة عمر بن الخطاب** أو ابن مسعود، و**الصلاة على النبي ﷺ** في التشهد، وهي من السنن التي يكمل بها العبد عبادته <b>بالتأسي به صلى الله عليه وسلم</b>. 💡 التفسير التربوي: تنوع صيغ التشهد يعكس سعة الإسلام ورحابته. استذكار هذه الصيغ والحرص عليها يربط قلب المصلي بالنبي ﷺ، ويجعل خاتمة الصلاة مليئة بالثناء والصلاة على أشرف الخلق.",
