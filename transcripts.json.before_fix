    "video_url": null,
    "segments": [
      {
        "ts": "0:00",
        "sec": 0,
        "text": "بسم الله والحمد لله والصلاة والسلام على رسول الله وعلى آله وصحبه ومن والاه. أما بعد، فهذا درس جديد من دروس التوحيد",
        "video_link": null
      },
