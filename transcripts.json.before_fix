        "text": "السَّلَامْ\". المندوب الثاني قال: \"تَأْمِينُ مَنْ صَلَّى عَدَا جَهْرَ الْإِمَامْ\". المندوب الثاني:",
        "video_link": null
      },
      {
        "ts": "3:07",
        "sec": 187,
        "text": "التأمين، والتأمين هو قول المصلي: \"آمين\"؛",
        "video_link": null
      },
      {
        "ts": "3:14",
        "sec": 194,
        "text": "وآمين تعني: اللهم استجب، اللهم استجب؛ هذا دعاء \"اللهم",
        "video_link": null
      },
      {
        "ts": "3:22",
        "sec": 202,
        "text": "استجب\". وردت في أحاديث كثيرة، ورد في أحاديث كثيرة الكلام على التأمين وبيان فضله؛",
        "video_link": null
      },
      {
        "ts": "3:30",
        "sec": 210,
        "text": "منها قول النبي صلى الله عليه وسلم: \"وَإِذَا قَالَ\" -أي الإمام- \"إِذَا قَالَ: {غَيْرِ",
        "video_link": null
      },
      {
        "ts": "3:38",
        "sec": 218,
        "text": "الْمَغْضُوبِ عَلَيْهِمْ وَلَا الضَّالِّينَ} فَقُولُوا: آمِينَ\" (فقولوا",
        "video_link": null
      },
      {
        "ts": "3:46",
        "sec": 226,
        "text": "آمين). وقوله صلى الله عليه وسلم: \"إِذَا أَمَّنَ الْإِمَامُ فَأَمِّنُوا، فَمَنْ وَافَقَ تَأْمِينُهُ تَأْمِينُ الْمَلَائِكَةِ",
        "video_link": null
      },
      {
        "ts": "3:55",
        "sec": 235,
        "text": "غُفِرَ لَهُ مَا تَقَدَّمَ مِنْ ذَنْبِهِ\".",
        "video_link": null
      },
      {
        "ts": "4:02",
        "sec": 242,
        "text": "عفواً، هذا التأمين الناظم رحمه الله ماذا قال؟ قال: \"تَأْمِينُ مَنْ صَلَّى عَدَا جَهْرَ الْإِمَامْ\"؛ أي",
        "video_link": null
      },
      {
        "ts": "4:12",
        "sec": 252,
        "text": "باستثناء الإمام في الجهرية؛ يعني مفهوم كلام",
        "video_link": null
      },
      {
        "ts": "4:19",
        "sec": 259,
        "text": "الناظم أن المنفرد (من يصلي لوحده) يؤمِّن",
        "video_link": null
      },
      {
        "ts": "4:27",
        "sec": 267,
        "text": "مطلقاً يؤمِّن، المأموم يؤمِّن مطلقاً؛ في السر في",
        "video_link": null
      },
      {
        "ts": "4:32",
        "sec": 272,
        "text": "السرية والجهرية كذلك المنفرد كما أسلفنا، الإمام",
        "video_link": null
      },
      {
        "ts": "4:40",
        "sec": 280,
        "text": "يؤمِّن في السرية ولا يؤمِّن في",
        "video_link": null
      },
      {
        "ts": "4:47",
        "sec": 287,
        "text": "الجهرية. هذا مشهور مذهب المالكية؛ أن الإمام في الصلاة الجهرية لا",
        "video_link": null
      },
      {
        "ts": "4:55",
        "sec": 295,
        "text": "يؤمِّن، لكن الحديث الذي ذكرناه آنفاً يرد على هذا؛ فقد قال النبي صلى الله عليه وسلم: \"إِذَا",
        "video_link": null
      },
      {
        "ts": "5:03",
        "sec": 303,
        "text": "أَمَّنَ الْإِمَامُ فَأَمِّنُوا\" يعني أن المأموم يسمع تأمين الإمام؛",
        "video_link": null
      },
      {
        "ts": "5:11",
        "sec": 311,
        "text": "\"إِذَا أَمَّنَ الْإِمَامُ\" أي قال الإمام:",
        "video_link": null
      },
      {
        "ts": "5:17",
        "sec": 317,
        "text": "\"آمين\" فـ أمِّنوا أنتم قولوا آمين. ورد في حديث في رواية أخرى: \"فَإِنَّ الْإِمَامَ يَقُولُ آمِينَ",
        "video_link": null
      },
      {
        "ts": "5:25",
        "sec": 325,
        "text": "وَالْمَلَائِكَةَ تَقُولُ آمِينَ\"، لذا قال صلى الله عليه وسلم في هذه الرواية: \"فَمَنْ وَافَقَ تَأْمِينُهُ تَأْمِينُ الْمَلَائِكَةِ",
        "video_link": null
      },
      {
        "ts": "5:33",
        "sec": 333,
        "text": "غُفِرَ لَهُ مَا تَقَدَّمَ مِنْ ذَنْبِهِ\". الـ المالكية رحمه الله عليهم",
        "video_link": null
      },
      {
        "ts": "5:43",
        "sec": 343,
        "text": "يؤولون هذا الحديث حديث \"إذا أمَّن الإمام\"، فيقولون إن معنى أمَّن أي بلغ موضع التأمين؛",
        "video_link": null
      },
      {
        "ts": "5:51",
        "sec": 351,
        "text": "كما تقول: \"أصبحتُ\" أي دخلتُ في الصباح، و\"أمسيتُ\" دخلتُ في المساء؛ ويقال: \"أنجدَ الرجل\" إذا دخل",
        "video_link": null
      },
      {
        "ts": "5:57",
        "sec": 357,
        "text": "نجداً، و\"أعرقَ\" إذا دخل العراق؛ فـ \"أمَّن\" أي بلغ موضع التأمين. لكن هذا تأويل لا حاجة إليه،",
        "video_link": null
      },
      {
        "ts": "6:04",
        "sec": 364,
        "text": "فالأصل حمل الكلام على حقيقته لا على المجاز، ويرده ما ورد في حديث في الحديث الصريح:",
        "video_link": null
      },
      {
        "ts": "6:12",
        "sec": 372,
        "text": "أنه صلى الله عليه وسلم كان إذا قال: {غَيْرِ الْمَغْضُوبِ عَلَيْهِمْ وَلَا الضَّالِّينَ} قال: \"آمِينَ\" حتى يُسمع من يليه.",
        "video_link": null
      },
      {
        "ts": "6:19",
        "sec": 379,
        "text": "فلذلك من مندوبات الصلاة التأمين مطلقاً؛",
        "video_link": null
      },
      {
        "ts": "6:25",
        "sec": 385,
        "text": "يؤمِّن؛ الإمام والمأموم والمنفرد، سواء كانت الصلاة سرية أو كانت جهرية؛ إذاً قال",
        "video_link": null
      },
      {
        "ts": "6:35",
        "sec": 395,
        "text": "رحمه الله: \"تَأْمِينُ مَنْ صَلَّى عَدَا جَهْرَ الْإِمَامْ\"، لأن مشهور المذهب أن الإمام لا يؤمِّن في الصلاة",
        "video_link": null
      },
      {
        "ts": "6:43",
        "sec": 403,
        "text": "الجهرية. ثم قال: \"وَقَوْلُ رَبَّنَا لَكَ الْحَمْدُ عَدَا *** مَنْ أَمَّ\". المندوب الثالث؛ قال الناظم رحمه الله:",
        "video_link": null
      },
      {
        "ts": "6:53",
        "sec": 413,
        "text": "\"وَقَوْلُ رَبَّنَا لَكَ الْحَمْدُ عَدَا *** مَنْ أَمَّ\". المندوب",
        "video_link": null
      },
      {
        "ts": "6:58",
        "sec": 418,
        "text": "الثالث هو التحميد؛ أي قول: \"ربنا لك الحمد\". وبالمناسبة في صيغ كلها ثابتة عن رسول الله",
        "video_link": null
      },
      {
        "ts": "7:07",
        "sec": 427,
        "text": "صلى الله عليه وسلم: \"ربنا لك الحمد\"، \"ربنا ولك الحمد\"، \"اللهم ربنا لك الحمد\"، \"اللهم ربنا",
        "video_link": null
      },
      {
        "ts": "7:14",
        "sec": 434,
        "text": "ولك الحمد\"؛ كلها ثابتة عن رسول الله صلى الله عليه وسلم. قال الحبيب صلى الله عليه وسلم وهو يبين لنا أمر الصلاة، قال: \"وَإِذَا",
        "video_link": null
      },
      {
        "ts": "7:24",
        "sec": 444,
        "text": "قَالَ\" -أي الإمام- \"وَإِذَا قَالَ: سَمِعَ اللَّهُ لِمَنْ حَمِدَهُ، فَقُولُوا: رَبَّنَا وَلَكَ الْحَمْدُ\" فقولوا: \"ربنا ولك",
        "video_link": null
      },
      {
        "ts": "7:31",
        "sec": 451,
        "text": "الحمد\". هذا التحميد يقوله",
        "video_link": null
      },
      {
        "ts": "7:38",
        "sec": 458,
        "text": "المنفرد ويقوله المأموم؛ الإمام يقول الناظم رحمه الله إن الإمام",
        "video_link": null
      },
      {
        "ts": "7:48",
        "sec": 468,
        "text": "لا لا يأتي به، لا يقول الإمام: \"ربنا ولك الحمد\"، لذلك قال رحمه الله: \"وَقَوْلُ رَبَّنَا لَكَ الْحَمْدُ عَدَا\"؛",
        "video_link": null
      },
      {
        "ts": "7:55",
        "sec": 475,
        "text": "عَدَا أي باستثناء \"مَنْ أَمَّ\"؛ أي باستثناء الإمام، لماذا؟ لأن في الحديث الذي ذكرناه",
        "video_link": null
      },
      {
        "ts": "8:02",
        "sec": 482,
        "text": "آنفاً يقول عليه الصلاة والسلام: \"وَإِذَا قَالَ: سَمِعَ اللَّهُ لِمَنْ حَمِدَهُ، فَقُولُوا: رَبَّنَا وَلَكَ الْحَمْدُ\"؛ لكن الواقع أنه ثبت أن رسول الله صلى",
        "video_link": null
      },
      {
        "ts": "8:10",
        "sec": 490,
        "text": "الله عليه وسلم كان يأتي بالتسميع والتحميد معاً وهو إمام؛ كان يقول: \"سمع الله لمن حمده\"، ويقول أيضاً: \"ربنا ولك الحمد\". ثم قال رحمه",
        "video_link": null
      },
      {
        "ts": "8:19",
        "sec": 499,
        "text": "الله: \"وَالْقُنُوتُ فِي الصُّبْحِ بَدَا\". المندوب الرابع:",
        "video_link": null
      },
      {
        "ts": "8:25",
        "sec": 505,
        "text": "القنوت. لفظة القنوت لها معانٍ متعددة؛ منها:",
        "video_link": null
      },
      {
        "ts": "8:32",
        "sec": 512,
        "text": "الدعاء، وهو المعنى المقصود هنا. المالكية ومن وافقهم رحمه الله على",
        "video_link": null
      },
      {
        "ts": "8:39",
        "sec": 519,
        "text": "علمائنا جميعاً يرون أن المصلي يقنت",
        "video_link": null
      },
      {
        "ts": "8:47",
        "sec": 527,
        "text": "متى؟ في صلاة الصبح في الركعة الثانية قبل",
        "video_link": null
      },
      {
        "ts": "8:54",
        "sec": 534,
        "text": "الركوع؛ صلاة الصبح خاصة في الركعة الثانية قبل أن يركع، أنهى القراءة يقنت؛ ماذا يقول؟",
        "video_link": null
      },
      {
        "ts": "9:03",
        "sec": 543,
        "text": "يدعو يدعو، ويرون في ذلك حديثاً أو دعاءً",
        "video_link": null
      },
      {
        "ts": "9:09",
        "sec": 549,
        "text": "يستحبونه وهو وفيه: \"اللهم إنا نستعينك",
        "video_link": null
      },
      {
        "ts": "9:16",
        "sec": 556,
        "text": "ونستغفرك ونؤمن بك ونخنع لك ونخلع من",
        "video_link": null
      },
      {
        "ts": "9:22",
        "sec": 562,
        "text": "ونخلع ونترك من يكفرك، اللهم إن اللهم إياك نعبد ولك نصلي",
        "video_link": null
      },
      {
        "ts": "9:29",
        "sec": 569,
        "text": "ونسجد وإليك نسعى ونحفد، نرجو رحمتك ونخاف",
        "video_link": null
      },
      {
        "ts": "9:36",
        "sec": 576,
        "text": "عذابك\" (نرجو رحمتك ونخاف عذابك الجد)، \"إن عذابك الجد بالكافرين",
        "video_link": null
      },
      {
        "ts": "9:43",
        "sec": 583,
        "text": "ملحق\"؛ هذا هذا دعاء الدعاء الذي يستحبون في في",
        "video_link": null
      },
      {
        "ts": "9:50",
        "sec": 590,
        "text": "القنوت في في هذا الموضع. وهذا يعني تحديد هذا المـ",
        "video_link": null
      },
      {
        "ts": "10:00",
        "sec": 600,
        "text": "ـوضع بالقنوت لعله لم يثبت فيه حديث صحيح؛ لكن هذا هذا المندوب",
        "video_link": null
      },
      {
        "ts": "10:09",
        "sec": 609,
        "text": "الرابع. ثم قال رحمه الله: \"رِدَا\"، رِدَا أي",
        "video_link": null
      },
      {
        "ts": "10:17",
        "sec": 617,
        "text": "الرداء؛ الرداء ما هو الرداء؟ الرداء هو الثوب",
        "video_link": null
      },
      {
        "ts": "10:22",
        "sec": 622,
        "text": "الذي يوضع على عاتق المصلي ويستر به صدره؛ يعني كأن نقول اللباس الذي يغطي أعلى",
        "video_link": null
      },
      {
        "ts": "10:31",
        "sec": 631,
        "text": "البدن. هذا نحن الآن نتحدث عن الرجل، لأن ستر العورة هذا من شروط الصلاة كما مر",
        "video_link": null
      },
      {
        "ts": "10:41",
        "sec": 641,
        "text": "معنا؛ عاتق الرجل وصدره ليس من",
        "video_link": null
      },
      {
        "ts": "10:49",
        "sec": 649,
        "text": "العورة، سترهما هذا من مندوبات الصلاة. قال النبي صلى الله عليه وسلم: \"لَا يُصَلِّيَنَّ أَحَدُكُمْ",
        "video_link": null
      },
      {
        "ts": "10:58",
        "sec": 658,
        "text": "فِي الثَّوْبِ الْوَاحِدِ لَيْسَ عَلَى عَاتِقِهِ مِنْهُ شَيْءٌ\" (لا يصلين أحدكم في الثوب الواحد ليس على عاتقه",
        "video_link": null
      },
      {
        "ts": "11:07",
        "sec": 667,
        "text": "منه شيء). ثم قال رحمه الله: وَرِدَا وَتَسْبِيحُ السُّجُودِ وَالرُّكُوعْ *** سَدْلُ يَدٍ تَكْبِيرُهُ مَعَ الشُّروعْ وَبَعْدَ أَنْ يَقُومَ مِنْ وُسْطَاهُ *** وَعَقْدُهُ الثَّلَاثَ مِنْ يُمْنَاهُ لَدَى التَّشَهُّدِ وَبَسْطُ مَا خَلَاهْ *** تَحْرِيكُ سَبَّابَتِهَا حِينَ تَلَاهْ",
        "video_link": null
      },
      {
        "ts": "11:17",
        "sec": 677,
        "text": "المقصود قول: \"سبحان ربي العظيم\" في",
        "video_link": null
      },
      {
        "ts": "11:23",
        "sec": 683,
        "text": "الركوع، وقول: \"سبحان ربي الأعلى\" في السجود؛",
        "video_link": null
      },
      {
        "ts": "11:29",
        "sec": 689,
        "text": "هذا المقصد بقوله: \"وَتَسْبِيحُ السُّجُودِ وَالرُّكُوعْ\" أي التسبيح في السجود",
        "video_link": null
      },
      {
        "ts": "11:37",
        "sec": 697,
        "text": "والركوع. لما نزل قول الله عز وجل: {فَسَبِّحْ بِاسْمِ رَبِّكَ الْعَظِيمِ} قال صلى الله عليه وسلم:",
        "video_link": null
      },
      {
        "ts": "11:45",
        "sec": 705,
        "text": "\"اجْعَلُوهَا فِي رُكُوعِكُمْ\"؛ ولما نزلت: {سَبِّحِ اسْمَ رَبِّكَ الْأَعْلَى} قال:",
        "video_link": null
      },
      {
        "ts": "11:52",
        "sec": 712,
        "text": "\"اجْعَلُوهَا فِي سُجُودِكُمْ\". فالإنسان لما يركع يقول: \"سبحان ربي العظيم،",
        "video_link": null
      },
      {
        "ts": "11:59",
        "sec": 719,
        "text": "سبحان ربي العظيم، سبحان ربي العظيم\" يعني على الأقل ثلاث مرات، ولو زاد",
        "video_link": null
      },
      {
        "ts": "12:08",
        "sec": 728,
        "text": "لا بأس إن شاء الله فهو أحب إلى الله عز وجل؛ وتجزئ مرة واحدة، تجزئ لو قالها مرة",
        "video_link": null
      },
      {
        "ts": "12:14",
        "sec": 734,
        "text": "واحدة تجزئه إن شاء الله. وإذا سجد يقول: \"سبحان ربي الأعلى، سبحان ربي الأعلى، سبحان",
        "video_link": null
      },
      {
        "ts": "12:21",
        "sec": 741,
        "text": "ربي الأعلى\". وحان لو تاملت في هذا تجد جمال الصلاة وجلالها؛ فإن حينما تركع لا تركع إلا",
        "video_link": null
      },
      {
        "ts": "12:29",
        "sec": 749,
        "text": "لعظيم، تقول: \"سبحان ربي العظيم، سبحان ربي العظيم، سبحان ربي العظيم\" وأنت راكع لمولاك",
        "video_link": null
      },
      {
        "ts": "12:36",
        "sec": 756,
        "text": "العظيم جل جلاله؛ ثم سبحان الله لما تسجد، تسجد تضع أعلى ما في جسدك الذي هو",
        "video_link": null
      },
      {
        "ts": "12:45",
        "sec": 765,
        "text": "الجبهة والأنف، تضعهما في التراب على الأرض، فأنت في قمة السفل وتسبح مَن هو في",
        "video_link": null
      },
      {
        "ts": "12:56",
        "sec": 776,
        "text": "قمة العلو فتقول: \"سبحان سبحان ربي الأعلى، سبحان ربي الأعلى، سبحان ربي الأعلى\" هذا في",
        "video_link": null
      },
      {
        "ts": "13:03",
        "sec": 783,
        "text": "السجود. طبعاً بعد ذلك تدعو بما شئت في السجود، كما قال صلى الله عليه وسلم عن السجود: \"فَاجْتَهِدُوا فِي الدُّعَاءِ، فَإِنَّهُ قَمِنٌ أَنْ",
        "video_link": null
      },
      {
        "ts": "13:13",
        "sec": 793,
        "text": "يُسْتَجَابَ لَكُمْ\"؛ أي حقيق أن يستجاب لكم. \"وَتَسْبِيحُ السُّجُودِ وَالرُّكُوعْ *** سَدْلُ يَدٍ\"؛ المندوب",
        "video_link": null
      },
      {
        "ts": "13:21",
        "sec": 801,
        "text": "السابع: سدل اليدين، سدل اليدين أي إرسالهما هكذا إرسالهما، وإرسال اليد الذي هو ضده",
        "video_link": null
      },
      {
        "ts": "13:30",
        "sec": 810,
        "text": "وضع اليد على الصدر (وضع اليمنى على اليسرى على الصدر)، هذا ضد السدل",
        "video_link": null
      },
      {
        "ts": "13:39",
        "sec": 819,
        "text": "والإرسال. المالكية رحمه الله عليهم يرون من مندوبات الصلاة في المشهور عندهم -طبعاً هذا المشهور وفي خلاف داخل",
        "video_link": null
      },
      {
        "ts": "13:47",
        "sec": 827,
        "text": "المذهب في هذا- المشهور أن المصلي يرسل يديه ولا يضعهما على صدره؛ وهذا في الفرض",
        "video_link": null
      },
      {
        "ts": "13:56",
        "sec": 836,
        "text": "خاصة، هذا في الصلاة المفروضة خاصة، أما في في النوافل فيستحب له أن يضع يده على",
        "video_link": null
      },
      {
        "ts": "14:05",
        "sec": 845,
        "text": "صدره. ودليل الواقع المالكية لما شهروا هذا ليس",
        "video_link": null
      },
      {
        "ts": "14:12",
        "sec": 852,
        "text": "معهم حديث لا صحيح ولا حسن ولا حديث ضعيف، وإنما من استدل بأن بعض الذي نقل صفة رـ",
        "video_link": null
      },
      {
        "ts": "14:22",
        "sec": 862,
        "text": "صلاة رسول الله صلى الله عليه وسلم مثل أبي حميد الساعدي وغيره لم ينقلوا أنه صلى",
        "video_link": null
      },
      {
        "ts": "14:29",
        "sec": 869,
        "text": "الله عليه وسلم وضع يده على",
        "video_link": null
      },
      {
        "ts": "14:35",
        "sec": 875,
        "text": "صدره؛ وأيضاً استُدل بما نُقل عن الإمام مالك رحمه الله أنه",
        "video_link": null
      },
      {
        "ts": "14:42",
        "sec": 882,
        "text": "يكره الاعتماد في الصلاة، يكره الاعتماد في الصلاة؛ الاعتماد: الاتكاء، طبعاً هذا باختصار نحن الآن في في",
        "video_link": null
      },
      {
        "ts": "14:50",
        "sec": 890,
        "text": "هذا شرح هذا النظم لا اريد أن أبسط الأدلة في أية مسألة، وإنما أحياناً بعض المسائل",
        "video_link": null
      },
      {
        "ts": "14:56",
        "sec": 896,
        "text": "أتوقف عندها فأتوسع قليلاً جداً باقتضاب؛ لكن الواقع",
        "video_link": null
      },
      {
        "ts": "15:03",
        "sec": 903,
        "text": "أن وضع اليد على الصدر (وضع اليمنى على اليسرى على الصدر)",
        "video_link": null
      },
      {
        "ts": "15:10",
        "sec": 910,
        "text": "هذا ثبت في أحاديث كثيرة، حوالي رُوي عن النبي صلى الله عليه وسلم حوالي عشرين حديثاً؛",
        "video_link": null
      },
      {
        "ts": "15:18",
        "sec": 918,
        "text": "جلها أحاديث صحاح؛ بعضها في الصحيحين بعضها في صحيح البخاري ومسلم، بل بعضها رواه الإمام",
        "video_link": null
      },
      {
        "ts": "15:26",
        "sec": 926,
        "text": "مالك رحمه الله في الموطأ؛ الإمام مالك رحمه الله روى في الموطأ أن قال إن النبي صلى الله عليه وسلم قال: \"أُمِرْنَا مَعْشَرَ الْأَنْبِيَاءِ",
        "video_link": null
      },
      {
        "ts": "15:36",
        "sec": 936,
        "text": "بِتَعْجِيلِ فِطْرِنَا، وَتَأْخِيرِ سُحُورِنَا، وَوَضْعِ أَيْمَانِنَا عَلَى شَمَائِلِنَا فِي الصَّلَاةِ\"؛",
        "video_link": null
      },
      {
        "ts": "15:44",
        "sec": 944,
        "text": "وفي صحيح البخاري عن سهل بن سعد الساعدي رضي الله عنه، قال: \"كَانَ النَّاسُ يُؤْمَرُونَ أَنْ يَضَعَ",
        "video_link": null
      },
      {
        "ts": "15:52",
        "sec": 952,
        "text": "الرَّجُلُ يَدَهُ الْيُمْنَى عَلَى ذِرَاعِهِ الْيُسْرَى فِي الصَّلَاةِ\" (عفواً: أن يضع الرجل يده اليمنى على ذراعه",
        "video_link": null
      },
      {
        "ts": "15:59",
        "sec": 959,
        "text": "اليسرى؛ كان الناس يؤمرون أن يضع الرجل يده اليمنى على ذراعه اليسرى)، وفي أحاديث كثيرة",
        "video_link": null
      },
      {
        "ts": "16:05",
        "sec": 965,
        "text": "يعني في هذا؛ فلذلك الصواب والراجح أن السنة والمندوب هو وضع اليد",
        "video_link": null
      },
      {
        "ts": "16:14",
        "sec": 974,
        "text": "اليمنى على اليسرى على الصدر لا إرسالهما، لصحة الأحاديث الواردة في ذلك وهي كثيرة",
        "video_link": null
      },
      {
        "ts": "16:23",
        "sec": 983,
        "text": "جداً؛ ولم يرد ولا حديث صحيح بل ولا ضعيف",
        "video_link": null
      },
      {
        "ts": "16:30",
        "sec": 990,
        "text": "في أنه صلى الله عليه وسلم كان يرسل، كان يرسل يديه. ثم هذا أيضاً هذا الذي يناسب، هذا الذي",
        "video_link": null
      },
      {
        "ts": "16:40",
        "sec": 1000,
        "text": "يناسب الأدب مع الله عز وجل، والإنسان بين يدي ربه سبحانه وتعالى يقف في غاية",
        "video_link": null
      },
      {
        "ts": "16:47",
        "sec": 1007,
        "text": "الأدب. ثم قال رحمه الله: \"تَكْبِيرُهُ مَعَ الشُّروعْ\"؛ تكبيره مع",
        "video_link": null
      },
      {
        "ts": "16:55",
        "sec": 1015,
        "text": "الشروع، هذا المندوب الثامن وهو مقارنة التكبير للشروع في الفعل، مقارنة",
        "video_link": null
      },
      {
        "ts": "17:05",
        "sec": 1025,
        "text": "التكبير للشروع في الفعل؛ معنى هذا الكلام مثلاً أنت تصلي واقف،",
        "video_link": null
      },
      {
        "ts": "17:13",
        "sec": 1033,
        "text": "تصلي أردت أن تركع؛ مع مع شروعك في الركوع تشرع في",
        "video_link": null
      },
      {
        "ts": "17:20",
        "sec": 1040,
        "text": "التكبير فتقول: \"الله أكبر\" وتنزل راكعاً، بمعنى ليس من السنة أنك تنزل للركوع",
        "video_link": null
      },
      {
        "ts": "17:31",
        "sec": 1051,
        "text": "وبعد أن تركع تقول: \"الله أكبر\" لا، بل يكون",
        "video_link": null
      },
      {
        "ts": "17:37",
        "sec": 1057,
        "text": "التكبير مقارناً للفعل؛ وكذلك ليس من السنة أنك مثلاً أنت واقف تقول: \"الله أكبر\" ثم تركع،",
        "video_link": null
      },
      {
        "ts": "17:47",
        "sec": 1067,
        "text": "لا، بل يكون التكبير مقارناً للركوع. إذا أردت أن تسجد تقول: \"الله أكبر\"",
        "video_link": null
      },
      {
        "ts": "17:55",
        "sec": 1075,
        "text": "وأنت تهوي إلى السجود؛ رفعت من السجود تقول: \"الله أكبر\" وتقوم من السجود، لا تكبر وأنت",
        "video_link": null
      },
      {
        "ts": "18:03",
        "sec": 1083,
        "text": "ساجد ثم ترفع، أو لا ترفع وأنت ساكت وبعد أن تجلس تقول: \"الله أكبر\"؛ ذا قال رحمه الله:",
        "video_link": null
      },
      {
        "ts": "18:11",
        "sec": 1091,
        "text": "\"تَكْبِيرُهُ مَعَ الشُّروعْ\" أي مقارنة التكبير للشروع في الفعل. ويدل على",
        "video_link": null
      },
      {
        "ts": "18:18",
        "sec": 1098,
        "text": "هذا ما ورد في وصف صلاة رسول الله صلى الله عليه وسلم: \"أَنَّهُ كَانَ يُكَبِّرُ حِينَ يَقُومُ،",
        "video_link": null
      },
      {
        "ts": "18:26",
        "sec": 1106,
        "text": "ثُمَّ يُكَبِّرُ حِينَ يَرْكَعُ، وَيُكَبِّرُ...\"؛ إذن في قول قول الصحابي: \"يكبر",
        "video_link": null
      },
      {
        "ts": "18:34",
        "sec": 1114,
        "text": "حين حين يقوم، حين يركع\" ففهم منه العلماء",
        "video_link": null
      },
      {
        "ts": "18:40",
        "sec": 1120,
        "text": "مقارنة التكبير للشروع في الفعل. قال رحمه الله تعالى: \"وَبَعْدَ أَنْ يَقُومَ مِنْ وُسْطَاهُ\"؛ وبعد أن يقوم",
        "video_link": null
      },
      {
        "ts": "18:50",
        "sec": 1130,
        "text": "من وسطاه، هنا المندوب التاسع:",
        "video_link": null
      },
      {
        "ts": "18:57",
        "sec": 1137,
        "text": "تأخير التكبير إلى حين إتمام القيام من",
        "video_link": null
      },
      {
        "ts": "19:03",
        "sec": 1143,
        "text": "الوسطى، تأخير التكبير إلى حين إتمام القيام الوسطى. نحن قلنا إن التكبير يقارن",
        "video_link": null
      },
      {
        "ts": "19:13",
        "sec": 1153,
        "text": "الفعل؛ يستثني المالكية في المشهور عندهم حالة واحدة،",
        "video_link": null
      },
      {
        "ts": "19:19",
        "sec": 1159,
        "text": "وهي حين تقوم من التشهد الأوسط إلى الركعة",
        "video_link": null
      },
      {
        "ts": "19:25",
        "sec": 1165,
        "text": "الثالثة، فيقولون: أنهيت التشهد الأوسط تقوم واقفاً حتى تستوي قائماً، حينئذٍ تقول: \"الله",
        "video_link": null
      },
      {
        "ts": "19:36",
        "sec": 1176,
        "text": "أكبر\". الواقع يعني هذا يستدل له",
        "video_link": null
      },
      {
        "ts": "19:43",
        "sec": 1183,
        "text": "بالحديث الذي ذكر طرف منه آنفاً وفيه: \"أَنَّهُ صلى الله عليه وسلم كَانَ يُكَبِّرُ حِينَ يَقُومُ،",
        "video_link": null
      },
      {
        "ts": "19:50",
        "sec": 1190,
        "text": "وَيُكَبِّرُ حِينَ يَرْكَعُ\" وفيه: \"وَإِذَا نَهَضَ مِنَ الرَّكْعَتَيْنِ كَبَّرَ\" (وإذا نهض من الركعتين كبر)؛ ففهموا من",
        "video_link": null
      },
      {
        "ts": "19:58",
        "sec": 1198,
        "text": "اللفظ أنه لا يكبر حتى يستوي قائماً حتى ينهض، هكذا فـ فقالوا: \"وإذا نهض من",
        "video_link": null
      },
      {
        "ts": "20:06",
        "sec": 1206,
        "text": "الركعتين يكبر\"، واللفظ يحتمل يحتمل فعلاً تأخير التكبير إلى حين إتمام",
        "video_link": null
      },
      {
        "ts": "20:14",
        "sec": 1214,
        "text": "القيام، ويحتمل مقارنة التكبير للقيام. قال رحمه الله تعالى: \"وَعَقْدُهُ الثَّلَاثَ مِنْ يُمْنَاهُ *** لَدَى التَّشَهُّدِ وَبَسْطُ مَا خَلَاهْ\"؛",
        "video_link": null
      },
      {
        "ts": "20:30",
        "sec": 1230,
        "text": "هذا المندوب العاشر: عقد الأصابع الثلاثة عند التشهد؛ الآن أنت جلست عند التشهد، كيف يكون",
        "video_link": null
      },
      {
        "ts": "20:40",
        "sec": 1240,
        "text": "حال أو وضع اليدين؟ طبعاً اليد اليسرى تضعها على ركبتك اليسرى، اليد",
        "video_link": null
      },
      {
        "ts": "20:48",
        "sec": 1248,
        "text": "اليمنى قال رحمه الله: \"وَعَقْدُهُ...\" وعقده الثلاث من يمناه؛ أي عقد ثلاث أصابع، ما هي الأصابع؟",
        "video_link": null
      },
      {
        "ts": "20:57",
        "sec": 1257,
        "text": "هي الخنصر والبنصر والوسطى؛ الخنصر،",
        "video_link": null
      },
      {
        "ts": "21:05",
        "sec": 1265,
        "text": "البنصر، الوسطى. قال لي هودي: \"وَبَسْطُ مَا خَلَاهْ\"؛ ما الذي",
        "video_link": null
      },
      {
        "ts": "21:13",
        "sec": 1273,
        "text": "يُبسط؟ السبابة، تشير بالسبابة تشير بالسبابة؛ لأن هي التي يُشار بها كما سيأتي",
        "video_link": null
      },
      {
        "ts": "21:22",
        "sec": 1282,
        "text": "في المندوب الموالي إن شاء الله. دليل هذا ما ثبت عنه صلى الله عليه وسلم أنه من حديث",
        "video_link": null
      },
      {
        "ts": "21:30",
        "sec": 1290,
        "text": "ابن عمر رضي الله عنهما: \"أَنَّهُ صلى الله عليه وسلم كَانَ إِذَا قَعَدَ عِنْدَ التَّشَهُّدِ وَضَعَ يَدَهُ",
        "video_link": null
      },
      {
        "ts": "21:37",
        "sec": 1297,
        "text": "الْيُسْرَى عَلَى رُكْبَتِهِ الْيُسْرَى، وَوَضَعَ يَدَهُ الْيُمْنَى عَلَى رُكْبَتِهِ الْيُمْنَى، وَعَقَدَ",
        "video_link": null
      },
      {
        "ts": "21:45",
        "sec": 1305,
        "text": "ثَلَاثاً وَخَمْسِينَ\" (وعقد ثلاثة وخمسين)، \"وَأَشَارَ بِالسَّبَّابَةِ\"؛ شو ثلاثة وخمسين؟ ثلاثة وخمسين عند العرب",
        "video_link": null
      },
      {
        "ts": "21:55",
        "sec": 1315,
        "text": "كانوا يقولون ثلاثة وخمسين؛ هذه ثلاثة وهذا الإبهام",
        "video_link": null
      },
      {
        "ts": "22:01",
        "sec": 1321,
        "text": "خمسون؛ الخنصر، البنصر، الوسطى ثلاث، هذا خمسون؛",
        "video_link": null
      },
      {
        "ts": "22:08",
        "sec": 1328,
        "text": "فعقد ثلاثة وخمسين ثم تشير بالسبابة؛ فهذا هذا المقصود بقوله: \"وَعَقْدُهُ الثَّلَاثَ مِنْ يُمْنَاهُ لَدَى التَّشَهُّدِ وَبَسْطُ مَا خَلَاهْ\". طبعاً هذه من الصيغ الواردة عن رسول الله صلى الله عليه وسلم، وورد عنه أنه كان يحلق أحياناً بين",
        "video_link": null
      },
      {
        "ts": "22:27",
        "sec": 1347,
        "text": "الوسطى والسبـ والابهام؛ يحلق بينهما، وورد عنه أنه كان يضمهما؛ فهذه يضم هكذا، فهذه كلها صيغ",
        "video_link": null
      },
      {
        "ts": "22:37",
        "sec": 1357,
        "text": "ثابتة عن سيدنا رسول الله صلى الله عليه وسلم، وهذا ما يُسمى اختلاف التنوع (هذا اختلاف التنوع). إذاً قال رحمه الله:",
        "video_link": null
      },
      {
        "ts": "22:48",
        "sec": 1368,
        "text": "\"وَعَقْدُهُ الثَّلَاثَ مِنْ يُمْنَاهُ لَدَى التَّشَهُّدِ وَبَسْطُ مَا خَلَاهْ\". ثم قال: \"تَحْرِيكُ سَبَّابَتِهَا حِينَ",
        "video_link": null
      },
      {
        "ts": "22:56",
        "sec": 1376,
        "text": "تَلَاهْ\". تحريك السبابة، هذا المندوب الحادي عشر؛ أثناء التشهد",
        "video_link": null
      },
      {
        "ts": "23:03",
        "sec": 1383,
        "text": "تحرك السبابة، لأنه قال صلى الله عليه وسلم أشار بالسبابة؛ ورد في رواية: \"يُحَرِّكُهَا يَدْعُو بِهَا\" (ورد في حديث أنه صلى الله عليه وسلم أشار بسبّابته يحرّكها يدعو بها)، والمالكية رحمه الله عليهم يختارون أن تحريك السبابة يكون",
        "video_link": null
      },
      {
        "ts": "23:19",
        "sec": 1399,
        "text": "من اليمين إلى اليسار؛ من اليمين يمنة ويسرة، يمنة ويسرة؛ هذا اختيار المالكية يمنة",
        "video_link": null
      },
      {
        "ts": "23:25",
        "sec": 1405,
        "text": "ويسرة يحركها هكذا؛ فهذا يعني في في التشهد هذا من مندوبات",
        "video_link": null
      },
      {
        "ts": "23:32",
        "sec": 1412,
        "text": "الصلاة؛ قال رحمه الله: \"لَدَى تَحْرِيكُ سَبَّابَتِهَا حِينَ تَلَاهْ\". ثم قال: وَالْبَطْنُ مِنْ فَخْذِ رِجَالٍ يُبْعِدونْ *** وَمِرْفَقاً مِنْ رُكْبَةٍ إِذْ يَسْجُدونْ",
        "video_link": null
      },
      {
        "ts": "23:40",
        "sec": 1420,
        "text": "هذا المندوب الثاني عشر: صفة",
        "video_link": null
      },
      {
        "ts": "23:47",
        "sec": 1427,
        "text": "السجود، كيف يكون السجود؟ نحن تقدم معنا أن السجود يكون على سبعة أعظم، لكن الصفة",
        "video_link": null
      },
      {
        "ts": "23:53",
        "sec": 1433,
        "text": "الكاملة للسجود أو ما أشار إليه الناظم هنا رحمه الله عليه قال: \"وَالْبَطْنُ مِنْ فَخْذِ",
        "video_link": null
      },
      {
        "ts": "24:00",
        "sec": 1440,
        "text": "رِجَالٍ يُبْعِدونْ\"؛ يعني أنك حين تسجد تبعد البطن عن الفخذ، لا تبقى منكمشاً",
        "video_link": null
      },
      {
        "ts": "24:07",
        "sec": 1447,
        "text": "عند السجود إنما تبعد بطنك عن عن فخذيك.",
        "video_link": null
      },
      {
        "ts": "24:13",
        "sec": 1453,
        "text": "طبعاً باعتدال، لا لا يبتعد الإنسان كثيراً يعني حتى يقترب من هيئة المنبطح، وإنما هو",
        "video_link": null
      },
      {
        "ts": "24:22",
        "sec": 1462,
        "text": "باعتدال يعني؛ فـ \"وَالْبَطْنُ مِنْ فَخْذِ رِجَالٍ يُبْعِدونْ\". قال:",
        "video_link": null
      },
      {
        "ts": "24:31",
        "sec": 1471,
        "text": "\"وَمِرْفَقاً...\" ومرفقاً \"مِنْ رُكْبَةٍ إِذْ يَسْجُدونْ\"؛ يعني",
        "video_link": null
      },
      {
        "ts": "24:36",
        "sec": 1476,
        "text": "البطن تبعده عن الفخذ، وتلقائياً ستكون قد أبعدت الفخذ عن الساق أيضاً. ثم قال: \"وَمِرْفَقاً",
        "video_link": null
      },
      {
        "ts": "24:47",
        "sec": 1487,
        "text": "مِنْ رُكْبَةٍ\"؛ يعني أن المرفق، هذا المرفق لا تلزقه بركبتيك حين تسجد،",
        "video_link": null
      },
      {
        "ts": "24:57",
        "sec": 1497,
        "text": "فأنت سجدت فتبعد فخذك بطنك عن فخذيك وتبعد",
        "video_link": null
      },
      {
        "ts": "25:04",
        "sec": 1504,
        "text": "مرفقك عن ركبتيك، وأيضاً تجافي تجافي بين العضدين والجنبين؛ يعني لا تبقى منكمشاً",
        "video_link": null
      },
      {
        "ts": "25:13",
        "sec": 1513,
        "text": "هكذا وإنما تجافي، فيكون السجود بهذه الهيئة. طبعاً تكون تكون أصابع يديك متجهة",
        "video_link": null
      },
      {
        "ts": "25:21",
        "sec": 1521,
        "text": "نحو القبلة، لا تضع أصابع يديك هكذا بل تضعهما في اتجاه هكذا فه القبلة،",
        "video_link": null
      },
      {
        "ts": "25:30",
        "sec": 1530,
        "text": "وتبعد تجافي عضدك عن عن عن جنبك،",
        "video_link": null
      },
      {
        "ts": "25:37",
        "sec": 1537,
        "text": "وتبعد البطن عن الفخذ؛ هذه صفة السجود. النبي صلى الله عليه وسلم كما تقول ميمونة",
        "video_link": null
      },
      {
        "ts": "25:45",
        "sec": 1545,
        "text": "ردي الله عنها: \"كَانَ النَّبِيُّ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ إِذَا سَجَدَ لَوْ شَاءَتْ بَهْمَةٌ أَنْ",
        "video_link": null
      },
      {
        "ts": "25:53",
        "sec": 1553,
        "text": "تَمُرَّ بَيْنَ يَدَيْهِ لَمَرَّتْ\"؛ البهمة هي الغنمة الصغيرة التي حديثة الولادة، فقال:",
        "video_link": null
      },
      {
        "ts": "26:02",
        "sec": 1562,
        "text": "لو أرادت أن تمر تمر يعني بين يديه صلى الله عليه وسلم؛ فهذه هذه صفة السجود.",
        "video_link": null
      },
      {
        "ts": "26:10",
        "sec": 1570,
        "text": "الناظم رحمه الله قال: \"وَالْبَطْنُ مِنْ فَخْذِ رِجَالٍ يُبْعِدونْ\"؛ رجالٌ، فقوله \"رِجَالٍ\" يُفهم منه أن",
        "video_link": null
      },
      {
        "ts": "26:17",
        "sec": 1577,
        "text": "المرأة خلاف هذا، لأن المالكية رحمه الله عليهم في المشهور عندهم يستحبون للمرأة أن",
        "video_link": null
      },
      {
        "ts": "26:23",
        "sec": 1583,
        "text": "تنضم؛ يقول إن المرأة ينبغي أن تنضم ولا تـ هذا والـ المهم هذا هذا مشهور مذهب",
        "video_link": null
      },
      {
        "ts": "26:34",
        "sec": 1594,
        "text": "المالكية. قال رحمه الله تعالى: \"وَالْبَطْنُ مِنْ فَخْذِ رِجَالٍ يُبْعِدونْ *** وَمِرْفَقاً مِنْ رُكْبَةٍ إِذْ يَسْجُدونْ\"؛",
        "video_link": null
      },
      {
        "ts": "26:43",
        "sec": 1603,
        "text": "ثم قال: وَصِفَةُ الْجُلُوسِ تَمْكِينُ الْيَدِ *** مِنْ رُكْبَتَيْهِ فِي الرُّكُوعِ وَزِدِ نَصْبَهُمَا قِرَاءَةً فِي سِرِّيَّهْ *** وَضْعَ الْيَدَيْنِ فَاقْتَدِ لَدَى السَّجْدَهْ حَذْوَ أُذُنٍ وَكَذَا رَفْعُ الْيَدَيْنْ *** عِنْدَ الْإِحْرَامِ خُذْ",
        "video_link": null
      },
      {
        "ts": "26:43",
        "sec": 1603,
        "text": "ثم قال: \"وَصِفَةُ الْجُلُوسِ\". المندوب الثالث عشر: صفة الجلوس؛ كيف يجلس",
        "video_link": null
      },
      {
        "ts": "26:50",
        "sec": 1610,
        "text": "الإنسان؟ وصفة الجلوس، الجلوس إنسان ما يجلس؛ أبو أبو حميد",
        "video_link": null
      },
      {
        "ts": "26:58",
        "sec": 1618,
        "text": "الساعدي رضي الله عنه وصف صفة وصف صلاة رسول الله صلى الله عليه وسلم بمحضر عشرة من الصحابة، فمما ذكره أنه صلى الله أنه صلى",
        "video_link": null
      },
      {
        "ts": "27:07",
        "sec": 1627,
        "text": "الله عليه وسلم لما جلس افترش رجله اليسرى؛ رجله اليسرى يفترش هذه",
        "video_link": null
      },
      {
        "ts": "27:15",
        "sec": 1635,
        "text": "الرجل اليسرى هاد الرجل اليسرى هاد الرجل اليسرى يفترشها فيجلس عليها، يجلس عليها؛ قال: \"وَأَقْبَلَ بِصَدْرِ الْيُمْنَى\"",
        "video_link": null
      },
      {
        "ts": "27:22",
        "sec": 1642,
        "text": "الرجل اليمنى أقبل بصدرها هكذا على قبلته هكذا؛ يعني فيجلس",
        "video_link": null
      },
      {
        "ts": "27:30",
        "sec": 1650,
        "text": "تنصب رجلك اليسرى قدمك اليسرى فتجلس عليها تفترش،",
        "video_link": null
      },
      {
        "ts": "27:37",
        "sec": 1657,
        "text": "وتنصب عفواً تفترش عفواً تفترش قدمك اليسرى فتجلس عليها، وتنصب رجلك اليمنى هكذا قدمك",
        "video_link": null
      },
      {
        "ts": "27:45",
        "sec": 1665,
        "text": "اليمنى هكذا تنصبها فتجلس بهذه الطريقة؛ هذه صفة الجلوس الثابتة عن سيدنا رسول الله",
        "video_link": null
      },
      {
        "ts": "27:55",
        "sec": 1675,
        "text": "صلى الله عليه وسلم كما في حديث أبي حميد الساعدي رضي الله عنه. طبعاً هـ هاته الطريقة الإنسان إذا لم يألفها قد يجد فيها شيئاً من المشقة والصعوبة، لكن",
        "video_link": null
      },
      {
        "ts": "28:04",
        "sec": 1684,
        "text": "بالإلف تصبح سهلة ميسورة إن شاء الله تعالى؛ من عجز ولم يستطع فيمكنه أن يفترش",
        "video_link": null
      },
      {
        "ts": "28:11",
        "sec": 1691,
        "text": "رجليه معاً (اليمنى واليسرى) هكذا ويجلس عليهما، لكن دون أن يفضي بإليتيه ومقعدته",
        "video_link": null
      },
      {
        "ts": "28:18",
        "sec": 1698,
        "text": "إلى الأرض ذاك من الإقعاء المكروه، وإنما هكذا ويجلس عليها إن شاء الله. المالكية رحمه",
        "video_link": null
      },
      {
        "ts": "28:25",
        "sec": 1705,
        "text": "الله عليهم يستحبون التورك في الصلاة كلها؛ في الصلاة كلها حتى بين السجدتين، ويستحبون التورك؛ ما هو التورك؟ أن الإنسان المصلي",
        "video_link": null
      },
      {
        "ts": "28:35",
        "sec": 1715,
        "text": "يجلس على وركه الأيسر، على وركه الأيسر، وينصب رجله اليمنى ويخرج رجله اليسرى من تحتها؛ هذا",
        "video_link": null
      },
      {
        "ts": "28:42",
        "sec": 1722,
        "text": "التورك، يجلس على الورك الأيسر يفضي بإليتيه ومقعدته الأرض جهة الورك الأيسر، ينصب الرجل اليمنى",
        "video_link": null
      },
      {
        "ts": "28:51",
        "sec": 1731,
        "text": "ويخرج الرجل اليسرى من تحت فخذه ورجله؛ فيستحب",
        "video_link": null
      },
      {
        "ts": "28:57",
        "sec": 1737,
        "text": "هذا في الصلاة كلها، وقد يكون في هذا شيـ شيء من مشقته خصوصاً في صلاة الجماعة.",
        "video_link": null
      },
      {
        "ts": "29:05",
        "sec": 1745,
        "text": "ثم قال رحمه الله: \"تَمْكِينُ الْيَدِ *** مِنْ رُكْبَتَيْهِ فِي الرُّكُوعِ وَزِدِ *** نَصْبَهُمَا\". إذن صفة الجلوس هذا المندوب الثالث",
        "video_link": null
      },
      {
        "ts": "29:21",
        "sec": 1761,
        "text": "عشر. المندوب الرابع عشر: تمكين اليد من ركبتيه في الركوع، تمكين",
        "video_link": null
      },
      {
        "ts": "29:29",
        "sec": 1769,
        "text": "اليد من الركبتين في الركوع. في حديث أبي حميد الساعدي قال رضي الله عنه: \"وَإِذَا رَكَعَ",
        "video_link": null
      },
      {
        "ts": "29:37",
        "sec": 1777,
        "text": "أَمْكَنَ يَدَيْهِ مِنْ رُكْبَتَيْهِ\" (النبي صلى الله عليه وسلم إذا ركع أمكن يديه من ركبتيه)، اليدان تمكنهما من ركبتيك؛ وفي",
        "video_link": null
      },
      {
        "ts": "29:46",
        "sec": 1786,
        "text": "حديث آخر: \"تُفَرِّقُ أَصَابِعَكَ\" (تفرق أصابعك) وأنت تمسك ركبتيك بيديك.",
        "video_link": null
      },
      {
        "ts": "29:58",
        "sec": 1798,
        "text": "المندوب الخامس عشر؛ قال: \"نَصْبَهُمَا\" أي نصب الركبتين، لأنه قال:",
        "video_link": null
      },
      {
        "ts": "30:07",
        "sec": 1807,
        "text": "\"تَمْكِينُ الْيَدِ مِنْ رُكْبَتَيْهِ فِي الرُّكُوعِ وَزِدِ نَصْبَهُمَا\"؛ أي نصب الركبتين. أبو حميد الساعدي",
        "video_link": null
      },
      {
        "ts": "30:17",
        "sec": 1817,
        "text": "رضي الله عنه قال: \"وَإِذَا رَكَعَ أَمْكَنَ يَدَيْهِ مِنْ رُكْبَتَيْهِ وَهَصَرَ ظَهْرَهُ\"؛ هصر ظهره يعني جعله مستوياً، مما يساعد على استواء الظهر نصب",
        "video_link": null
      },
      {
        "ts": "30:26",
        "sec": 1826,
        "text": "الركبتين؛ يعني أن الركبتين تكونان منتصبتين لا لا تثني ركبتيك لا تثني",
        "video_link": null
      },
      {
        "ts": "30:34",
        "sec": 1834,
        "text": "ركبتيك، فتكون الركبتان منتصبتين واقفتين وتمكن يديك من ركبتيك ويكون الظهر مستوياً،",
        "video_link": null
      },
      {
        "ts": "30:43",
        "sec": 1843,
        "text": "يكون الظهر مستوياً؛ وعلماؤنا يقول حتى لو صُبَّ الماء على الظهر لبقي مستقراً، فأنت لا تحني ظهرك هكذا ولا ترفعه في",
        "video_link": null
      },
      {
        "ts": "30:53",
        "sec": 1853,
        "text": "الركوع قال رحمه الله. ثم قال: \"قِرَاءَةً فِي سِرِّيَّهْ\". قراءة",
        "video_link": null
      },
      {
        "ts": "31:01",
        "sec": 1861,
        "text": "المأموم في السرية، قراءة المأموم في",
        "video_link": null
      },
      {
        "ts": "31:09",
        "sec": 1869,
        "text": "السرية؛ فالصلاة الجهرية المأموم يستمع قراءة",
        "video_link": null
      },
      {
        "ts": "31:18",
        "sec": 1878,
        "text": "الإمام، في الصلاة السرية تقرأ خلف",
        "video_link": null
      },
      {
        "ts": "31:25",
        "sec": 1885,
        "text": "إمامك؛ صلاة الظهر، العصر، الركعة الثالثة في المغرب، الركعتان الأخيرتان في",
        "video_link": null
      },
      {
        "ts": "31:33",
        "sec": 1893,
        "text": "العشاء تقرأ. يدل على هذا أنه صلى الله عليه وسلم مرة كان يصلي فـ في صلاة جهرية،",
        "video_link": null
      },
      {
        "ts": "31:41",
        "sec": 1901,
        "text": "فلما سلّم قال: \"هَلْ قَرَأَ مَعِي أَحَدٌ مِنْكُمْ آنِفاً؟\" قالوا: نعم؛ فقال صلى الله عليه وسلم: \"وَأَنَا أَقُولُ مَا لِي أُنَازَعُ؟\" فقال أبو هريرة قال أبو",
        "video_link": null
      },
      {
        "ts": "31:51",
        "sec": 1911,
        "text": "هريرة رضي الله عنه: \"فَانْتَهَى النَّاسُ عَنِ الْقِرَاءَةِ مَعَ رَسُولِ اللَّهِ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ فِيمَا جَهَرَ فِيهِ\"",
        "video_link": null
      },
      {
        "ts": "31:59",
        "sec": 1919,
        "text": "(قوله فانتهى الناس عن القراءة فيما جهر فيه رسول الله صلى الله عليه وسلم يفهم منه أن فيما جهر ينتهي الناس عن",
        "video_link": null
      },
      {
        "ts": "32:09",
        "sec": 1929,
        "text": "القراءة يستمعون، لكن في السرية تكون القراءه). بعض الناس يطرح إشكالاً يقول لك: \"طيب إذا قرأت في السرية ربما أسبق الإمام\"، هذا لا يهم حتى",
        "video_link": null
      },
      {
        "ts": "32:18",
        "sec": 1938,
        "text": "لو سبقته وتخلفت عنه؛ \"ربما أسبق بالفاتحة\"، ربما يقول لك: \"طيب أنا أحياناً ربما أنا أقرأ السورة وهو يقرأ سورة أخرى\"، لا، هذا لا يؤثر.",
        "video_link": null
      },
      {
        "ts": "32:27",
        "sec": 1947,
        "text": "ما دام الناس عن القراءة فيما جهر فيه رسول الله صلى الله عليه وسلم يفهم منه استماع القراءة فيما أسر فيه صلى الله عليه وسلم،",
        "video_link": null
      },
      {
        "ts": "32:34",
        "sec": 1954,
        "text": "فهذا من مندوبات الصلاة؛ فتقرأ خلف إمامك، مثلاً في صلاة الظهر في الركعتين الأوليين تقرأ",
        "video_link": null
      },
      {
        "ts": "32:40",
        "sec": 1960,
        "text": "الفاتحة وتقرأ ما تيسر بعد الفاتحة حتى يركع إمامك، وفي الركعتين الأخيرتين",
        "video_link": null
      },
      {
        "ts": "32:47",
        "sec": 1967,
        "text": "تقرأ الفاتحة فقط وهكذا. ثم",
        "video_link": null
      },
      {
        "ts": "32:54",
        "sec": 1974,
        "text": "قال: \"وَضْعَ الْيَدَيْنِ فَاقْتَدِ لَدَى السَّجْدَهْ *** حَذْوَ أُذُنٍ\"؛ هذا المندوب السابع عشر وهو: وضع اليدين",
        "video_link": null
      },
      {
        "ts": "33:06",
        "sec": 1986,
        "text": "حذو الأذنين في السجود، وضع اليدين حذو الأذنين في",
        "video_link": null
      },
      {
        "ts": "33:14",
        "sec": 1994,
        "text": "السجود. لما تسجد أين تضع أين يكون موضع رأسك مقاساً مع يديك؟ قال لك: تضع تسجد وـ",
        "video_link": null
      },
      {
        "ts": "33:24",
        "sec": 2004,
        "text": "ويكون تكون يكون وضع اليدين محاذياً للاذنين؛ في",
        "video_link": null
      },
      {
        "ts": "33:31",
        "sec": 2011,
        "text": "السجود تكون اليدان محاذيتين للاذنين حال",
        "video_link": null
      },
      {
        "ts": "33:38",
        "sec": 2018,
        "text": "السجود. ممن وصف صلاة رسول الله صلى الله عليه وسلم وائل بن حجر رضي الله عنه؛ وائل بن حجر كما في صحيح مسلم يقول: \"كَانَ إِذَا",
        "video_link": null
      },
      {
        "ts": "33:48",
        "sec": 2028,
        "text": "سَجَدَ وَضَعَ رَأْسَهُ بَيْنَ كَفَّيْهِ\" (وضع رأسه بين كفيه)؛",
        "video_link": null
      },
      {
        "ts": "33:56",
        "sec": 2036,
        "text": "فهذا هذا في وضع اليدين حال",
        "video_link": null
      },
      {
        "ts": "34:02",
        "sec": 2042,
        "text": "السجود. ثم قال رحمه الله: \"وَكَذَا رَفْعُ الْيَدَيْنِ *** عِنْدَ الْإِحْرَامِ خُذْ\". رفع",
        "video_link": null
      },
      {
        "ts": "34:11",
        "sec": 2051,
        "text": "اليدين؛ أي رفع اليدين عند الإحرام. قال لحظ قال: \"وَضْعَ الْيَدَيْنِ فَاقْتَدِ لَدَى السَّجْدَهْ حَذْوَ أُذُنٍ\"، هنا انتهى المندوب السابق؛ ثم قال: \"وَكَذَا",
        "video_link": null
      },
      {
        "ts": "34:28",
        "sec": 2068,
        "text": "رَفْعُ الْيَدَيْنِ عِنْدَ الْإِحْرَامِ خُذْ\"؛ أي خذ ألف الإطلاق، أي خذ كذلك ما معنى هذا الكلام؟ أي",
        "video_link": null
      },
      {
        "ts": "34:37",
        "sec": 2077,
        "text": "حين تكبر الإحرام؛ تقدم معنا أنها ركن من أركان الصلاة، طـ رفع اليدين هذا من مندوبات",
        "video_link": null
      },
      {
        "ts": "34:44",
        "sec": 2084,
        "text": "الصلاة. رفع اليدين الإحرام؛ لما تكبر الصلاة الإحرام تقول: \"الله أكبر\"؛ طيب ترفع",
        "video_link": null
      },
      {
        "ts": "34:50",
        "sec": 2090,
        "text": "يديك إلى أين؟ قال: \"وَكَذَا\" أي أيضاً ترفعها حذو الأذنين، ترفع حذو الأذنين هكذا حذو",
        "video_link": null
      },
      {
        "ts": "34:59",
        "sec": 2099,
        "text": "الأذنين بمحاذاة الأذنين. بالمناسبة لما نقول حذوه لا تعني مماسته؛ إياك أن تفهم أن المقصود أن تمس لا،",
        "video_link": null
      },
      {
        "ts": "35:07",
        "sec": 2107,
        "text": "حذو اليدين أي بمحاذاتهما فـ \"رَفْعُ الْيَدَيْنِ عِنْدَ الْإِحْرَامِ خُذْ\". وهذا ثبت عن رسول الله صلى الله عليه وسلم،",
        "video_link": null
      },
      {
        "ts": "35:15",
        "sec": 2115,
        "text": "وثبت أيضاً أنه كان يرفع يديه حذو منكبيه كذلك، وذا ثبت في الصحيح أيضاً أنه صلى الله عليه وسلم كان وهذا اختاره مالك رحمه الله",
        "video_link": null
      },
      {
        "ts": "35:22",
        "sec": 2122,
        "text": "عليه: رفع اليدين حذو المنكبين (المنكبين)؛ فسواء نرفع حذو المنكبين أو حذو الأذنين",
        "video_link": null
      },
      {
        "ts": "35:29",
        "sec": 2129,
        "text": "فهذا مندوبات الصلاة إن شاء الله، يعني حذو الأذنين هكذا عفواً لأن هذا هذا ما بين بين",
        "video_link": null
      },
      {
        "ts": "35:36",
        "sec": 2136,
        "text": "المنكبين والأذنين، وإنما حد الأذنين هكذا يعني حذو الأذنين؛ وحتى هذه ثابتة عن رسول الله صلى",
        "video_link": null
      },
      {
        "ts": "35:45",
        "sec": 2145,
        "text": "الله عليه وسلم أيضاً بين المنكبين وبين الأذنين، كما أسلفت غير مرة هذا اختلاف تنوع. قال رحمه الله: تَطْوِيلُهُ صُبْحاً وَظُهْراً سُورَتَيْنْ *** تَوَسُّطُ الْعِشَا وَقَصْرُ الْبَاقِيَيْنْ كَسُورَةِ الْأُخْرَى كَذَا الْوُسْطَى اسْتُحِبّ *** سَبْقُ يَدٍ وَضْعاً وَفِي الرَّفْعِ الرُّكَبْ",
        "video_link": null
      },
      {
        "ts": "36:03",
        "sec": 2163,
        "text": "الآن هذه هذا المندوب يتعلق بكيفيات القراءة في الصلوات؛ كيفيات القراءة في",
        "video_link": null
      },
      {
        "ts": "36:09",
        "sec": 2169,
        "text": "الصلوات من جهة الطول والقصر، من جهة الطول والقصر؛ كيفية القراءة في الصلوات طولاً",
        "video_link": null
      },
      {
        "ts": "36:16",
        "sec": 2176,
        "text": "وقصراً. من السنة والتي وردت في هذا أحاديث سوف وأدلة سوف نطوـ لأن طال وقت",
        "video_link": null
      },
      {
        "ts": "36:24",
        "sec": 2184,
        "text": "الحلقة؛ الصبح تستحب يستحب",
        "video_link": null
      },
      {
        "ts": "36:29",
        "sec": 2189,
        "text": "فيها تطويل القراءة، صلاة الصبح يستحب فيها تطويل القراءة؛ والله تعالى",
        "video_link": null
      },
      {
        "ts": "36:36",
        "sec": 2196,
        "text": "يقول: {أَقِمِ الصَّلَاةَ لِدُلُوكِ الشَّمْسِ إِلَىٰ غَسَقِ اللَّيْلِ وَقُرْآنَ الْفَجْرِ}. قال بعض",
        "video_link": null
      },
      {
        "ts": "36:44",
        "sec": 2204,
        "text": "العلماء: لماذا قال ربنا {وَقُرْآنَ الْفَجْرِ} ولم يقل صلاة الفجر؟ عبَّر بقرآن الفجر، قالوا لأن صلاة الفجر يستحب أن يطيل فيها",
        "video_link": null
      },
      {
        "ts": "36:52",
        "sec": 2212,
        "text": "الإنسان قراءة القرآن؛ إذاً قال: \"تَطْوِيلُهُ صُبْحاً وَظُهْراً\". أيضاً تطويل صلاة الظهر؛ حتى كان",
        "video_link": null
      },
      {
        "ts": "36:58",
        "sec": 2218,
        "text": "الرجل كانت تقام الصلاة تقام الصلاة ويدخل صلى الله عليه وسلم في صلاة الظهر، يذهب الرجل يذهب لقضاء حاجته ويتوضأ ثم يرجع ثم",
        "video_link": null
      },
      {
        "ts": "37:07",
        "sec": 2227,
        "text": "يدرك الركعة الأولى من صلاة الظهر مع رسول الله صلى الله عليه وسلم، لكثرة ما كان يطيلها؛ إذن \"تَطْوِيلُهُ صُبْحاً وَظُهْراً سُورَتَيْنْ\". قال: \"تَوَسُّطُ الْعِشَا\"؛ صلاة العشاء يتوسط تُقرأ قراءة متوسطة، قراءة متوسطة؛ لأن صلاة",
        "video_link": null
      },
      {
        "ts": "37:25",
        "sec": 2245,
        "text": "العشاء يكون الناس يستعدون للنوم وبعد عناء اليوم فيتوسط في القراءة. \"وَقَصْرُ الْبَاقِيَيْنْ\"؛ ما هما الباقيان؟ هما العصر والمغرب؛ صلاة العصر والمغرب",
        "video_link": null
      },
      {
        "ts": "37:41",
        "sec": 2261,
        "text": "يستحب تقصير القراءة فيهما، يستحب تقصير القراءة فيهما. قال: \"وَقَصْرُ الْبَاقِيَيْنْ\"، ثم قال: \"كَسُورَةِ الْأُخْرَى\"؛ الكاف كاف",
        "video_link": null
      },
      {
        "ts": "37:56",
        "sec": 2276,
        "text": "التشبيه، تشبيه السورة الأخرى بما سبق في أي شيء؟ في القصر؛ قال: \"وقصر...\" حتى نفهم النظم؛",
        "video_link": null
      },
      {
        "ts": "38:04",
        "sec": 2284,
        "text": "قال: \"تَطْوِيلُهُ صُبْحاً وَظُهْراً سُورَتَيْنْ\" انتهى التطويل، \"تَوَسُّطُ الْعِشَا\" انتهى التوسط، \"وَقَصْرُ",
        "video_link": null
      },
      {
        "ts": "38:13",
        "sec": 2293,
        "text": "الْبَاقِيَيْنْ\" اللذان هما قلنا العصر والمغرب، \"وَقَصْرُ الْبَاقِيَيْنْ كَسُورَةِ الْأُخْرَى\"؛",
        "video_link": null
      },
      {
        "ts": "38:21",
        "sec": 2301,
        "text": "أي السورة الثانية؛ تقصير هذا المندوب الموالي، تقصير",
        "video_link": null
      },
      {
        "ts": "38:29",
        "sec": 2309,
        "text": "السورة الثانية (أي سورة الركعة الثانية، سورة الركعة الثانية)؛ يعني أنكما تصلي هذه، النبي عليه الصلاة والسلام أنه كان الركعة",
        "video_link": null
      },
      {
        "ts": "38:38",
        "sec": 2318,
        "text": "الأولى تكون القراءة فيها أطول من الركعة الثانية؛ هذه السنة، الركعة الثانية تقصر",
        "video_link": null
      },
      {
        "ts": "38:45",
        "sec": 2325,
        "text": "القراءة فيها مقارنة مع الركعة الأولى، مقارنة مع الركعة الأولى. قال: \"وَقَصْرُ الْبَاقِيَيْنْ كَسُورَةِ الْأُخْرَى كَذَا",
        "video_link": null
      },
      {
        "ts": "38:54",
        "sec": 2334,
        "text": "الْوُسْطَى\"؛ هذا المندوب الموالي: \"كَذَا الْوُسْطَى\"، ما الوسطى؟ التشهد الأوسط يستحب قِصره أيضاً،",
        "video_link": null
      },
      {
        "ts": "39:01",
        "sec": 2341,
        "text": "التشهد الأوسط يستحب قِصره يُندب قِصر التشهد الأوسط مقاساً مع",
        "video_link": null
      },
      {
        "ts": "39:08",
        "sec": 2348,
        "text": "التشهد الأخير؛ إذاً قِصر الوسطى قال: \"كَذَا الْوُسْطَى\"، إذن كـ \"سُورَةِ الْأُخْرَى كَذَا الْوُسْطَى\" أي في",
        "video_link": null
      },
      {
        "ts": "39:16",
        "sec": 2356,
        "text": "التقصير. ثم قال: \"اسْتُحِبّ *** سَبْقُ يَدٍ وَضْعاً\"؛ هذا",
        "video_link": null
      },
      {
        "ts": "39:23",
        "sec": 2363,
        "text": "المندوب الحادي الثاني والعشرين (22)، معنى الكلام قال: \"اسْتُحِبّ سَبْقُ يَدٍ وَضْعاً\"؛ أنت",
        "video_link": null
      },
      {
        "ts": "39:32",
        "sec": 2372,
        "text": "قائم تريد أن تهوي للسجود، ماذا تقدم؟ هل تقدم يديك إلى الأرض ثم ركبتيك، أم تقدم",
        "video_link": null
      },
      {
        "ts": "39:42",
        "sec": 2382,
        "text": "ركبتيك ثم يديك؟ قال رحمه الله: \"سَبْقُ يَدٍ\" (يدين) \"وَضْعاً\"؛",
        "video_link": null
      },
      {
        "ts": "39:57",
        "sec": 2397,
        "text": "كَمَا يَبْرُكُ الْبَعِيرُ، وَلْيَضَعْ يَدَيْهِ قَبْلَ رُكْبَتَيْهِ\"؛ وابن عمر رضي الله عنهما يقول: \"رأيت رسول الله صلى الله عليه",
        "video_link": null
      },
      {
        "ts": "40:05",
        "sec": 2405,
        "text": "وسلم\"، إذن: \"رأيت رسول الله صلى الله عليه وسلم يضع يديه قبل ركبتيه\" هـ نعم رأيت رسول الله",
        "video_link": null
      },
      {
        "ts": "40:13",
        "sec": 2413,
        "text": "صلى الله عليه وسلم يضع يديه قبل ركبتيه؛ كذا قال ابن عمر رضي الله عنهما. إذاً تقدم اليدين على",
        "video_link": null
      },
      {
        "ts": "40:21",
        "sec": 2421,
        "text": "الركبتين. ثم آخراً قال: \"وَفِي الرَّفْعِ الرُّكَبْ\"؛ طيب إذا أردت أن ترفع،",
        "video_link": null
      },
      {
        "ts": "40:29",
        "sec": 2429,
        "text": "نهضت من السجود تريد أن تقوم للركعة الموالية، ماذا ترفع أولاً؟ هل ترفع",
        "video_link": null
      },
      {
        "ts": "40:38",
        "sec": 2438,
        "text": "يديك ثم تعتمد على ركبتيك وترفعهما، أم أنك تعتمد بيديك على الأرض وترفع ركبتيك ثم",
        "video_link": null
      },
      {
        "ts": "40:48",
        "sec": 2448,
        "text": "ترفع يديك؟ هذا الثاني؛ قال: \"وَفِي الرَّفْعِ الرُّكَبْ\" أي عندما تجد أن ترفع ترفع ركبتيك أولاً ثم",
        "video_link": null
      },
      {
        "ts": "40:50",
        "sec": 2450,
        "text": "تقدم اليدين قبل الركبتين. دليل هذا قوله صلى الله عليه وسلم: \"إِذَا سَجَدَ أَحَدُكُمْ فَلَا يَبْرُكْ",
        "video_link": null
      },
      {
        "ts": "40:57",
        "sec": 2457,
        "text": "ترفع يديك؛ هكذا تعتمد بيديك ترفع الركبتين ثم ترفع اليدين. قال رحمه الله: \"اسْتُحِبّ سَبْقُ يَدٍ",
        "video_link": null
      },
      {
        "ts": "41:07",
        "sec": 2467,
        "text": "وَضْعاً\" أي عندما تهوي إلى السجود تقدم يديك أولاً ثم ركبتيك",
        "video_link": null
      },
      {
        "ts": "41:13",
        "sec": 2473,
        "text": "ثانياً، \"وَفِي الرَّفْعِ الرُّكَبْ\" العكس؛ في الرفع ترفع ركبتيك ركبتيك أولاً ثم ترفع يديك. هذه",
        "video_link": null
      },
      {
        "ts": "41:23",
        "sec": 2483,
        "text": "مندوبات الصلاة. وإلى المجلس المقبل إن شاء الله تعالى؛ سبحانك اللهم وبحمدك أشهد أن لا إله إلا أنت أستغفرك وأتوب إليك، وصلى الله وسلم",
        "video_link": null
      },
      {
        "ts": "41:30",
        "sec": 2490,
        "text": "وبارك على سيدنا محمد وعلى آله، والحمد لله رب العالمين. السلام عليكم ورحمة الله وبركاته.",
        "video_link": null
      }
    ]
  },
  {
    "subject": "fiqh",
    "subjectLabel": "الفقه الإسلامي",
    "lesson": "الدرس 18",
    "lessonNum": 18,
    "title": "الدرس 18",
    "summary": "📚 <b>الملخص الشامل لدرس: مندوبات الصلاة (من منظومة ابن عاشر)</b>\n\n🔹 <b>الخلاصة المحورية للدرس:</b>\n<blockquote>يتناول هذا الدرس استعراضاً تفصيلياً لمندوبات الصلاة (وهي التي يُثاب فاعلها ولا يُعاقب تاركها) بناءً على ما أورده الإمام ابن عاشر في منظومته، حيث بيّن الشيخ أحكام التسليم، والتأمين، والتحميد، والقنوت، والهيئات المسنونة في السجود والجلوس، وكيفية القراءة، وغيرها من السنن التي تُجمل الصلاة وتزيد من كمالها.</blockquote>\n\n🔹 <b>الأحداث والوقائع / القواعد والمسائل بالتفصيل:</b>\n<blockquote>\n• <b>التياُمن مع السلام:</b> يُندب للمصلي إذا سلّم تسليمة واحدة أن يميل برأسه قليلاً إلى جهة اليمين، تأسياً بفعل النبي ﷺ.\n• <b>التأمين:</b> قول \"آمين\" بعد قراءة الفاتحة هو من المندوبات المطلقة لكل مصلٍ (إمام، مأموم، منفرد)، في السرية والجهرية، خلافاً لما يراه بعض المالكية من استثناء الإمام في الجهرية.\n• <b>التحميد:</b> قول \"ربنا ولك الحمد\" عند الرفع من الركوع، وهو مندوب لكل مصلٍ، وقد ثبت عن النبي ﷺ الجمع بين التسميع والتحميد.\n• <b>القنوت في الصبح:</b> هو دعاء مخصوص يُؤتى به في الركعة الثانية من صلاة الصبح قبل الركوع.\n• <b>ستر العاتق بالرداء:</b> يُندب للرجل تغطية عاتقيه في الصلاة ولا يكتفي بستر العورة فقط.\n• <b>تسبيح السجود والركوع:</b> يُندب قول \"سبحان ربي العظيم\" في الركوع، و\"سبحان ربي الأعلى\" في السجود، (ثلاث مرات).\n• <b>سدل اليدين:</b> هو إرسال اليدين، والمشهور عند المالكية استحبابه في الفرض، بينما يرى جمهور العلماء والراجح من الأدلة استحباب وضع اليمنى على اليسرى على الصدر.\n• <b>مقارنة التكبير للفعل:</b> يُندب أن يبدأ المصلي بالتكبير مع الشروع في الانتقال (كالركوع والسجود)، ويستثنى عند المالكية القيام من التشهد الأوسط حيث يؤخر التكبير حتى يستوي قائماً.\n• <b>وضع اليد في التشهد:</b> يُندب قبض الأصابع الثلاث (الخنصر والبنصر والوسطى) وبسط السبابة للإشارة بها، والتحريك يمنة ويسرة عند المالكية.\n• <b>صفة السجود:</b> يُندب للرجل تجافي العضدين عن الجنبين، وإبعاد البطن عن الفخذ، وإبعاد المرفق عن الركبتين.\n• <b>كيفية القراءة:</b> يُندب التطويل في الصبح والظهر، والتوسط في العشاء، والتقصير في العصر والمغرب. وتكون القراءة في الركعة الأولى أطول من الثانية.\n• <b>السجود والنهوض:</b> يُندب تقديم اليدين عند الهوي للسجود، وتقديم الركبتين عند النهوض للقيام.\n</blockquote>\n\n🔹 <b>الأسماء والمصطلحات الرئيسية:</b>\n<blockquote>\n• <b>الإمام ابن عاشر:</b> صاحب المنظومة الفقهية التي تُعد مرجعاً لطلاب المذهب المالكي.\n• <b>التأمين:</b> قول \"آمين\" بمعنى \"اللهم استجب\".\n• <b>السدل:</b> إرسال اليدين دون قبضهما على الصدر.\n• <b>اختلاف التنوع:</b> وصف للعبادات التي ثبتت عن النبي ﷺ على أوجه متعددة (مثل صيغ الرفع، أو وضع اليدين)، فكلها سُنة جائزة.\n• <b>أبو حميد الساعدي:</b> الصحابي الجليل الذي نقل صفة صلاة النبي ﷺ بحضور عشرة من الصحابة.\n</blockquote>\n\n🔹 <b>العِبر والأحكام المستفادة:</b>\n<blockquote>\n• الصلاة ليست مجرد حركات، بل هي هيئة كاملة من الأدب مع الله (التسبيح، الخشوع، هيئة الجلوس).\n• أهمية اتباع السُنة في كل تفاصيل الصلاة ليكون العبد على نهج نبيه ﷺ.\n• أن الاختلاف في بعض هيئات الصلاة بين العلماء غالباً ما يكون من باب \"اختلاف التنوع\" الذي يوسع على المسلمين.\n• التدبر في معاني الأذكار يزيد من خشوع المصلي (مثل التسبيح في السجود والركوع).\n</blockquote>\n\n🔹 <b>سؤال تدبر ومراجعة ذاتية:</b>\n<blockquote>ما هو الفرق الجوهري بين \"سُنن الصلاة\" و\"مندوباتها\" في المذهب المالكي؟ وكيف نجمع بين حديث \"لا يصلين أحدكم في الثوب الواحد ليس على عاتقه منه شيء\" وبين مفهوم ستر العورة؟</blockquote>",
    "full_text": "بسم الله الرحمن الرحيم، الحمد لله رب العالمين، والصلاة والسلام الأتمان الأكملان على سيدنا محمد الصادق الأمين، وعلى آله وصحبه أجمعين. أما بعد، السلام عليكم ورحمة الله وبركاته. وصلنا مع الناظم الإمام عبد الواحد بن عاشر رحمه الله تعالى إلى باب مندوبات الصلاة؛ الصلاة لها فرائض وسنن ومندوبات. أنهينا في المجلس الماضي الحديث عن سنن الصلاة، ونشرع الآن بإذن الله عز وجل في الكلام على مندوباتها؛ قال رحمه الله تعالى: مَنْدُوبُهَا تَيَامُنٌ مَعَ السَّلَامْ *** تَأْمِينُ مَنْ صَلَّى عَدَا جَهْرَ الْإِمَامْ وَقَوْلُ رَبَّنَا لَكَ الْحَمْدُ عَدَا *** مَنْ أَمَّ وَالْقُنُوتُ فِي الصُّبْحِ بَدَا قال رحمه الله تعالى: \"مَنْدُوبُهَا تَيَامُنٌ مَعَ السَّلَامْ\". السلام هذا ركن من أركان الصلاة كما مر معنا، لقوله صلى الله عليه وسلم: \"مِفْتَاحُ الصَّلَاةِ الطُّهُورُ، وَتَحْرِيمُهَا التَّكْبِيرُ، وَتَحْلِيلُهَا التَّسْلِيمُ\"؛ لكن التيامن يعني أنك تلتفت جهة اليمين، هذا من مندوبات الصلاة. وهذا بناء على المشهور من مذهب المالكية؛ أنهم يرون هنا أن الأصل أن يسلم المصلي تسليمة واحدة فقط، فهذه التسليمة الواحدة يتياَمن الإنسان حينها برأسه قليلاً؛ يدل على ذلك ما ذكرت أم المؤمنين عائشة رضي الله عنها وهي تصف صلاة رسول الله صلى الله عليه وسلم، قالت: \"كَانَ يُسَلِّمُ فِي الصَّلَاةِ تَسْلِيمَةً وَاحِدَةً يَمِيلُ بِوَجْهِهِ تِلْقَاءَ وَجْهِهِ\" أو \"إِلَى الشِّقِّ الْأَيْمَنِ قَلِيلًا\" (يميل إلى الشق الأيمن قليلاً). هذا هو التسليم؛ إذا سلّم الإنسان تسليمة واحدة فيقول: \"السلام عليكم\" يميل إلى الشق الأيمن، يميل إلى الشق الأيمن قليلاً؛ فهذا هو هذا المقصود بقوله: \"تَيَامُنٌ مَعَ السَّلَامْ\". لكن طبعاً وردت في أحاديث أخرى أن أن أن الأصل في تسليمه صلى الله عليه وسلم أنه كان يسلم عن يمينه وعن شماله فيقول: \"السلام عليكم ورحمة الله، السلام عليكم ورحمة الله\"، أو: \"السلام عليكم ورحمة الله وبركاته، السلام عليكم ورحمة الله وبركاته\"؛ المهم صيغ مختلفة، لكن لو سلّم الإنسان تسليمة واحدة فإنه يتياَمن قليلاً كما أخبرت عائشة رضي الله عنها. قال رحمه الله: \"مَنْدُوبُهَا تَيَامُنٌ مَعَ السَّلَامْ\". المندوب الثاني قال: \"تَأْمِينُ مَنْ صَلَّى عَدَا جَهْرَ الْإِمَامْ\". المندوب الثاني: التأمين، والتأمين هو قول المصلي: \"آمين\"؛ وآمين تعني: اللهم استجب، اللهم استجب؛ هذا دعاء \"اللهم استجب\". وردت في أحاديث كثيرة، ورد في أحاديث كثيرة الكلام على التأمين وبيان فضله؛ منها قول النبي صلى الله عليه وسلم: \"وَإِذَا قَالَ\" -أي الإمام- \"إِذَا قَالَ: {غَيْرِ الْمَغْضُوبِ عَلَيْهِمْ وَلَا الضَّالِّينَ} فَقُولُوا: آمِينَ\" (فقولوا آمين). وقوله صلى الله عليه وسلم: \"إِذَا أَمَّنَ الْإِمَامُ فَأَمِّنُوا، فَمَنْ وَافَقَ تَأْمِينُهُ تَأْمِينُ الْمَلَائِكَةِ غُفِرَ لَهُ مَا تَقَدَّمَ مِنْ ذَنْبِهِ\". عفواً، هذا التأمين الناظم رحمه الله ماذا قال؟ قال: \"تَأْمِينُ مَنْ صَلَّى عَدَا جَهْرَ الْإِمَامْ\"؛ أي باستثناء الإمام في الجهرية؛ يعني مفهوم كلام الناظم أن المنفرد (من يصلي لوحده) يؤمِّن مطلقاً يؤمِّن، المأموم يؤمِّن مطلقاً؛ في السر في السرية والجهرية كذلك المنفرد كما أسلفنا، الإمام يؤمِّن في السرية ولا يؤمِّن في الجهرية. هذا مشهور مذهب المالكية؛ أن الإمام في الصلاة الجهرية لا يؤمِّن، لكن الحديث الذي ذكرناه آنفاً يرد على هذا؛ فقد قال النبي صلى الله عليه وسلم: \"إِذَا أَمَّنَ الْإِمَامُ فَأَمِّنُوا\" يعني أن المأموم يسمع تأمين الإمام؛ \"إِذَا أَمَّنَ الْإِمَامُ\" أي قال الإمام: \"آمين\" فـ أمِّنوا أنتم قولوا آمين. ورد في حديث في رواية أخرى: \"فَإِنَّ الْإِمَامَ يَقُولُ آمِينَ وَالْمَلَائِكَةَ تَقُولُ آمِينَ\"، لذا قال صلى الله عليه وسلم في هذه الرواية: \"فَمَنْ وَافَقَ تَأْمِينُهُ تَأْمِينُ الْمَلَائِكَةِ غُفِرَ لَهُ مَا تَقَدَّمَ مِنْ ذَنْبِهِ\". الـ المالكية رحمه الله عليهم يؤولون هذا الحديث حديث \"إذا أمَّن الإمام\"، فيقولون إن معنى أمَّن أي بلغ موضع التأمين؛ كما تقول: \"أصبحتُ\" أي دخلتُ في الصباح، و\"أمسيتُ\" دخلتُ في المساء؛ ويقال: \"أنجدَ الرجل\" إذا دخل نجداً، و\"أعرقَ\" إذا دخل العراق؛ فـ \"أمَّن\" أي بلغ موضع التأمين. لكن هذا تأويل لا حاجة إليه، فالأصل حمل الكلام على حقيقته لا على المجاز، ويرده ما ورد في حديث في الحديث الصريح: أنه صلى الله عليه وسلم كان إذا قال: {غَيْرِ الْمَغْضُوبِ عَلَيْهِمْ وَلَا الضَّالِّينَ} قال: \"آمِينَ\" حتى يُسمع من يليه. فلذلك من مندوبات الصلاة التأمين مطلقاً؛ يؤمِّن؛ الإمام والمأموم والمنفرد، سواء كانت الصلاة سرية أو كانت جهرية؛ إذاً قال رحمه الله: \"تَأْمِينُ مَنْ صَلَّى عَدَا جَهْرَ الْإِمَامْ\"، لأن مشهور المذهب أن الإمام لا يؤمِّن في الصلاة الجهرية. ثم قال: \"وَقَوْلُ رَبَّنَا لَكَ الْحَمْدُ عَدَا *** مَنْ أَمَّ\". المندوب الثالث؛ قال الناظم رحمه الله: \"وَقَوْلُ رَبَّنَا لَكَ الْحَمْدُ عَدَا *** مَنْ أَمَّ\". المندوب الثالث هو التحميد؛ أي قول: \"ربنا لك الحمد\". وبالمناسبة في صيغ كلها ثابتة عن رسول الله صلى الله عليه وسلم: \"ربنا لك الحمد\"، \"ربنا ولك الحمد\"، \"اللهم ربنا لك الحمد\"، \"اللهم ربنا ولك الحمد\"؛ كلها ثابتة عن رسول الله صلى الله عليه وسلم. قال الحبيب صلى الله عليه وسلم وهو يبين لنا أمر الصلاة، قال: \"وَإِذَا قَالَ\" -أي الإمام- \"وَإِذَا قَالَ: سَمِعَ اللَّهُ لِمَنْ حَمِدَهُ، فَقُولُوا: رَبَّنَا وَلَكَ الْحَمْدُ\" فقولوا: \"ربنا ولك الحمد\". هذا التحميد يقوله المنفرد ويقوله المأموم؛ الإمام يقول الناظم رحمه الله إن الإمام لا لا يأتي به، لا يقول الإمام: \"ربنا ولك الحمد\"، لذلك قال رحمه الله: \"وَقَوْلُ رَبَّنَا لَكَ الْحَمْدُ عَدَا\"؛ عَدَا أي باستثناء \"مَنْ أَمَّ\"؛ أي باستثناء الإمام، لماذا؟ لأن في الحديث الذي ذكرناه آنفاً يقول عليه الصلاة والسلام: \"وَإِذَا قَالَ: سَمِعَ اللَّهُ لِمَنْ حَمِدَهُ، فَقُولُوا: رَبَّنَا وَلَكَ الْحَمْدُ\"؛ لكن الواقع أنه ثبت أن رسول الله صلى الله عليه وسلم كان يأتي بالتسميع والتحميد معاً وهو إمام؛ كان يقول: \"سمع الله لمن حمده\"، ويقول أيضاً: \"ربنا ولك الحمد\". ثم قال رحمه الله: \"وَالْقُنُوتُ فِي الصُّبْحِ بَدَا\". المندوب الرابع: القنوت. لفظة القنوت لها معانٍ متعددة؛ منها: الدعاء، وهو المعنى المقصود هنا. المالكية ومن وافقهم رحمه الله على علمائنا جميعاً يرون أن المصلي يقنت متى؟ في صلاة الصبح في الركعة الثانية قبل الركوع؛ صلاة الصبح خاصة في الركعة الثانية قبل أن يركع، أنهى القراءة يقنت؛ ماذا يقول؟ يدعو يدعو، ويرون في ذلك حديثاً أو دعاءً يستحبونه وهو وفيه: \"اللهم إنا نستعينك ونستغفرك ونؤمن بك ونخنع لك ونخلع من ونخلع ونترك من يكفرك، اللهم إن اللهم إياك نعبد ولك نصلي ونسجد وإليك نسعى ونحفد، نرجو رحمتك ونخاف عذابك\" (نرجو رحمتك ونخاف عذابك الجد)، \"إن عذابك الجد بالكافرين ملحق\"؛ هذا هذا دعاء الدعاء الذي يستحبون في في القنوت في في هذا الموضع. وهذا يعني تحديد هذا المـ ـوضع بالقنوت لعله لم يثبت فيه حديث صحيح؛ لكن هذا هذا المندوب الرابع. ثم قال رحمه الله: \"رِدَا\"، رِدَا أي الرداء؛ الرداء ما هو الرداء؟ الرداء هو الثوب الذي يوضع على عاتق المصلي ويستر به صدره؛ يعني كأن نقول اللباس الذي يغطي أعلى البدن. هذا نحن الآن نتحدث عن الرجل، لأن ستر العورة هذا من شروط الصلاة كما مر معنا؛ عاتق الرجل وصدره ليس من العورة، سترهما هذا من مندوبات الصلاة. قال النبي صلى الله عليه وسلم: \"لَا يُصَلِّيَنَّ أَحَدُكُمْ فِي الثَّوْبِ الْوَاحِدِ لَيْسَ عَلَى عَاتِقِهِ مِنْهُ شَيْءٌ\" (لا يصلين أحدكم في الثوب الواحد ليس على عاتقه منه شيء). ثم قال رحمه الله: وَرِدَا وَتَسْبِيحُ السُّجُودِ وَالرُّكُوعْ *** سَدْلُ يَدٍ تَكْبِيرُهُ مَعَ الشُّروعْ وَبَعْدَ أَنْ يَقُومَ مِنْ وُسْطَاهُ *** وَعَقْدُهُ الثَّلَاثَ مِنْ يُمْنَاهُ لَدَى التَّشَهُّدِ وَبَسْطُ مَا خَلَاهْ *** تَحْرِيكُ سَبَّابَتِهَا حِينَ تَلَاهْ المقصود قول: \"سبحان ربي العظيم\" في الركوع، وقول: \"سبحان ربي الأعلى\" في السجود؛ هذا المقصد بقوله: \"وَتَسْبِيحُ السُّجُودِ وَالرُّكُوعْ\" أي التسبيح في السجود والركوع. لما نزل قول الله عز وجل: {فَسَبِّحْ بِاسْمِ رَبِّكَ الْعَظِيمِ} قال صلى الله عليه وسلم: \"اجْعَلُوهَا فِي رُكُوعِكُمْ\"؛ ولما نزلت: {سَبِّحِ اسْمَ رَبِّكَ الْأَعْلَى} قال: \"اجْعَلُوهَا فِي سُجُودِكُمْ\". فالإنسان لما يركع يقول: \"سبحان ربي العظيم، سبحان ربي العظيم، سبحان ربي العظيم\" يعني على الأقل ثلاث مرات، ولو زاد لا بأس إن شاء الله فهو أحب إلى الله عز وجل؛ وتجزئ مرة واحدة، تجزئ لو قالها مرة واحدة تجزئه إن شاء الله. وإذا سجد يقول: \"سبحان ربي الأعلى، سبحان ربي الأعلى، سبحان ربي الأعلى\". وحان لو تاملت في هذا تجد جمال الصلاة وجلالها؛ فإن حينما تركع لا تركع إلا لعظيم، تقول: \"سبحان ربي العظيم، سبحان ربي العظيم، سبحان ربي العظيم\" وأنت راكع لمولاك العظيم جل جلاله؛ ثم سبحان الله لما تسجد، تسجد تضع أعلى ما في جسدك الذي هو الجبهة والأنف، تضعهما في التراب على الأرض، فأنت في قمة السفل وتسبح مَن هو في قمة العلو فتقول: \"سبحان سبحان ربي الأعلى، سبحان ربي الأعلى، سبحان ربي الأعلى\" هذا في السجود. طبعاً بعد ذلك تدعو بما شئت في السجود، كما قال صلى الله عليه وسلم عن السجود: \"فَاجْتَهِدُوا فِي الدُّعَاءِ، فَإِنَّهُ قَمِنٌ أَنْ يُسْتَجَابَ لَكُمْ\"؛ أي حقيق أن يستجاب لكم. \"وَتَسْبِيحُ السُّجُودِ وَالرُّكُوعْ *** سَدْلُ يَدٍ\"؛ المندوب السابع: سدل اليدين، سدل اليدين أي إرسالهما هكذا إرسالهما، وإرسال اليد الذي هو ضده وضع اليد على الصدر (وضع اليمنى على اليسرى على الصدر)، هذا ضد السدل والإرسال. المالكية رحمه الله عليهم يرون من مندوبات الصلاة في المشهور عندهم -طبعاً هذا المشهور وفي خلاف داخل المذهب في هذا- المشهور أن المصلي يرسل يديه ولا يضعهما على صدره؛ وهذا في الفرض خاصة، هذا في الصلاة المفروضة خاصة، أما في في النوافل فيستحب له أن يضع يده على صدره. ودليل الواقع المالكية لما شهروا هذا ليس معهم حديث لا صحيح ولا حسن ولا حديث ضعيف، وإنما من استدل بأن بعض الذي نقل صفة رـ صلاة رسول الله صلى الله عليه وسلم مثل أبي حميد الساعدي وغيره لم ينقلوا أنه صلى الله عليه وسلم وضع يده على صدره؛ وأيضاً استُدل بما نُقل عن الإمام مالك رحمه الله أنه يكره الاعتماد في الصلاة، يكره الاعتماد في الصلاة؛ الاعتماد: الاتكاء، طبعاً هذا باختصار نحن الآن في في هذا شرح هذا النظم لا اريد أن أبسط الأدلة في أية مسألة، وإنما أحياناً بعض المسائل أتوقف عندها فأتوسع قليلاً جداً باقتضاب؛ لكن الواقع أن وضع اليد على الصدر (وضع اليمنى على اليسرى على الصدر) هذا ثبت في أحاديث كثيرة، حوالي رُوي عن النبي صلى الله عليه وسلم حوالي عشرين حديثاً؛ جلها أحاديث صحاح؛ بعضها في الصحيحين بعضها في صحيح البخاري ومسلم، بل بعضها رواه الإمام مالك رحمه الله في الموطأ؛ الإمام مالك رحمه الله روى في الموطأ أن قال إن النبي صلى الله عليه وسلم قال: \"أُمِرْنَا مَعْشَرَ الْأَنْبِيَاءِ بِتَعْجِيلِ فِطْرِنَا، وَتَأْخِيرِ سُحُورِنَا، وَوَضْعِ أَيْمَانِنَا عَلَى شَمَائِلِنَا فِي الصَّلَاةِ\"؛ وفي صحيح البخاري عن سهل بن سعد الساعدي رضي الله عنه، قال: \"كَانَ النَّاسُ يُؤْمَرُونَ أَنْ يَضَعَ الرَّجُلُ يَدَهُ الْيُمْنَى عَلَى ذِرَاعِهِ الْيُسْرَى فِي الصَّلَاةِ\" (عفواً: أن يضع الرجل يده اليمنى على ذراعه اليسرى؛ كان الناس يؤمرون أن يضع الرجل يده اليمنى على ذراعه اليسرى)، وفي أحاديث كثيرة يعني في هذا؛ فلذلك الصواب والراجح أن السنة والمندوب هو وضع اليد اليمنى على اليسرى على الصدر لا إرسالهما، لصحة الأحاديث الواردة في ذلك وهي كثيرة جداً؛ ولم يرد ولا حديث صحيح بل ولا ضعيف في أنه صلى الله عليه وسلم كان يرسل، كان يرسل يديه. ثم هذا أيضاً هذا الذي يناسب، هذا الذي يناسب الأدب مع الله عز وجل، والإنسان بين يدي ربه سبحانه وتعالى يقف في غاية الأدب. ثم قال رحمه الله: \"تَكْبِيرُهُ مَعَ الشُّروعْ\"؛ تكبيره مع الشروع، هذا المندوب الثامن وهو مقارنة التكبير للشروع في الفعل، مقارنة التكبير للشروع في الفعل؛ معنى هذا الكلام مثلاً أنت تصلي واقف، تصلي أردت أن تركع؛ مع مع شروعك في الركوع تشرع في التكبير فتقول: \"الله أكبر\" وتنزل راكعاً، بمعنى ليس من السنة أنك تنزل للركوع وبعد أن تركع تقول: \"الله أكبر\" لا، بل يكون التكبير مقارناً للفعل؛ وكذلك ليس من السنة أنك مثلاً أنت واقف تقول: \"الله أكبر\" ثم تركع، لا، بل يكون التكبير مقارناً للركوع. إذا أردت أن تسجد تقول: \"الله أكبر\" وأنت تهوي إلى السجود؛ رفعت من السجود تقول: \"الله أكبر\" وتقوم من السجود، لا تكبر وأنت ساجد ثم ترفع، أو لا ترفع وأنت ساكت وبعد أن تجلس تقول: \"الله أكبر\"؛ ذا قال رحمه الله: \"تَكْبِيرُهُ مَعَ الشُّروعْ\" أي مقارنة التكبير للشروع في الفعل. ويدل على هذا ما ورد في وصف صلاة رسول الله صلى الله عليه وسلم: \"أَنَّهُ كَانَ يُكَبِّرُ حِينَ يَقُومُ، ثُمَّ يُكَبِّرُ حِينَ يَرْكَعُ، وَيُكَبِّرُ...\"؛ إذن في قول قول الصحابي: \"يكبر حين حين يقوم، حين يركع\" ففهم منه العلماء مقارنة التكبير للشروع في الفعل. قال رحمه الله تعالى: \"وَبَعْدَ أَنْ يَقُومَ مِنْ وُسْطَاهُ\"؛ وبعد أن يقوم من وسطاه، هنا المندوب التاسع: تأخير التكبير إلى حين إتمام القيام من الوسطى، تأخير التكبير إلى حين إتمام القيام الوسطى. نحن قلنا إن التكبير يقارن الفعل؛ يستثني المالكية في المشهور عندهم حالة واحدة، وهي حين تقوم من التشهد الأوسط إلى الركعة الثالثة، فيقولون: أنهيت التشهد الأوسط تقوم واقفاً حتى تستوي قائماً، حينئذٍ تقول: \"الله أكبر\". الواقع يعني هذا يستدل له بالحديث الذي ذكر طرف منه آنفاً وفيه: \"أَنَّهُ صلى الله عليه وسلم كَانَ يُكَبِّرُ حِينَ يَقُومُ، وَيُكَبِّرُ حِينَ يَرْكَعُ\" وفيه: \"وَإِذَا نَهَضَ مِنَ الرَّكْعَتَيْنِ كَبَّرَ\" (وإذا نهض من الركعتين كبر)؛ ففهموا من اللفظ أنه لا يكبر حتى يستوي قائماً حتى ينهض، هكذا فـ فقالوا: \"وإذا نهض من الركعتين يكبر\"، واللفظ يحتمل يحتمل فعلاً تأخير التكبير إلى حين إتمام القيام، ويحتمل مقارنة التكبير للقيام. قال رحمه الله تعالى: \"وَعَقْدُهُ الثَّلَاثَ مِنْ يُمْنَاهُ *** لَدَى التَّشَهُّدِ وَبَسْطُ مَا خَلَاهْ\"؛ هذا المندوب العاشر: عقد الأصابع الثلاثة عند التشهد؛ الآن أنت جلست عند التشهد، كيف يكون حال أو وضع اليدين؟ طبعاً اليد اليسرى تضعها على ركبتك اليسرى، اليد اليمنى قال رحمه الله: \"وَعَقْدُهُ...\" وعقده الثلاث من يمناه؛ أي عقد ثلاث أصابع، ما هي الأصابع؟ هي الخنصر والبنصر والوسطى؛ الخنصر، البنصر، الوسطى. قال لي هودي: \"وَبَسْطُ مَا خَلَاهْ\"؛ ما الذي يُبسط؟ السبابة، تشير بالسبابة تشير بالسبابة؛ لأن هي التي يُشار بها كما سيأتي في المندوب الموالي إن شاء الله. دليل هذا ما ثبت عنه صلى الله عليه وسلم أنه من حديث ابن عمر رضي الله عنهما: \"أَنَّهُ صلى الله عليه وسلم كَانَ إِذَا قَعَدَ عِنْدَ التَّشَهُّدِ وَضَعَ يَدَهُ الْيُسْرَى عَلَى رُكْبَتِهِ الْيُسْرَى، وَوَضَعَ يَدَهُ الْيُمْنَى عَلَى رُكْبَتِهِ الْيُمْنَى، وَعَقَدَ ثَلَاثاً وَخَمْسِينَ\" (وعقد ثلاثة وخمسين)، \"وَأَشَارَ بِالسَّبَّابَةِ\"؛ شو ثلاثة وخمسين؟ ثلاثة وخمسين عند العرب كانوا يقولون ثلاثة وخمسين؛ هذه ثلاثة وهذا الإبهام خمسون؛ الخنصر، البنصر، الوسطى ثلاث، هذا خمسون؛ فعقد ثلاثة وخمسين ثم تشير بالسبابة؛ فهذا هذا المقصود بقوله: \"وَعَقْدُهُ الثَّلَاثَ مِنْ يُمْنَاهُ لَدَى التَّشَهُّدِ وَبَسْطُ مَا خَلَاهْ\". طبعاً هذه من الصيغ الواردة عن رسول الله صلى الله عليه وسلم، وورد عنه أنه كان يحلق أحياناً بين الوسطى والسبـ والابهام؛ يحلق بينهما، وورد عنه أنه كان يضمهما؛ فهذه يضم هكذا، فهذه كلها صيغ ثابتة عن سيدنا رسول الله صلى الله عليه وسلم، وهذا ما يُسمى اختلاف التنوع (هذا اختلاف التنوع). إذاً قال رحمه الله: \"وَعَقْدُهُ الثَّلَاثَ مِنْ يُمْنَاهُ لَدَى التَّشَهُّدِ وَبَسْطُ مَا خَلَاهْ\". ثم قال: \"تَحْرِيكُ سَبَّابَتِهَا حِينَ تَلَاهْ\". تحريك السبابة، هذا المندوب الحادي عشر؛ أثناء التشهد تحرك السبابة، لأنه قال صلى الله عليه وسلم أشار بالسبابة؛ ورد في رواية: \"يُحَرِّكُهَا يَدْعُو بِهَا\" (ورد في حديث أنه صلى الله عليه وسلم أشار بسبّابته يحرّكها يدعو بها)، والمالكية رحمه الله عليهم يختارون أن تحريك السبابة يكون من اليمين إلى اليسار؛ من اليمين يمنة ويسرة، يمنة ويسرة؛ هذا اختيار المالكية يمنة ويسرة يحركها هكذا؛ فهذا يعني في في التشهد هذا من مندوبات الصلاة؛ قال رحمه الله: \"لَدَى تَحْرِيكُ سَبَّابَتِهَا حِينَ تَلَاهْ\". ثم قال: وَالْبَطْنُ مِنْ فَخْذِ رِجَالٍ يُبْعِدونْ *** وَمِرْفَقاً مِنْ رُكْبَةٍ إِذْ يَسْجُدونْ هذا المندوب الثاني عشر: صفة السجود، كيف يكون السجود؟ نحن تقدم معنا أن السجود يكون على سبعة أعظم، لكن الصفة الكاملة للسجود أو ما أشار إليه الناظم هنا رحمه الله عليه قال: \"وَالْبَطْنُ مِنْ فَخْذِ رِجَالٍ يُبْعِدونْ\"؛ يعني أنك حين تسجد تبعد البطن عن الفخذ، لا تبقى منكمشاً عند السجود إنما تبعد بطنك عن عن فخذيك. طبعاً باعتدال، لا لا يبتعد الإنسان كثيراً يعني حتى يقترب من هيئة المنبطح، وإنما هو باعتدال يعني؛ فـ \"وَالْبَطْنُ مِنْ فَخْذِ رِجَالٍ يُبْعِدونْ\". قال: \"وَمِرْفَقاً...\" ومرفقاً \"مِنْ رُكْبَةٍ إِذْ يَسْجُدونْ\"؛ يعني البطن تبعده عن الفخذ، وتلقائياً ستكون قد أبعدت الفخذ عن الساق أيضاً. ثم قال: \"وَمِرْفَقاً مِنْ رُكْبَةٍ\"؛ يعني أن المرفق، هذا المرفق لا تلزقه بركبتيك حين تسجد، فأنت سجدت فتبعد فخذك بطنك عن فخذيك وتبعد مرفقك عن ركبتيك، وأيضاً تجافي تجافي بين العضدين والجنبين؛ يعني لا تبقى منكمشاً هكذا وإنما تجافي، فيكون السجود بهذه الهيئة. طبعاً تكون تكون أصابع يديك متجهة نحو القبلة، لا تضع أصابع يديك هكذا بل تضعهما في اتجاه هكذا فه القبلة، وتبعد تجافي عضدك عن عن عن جنبك، وتبعد البطن عن الفخذ؛ هذه صفة السجود. النبي صلى الله عليه وسلم كما تقول ميمونة ردي الله عنها: \"كَانَ النَّبِيُّ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ إِذَا سَجَدَ لَوْ شَاءَتْ بَهْمَةٌ أَنْ تَمُرَّ بَيْنَ يَدَيْهِ لَمَرَّتْ\"؛ البهمة هي الغنمة الصغيرة التي حديثة الولادة، فقال: لو أرادت أن تمر تمر يعني بين يديه صلى الله عليه وسلم؛ فهذه هذه صفة السجود. الناظم رحمه الله قال: \"وَالْبَطْنُ مِنْ فَخْذِ رِجَالٍ يُبْعِدونْ\"؛ رجالٌ، فقوله \"رِجَالٍ\" يُفهم منه أن المرأة خلاف هذا، لأن المالكية رحمه الله عليهم في المشهور عندهم يستحبون للمرأة أن تنضم؛ يقول إن المرأة ينبغي أن تنضم ولا تـ هذا والـ المهم هذا هذا مشهور مذهب المالكية. قال رحمه الله تعالى: \"وَالْبَطْنُ مِنْ فَخْذِ رِجَالٍ يُبْعِدونْ *** وَمِرْفَقاً مِنْ رُكْبَةٍ إِذْ يَسْجُدونْ\"؛ ثم قال: وَصِفَةُ الْجُلُوسِ تَمْكِينُ الْيَدِ *** مِنْ رُكْبَتَيْهِ فِي الرُّكُوعِ وَزِدِ نَصْبَهُمَا قِرَاءَةً فِي سِرِّيَّهْ *** وَضْعَ الْيَدَيْنِ فَاقْتَدِ لَدَى السَّجْدَهْ حَذْوَ أُذُنٍ وَكَذَا رَفْعُ الْيَدَيْنْ *** عِنْدَ الْإِحْرَامِ خُذْ ثم قال: \"وَصِفَةُ الْجُلُوسِ\". المندوب الثالث عشر: صفة الجلوس؛ كيف يجلس الإنسان؟ وصفة الجلوس، الجلوس إنسان ما يجلس؛ أبو أبو حميد الساعدي رضي الله عنه وصف صفة وصف صلاة رسول الله صلى الله عليه وسلم بمحضر عشرة من الصحابة، فمما ذكره أنه صلى الله أنه صلى الله عليه وسلم لما جلس افترش رجله اليسرى؛ رجله اليسرى يفترش هذه الرجل اليسرى هاد الرجل اليسرى هاد الرجل اليسرى يفترشها فيجلس عليها، يجلس عليها؛ قال: \"وَأَقْبَلَ بِصَدْرِ الْيُمْنَى\" الرجل اليمنى أقبل بصدرها هكذا على قبلته هكذا؛ يعني فيجلس تنصب رجلك اليسرى قدمك اليسرى فتجلس عليها تفترش، وتنصب عفواً تفترش عفواً تفترش قدمك اليسرى فتجلس عليها، وتنصب رجلك اليمنى هكذا قدمك اليمنى هكذا تنصبها فتجلس بهذه الطريقة؛ هذه صفة الجلوس الثابتة عن سيدنا رسول الله صلى الله عليه وسلم كما في حديث أبي حميد الساعدي رضي الله عنه. طبعاً هـ هاته الطريقة الإنسان إذا لم يألفها قد يجد فيها شيئاً من المشقة والصعوبة، لكن بالإلف تصبح سهلة ميسورة إن شاء الله تعالى؛ من عجز ولم يستطع فيمكنه أن يفترش رجليه معاً (اليمنى واليسرى) هكذا ويجلس عليهما، لكن دون أن يفضي بإليتيه ومقعدته إلى الأرض ذاك من الإقعاء المكروه، وإنما هكذا ويجلس عليها إن شاء الله. المالكية رحمه الله عليهم يستحبون التورك في الصلاة كلها؛ في الصلاة كلها حتى بين السجدتين، ويستحبون التورك؛ ما هو التورك؟ أن الإنسان المصلي يجلس على وركه الأيسر، على وركه الأيسر، وينصب رجله اليمنى ويخرج رجله اليسرى من تحتها؛ هذا التورك، يجلس على الورك الأيسر يفضي بإليتيه ومقعدته الأرض جهة الورك الأيسر، ينصب الرجل اليمنى ويخرج الرجل اليسرى من تحت فخذه ورجله؛ فيستحب هذا في الصلاة كلها، وقد يكون في هذا شيـ شيء من مشقته خصوصاً في صلاة الجماعة. ثم قال رحمه الله: \"تَمْكِينُ الْيَدِ *** مِنْ رُكْبَتَيْهِ فِي الرُّكُوعِ وَزِدِ *** نَصْبَهُمَا\". إذن صفة الجلوس هذا المندوب الثالث عشر. المندوب الرابع عشر: تمكين اليد من ركبتيه في الركوع، تمكين اليد من الركبتين في الركوع. في حديث أبي حميد الساعدي قال رضي الله عنه: \"وَإِذَا رَكَعَ أَمْكَنَ يَدَيْهِ مِنْ رُكْبَتَيْهِ\" (النبي صلى الله عليه وسلم إذا ركع أمكن يديه من ركبتيه)، اليدان تمكنهما من ركبتيك؛ وفي حديث آخر: \"تُفَرِّقُ أَصَابِعَكَ\" (تفرق أصابعك) وأنت تمسك ركبتيك بيديك. المندوب الخامس عشر؛ قال: \"نَصْبَهُمَا\" أي نصب الركبتين، لأنه قال: \"تَمْكِينُ الْيَدِ مِنْ رُكْبَتَيْهِ فِي الرُّكُوعِ وَزِدِ نَصْبَهُمَا\"؛ أي نصب الركبتين. أبو حميد الساعدي رضي الله عنه قال: \"وَإِذَا رَكَعَ أَمْكَنَ يَدَيْهِ مِنْ رُكْبَتَيْهِ وَهَصَرَ ظَهْرَهُ\"؛ هصر ظهره يعني جعله مستوياً، مما يساعد على استواء الظهر نصب الركبتين؛ يعني أن الركبتين تكونان منتصبتين لا لا تثني ركبتيك لا تثني ركبتيك، فتكون الركبتان منتصبتين واقفتين وتمكن يديك من ركبتيك ويكون الظهر مستوياً، يكون الظهر مستوياً؛ وعلماؤنا يقول حتى لو صُبَّ الماء على الظهر لبقي مستقراً، فأنت لا تحني ظهرك هكذا ولا ترفعه في الركوع قال رحمه الله. ثم قال: \"قِرَاءَةً فِي سِرِّيَّهْ\". قراءة المأموم في السرية، قراءة المأموم في السرية؛ فالصلاة الجهرية المأموم يستمع قراءة الإمام، في الصلاة السرية تقرأ خلف إمامك؛ صلاة الظهر، العصر، الركعة الثالثة في المغرب، الركعتان الأخيرتان في العشاء تقرأ. يدل على هذا أنه صلى الله عليه وسلم مرة كان يصلي فـ في صلاة جهرية، فلما سلّم قال: \"هَلْ قَرَأَ مَعِي أَحَدٌ مِنْكُمْ آنِفاً؟\" قالوا: نعم؛ فقال صلى الله عليه وسلم: \"وَأَنَا أَقُولُ مَا لِي أُنَازَعُ؟\" فقال أبو هريرة قال أبو هريرة رضي الله عنه: \"فَانْتَهَى النَّاسُ عَنِ الْقِرَاءَةِ مَعَ رَسُولِ اللَّهِ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ فِيمَا جَهَرَ فِيهِ\" (قوله فانتهى الناس عن القراءة فيما جهر فيه رسول الله صلى الله عليه وسلم يفهم منه أن فيما جهر ينتهي الناس عن القراءة يستمعون، لكن في السرية تكون القراءه). بعض الناس يطرح إشكالاً يقول لك: \"طيب إذا قرأت في السرية ربما أسبق الإمام\"، هذا لا يهم حتى لو سبقته وتخلفت عنه؛ \"ربما أسبق بالفاتحة\"، ربما يقول لك: \"طيب أنا أحياناً ربما أنا أقرأ السورة وهو يقرأ سورة أخرى\"، لا، هذا لا يؤثر. ما دام الناس عن القراءة فيما جهر فيه رسول الله صلى الله عليه وسلم يفهم منه استماع القراءة فيما أسر فيه صلى الله عليه وسلم، فهذا من مندوبات الصلاة؛ فتقرأ خلف إمامك، مثلاً في صلاة الظهر في الركعتين الأوليين تقرأ الفاتحة وتقرأ ما تيسر بعد الفاتحة حتى يركع إمامك، وفي الركعتين الأخيرتين تقرأ الفاتحة فقط وهكذا. ثم قال: \"وَضْعَ الْيَدَيْنِ فَاقْتَدِ لَدَى السَّجْدَهْ *** حَذْوَ أُذُنٍ\"؛ هذا المندوب السابع عشر وهو: وضع اليدين حذو الأذنين في السجود، وضع اليدين حذو الأذنين في السجود. لما تسجد أين تضع أين يكون موضع رأسك مقاساً مع يديك؟ قال لك: تضع تسجد وـ ويكون تكون يكون وضع اليدين محاذياً للاذنين؛ في السجود تكون اليدان محاذيتين للاذنين حال السجود. ممن وصف صلاة رسول الله صلى الله عليه وسلم وائل بن حجر رضي الله عنه؛ وائل بن حجر كما في صحيح مسلم يقول: \"كَانَ إِذَا سَجَدَ وَضَعَ رَأْسَهُ بَيْنَ كَفَّيْهِ\" (وضع رأسه بين كفيه)؛ فهذا هذا في وضع اليدين حال السجود. ثم قال رحمه الله: \"وَكَذَا رَفْعُ الْيَدَيْنِ *** عِنْدَ الْإِحْرَامِ خُذْ\". رفع اليدين؛ أي رفع اليدين عند الإحرام. قال لحظ قال: \"وَضْعَ الْيَدَيْنِ فَاقْتَدِ لَدَى السَّجْدَهْ حَذْوَ أُذُنٍ\"، هنا انتهى المندوب السابق؛ ثم قال: \"وَكَذَا رَفْعُ الْيَدَيْنِ عِنْدَ الْإِحْرَامِ خُذْ\"؛ أي خذ ألف الإطلاق، أي خذ كذلك ما معنى هذا الكلام؟ أي حين تكبر الإحرام؛ تقدم معنا أنها ركن من أركان الصلاة، طـ رفع اليدين هذا من مندوبات الصلاة. رفع اليدين الإحرام؛ لما تكبر الصلاة الإحرام تقول: \"الله أكبر\"؛ طيب ترفع يديك إلى أين؟ قال: \"وَكَذَا\" أي أيضاً ترفعها حذو الأذنين، ترفع حذو الأذنين هكذا حذو الأذنين بمحاذاة الأذنين. بالمناسبة لما نقول حذوه لا تعني مماسته؛ إياك أن تفهم أن المقصود أن تمس لا، حذو اليدين أي بمحاذاتهما فـ \"رَفْعُ الْيَدَيْنِ عِنْدَ الْإِحْرَامِ خُذْ\". وهذا ثبت عن رسول الله صلى الله عليه وسلم، وثبت أيضاً أنه كان يرفع يديه حذو منكبيه كذلك، وذا ثبت في الصحيح أيضاً أنه صلى الله عليه وسلم كان وهذا اختاره مالك رحمه الله عليه: رفع اليدين حذو المنكبين (المنكبين)؛ فسواء نرفع حذو المنكبين أو حذو الأذنين فهذا مندوبات الصلاة إن شاء الله، يعني حذو الأذنين هكذا عفواً لأن هذا هذا ما بين بين المنكبين والأذنين، وإنما حد الأذنين هكذا يعني حذو الأذنين؛ وحتى هذه ثابتة عن رسول الله صلى الله عليه وسلم أيضاً بين المنكبين وبين الأذنين، كما أسلفت غير مرة هذا اختلاف تنوع. قال رحمه الله: تَطْوِيلُهُ صُبْحاً وَظُهْراً سُورَتَيْنْ *** تَوَسُّطُ الْعِشَا وَقَصْرُ الْبَاقِيَيْنْ كَسُورَةِ الْأُخْرَى كَذَا الْوُسْطَى اسْتُحِبّ *** سَبْقُ يَدٍ وَضْعاً وَفِي الرَّفْعِ الرُّكَبْ الآن هذه هذا المندوب يتعلق بكيفيات القراءة في الصلوات؛ كيفيات القراءة في الصلوات من جهة الطول والقصر، من جهة الطول والقصر؛ كيفية القراءة في الصلوات طولاً وقصراً. من السنة والتي وردت في هذا أحاديث سوف وأدلة سوف نطوـ لأن طال وقت الحلقة؛ الصبح تستحب يستحب فيها تطويل القراءة، صلاة الصبح يستحب فيها تطويل القراءة؛ والله تعالى يقول: {أَقِمِ الصَّلَاةَ لِدُلُوكِ الشَّمْسِ إِلَىٰ غَسَقِ اللَّيْلِ وَقُرْآنَ الْفَجْرِ}. قال بعض العلماء: لماذا قال ربنا {وَقُرْآنَ الْفَجْرِ} ولم يقل صلاة الفجر؟ عبَّر بقرآن الفجر، قالوا لأن صلاة الفجر يستحب أن يطيل فيها الإنسان قراءة القرآن؛ إذاً قال: \"تَطْوِيلُهُ صُبْحاً وَظُهْراً\". أيضاً تطويل صلاة الظهر؛ حتى كان الرجل كانت تقام الصلاة تقام الصلاة ويدخل صلى الله عليه وسلم في صلاة الظهر، يذهب الرجل يذهب لقضاء حاجته ويتوضأ ثم يرجع ثم يدرك الركعة الأولى من صلاة الظهر مع رسول الله صلى الله عليه وسلم، لكثرة ما كان يطيلها؛ إذن \"تَطْوِيلُهُ صُبْحاً وَظُهْراً سُورَتَيْنْ\". قال: \"تَوَسُّطُ الْعِشَا\"؛ صلاة العشاء يتوسط تُقرأ قراءة متوسطة، قراءة متوسطة؛ لأن صلاة العشاء يكون الناس يستعدون للنوم وبعد عناء اليوم فيتوسط في القراءة. \"وَقَصْرُ الْبَاقِيَيْنْ\"؛ ما هما الباقيان؟ هما العصر والمغرب؛ صلاة العصر والمغرب يستحب تقصير القراءة فيهما، يستحب تقصير القراءة فيهما. قال: \"وَقَصْرُ الْبَاقِيَيْنْ\"، ثم قال: \"كَسُورَةِ الْأُخْرَى\"؛ الكاف كاف التشبيه، تشبيه السورة الأخرى بما سبق في أي شيء؟ في القصر؛ قال: \"وقصر...\" حتى نفهم النظم؛ قال: \"تَطْوِيلُهُ صُبْحاً وَظُهْراً سُورَتَيْنْ\" انتهى التطويل، \"تَوَسُّطُ الْعِشَا\" انتهى التوسط، \"وَقَصْرُ الْبَاقِيَيْنْ\" اللذان هما قلنا العصر والمغرب، \"وَقَصْرُ الْبَاقِيَيْنْ كَسُورَةِ الْأُخْرَى\"؛ أي السورة الثانية؛ تقصير هذا المندوب الموالي، تقصير السورة الثانية (أي سورة الركعة الثانية، سورة الركعة الثانية)؛ يعني أنكما تصلي هذه، النبي عليه الصلاة والسلام أنه كان الركعة الأولى تكون القراءة فيها أطول من الركعة الثانية؛ هذه السنة، الركعة الثانية تقصر القراءة فيها مقارنة مع الركعة الأولى، مقارنة مع الركعة الأولى. قال: \"وَقَصْرُ الْبَاقِيَيْنْ كَسُورَةِ الْأُخْرَى كَذَا الْوُسْطَى\"؛ هذا المندوب الموالي: \"كَذَا الْوُسْطَى\"، ما الوسطى؟ التشهد الأوسط يستحب قِصره أيضاً، التشهد الأوسط يستحب قِصره يُندب قِصر التشهد الأوسط مقاساً مع التشهد الأخير؛ إذاً قِصر الوسطى قال: \"كَذَا الْوُسْطَى\"، إذن كـ \"سُورَةِ الْأُخْرَى كَذَا الْوُسْطَى\" أي في التقصير. ثم قال: \"اسْتُحِبّ *** سَبْقُ يَدٍ وَضْعاً\"؛ هذا المندوب الحادي الثاني والعشرين (22)، معنى الكلام قال: \"اسْتُحِبّ سَبْقُ يَدٍ وَضْعاً\"؛ أنت قائم تريد أن تهوي للسجود، ماذا تقدم؟ هل تقدم يديك إلى الأرض ثم ركبتيك، أم تقدم ركبتيك ثم يديك؟ قال رحمه الله: \"سَبْقُ يَدٍ\" (يدين) \"وَضْعاً\"؛ كَمَا يَبْرُكُ الْبَعِيرُ، وَلْيَضَعْ يَدَيْهِ قَبْلَ رُكْبَتَيْهِ\"؛ وابن عمر رضي الله عنهما يقول: \"رأيت رسول الله صلى الله عليه وسلم\"، إذن: \"رأيت رسول الله صلى الله عليه وسلم يضع يديه قبل ركبتيه\" هـ نعم رأيت رسول الله صلى الله عليه وسلم يضع يديه قبل ركبتيه؛ كذا قال ابن عمر رضي الله عنهما. إذاً تقدم اليدين على الركبتين. ثم آخراً قال: \"وَفِي الرَّفْعِ الرُّكَبْ\"؛ طيب إذا أردت أن ترفع، نهضت من السجود تريد أن تقوم للركعة الموالية، ماذا ترفع أولاً؟ هل ترفع يديك ثم تعتمد على ركبتيك وترفعهما، أم أنك تعتمد بيديك على الأرض وترفع ركبتيك ثم ترفع يديك؟ هذا الثاني؛ قال: \"وَفِي الرَّفْعِ الرُّكَبْ\" أي عندما تجد أن ترفع ترفع ركبتيك أولاً ثم تقدم اليدين قبل الركبتين. دليل هذا قوله صلى الله عليه وسلم: \"إِذَا سَجَدَ أَحَدُكُمْ فَلَا يَبْرُكْ ترفع يديك؛ هكذا تعتمد بيديك ترفع الركبتين ثم ترفع اليدين. قال رحمه الله: \"اسْتُحِبّ سَبْقُ يَدٍ وَضْعاً\" أي عندما تهوي إلى السجود تقدم يديك أولاً ثم ركبتيك ثانياً، \"وَفِي الرَّفْعِ الرُّكَبْ\" العكس؛ في الرفع ترفع ركبتيك ركبتيك أولاً ثم ترفع يديك. هذه مندوبات الصلاة. وإلى المجلس المقبل إن شاء الله تعالى؛ سبحانك اللهم وبحمدك أشهد أن لا إله إلا أنت أستغفرك وأتوب إليك، وصلى الله وسلم وبارك على سيدنا محمد وعلى آله، والحمد لله رب العالمين. السلام عليكم ورحمة الله وبركاته.",
    "blocks_search_text": "مندوبات الصلاة المتعلقة بالتيامن والتأمين والتحميد والقنوت والرداء مَنْدُوبُهَا تَيَامُنٌ مَعَ السَّلَامْ *** تَأْمِينُ مَنْ صَلَّى عَدَا جَهْرَ الْإِمَامْ وَقَوْلُ رَبَّنَا لَكَ الْحَمْدُ عَدَا *** مَنْ أَمَّ وَالْقُنُوتُ فِي الصُّبْحِ بَدَا تناول الشيخ في هذا المحور جملة من أوائل مندوبات الصلاة كأهمية التيامن الخفيف عند السلام، وأحكام التأمين والتحميد للمصلي إماماً ومأموماً ومنفرداً، بالإضافة إلى حكم القنوت في صلاة الفجر وندب ستر عاتق الرجل بالرداء. مندوبات الصلاة في الهيئات البدنية والتكبير والتسبيح ومسألة السدل وَرِدَا وَتَسْبِيحُ السُّجُودِ وَالرُّكُوعْ *** سَدْلُ يَدٍ تَكْبِيرُهُ مَعَ الشُّروعْ وَبَعْدَ أَنْ يَقُومَ مِنْ وُسْطَاهُ *** شرح الشيخ هنا المندوبات الخاصة بالتسبيح في الركوع والسجود، ومقارنة التكبير للانتقال بالفعل، وصفة عقد الأصابع وتحريك السبابة في التشهد، بالإضافة لصفة السجود ومناقشة مسألة سدل اليدين في المذهب المالكي. مندوبات الصلاة في صفة الجلوس وهيئة الركوع وتفصيل القراءة والهوي للسجود وَصِفَةُ الْجُلُوسِ تَمْكِينُ الْيَدِ *** مِنْ رُكْبَتَيْهِ فِي الرُّكُوعِ وَزِدِ نَصْبَهُمَا قِرَاءَةً فِي سِرِّيَّهْ *** فصّل الشيخ في هذا المحور صفة الجلوس المسنونة بين الافتراش والتورك، واستواء الظهر مع تمكين الركبتين في الركوع، وقراءة المأموم في الصلاة السرية، ومقادير طول السور في الصلوات الخمس، وكيفية الهوي للسجود والرفع منه.",
