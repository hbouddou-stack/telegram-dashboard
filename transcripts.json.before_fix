        "ts": "3:09",
        "sec": 189,
        "text": "العيدين، تُسمى صلاة العيد. هذه",
        "video_link": null
      },
      {
        "ts": "3:16",
        "sec": 196,
        "text": "الصلاة وردت الإشارة إليها في قول ربنا تبارك وتعالى: {فَصَلِّ لِرَبِّكَ وَانْحَرْ}؛",
        "video_link": null
      },
      {
        "ts": "3:25",
        "sec": 205,
        "text": "قال بعض العلماء هنا: الصلاة صلاة العيد (عيد الأضحى)، وانحر أي",
        "video_link": null
      },
      {
        "ts": "3:32",
        "sec": 212,
        "text": "اذبح اذبح لربك عز وجل؛ وبعضهم ذكر أن الإشارة إلى صلاة الفطر في",
        "video_link": null
      },
      {
        "ts": "3:40",
        "sec": 220,
        "text": "قوله تعالى: {وَذَكَرَ اسْمَ رَبِّهِ فَصَلَّىٰ}. ويقول البراء بن عازب رضي الله عنه: \"خَرَجَ",
        "video_link": null
      },
      {
        "ts": "3:49",
        "sec": 229,
        "text": "النَّبِيُّ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ يَوْمَ أَضْحَى فَصَلَّى الْعِيدَ رَكْعَتَيْنِ\".",
        "video_link": null
      },
      {
        "ts": "3:56",
        "sec": 236,
        "text": "صلاة العيد ركعتان، أو ما هي صفة صلاة العيدين؟ صفتها",
        "video_link": null
      },
      {
        "ts": "4:04",
        "sec": 244,
        "text": "أنها ركعتان",
        "video_link": null
      },
      {
        "ts": "4:12",
        "sec": 252,
        "text": "جهراً، بعدهما خطبة. هاتان",
        "video_link": null
      },
      {
        "ts": "4:20",
        "sec": 260,
        "text": "الركعتان فـ في الركعة الأولى سبع",
        "video_link": null
      },
      {
        "ts": "4:27",
        "sec": 267,
        "text": "تكبيرات، تكبيرة الإحرام داخلة ضمن هذه السبع؛ يصلي الإنسان صلاة العيد فيكبر في",
        "video_link": null
      },
      {
        "ts": "4:36",
        "sec": 276,
        "text": "الأولى سبع تكبيرات: \"الله أكبر\" هذه تكبيرة الإحرام، ثم يضيف إليها ست تكبيرات",
        "video_link": null
      },
      {
        "ts": "4:44",
        "sec": 284,
        "text": "أخرى؛ ثم يقرأ جهراً، ويستحب أن يقرأ في الركعة الأولى:",
        "video_link": null
      },
      {
        "ts": "4:52",
        "sec": 292,
        "text": "{سَبِّحِ اسْمَ رَبِّكَ الْأَعْلَى}. ثم في الركعة الثانية خمس",
        "video_link": null
      },
      {
        "ts": "5:01",
        "sec": 301,
        "text": "تكبيرات؛ يكبر الإنسان فيقوم من سجوده إلى الركعة الثانية، هذه تكبيرة",
        "video_link": null
      },
      {
        "ts": "5:08",
        "sec": 308,
        "text": "الانتقال، ثم يكبر خمس تكبيرات؛ إذن في الركعة الأولى سبع",
        "video_link": null
      },
      {
        "ts": "5:17",
        "sec": 317,
        "text": "تكبيرات داخلة ضمنها تكبيرة الإحرام، وفي الركعة",
        "video_link": null
      },
      {
        "ts": "5:26",
        "sec": 326,
        "text": "الثانية ست تكبيرات خمس تكبيرات عفواً، خمس تكبيرات؛ ست إذا احتسبنا تكبيرة تكبيرة",
        "video_link": null
      },
      {
        "ts": "5:34",
        "sec": 334,
        "text": "القيام، فـ إذا لم نحتسبها فهي خمس تكبيرات؛ ثم يقرأ",
        "video_link": null
      },
      {
        "ts": "5:41",
        "sec": 341,
        "text": "الفاتحة ويستحب له أن يقرأ سورة الشمس: {وَالشَّمْسِ وَضُحَاهَا}.",
        "video_link": null
      },
      {
        "ts": "5:50",
        "sec": 350,
        "text": "ا صلاة العيد هاته ا وقتها يبدأ من حِلِّ",
        "video_link": null
      },
      {
        "ts": "5:59",
        "sec": 359,
        "text": "النافلة إلى الزوال؛ لما نقول من حِلِّ",
        "video_link": null
      },
      {
        "ts": "6:05",
        "sec": 365,
        "text": "النافلة، يعني من زوال وقت الكراهة؛",
        "video_link": null
      },
      {
        "ts": "6:11",
        "sec": 371,
        "text": "لأن الصلاة تكره بعد صلاة الصبح؛ قال صلى الله عليه وسلم: \"لَا صَلَاةَ بَعْدَ الصُّبْحِ حَتَّى",
        "video_link": null
      },
      {
        "ts": "6:19",
        "sec": 379,
        "text": "تَطْلُعَ الشَّمْسُ\". فإذا صليت الصبح يبدأ وقت الكراهة فلا يتنفل",
        "video_link": null
      },
      {
        "ts": "6:27",
        "sec": 387,
        "text": "حينئذٍ حتى تطلع الشمس وترتفع قدر",
        "video_link": null
      },
      {
        "ts": "6:32",
        "sec": 392,
        "text": "رمح؛ يعني حوالي ربع ساعة بعد شروق الشمس، من هنا يبدأ",
        "video_link": null
      },
      {
        "ts": "6:40",
        "sec": 400,
        "text": "وقت صلاة العيد ويستمر إلى الزوال. قال رحمه الله",
        "video_link": null
      },
      {
        "ts": "6:47",
        "sec": 407,
        "text": "تعالى: \"وِتْرٌ كُسُوفٌ عِيدٌ\"؛ هذا الكلام على صلاة العيدين باختصار، وهي من السنة المؤكدة. ثم",
        "video_link": null
      },
      {
        "ts": "6:55",
        "sec": 415,
        "text": "قال: \"اسْتِسْقَا\"؛ صلاة الاستسقاء. صلاة الاستسقاء هي",
        "video_link": null
      },
      {
        "ts": "7:04",
        "sec": 424,
        "text": "صلاة شُرعت للمسلمين كلما انحبس",
        "video_link": null
      },
      {
        "ts": "7:11",
        "sec": 431,
        "text": "المطر واحتاجوا إلى السقيا؛ فإنهم",
        "video_link": null
      },
      {
        "ts": "7:17",
        "sec": 437,
        "text": "يخرجون ليصلوا متضرعين إلى ربهم عز وجل، متذللين له؛ يسألونه سبحانه أن",
        "video_link": null
      },
      {
        "ts": "7:28",
        "sec": 448,
        "text": "يغيثهم بماء السماء؛ هذه صلاة",
        "video_link": null
      },
      {
        "ts": "7:34",
        "sec": 454,
        "text": "الاستسقاء. ويستحب وـ فـ بالمناسبة صلاة العيد -لما ذكرنا- تؤدى في المصلى، وكذلك صلاة",
        "video_link": null
      },
      {
        "ts": "7:44",
        "sec": 464,
        "text": "الاستسقاء؛ الأصل في صلاة العيدين أن تؤدى في الفضاء لا تؤدى في المساجد إلا لمطار",
        "video_link": null
      },
      {
        "ts": "7:50",
        "sec": 470,
        "text": "لعذر كالمطر، وتجوز أن تؤدى في المسجد ولكن الأصل أن تؤدى في المصليات لفعل النبي صلى الله عليه وسلم ذلك؛ كذلك صلاة",
        "video_link": null
      },
      {
        "ts": "8:00",
        "sec": 480,
        "text": "الاستسقاء. صلاة الاستسقاء أيضاً تؤدى ا في المصليات في الخارج، يخرج الناس إليها",
        "video_link": null
      },
      {
        "ts": "8:07",
        "sec": 487,
        "text": "متواضعين متذللين إلى ربهم عز وجل، مستغفرين الله تعالى من ذنوبهم؛ فإن من أسباب انحباس",
        "video_link": null
      },
      {
        "ts": "8:15",
        "sec": 495,
        "text": "القطر ذنوب العباد، ذنوب العباد؛ ا فيخرجون",
        "video_link": null
      },
      {
        "ts": "8:23",
        "sec": 503,
        "text": "فيصلون صلاة الاستسقاء. صلاة",
        "video_link": null
      },
      {
        "ts": "8:30",
        "sec": 510,
        "text": "الاستسقاء تشبه صلاة العيد في كونها تؤدى في",
        "video_link": null
      },
      {
        "ts": "8:37",
        "sec": 517,
        "text": "المصلى، وفي كونها ركعتين؛ هي أيضاً ركعتان وهي أيضاً",
        "video_link": null
      },
      {
        "ts": "8:44",
        "sec": 524,
        "text": "جهراً، وبعدها خطبة؛ مثل صلاة العيد. فصلاة العيد تُصلى ركعتين بعدها خطبة، كذلك صلاة الاستسقاء",
        "video_link": null
      },
      {
        "ts": "8:52",
        "sec": 532,
        "text": "ركعتان جهراً بعدها خطبة. المالكية رحمه الله عليهم اختاروا",
        "video_link": null
      },
      {
        "ts": "9:01",
        "sec": 541,
        "text": "أنها تخالف صلاة العيد في التكبير؛ فصلاة العيدين فيها سبع تكبيرات في الأولى وخمس",
        "video_link": null
      },
      {
        "ts": "9:09",
        "sec": 549,
        "text": "في الثانية، وصلاة الاستسقاء اختار المالكية رحمه الله عليهم أن أنه ليس أنه ليس في هذا التكبير، وإنما فقط تكبيرة الإحرام وتكبيرة",
        "video_link": null
      },
      {
        "ts": "9:18",
        "sec": 558,
        "text": "الانتقال؛ فقط تكبيرة الإحرام في في الركعة الأولى، وتكبيرة الانتقال للركعة الثانية",
        "video_link": null
      },
      {
        "ts": "9:25",
        "sec": 565,
        "text": "فقط. بعدها خطبة، هذه الخطبة فيها تتضمن الحث على",
        "video_link": null
      },
      {
        "ts": "9:32",
        "sec": 572,
        "text": "الاستغفار، والتوبة إلى الله عز وجل، والإنابة إليه، والإنابة",
        "video_link": null
      },
      {
        "ts": "9:40",
        "sec": 580,
        "text": "إليه. وفي نهايتها يحوّل الإمام رداءه، يحول السلهام دياله مثلاً يحوله؛ ا يجعل يمينه",
        "video_link": null
      },
      {
        "ts": "9:50",
        "sec": 590,
        "text": "يساراً والعكس، ويجعل ظهره بطناً، وكذلك المأمومون؛ ويرفع يديه إلى السماء داعياً",
        "video_link": null
      },
      {
        "ts": "9:59",
        "sec": 599,
        "text": "ربه عز وجل؛ يتوجه إلى القبلة ويرفع يديه داعياً ربه جل جلاله",
        "video_link": null
      },
      {
        "ts": "10:06",
        "sec": 606,
        "text": "أن يغيث العباد مع التضرع إلى الله جل جلاله سبحانه؛ هذه صلاة",
        "video_link": null
      },
      {
        "ts": "10:17",
        "sec": 617,
        "text": "الاستسقاء. قال رحمه الله تعالى: \"وِتْرٌ كُسُوفٌ عِيدٌ اسْتِسْقَا سُنَنْ\"؛ بهذا أنهى الكلام",
        "video_link": null
      },
      {
        "ts": "10:25",
        "sec": 625,
        "text": "على السنن المؤكدة. بعد ذلك انتقل للحديث عن",
        "video_link": null
      },
      {
        "ts": "10:33",
        "sec": 633,
        "text": "الرغيبة؛ المالكية رحمه الله عليهم عندهم شيء يُسمى الرغيبة، الرغيبة يعني يرغب فيها الإنسان وهي",
        "video_link": null
      },
      {
        "ts": "10:42",
        "sec": 642,
        "text": "الفجر؛ وفي الواقع وهي أيضاً حق السنة مؤكدة لكن المالكية يسمونها الرغيبة، وفي هذا",
        "video_link": null
      },
      {
        "ts": "10:49",
        "sec": 649,
        "text": "كلام طويل لا ليس محل الدخول فيه. ا الفجر؛",
        "video_link": null
      },
      {
        "ts": "10:58",
        "sec": 658,
        "text": "ركعتان رغَّب فيهما النبي صلى الله عليه وسلم كثيراً وحثَّ",
        "video_link": null
      },
      {
        "ts": "11:05",
        "sec": 665,
        "text": "عليهما؛ فقال صلى الله عليه وسلم: \"رَكْعَتَا الْفَجْرِ خَيْرٌ مِنَ الدُّنْيَا وَمَا",
        "video_link": null
      },
      {
        "ts": "11:15",
        "sec": 675,
        "text": "فِيهَا\" (ركعتا الفجر خير من الدنيا وما",
        "video_link": null
      },
      {
        "ts": "11:22",
        "sec": 682,
        "text": "فيها). ويقول صلى الله صلى الله عليه وسلم -يُروى عنه أنه قال في الحديث والحديث متكلم",
        "video_link": null
      },
      {
        "ts": "11:30",
        "sec": 690,
        "text": "في سنده، قال-: \"لَا تَدَعُوهُمَا وَلَوْ طَرَدَتْكُمُ الْخَيْلُ\". وتقول تقول عائشة أم المؤمنين رضي",
        "video_link": null
      },
      {
        "ts": "11:39",
        "sec": 699,
        "text": "الله عنها وهي تحكي عن النبي صلى الله عليه وسلم: \"لَمْ يَكُنْ عَلَى شَيْءٍ مِنَ النَّوَافِلِ",
        "video_link": null
      },
      {
        "ts": "11:47",
        "sec": 707,
        "text": "أَشَدَّ تَعَاهُداً مِنْهُ عَلَى رَكْعَتَيِ الْفَجْرِ\"؛ يعني كان يحرص على ركعتي الفجر حرصاً",
        "video_link": null
      },
      {
        "ts": "11:57",
        "sec": 717,
        "text": "شديداً، فرغَّب فيها صلى الله عليه وسلم. ركعتا الفجر تكونان سراً،",
        "video_link": null
      },
      {
        "ts": "12:07",
        "sec": 727,
        "text": "ويقرأ في الركعة الأولى بسورة الإخلاص، وفي الركعة الثانية عفواً؛ في",
        "video_link": null
      },
      {
        "ts": "12:15",
        "sec": 735,
        "text": "الركعة الأولى سورة الكافرون، وفي الركعة الثانية سورة الإخلاص؛ يستحب أن يقرأ المصلي صلاة ركعتي",
        "video_link": null
      },
      {
        "ts": "12:26",
        "sec": 746,
        "text": "الفجر في الركعة الأولى بسورة الكافرون، وفي الركعة الثانية بسورة الإخلاص.",
        "video_link": null
      },
      {
        "ts": "12:36",
        "sec": 756,
        "text": "هذه يعني هذه هذه ركعتا الفجر. بالمناسبة، بعض",
        "video_link": null
      },
      {
        "ts": "12:43",
        "sec": 763,
        "text": "الناس يقع لهم شيء من الخلط بين الصبح والفجر؛ صلاة",
        "video_link": null
      },
      {
        "ts": "12:52",
        "sec": 772,
        "text": "الصبح هي الصلاة المفروضة التي تندرج ضمن الصلوات الخمس",
        "video_link": null
      },
      {
        "ts": "13:00",
        "sec": 780,
        "text": "المفروضة؛ تُسمى صلاة الصبح وتكون جهراً ركعتان",
        "video_link": null
      },
      {
        "ts": "13:08",
        "sec": 788,
        "text": "جهراً، ويصح أن ويُطلق عليها أيضاً فريضة الفجر؛ يُطلق عليها أيضاً فريضة الفجر، فهي",
        "video_link": null
      },
      {
        "ts": "13:16",
        "sec": 796,
        "text": "صلاة الصبح وهي أيضاً فريضة",
        "video_link": null
      },
      {
        "ts": "13:22",
        "sec": 802,
        "text": "الفجر. سنة الفجر هي التي تحدثنا عنها الآن؛ تُصلى",
        "video_link": null
      },
      {
        "ts": "13:29",
        "sec": 809,
        "text": "ركعتان سراً، تُسمى سنة الفجر أو رغيبة الفجر كما يسميها المالكية؛",
        "video_link": null
      },
      {
        "ts": "13:39",
        "sec": 819,
        "text": "رغيبة الفجر. ومثلاً عندنا في المغرب مثلاً الناس تفرّق يقول الصبح والفجر؛ الصبح",
        "video_link": null
      },
      {
        "ts": "13:47",
        "sec": 827,
        "text": "يقصدون به الفرض، ولما تيقولوا الفجر والفجر يقصدون به السنة الرغيبة؛ فـ حتى",
        "video_link": null
      },
      {
        "ts": "13:57",
        "sec": 837,
        "text": "تفريق طبعاً سائغ طبعاً عادي لغةً وعرفاً وشرعاً، فتقول لك الصبح وهذا الفجر؛ أو هذيك",
        "video_link": null
      },
      {
        "ts": "14:04",
        "sec": 844,
        "text": "فريضة الصبح هذه رغيبة الفجر، أو تقول عن الأولى فريضة الفجر وهذه سنة الفجر؛ تلك فريضة الفجر وهذه السنة سنة",
        "video_link": null
      },
      {
        "ts": "14:13",
        "sec": 853,
        "text": "الفجر. طيب قال رحمه الله: \"فَجْرٌ رَغِيبَةٌ\"، ثم قال: \"وَتُقْضَى لِلزَّوَالْ\"؛ وتقضى",
        "video_link": null
      },
      {
        "ts": "14:22",
        "sec": 862,
        "text": "للزوال؛ تقضى للزوال يعني أن وقت قضائها يمتد إلى الزوال.",
        "video_link": null
      },
      {
        "ts": "14:29",
        "sec": 869,
        "text": "إنسان ا استيقظ متأخراً مثلاً، لم",
        "video_link": null
      },
      {
        "ts": "14:36",
        "sec": 876,
        "text": "يبقَ على طلوع الشمس وقت كافٍ يسعه لكي يؤدي ركعتي رغيبة الفجر",
        "video_link": null
      },
      {
        "ts": "14:45",
        "sec": 885,
        "text": "والفريضة وفريضة الصبح؛ فماذا يفعل؟ يصلي الفريضة فريضة الصبح حتى يؤديها داخل",
        "video_link": null
      },
      {
        "ts": "14:54",
        "sec": 894,
        "text": "الوقت، الرغيبة ستقضى؛ يقضيها بعد شروق الشمس. متى ينتهي وقت",
        "video_link": null
      },
      {
        "ts": "15:02",
        "sec": 902,
        "text": "القضاء؟ ينتهي بزوال الشمس؛ قال: \"فَجْرٌ رَغِيبَةٌ وَتُقْضَى لِلزَّوَالْ\".",
        "video_link": null
      },
      {
        "ts": "15:09",
        "sec": 909,
        "text": "الزوال؛ لو إنسان مثلاً ا ذهب إلى المسجد",
        "video_link": null
      },
      {
        "ts": "15:18",
        "sec": 918,
        "text": "ليصلي، فوجد الإمام قائماً يصلي صلاة الصبح؛ صلى يدخل معه طبعاً، فيصلي يصلي صلاة",
        "video_link": null
      },
      {
        "ts": "15:30",
        "sec": 930,
        "text": "الصبح؛ بقي عليه أن يقضي رغيبة الفجر. المالكية رحمه الله",
        "video_link": null
      },
      {
        "ts": "15:37",
        "sec": 937,
        "text": "عليهم في المشهور يختاروا يختارون أنه أنه",
        "video_link": null
      },
      {
        "ts": "15:44",
        "sec": 944,
        "text": "يقضيها بعد طلوع الشمس، لأن قبل لأنه قبل طلوع الشمس قالوا هذا وقت",
        "video_link": null
      },
      {
        "ts": "15:53",
        "sec": 953,
        "text": "كراهة، وهو حقاً وقت كراهة؛ فقالوا لا يقضيها في ذلك الوقت، وإنما يقضيها بعد شروق",
        "video_link": null
      },
      {
        "ts": "16:02",
        "sec": 962,
        "text": "الشمس. و وله ووقت قضائها ممتد إلى الزوال، إلى",
        "video_link": null
      },
      {
        "ts": "16:09",
        "sec": 969,
        "text": "الزوال. وثم تعين آخر يقول إنه يجوز أن يقضيها بعد أن بعد أن يكون بعد أن ينتهي من صلاة",
        "video_link": null
      },
      {
        "ts": "16:17",
        "sec": 977,
        "text": "الصبح؛ صلى صلاة الصبح",
        "video_link": null
      },
      {
        "ts": "16:25",
        "sec": 985,
        "text": "وسلم، يجوز أن يصلي صلاة أن يقضي رغيبة الفجر؛ وقد ثبت",
        "video_link": null
      },
      {
        "ts": "16:31",
        "sec": 991,
        "text": "هذا في السنة التقريرية لرسول الله صلى الله عليه وسلم. فإنه مرة صلى بالمسلمين صلاة",
        "video_link": null
      },
      {
        "ts": "16:41",
        "sec": 1001,
        "text": "الصبح، كان خارجاً من المسجد فوجد رجلاً يصلي؛ فقال له صلى الله عليه وسلم: \"أَصَلَاةُ الصُّبْحِ",
        "video_link": null
      },
      {
        "ts": "16:48",
        "sec": 1008,
        "text": "أَرْبَعاً؟ أَصَلَاةُ الصُّبْحِ أَرْبَعاً؟\" (أي تريد أن تصلي صلاة الصبح أربع ركعات)؛ فقال الرجل: \"يا رسول الله، هذه يعني",
        "video_link": null
      },
      {
        "ts": "16:56",
        "sec": 1016,
        "text": "الفجر أقضيها\" أو كما قال؛ فسكت صلى الله عليه وسلم وتركه، هذه تُسمى السنة التقريرية؛",
        "video_link": null
      },
      {
        "ts": "17:02",
        "sec": 1022,
        "text": "أقرّه صلى الله عليه وسلم على ذلك. وثبت عنه صلى الله صلى الله عليه وسلم أيضاً ا قضاء",
        "video_link": null
      },
      {
        "ts": "17:10",
        "sec": 1030,
        "text": "أن الرغيبة تقضى بعد شروق الشمس، فثبت عنه الأمران؛",
        "video_link": null
      },
      {
        "ts": "17:18",
        "sec": 1038,
        "text": "فنقول قضاء رغيبة الفجر يصح أن يكون بعد صلاة الصبح وقبل شروق الشمس، ويصح أن يكون",
        "video_link": null
      },
      {
        "ts": "17:26",
        "sec": 1046,
        "text": "بعد شروق الشمس. نعم قبل شروق الشمس وقت كراهة، لكن بنص سنة رسول الله صلى الله",
        "video_link": null
      },
      {
        "ts": "17:34",
        "sec": 1054,
        "text": "عليه وسلم استثناء؛ وهذا قد يكون مفيداً وفيه تيسير على بعض الناس. مثلاً بعض الناس",
        "video_link": null
      },
      {
        "ts": "17:41",
        "sec": 1061,
        "text": "مثلاً يكون متبوعاً بالذهاب إلى بعض الأسواق أو بالعمل، فإذا إذا أشرقت الشمس لا يتيسر",
        "video_link": null
      },
      {
        "ts": "17:49",
        "sec": 1069,
        "text": "له أن مكان يصلي فيه أو وقت يصلي فيه رغيبة الفجر؛ فيأخذ بهذا التيسير ويمكنه أن",
        "video_link": null
      },
      {
        "ts": "17:59",
        "sec": 1079,
        "text": "يقضِيها بعد صلاة الصبح. قال رحمه الله تعالى: \"فَجْرٌ رَغِيبَةٌ\"؛",
        "video_link": null
      },
      {
        "ts": "18:06",
        "sec": 1086,
        "text": "\"وَتُقْضَى لِلزَّوَالْ\". لما ذكر لك قضاء رغيبة الفجر، استطرد",
        "video_link": null
      },
      {
        "ts": "18:13",
        "sec": 1093,
        "text": "ليتحدث عن ا قضاء الصلوات المفروضات فقال قال: \"وَالْفَرْضُ يُقْضَى أَبَداً وَبِالتَّوَالْ\"؛",
        "video_link": null
      },
      {
        "ts": "18:21",
        "sec": 1101,
        "text": "الفرض يقضى أبداً. إنسان نسي صلاة",
        "video_link": null
      },
      {
        "ts": "18:30",
        "sec": 1110,
        "text": "مفروضة نسيها، يجب عليه أن يقضيها؛ قال النبي صلى",
        "video_link": null
      },
      {
        "ts": "18:37",
        "sec": 1117,
        "text": "الله عليه وسلم: \"مَنْ نَسِيَ صَلَاةً فَلْيُصَلِّهَا إِذَا ذَكَرَهَا، لَا كَفَّارَةَ لَهَا إِلَّا",
        "video_link": null
      },
      {
        "ts": "18:46",
        "sec": 1126,
        "text": "ذَلِكَ\" (من نسي صلاة فليصلها إذا ذكرها لا كفارة لها إلا",
        "video_link": null
      },
      {
        "ts": "18:55",
        "sec": 1135,
        "text": "ذلك، لا كفارة لها إلا ذلك). وفي الواقع لما قال \"وَالْفَرْضُ يُقْضَى",
        "video_link": null
      },
      {
        "ts": "19:04",
        "sec": 1144,
        "text": "أَبَداً\"، فسواء نسي هته الصلاة، أو تهاون بها، أو سها",
        "video_link": null
      },
      {
        "ts": "19:12",
        "sec": 1152,
        "text": "عنها، أو نام عنها؛ مهما كان السبب يقضيها.",
        "video_link": null
      },
      {
        "ts": "19:22",
        "sec": 1162,
        "text": "ا قال: \"وَالْفَرْضُ يُقْضَى أَبَداً وَبِالتَّوَالْ\"؛ بالتوال أي بالتوالي، أي",
        "video_link": null
      },
      {
        "ts": "19:30",
        "sec": 1170,
        "text": "بالترتيب، بالترتيب. مثلاً إنسان طيب نفترض أن إنساناً مثلاً ا جاء قبل",
        "video_link": null
      },
      {
        "ts": "19:41",
        "sec": 1181,
        "text": "الظهر منهكاً من عمله، قال: \"سأنام قليلاً ثم أقوم حين يؤذن الظهر",
        "video_link": null
      },
      {
        "ts": "19:48",
        "sec": 1188,
        "text": "فأصلي\"، فإذا به نام نومة عميقة فلم يستيقظ إلا مع أذان",
        "video_link": null
      },
      {
        "ts": "19:57",
        "sec": 1197,
        "text": "العشاء؛ ففاتته الظهر والعصر والمغرب وأذن",
        "video_link": null
      },
      {
        "ts": "20:05",
        "sec": 1205,
        "text": "العشاء، ثم استيقظ؛ ماذا عليه؟ عليه أن يقضي صلاة",
        "video_link": null
      },
      {
        "ts": "20:12",
        "sec": 1212,
        "text": "الظهر، ثم بعدها العصر، ثم بعدها المغرب، ثم يصلي صلاة العشاء؛ \"وَالْفَرْضُ يُقْضَى أَبَداً",
        "video_link": null
      },
      {
        "ts": "20:19",
        "sec": 1219,
        "text": "وَبِالتَّوَالْ\" أي بالترتيب، لأنها شُرعت وفُرضت مرتبة فيجب",
        "video_link": null
      },
      {
        "ts": "20:26",
        "sec": 1226,
        "text": "أداؤها مرتبة؛ لذا قال: \"وَالْفَرْضُ يُقْضَى أَبَداً *** وَبِالتَّوَالْ\". ثم قال رحمه الله: \"نُدِبَ نَفْلٌ مُطْلَقاً وَأُكِّدَتْ *** تَحِيَّةٌ ضُحاً تَرَاوِيحُ تَلَتْ\"",
        "video_link": null
      },
      {
        "ts": "20:51",
        "sec": 1251,
        "text": "\"نُدِبَ نَفْلٌ مُطْلَقاً\"؛ أي يُشرع ويستحب أن يتنفل الإنسان تنفلاً مطلقاً، نفل مطلقاً؛ هذا ليس يعني نفل ليس له",
        "video_link": null
      },
      {
        "ts": "21:00",
        "sec": 1260,
        "text": "اسم يخصه وليس له وقت يخصه، فقط تترك أوقات النهي (أوقات الكراهة)؛",
        "video_link": null
      },
      {
        "ts": "21:09",
        "sec": 1269,
        "text": "والتي هي بعد صلاة بعد صلاة الصبح حتى تطلع الشمس،",
        "video_link": null
      },
      {
        "ts": "21:16",
        "sec": 1276,
        "text": "وبعد صلاة العصر حتى تغرب الشمس، ووقت حين يقوم قائم الظهيرة قبيل الزوال؛ هذه أوقات كراهة",
        "video_link": null
      },
      {
        "ts": "21:23",
        "sec": 1283,
        "text": "لا تصلي فيها النوافل. لكن غير ذلك، مثلاً",
        "video_link": null
      },
      {
        "ts": "21:29",
        "sec": 1289,
        "text": "إنسان مثلاً دعـ صلى الظهر، كان جالساً قال: \"أقوم أصلي لله عز وجل مائة ركعة\"، لك ذلك.",
        "video_link": null
      },
      {
        "ts": "21:39",
        "sec": 1299,
        "text": "إنسان صلى صلاة المغرب قال: \"سأقوم أصلي خمسين ركعة لله عز وجل بين المغرب والعشاء\"، ما",
        "video_link": null
      },
      {
        "ts": "21:45",
        "sec": 1305,
        "text": "كذلك؛ نفل مطلق، نفل مطلق هذا. وبالمناسبة بين قوسين أنبه",
        "video_link": null
      },
      {
        "ts": "21:55",
        "sec": 1315,
        "text": "إخواني وأخواتي إلى أهمية هذه النوافل، أهمية النوافل؛ النوافل بارك الله",
        "video_link": null
      },
      {
        "ts": "22:02",
        "sec": 1322,
        "text": "فيكم مهمة جداً لجبر النقص الذي يحصل في الصلوات المفروضات.",
        "video_link": null
      },
      {
        "ts": "22:09",
        "sec": 1329,
        "text": "ا الصلوات الصلاة بالأخص نوافل الصلاة، الصلاة هذه عمود الدين وأول ما يحاسب",
        "video_link": null
      },
      {
        "ts": "22:18",
        "sec": 1338,
        "text": "العبد يوم القيامة، كما قال صلى الله عليه وسلم: \"إِنَّ أَوَّلَ مَا يُحَاسَبُ بِهِ الْعَبْدُ يَوْمَ الْقِيَامَةِ مِنْ عَمَلِهِ صَلَاتُهُ؛ فَإِنْ صَلُحَتْ صَلُحَ سَائِرُ عَمَلِهِ، وَإِنْ فَسَدَتْ فَسَدَ سَائِرُ عَمَلِهِ\". الإنسان ضعيف فربما ينتقص من",
        "video_link": null
      },
      {
        "ts": "22:29",
        "sec": 1349,
        "text": "صلواته شيئاً، فتُكمل له الصلوات المفروضات من",
        "video_link": null
      },
      {
        "ts": "22:37",
        "sec": 1357,
        "text": "تطوعاته؛ أخبر النبي صلى الله عليه وسلم أن الإنسان يحاسب على صلاته يوم القيامة، فإن",
        "video_link": null
      },
      {
        "ts": "22:46",
        "sec": 1366,
        "text": "كانت تامة كُتبت تامة، فإن كانت ناقصة يقول الله عز وجل لملائكته: \"انْظُرُوا",
        "video_link": null
      },
      {
        "ts": "22:55",
        "sec": 1375,
        "text": "هَلْ لِعَبْدِي مِنْ تَطَوُّعٍ\" (انظروا هل لعبدي من",
        "video_link": null
      },
      {
        "ts": "23:02",
        "sec": 1382,
        "text": "تطوع؟) فُتتم له صلاته من خلال تطوعه؛ فالنوافل",
        "video_link": null
      },
      {
        "ts": "23:08",
        "sec": 1388,
        "text": "والتطوعات من من المهم أن يكثر منها الإنسان، لا بعض الناس تجده فقط يكتفي",
        "video_link": null
      },
      {
        "ts": "23:16",
        "sec": 1396,
        "text": "بالصلوات المفروضة فقط وهذا خطأ؛ لِمَا؟ أولاً لأنه الإنسان مهما اجتهد",
        "video_link": null
      },
      {
        "ts": "23:26",
        "sec": 1406,
        "text": "لا بد أن يتطرق نقص إلى صلاته بحكم الإنسان ناقص الإنسان فيه نقص، الكمال لله عز وجل؛",
        "video_link": null
      },
      {
        "ts": "23:33",
        "sec": 1413,
        "text": "فلا يغامر الإنسان بنفسه أن يأتي ربه يوم القيامة بصلاة ناقصة فيحتاج أن يكملها يكملها من",
        "video_link": null
      },
      {
        "ts": "23:42",
        "sec": 1422,
        "text": "تطوعاته. ثم لأن ثانياً: النوافل هي السياج الذي يحمي",
        "video_link": null
      },
      {
        "ts": "23:48",
        "sec": 1428,
        "text": "الفرائض؛ فالإنسان الذي يتهاون بالنوافل لا يلبث أن يترك الفرائض أو يتهاون بها على",
        "video_link": null
      },
      {
        "ts": "23:56",
        "sec": 1436,
        "text": "أقل تقدير، أما الذي يأتي النوافل ويحافظ عليها يبعد بإذن الله عز وجل أن يترك",
        "video_link": null
      },
      {
        "ts": "24:04",
        "sec": 1444,
        "text": "الفرائض؛ فلذلك النوافل تكمل الفرائض فلا يليق",
        "video_link": null
      },
      {
        "ts": "24:11",
        "sec": 1451,
        "text": "بالمسلم والمسلمة وخصوصاً بطلبة العلم وطالباته، لا يليق بهم أن يتركوا",
        "video_link": null
      },
      {
        "ts": "24:21",
        "sec": 1461,
        "text": "النوافل وأن يقتصروا على الفرائض فقط؛ فطالب العلم ينبغي أن يجتهد في التقرب من",
        "video_link": null
      },
      {
        "ts": "24:28",
        "sec": 1468,
        "text": "ربه عز وجل أكثر من غيره، وأن يجتهد في تزكية نفسه أكثر من غيره فهو قد",
        "video_link": null
      },
      {
        "ts": "24:37",
        "sec": 1477,
        "text": "تعلم وعلم ما عليه فعله فهو يصحح الفرائض فيؤديها كما ينبغي ويجتهد",
        "video_link": null
      },
      {
        "ts": "24:46",
        "sec": 1486,
        "text": "في النوافل تقرباً إلى ربه عز وجل، فلا يكون كعامة الناس الذين لم يتعلموا ولم يدرَسوا فقهاً ولا حديثاً ولا أصولاً ولا لغةً ولا أي",
        "video_link": null
      },
      {
        "ts": "24:54",
        "sec": 1494,
        "text": "شيء. أسأل الله ربنا أن يعيننا وأن يوفقنا. اللهم صل وسلم وبارك على",
        "video_link": null
      },
      {
        "ts": "25:03",
        "sec": 1503,
        "text": "الحبيب. قال رحمه الله: \"نُدِبَ نَفْلٌ مُطْلَقاً وَأُكِّدَتْ\"؛ أي هناك نوافل",
        "video_link": null
      },
      {
        "ts": "25:12",
        "sec": 1512,
        "text": "مؤكدة هو قال أكدت؛ أي النفل السنة المؤكدة مرت معنا، لكن قال: \"وَأُكِّدَتْ",
        "video_link": null
      },
      {
        "ts": "25:20",
        "sec": 1520,
        "text": "تَحِيَّةٌ\"؛ التحية المقصود تحية المسجد، تحية المسجد. يقول النبي صلى الله عليه وسلم:",
        "video_link": null
      },
      {
        "ts": "25:27",
        "sec": 1527,
        "text": "\"إِذَا دَخَلَ أَحَدُكُمُ الْمَسْجِدَ فَلَا يَجْلِسْ حَتَّىٰ يَرْكَعَ",
        "video_link": null
      },
      {
        "ts": "25:34",
        "sec": 1534,
        "text": "رَكْعَتَيْنِ\" (إذا جاء أحدكم المسجد فلا يجلس حتى يركع",
        "video_link": null
      },
      {
        "ts": "25:39",
        "sec": 1539,
        "text": "ركعتين)؛ سيدخل المسجد يصلي ركعتي تحية المسجد. طبعاً بالمناسبة قد يقول قائل: \"طيب",
        "video_link": null
      },
      {
        "ts": "25:48",
        "sec": 1548,
        "text": "مثلاً الأمر برغيبة الفجر، الأمر بتحية المسجد، العيد إلى اخره؛ لِمَ لِمَ اعتبرها",
        "video_link": null
      },
      {
        "ts": "25:55",
        "sec": 1555,
        "text": "العلماء من السنن ومن النوافل ولم يعتبروها من الواجبات؟\" لم يعتبروها من الواجبات للحديث الذي ذكرناه في المجلس الماضي حديث",
        "video_link": null
      },
      {
        "ts": "26:03",
        "sec": 1563,
        "text": "الأعرابي الذي جاء إلى رسول الله صلى الله عليه وسلم عن الإسلام، فقال عليه الصلاة والسلام فقال له عليه الصلاة والسلام: \"خَمْسُ",
        "video_link": null
      },
      {
        "ts": "26:10",
        "sec": 1570,
        "text": "صَلَوَاتٍ\" (خمس صلوات في يوم الليلة)؛ قال: \"هل عليَّ غيرها؟\" قال: \"لَا، إِلَّا أَنْ تَطَّوَّعَ\"؛ فهذا يسميه",
        "video_link": null
      },
      {
        "ts": "26:18",
        "sec": 1578,
        "text": "العلماء القرينة الصارفة عن الوجوب إلى الاستحباب. رأيتم لعلكم رأيتم في الأصول أن",
        "video_link": null
      },
      {
        "ts": "26:27",
        "sec": 1587,
        "text": "الأمر يفيد الوجوب؛ فلما يقول صلى الله عليه وسلم \"لا يجلس حتى يركع ركعتين\" هذا أمر،",
        "video_link": null
      },
      {
        "ts": "26:33",
        "sec": 1593,
        "text": "أمر بأداء ركعتي تحية المسجد. لما يقول صلى الله عليه وسلم: \"يَا أَهْلَ",
        "video_link": null
      },
      {
        "ts": "26:40",
        "sec": 1600,
        "text": "الْقُرْآنِ أَوْتِرُوا\" (أوتروا يا أهل القرآن أوتروا)، هذا أمر؛ فما الذي صرف مثل هذه",
        "video_link": null
      },
      {
        "ts": "26:47",
        "sec": 1607,
        "text": "الأوامر والأصل في الأمر أنه في الوجوب؟ ما الذي صرف هذه الأوامر عن الوجوب إلى الاستحباب؟",
        "video_link": null
      },
      {
        "ts": "26:54",
        "sec": 1614,
        "text": "القرينة؛ ما هي القرينة الصارفة؟ هو حديث الأعرابي الذي ذكرناه آنفاً. إذاً تحية المسجد",
        "video_link": null
      },
      {
        "ts": "27:04",
        "sec": 1624,
        "text": "هذه هادي من مما يؤكد من من النوافل المؤكدة في حق المسلم؛",
        "video_link": null
      },
      {
        "ts": "27:11",
        "sec": 1631,
        "text": "إذا دخل المسجد أن لا يجلس حتى يركع ركعتين تحية",
        "video_link": null
      },
      {
        "ts": "27:17",
        "sec": 1637,
        "text": "المسجد. قال: \"ضُحاً\"؛ صلاة الضحى، صلاة الضحى، صلاة الضحى التي وصفها صلى الله",
        "video_link": null
      },
      {
        "ts": "27:26",
        "sec": 1646,
        "text": "عليه وسلم بأنها صلاة الأوابين؛ صلاة الأوابين أي الراجعين إلى الله عز وجل. قال",
        "video_link": null
      },
      {
        "ts": "27:33",
        "sec": 1653,
        "text": "صلى الله عليه وسلم: \"يُصْبِحُ عَلَى كُلِّ سُلَامَى مِنْ أَحَدِكُمْ صَدَقَةٌ\"؛ كُل سلامى؛ أي كل مفصل",
        "video_link": null
      },
      {
        "ts": "27:43",
        "sec": 1663,
        "text": "صدقة؛ قال صلى الله عليه وسلم: \"فَكُلُّ تَسْبِيحَةٍ صَدَقَةٌ، وَكُلُّ تَحْمِيدَةٍ صَدَقَةٌ، وَكُلُّ",
        "video_link": null
      },
      {
        "ts": "27:50",
        "sec": 1670,
        "text": "تَهْلِيلَةٍ صَدَقَةٌ، وَكُلُّ تَكْبِيرَةٍ صَدَقَةٌ، وَأَمْرٌ بِالْمَعْرُوفِ صَدَقَةٌ، وَنَهْيٌ عَنِ الْمُنْكَرِ صَدَقَةٌ، وَتُعِينُ الرَّجُلَ فِي دَابَّتِهِ فَتَحْمِلُهُ عَلَيْهَا أَوْ تَرْفَعُ لَهُ عَلَيْهَا",
        "video_link": null
      },
      {
        "ts": "27:59",
        "sec": 1679,
        "text": "مَتَاعَهُ صَدَقَةٌ\" إلى أن قال صلى الله عليه وسلم: \"وَيُجْزِئُ مِنْ ذَلِكَ كُلِّهِ رَكْعَتَانِ يَرْكَعُهُمَا مِنَ",
        "video_link": null
      },
      {
        "ts": "28:06",
        "sec": 1686,
        "text": "الضُّحَى\". الإنسان في 360 مفصلاً يشهد الإنسان أن أن أن يتصدق على كل",
        "video_link": null
      },
      {
        "ts": "28:13",
        "sec": 1693,
        "text": "مفصل، فما شاء الله 360 صدقة كل يوم أمر ليس بالهين؛ ما شاء الله يعني من وفقه الله",
        "video_link": null
      },
      {
        "ts": "28:19",
        "sec": 1699,
        "text": "لهذا فهو خير كثير، يجزئك من كل هذا ركعتان تركعهما من الضحى؛ فركعتان تركعهما من الضحى",
        "video_link": null
      },
      {
        "ts": "28:27",
        "sec": 1707,
        "text": "تعدلان ا 360 صدقة. يقول أبو هريرة رضي الله عنه: \"أَوْصَانِي خَلِيلِي",
        "video_link": null
      },
      {
        "ts": "28:35",
        "sec": 1715,
        "text": "صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ بِثَلَاثٍ لَا أَدَعُهُنَّ حَتَّى أَمُوتَ\" ا قال: \"صَوْمِ ثَلَاثَةِ أَيَّامٍ مِنْ كُلِّ شَهْرٍ، وَرَكْعَتَيِ الضُّحَى، وَأَنْ أُوتِرَ قَبْلَ أَنْ أَنَامَ\"؛ أوصاه النبي صلى الله عليه وسلم أن",
        "video_link": null
      },
      {
        "ts": "28:51",
        "sec": 1731,
        "text": "يركع ركعتين من الضحى، فصلاة الضحى من النوافل المؤكدة. وقتها أيضاً من",
        "video_link": null
      },
      {
        "ts": "29:00",
        "sec": 1740,
        "text": "حِلِّ النافلة، من من وقت تحل النافلة إلى إلى الزوال.",
        "video_link": null
      },
      {
        "ts": "29:07",
        "sec": 1747,
        "text": "\"ضُحاً\" ا قال: \"تَرَاوِيحُ تَلَتْ\"؛ صلاة التراويح أيضاً في رمضان،",
        "video_link": null
      },
      {
        "ts": "29:16",
        "sec": 1756,
        "text": "التراويح؛ صلاة التراويح أيضاً من النوافل المؤكدة. سبحان الله مع الأسف في هذا الزمن",
        "video_link": null
      },
      {
        "ts": "29:24",
        "sec": 1764,
        "text": "الذي نسمع فيه تشغيباً على الأحكام الشرعية، نسمع بعض الناس يزهدون يزهدون يريدون",
        "video_link": null
      },
      {
        "ts": "29:31",
        "sec": 1771,
        "text": "تزهيد المسلمين في التراويح؛ فيقولون يقولون لهم إن التراويح ليست مشروعة ولم يُصَلِّ",
        "video_link": null
      },
      {
        "ts": "29:38",
        "sec": 1778,
        "text": "ولم يصلِّ لم يصلِّها النبي صلى الله عليه وسلم ونحـ ونحو ذلك من هذا الكلام، وهذا خطأ.",
        "video_link": null
      },
      {
        "ts": "29:47",
        "sec": 1787,
        "text": "صلاة التراويح صلاها رسول الله صلى الله عليه وسلم؛ أولاً حث عليها في قوله: \"مَنْ قَامَ مَعَ الْإِمَامِ",
        "video_link": null
      },
      {
        "ts": "29:55",
        "sec": 1795,
        "text": "حَتَّى يَنْصَرِفَ كُتِبَ لَهُ قِيَامُ لَيْلَةٍ\". ثم صلاها ليلتين أو",
        "video_link": null
      },
      {
        "ts": "30:02",
        "sec": 1802,
        "text": "ثلاثاً النبي صلى الله عليه وسلم؛ مرة خرج إلى المسجد فصلى (ما هي التراويح؟ هي قيام الليل في",
        "video_link": null
      },
      {
        "ts": "30:08",
        "sec": 1808,
        "text": "رمضان تُسمى التراويح، سُميت التراويح لأن الناس تستريح بين كل ركعتين، كان الناس",
        "video_link": null
      },
      {
        "ts": "30:16",
        "sec": 1816,
        "text": "تطيل القيام كانوا يطيلون القيام فكانوا يحتاجون إلى أن يستريحوا بين كل ركعتين). فخرج صلى الله عليه وسلم إلى المسجد فصلى",
        "video_link": null
      },
      {
        "ts": "30:26",
        "sec": 1826,
        "text": "ركعتين، كان بعض الناس جالسين في المسجد فـ رأوا رسول الله يصلي فقاموا صلوا معه؛ التراويح تلك",
        "video_link": null
      },
      {
        "ts": "30:33",
        "sec": 1833,
        "text": "الليلة. طبعاً لم يصليها بعد العشاء مباشرة، ما كانوا يصلون في الأول في زمن الرسول عليه الصلاة والسلام ما كانوا يصلون التراويح بعد صلاة العشاء مباشرة. في",
        "video_link": null
      },
      {
        "ts": "30:42",
        "sec": 1842,
        "text": "الركعة الثانية خرج صلى الله عليه وسلم فصلى في المسجد، فصلى معه من كان حاضراً",
        "video_link": null
      },
      {
        "ts": "30:49",
        "sec": 1849,
        "text": "في المسجد؛ لأن أولئك الذين صلوا الليلة الأولى أخبروا غيرهم أن كنا في المسجد وخرج رسول الله صلى الله عليه وسلم فصلى",
        "video_link": null
      },
      {
        "ts": "30:58",
        "sec": 1858,
        "text": "فصلينا. فجاء بعض الناس في الليلة الثالثة صلى خرج فصلى، ازداد",
        "video_link": null
      },
      {
        "ts": "31:06",
        "sec": 1866,
        "text": "العدد؛ فالليلة الرابعة امتلأ المسجد عن آخره بالناس؛ وصل الخبر أن الرسول صلى الله",
        "video_link": null
      },
      {
        "ts": "31:14",
        "sec": 1874,
        "text": "عليه وسلم صلى التراويح يعني صلى التراويح في المسجد الليلة الأولى والثانية والثالثة فامتلأ المسجد عن آخره، كلهم يريد",
        "video_link": null
      },
      {
        "ts": "31:22",
        "sec": 1882,
        "text": "أن يصلي التراويح خلف رسول الله صلى الله عليه وسلم؛ ينتظرون خروجه ليصل ليصلوا",
        "video_link": null
      },
      {
        "ts": "31:29",
        "sec": 1889,
        "text": "خلفه، فلم يخرج صلى الله عليه وسلم؛ لم يخرج وبقي الناس إلى الصبح. لما خرج صلى الله ثم صلى الصبح، كلَّمهم",
        "video_link": null
      },
      {
        "ts": "31:39",
        "sec": 1899,
        "text": "وقال لهم: \"أَمَّا بَعْدُ، فَإِنَّهُ لَمْ يَخْفَ عَلَيَّ مَكَانُكُمْ الْبَارِحَةَ\" يعني يقول لهم أنا علمت بأن علمت بوجودكم في المسجد وأنكم",
        "video_link": null
      },
      {
        "ts": "31:48",
        "sec": 1908,
        "text": "تنتظرونني؛ قال: \"وَلَكِنِّي خَشِيتُ أَنْ تُفْرَضَ عَلَيْكُمْ\" صلى الله عليه وسلم (يعني أنه لم",
        "video_link": null
      },
      {
        "ts": "31:55",
        "sec": 1915,
        "text": "يخرج ليصلي بالمسلمين خشية أن تصبح التراويح مفروضة). بالمناسبة، ومن هنا نفهم",
        "video_link": null
      },
      {
        "ts": "32:02",
        "sec": 1922,
        "text": "أن صلاة التراويح ليست مفروضة، فخشي أن تُفرض التراويح فلم يصلِّها",
        "video_link": null
      },
      {
        "ts": "32:10",
        "sec": 1930,
        "text": "بالمسلمين. فاستمر الحال على ما كان عليه؛ يصلي الناس ا أفراداً أو جماعات فيما بينهم،",
        "video_link": null
      },
      {
        "ts": "32:18",
        "sec": 1938,
        "text": "مثلاً ربما يصلي الواحد التراويح بمفرده، ربما يصلي يصلي ثلاثة، هناك خمسة يصلون لوحدهم،",
        "video_link": null
      },
      {
        "ts": "32:25",
        "sec": 1945,
        "text": "هناك لا يصلون مجتمعين؛ إلى أن انتقل صلى الله عليه وسلم إلى الرفيق",
        "video_link": null
      },
      {
        "ts": "32:35",
        "sec": 1955,
        "text": "الأعلى. ثم جاء بعده أبو بكر الصديق رضي الله عنه وبقي الحال على ما هو",
        "video_link": null
      },
      {
        "ts": "32:41",
        "sec": 1961,
        "text": "عليه، ثم جاءت خلافة أمير المؤمنين عمر بن الخطاب رضي الله عنه. مرة خرج عمر بن الخطاب رضي الله",
        "video_link": null
      },
      {
        "ts": "32:50",
        "sec": 1970,
        "text": "عنه فرأى الناس متفرقين ا يصلون التراويح متفرقين؛ ثلاثة",
        "video_link": null
      },
      {
        "ts": "32:57",
        "sec": 1977,
        "text": "هنا، خمسة هناك، واحد بمفرده هناك؛ فقال قال: \"لو جمعتُ هؤلاء على إمام واحد بدل أن يصلوا",
        "video_link": null
      },
      {
        "ts": "33:03",
        "sec": 1983,
        "text": "متفرقين اجمعهم على إمام واحد يصلي بهم\"؛ فجمعهم على إمام",
        "video_link": null
      },
      {
        "ts": "33:11",
        "sec": 1991,
        "text": "واحد، فمنه من ساعتها بدأ المسلمون يصلون التراويح في المسجد خلف إمام",
        "video_link": null
      },
      {
        "ts": "33:19",
        "sec": 1999,
        "text": "واحد. هل أتى عمر ببدعة بهذا بفعل هذا؟ لا. ولما تحدث بعض الناس في هذا، قال عمر رضي",
        "video_link": null
      },
      {
        "ts": "33:29",
        "sec": 2009,
        "text": "الله عنه: \"نِعْمَتِ الْبِدْعَةُ هَذِهِ\"؛ لما قال له \"نعمت البدعة هذه\" هو لا يقصد البدعة الشرعية، وإنما يقصد البدعة اللغوية؛ وإلا",
        "video_link": null
      },
      {
        "ts": "33:36",
        "sec": 2016,
        "text": "فليس بدعة شرعية، فالبدعة فكل البدعة بمفهومها الشرعي: \"كُلُّ بِدْعَةٍ ضَلَالَةٌ\".",
        "video_link": null
      },
      {
        "ts": "33:43",
        "sec": 2023,
        "text": "لكن يقصد بدعة لغوية؛ لماذا ليست بدعة شرعية؟ لأن النبي صلى الله عليه وسلم صلاها، صلى النبي صلى الله عليه وسلم بالناس وهو",
        "video_link": null
      },
      {
        "ts": "33:51",
        "sec": 2031,
        "text": "إمام واحد وهو صلى في المسجد، صلى بمن كان حاضراً في المسجد وهو إمام واحد. والنبي النبي صلى الله عليه وسلم",
        "video_link": null
      },
      {
        "ts": "34:00",
        "sec": 2040,
        "text": "إنما تركها خشية أن تُفرض؛ والقاعدة عند العلماء يقول الأصوليون: \"العِلَّةُ تَدُورُ مَعَ",
        "video_link": null
      },
      {
        "ts": "34:07",
        "sec": 2047,
        "text": "الْمَعْلُولِ وُجُوداً وَعَدَماً\" (العله تدور مع المعلول وجودا وعدما). طيب الرسول صلى الله",
        "video_link": null
      },
      {
        "ts": "34:13",
        "sec": 2053,
        "text": "صلى الله عليه وسلم لما ترك صلاة التراويح جماعة بالناس هو هو كان",
        "video_link": null
      },
      {
        "ts": "34:21",
        "sec": 2061,
        "text": "بعض الناس يصلي، كان بعض الناس يصلونها جماعة لكن متفرقين؛ كما رأينا في كما دل عليه حديث عمر هذا الذي رواه عبد الرحمن",
        "video_link": null
      },
      {
        "ts": "34:29",
        "sec": 2069,
        "text": "بن عبد القاري، لأن عمر رآهم وقال: \"لو جمعتهم على إمام واحد\"؛ لكن إمام واحد يصلي الناس خلفه",
        "video_link": null
      },
      {
        "ts": "34:36",
        "sec": 2076,
        "text": "كما دي فعلها صلى الله عليه وسلم، ثم تركها؛ ما علة تركها؟ علة تركها: خشية أن تُفرض",
        "video_link": null
      },
      {
        "ts": "34:45",
        "sec": 2085,
        "text": "وتصبح مفروضة. هل بعد وفاة رسول الله صلى الله عليه وسلم بقي ما زالت هذه العلة قائمة؟ أبداً هذه العلة",
        "video_link": null
      },
      {
        "ts": "34:54",
        "sec": 2094,
        "text": "زالت، لأن الوحي انقطع بموت رسول الله صلى الله عليه وسلم وانقطع التشريع فزالت العلة؛ العلة تدور مع المعلول وجوداً",
        "video_link": null
      },
      {
        "ts": "35:04",
        "sec": 2104,
        "text": "وعدماً. زالت العلة هي خشية أن تُفرض، فزال المعلول وهو",
        "video_link": null
      },
      {
        "ts": "35:11",
        "sec": 2111,
        "text": "يعني الحاجة إلى ترك الناس يصلونها متفرقين، فجمع عمر رضي الله عنه الناس على",
        "video_link": null
      },
      {
        "ts": "35:18",
        "sec": 2118,
