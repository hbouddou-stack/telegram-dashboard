        "citation": "وَتَفْتَقِرُ المَوْصُولَاتُ كُلُّهَا إِلَى صِلَةٍ مُتَأَخِّرَةٍ عَنْهَا وَعَائِدٍ... وَصِلَتُهُ إِمَّا جُمْلَةٌ أَوْ شِبْهُهَا.",
        "explanation": "يتناول هذا المحور شرح صلة الموصول وأنواعها، مبيناً أنها قد تأتي جملة اسمية أو فعلية، أو شبه جملة كالظرف والجار والمجرور، أو صفة صريحة.",
        "video_link": null,
        "search_text": "صلة الموصول (الجملة وشبه الجملة والصفة الصريحة) وَتَفْتَقِرُ المَوْصُولَاتُ كُلُّهَا إِلَى صِلَةٍ مُتَأَخِّرَةٍ عَنْهَا وَعَائِدٍ... وَصِلَتُهُ إِمَّا جُمْلَةٌ أَوْ شِبْهُهَا. يتناول هذا المحور شرح صلة الموصول وأنواعها، مبيناً أنها قد تأتي جملة اسمية أو فعلية، أو شبه جملة كالظرف والجار والمجرور، أو صفة صريحة."
      },
      {
        "title": "العائد في صلة الموصول وأحكام حذفه",
        "timestamp": "8:17",
        "start_seconds": 497,
        "end_seconds": 728,
        "citation": "وَالْعَائِدُ ضَمِيرٌ مُطَابِقٌ لِلْمَوْصُولِ فِي الْإِفْرَادِ وَالتَّثْنِيَةِ وَالْجَمْعِ وَالتَّذْكِيرِ وَالتَّأْنِيثِ",
        "explanation": "يوضح هذا المحور مفهوم العائد الذي يربط صلة الموصول بالاسم الموصول ووجوب مطابقته له، مع تفصيل حالات حذفه جوازاً إذا كان مرفوعاً أو منصوباً أو مجروراً.",
        "video_link": null,
        "search_text": "العائد في صلة الموصول وأحكام حذفه وَالْعَائِدُ ضَمِيرٌ مُطَابِقٌ لِلْمَوْصُولِ فِي الْإِفْرَادِ وَالتَّثْنِيَةِ وَالْجَمْعِ وَالتَّذْكِيرِ وَالتَّأْنِيثِ يوضح هذا المحور مفهوم العائد الذي يربط صلة الموصول بالاسم الموصول ووجوب مطابقته له، مع تفصيل حالات حذفه جوازاً إذا كان مرفوعاً أو منصوباً أو مجروراً."
      },
      {
        "title": "المعرف بالأداة (أل) وأقسامها العهدية والجنسية",
        "timestamp": "12:08",
        "start_seconds": 728,
        "end_seconds": 1176,
        "citation": "وَأَمَّا الْمُعَرَّفُ بِالْأَدَاةِ فَهُوَ الْمُعَرَّفُ بِالْأَلِفِ وَاللَّامِ، عهدية وجنسية.",
        "explanation": "يشرح هذا الجزء المعرّف بـ 'أل' مبيناً انقسامها إلى عهدية (ذكري، ذهني، حضوري) وجنسية (لتعريف الماهية، واستغراق الأفراد أو خصائصهم)، مع التنبيه على لغة حمير.",
        "video_link": null,
        "search_text": "المعرف بالأداة (أل) وأقسامها العهدية والجنسية وَأَمَّا الْمُعَرَّفُ بِالْأَدَاةِ فَهُوَ الْمُعَرَّفُ بِالْأَلِفِ وَاللَّامِ، عهدية وجنسية. يشرح هذا الجزء المعرّف بـ 'أل' مبيناً انقسامها إلى عهدية (ذكري، ذهني، حضوري) وجنسية (لتعريف الماهية، واستغراق الأفراد أو خصائصهم)، مع التنبيه على لغة حمير."
      }
    ],
    "video_url": null,
    "segments": [
      {
        "ts": "0:00",
        "sec": 0,
        "text": "بسم الله الرحمن الرحيم، الحمد لله رب العالمين، وصلى الله وسلم وبارك على نبينا محمد وعلى",
        "video_link": null
      },
      {
        "ts": "0:07",
        "sec": 7,
        "text": "آله وصحبه والتابعين، ومن تبعهم بإحسان إلى يوم الدين. ذكرنا الاسم الموصول وأنواعه ومجموعة من",
        "video_link": null
      },
      {
        "ts": "0:17",
        "sec": 17,
        "text": "المباحث التي تتعلق به، ثم وصلنا إلى قضية الصلة والعائد. قال: وَتَفْتَقِرُ المَوْصُولَاتُ كُلُّهَا",
        "video_link": null
      },
      {
        "ts": "0:24",
        "sec": 24,
        "text": "إِلَى صِلَةٍ مُتَأَخِّرَةٍ عَنْهَا وَعَائِدٍ، ذكرناه في تعريف الاسم الموصول فقط.",
        "video_link": null
      },
      {
        "ts": "0:39",
        "sec": 39,
        "text": "فإذن قال: وَصِلَتُهُ إِمَّا جُمْلَةٌ أَوْ شِبْهُهَا.",
        "video_link": null
      },
      {
        "ts": "0:48",
        "sec": 48,
        "text": "إذن ما الجملة وما شبه الجملة؟ فالجملة ما تركب من فعل وفاعل، نحو: جَاءَ",
        "video_link": null
      },
      {
        "ts": "0:57",
        "sec": 57,
        "text": "الَّذِي قَامَ أَبُوهُ، جَاءَ: فعل ماضٍ مبني على الفتح، الَّذِي: اسم موصول مبني في محل رفع",
        "video_link": null
      },
      {
        "ts": "1:07",
        "sec": 67,
        "text": "فاعل، قَامَ: فعل ماضٍ مبني على الفتح، أَبُو: فاعل مرفوع",
        "video_link": null
      },
      {
        "ts": "1:14",
        "sec": 74,
        "text": "وعلامة رفعه الواو النائبة عن الضمة لأنه من الأسماء الستة وهو مضاف، الهاء:",
        "video_link": null
      },
      {
        "ts": "1:22",
        "sec": 82,
        "text": "ضمير متصل مبني في محل جر مضاف إليه. وجملة قَامَ أَبُوهُ الجملة الفعلية في، والجملة",
        "video_link": null
      },
      {
        "ts": "1:30",
        "sec": 90,
        "text": "الفعلية صلة الموصول لا محل لها من الإعراب. وقوله تعالى: {الْحَمْدُ لِلَّهِ الَّذِي صَدَقَنَا وَعْدَهُ}، الَّذِي: نعت لاسم الجلالة، وجملة",
        "video_link": null
      },
      {
        "ts": "1:40",
        "sec": 100,
        "text": "صَدَقَنَا وَعْدَهُ: جملة فعلية مكونة من",
        "video_link": null
      },
      {
        "ts": "1:48",
        "sec": 108,
        "text": "شيء آخر غير الفاعل، همم يعني مفعولين اثنين؛ هذه الجملة الفعلية هي صلة الموصول.",
        "video_link": null
      },
      {
        "ts": "1:57",
        "sec": 117,
        "text": "إذن هذه الأولى، أو من مبتدأ وخبر، نحو: جَاءَ الَّذِي أَبُوهُ قَائِمٌ، جَاءَ الَّذِي أعربناها من قبل،",
        "video_link": null
      },
      {
        "ts": "2:06",
        "sec": 126,
        "text": "أَبُو: مبتدأ وهو مضاف، الهاء: مضاف إليه، قَائِمٌ: خبر، وجملة المبتدأ والخبر الجملة",
        "video_link": null
      },
      {
        "ts": "2:14",
        "sec": 134,
        "text": "الاسمية في محل عفواً، الجملة الاسمية صلة الموصول لا محل لها من الإعراب. قضية",
        "video_link": null
      },
      {
        "ts": "2:22",
        "sec": 142,
        "text": "إعراب الجمل؛ أنا ذكرت لكم الآن مثالاً على ذلك قلت مثلاً: صلة الموصول لا محل لها من الإعراب، مثل هذه",
        "video_link": null
      },
      {
        "ts": "2:30",
        "sec": 150,
        "text": "القضايا هل الجملة لها محل من الإعراب أو ليس لها محل من الإعراب؟ هذا موضوع آخر لا",
        "video_link": null
      },
      {
        "ts": "2:37",
        "sec": 157,
        "text": "نريد أن ندخل فيه، وليس من الأشياء التي يعتني بها المبتدئ في علم النحو، لكن هناك",
        "video_link": null
      },
      {
        "ts": "2:45",
        "sec": 165,
        "text": "أصلاً متون مخصصة لإعراب الجمل.",
        "video_link": null
      },
      {
        "ts": "2:51",
        "sec": 171,
        "text": "وقوله تعالى: {الَّذِي هُمْ فِيهِ مُخْتَلِفُونَ}، هُمْ: مبتدأ،",
        "video_link": null
      },
      {
        "ts": "2:57",
        "sec": 177,
        "text": "مُخْتَلِفُونَ: خبر، وجملة المبتدأ والخبر، إذن هذا",
        "video_link": null
      },
      {
        "ts": "3:04",
        "sec": 184,
        "text": "عن صلة الموصول حين تكون جملة فعلية كانت أو اسمية. وأما شبه الجملة فما المراد بذلك؟",
        "video_link": null
      },
      {
        "ts": "3:12",
        "sec": 192,
        "text": "قال: وَشِبْهُ الْجُمْلَةِ ثَلَاثَةُ أَشْيَاءَ؛ أَحَدُهَا: الظَّرْفُ، نحو: جَاءَ الَّذِي عِنْدَكَ،",
        "video_link": null
      },
      {
        "ts": "3:20",
        "sec": 200,
        "text": "عِنْدَ: ظرف مكان وهو مضاف، ظرف مكان منصوب وهو مضاف، الكاف: ضمير",
        "video_link": null
      },
      {
        "ts": "3:29",
        "sec": 209,
        "text": "متصل مبني في محل جر مضاف إليه. شبه الجملة المكونة من هذا الظرف هي",
        "video_link": null
      },
      {
        "ts": "3:37",
        "sec": 217,
        "text": "صلة الموصول. وقوله تعالى: {مَا عِندَكُمْ يَنفَدُ ۖ وَمَا عِندَ اللَّهِ بَاقٍ}، فإذن مَا: اسم موصول",
        "video_link": null
      },
      {
        "ts": "3:49",
        "sec": 229,
        "text": "مبتدأ، عِنْدَ: ظرف وهو مضاف، والكاف مضاف إليه،",
        "video_link": null
      },
      {
        "ts": "3:58",
        "sec": 238,
        "text": "يَنفَدُ: هذه مكونة من فعل مضارع",
        "video_link": null
      },
      {
        "ts": "4:09",
        "sec": 249,
        "text": "وفاعله ضمير مستتر، وهذه الجملة الفعلية هي في محل رفع خبر المبتدأ.",
        "video_link": null
      },
      {
        "ts": "4:17",
        "sec": 257,
        "text": "{وَمَا عِندَ اللَّهِ بَاقٍ}، الثانية نفس الإعراب إلا أن الذي يتغير أن الخبر هنا",
        "video_link": null
      },
      {
        "ts": "4:24",
        "sec": 264,
        "text": "ليس جملة.",
        "video_link": null
      },
      {
        "ts": "4:46",
        "sec": 286,
        "text": "فباقي مع التنوين صارت باقٍ، لالتقاء الساكنين أولهما لين فتصبح باقٍ،",
        "video_link": null
      },
      {
        "ts": "4:57",
        "sec": 297,
        "text": "وذلك هذا الاسم المنقوص مرفوع وخبر مرفوع وعلامة رفعه",
        "video_link": null
      },
      {
        "ts": "5:04",
        "sec": 304,
        "text": "الضمة المقدرة على الياء المحذوفة لالتقاء الساكنين.",
        "video_link": null
      },
      {
        "ts": "5:15",
        "sec": 315,
        "text": "هذا النوع الأول من شبه الجملة. النوع الثاني:",
        "video_link": null
      },
      {
        "ts": "5:24",
        "sec": 324,
        "text": "جار ومجرور، نحو: جَاءَ الَّذِي فِي الدَّارِ، فِي الدَّارِ: اسم مجرور، شبه الجملة من الجار والمجرور صلة الموصول. {وَأَلْقَتْ مَا فِيهَا وَتَخَلَّتْ}،",
        "video_link": null
      },
      {
        "ts": "5:33",
        "sec": 333,
        "text": "فِيهَا: في حرف جر، والضمير هَا: ضمير مبني في محل جر",
        "video_link": null
      },
      {
        "ts": "5:41",
        "sec": 341,
        "text": "اسم يعني، الجار والمجرور",
        "video_link": null
      },
      {
        "ts": "5:49",
        "sec": 349,
        "text": "صلة الموصول. شبه جملة الموصول الظرف والجار والمجرور",
        "video_link": null
      },
      {
        "ts": "5:56",
        "sec": 356,
        "text": "يتعلقان، يتعلق الظرف والجار والمجرور إذا وقعا صلة بفعل محذوف وجوباً تقديره \"استقر\".",
        "video_link": null
      },
      {
        "ts": "6:05",
        "sec": 365,
        "text": "طيب، حالة الإعراب السهل هو الذي ذكرته لكم من قبل؛ أن تقول عِنْدَ ظرف صلة",
        "video_link": null
      },
      {
        "ts": "6:12",
        "sec": 372,
        "text": "الموصول، وتقول فِي الدَّارِ جار ومجرور شبه جملة صلة الموصول. الإعراب الأصح هو هذا الذي يذكره هنا،",
        "video_link": null
      },
      {
        "ts": "6:22",
        "sec": 382,
        "text": "فيقول: لا، الظرف متعلق بفعل محذوف تقديره \"استقر\"، فيكون تقدير",
        "video_link": null
      },
      {
        "ts": "6:30",
        "sec": 390,
        "text": "الكلام مثلاً: جَاءَ الَّذِي عِنْدَكَ؛ جَاءَ الَّذِي اسْتَقَرَّ عِنْدَكَ، وحينئذٍ شبه الجملة لأن أصل الكلام",
        "video_link": null
      },
      {
        "ts": "6:39",
        "sec": 399,
        "text": "يصبح جملة فعلية. جَاءَ الَّذِي فِي الدَّارِ؛ أي جَاءَ الَّذِي اسْتَقَرَّ",
        "video_link": null
      },
      {
        "ts": "6:47",
        "sec": 407,
        "text": "فِي الدَّارِ، وحينئذٍ يشبه الجملة أنك تقدر فعلاً وجوباً تقديره \"استقر\"،",
        "video_link": null
      },
      {
        "ts": "6:59",
        "sec": 419,
        "text": "فصلة الموصول تبقى على الأصل من أنها جملة جملة فعلية.",
        "video_link": null
      },
      {
        "ts": "7:06",
        "sec": 426,
        "text": "صلة الموصول.",
        "video_link": null
      },
      {
        "ts": "7:16",
        "sec": 436,
        "text": "أو بحرف جر ناوين معنى كائن أو استقر، فحتى حين يكون الخبر",
        "video_link": null
      },
      {
        "ts": "7:25",
        "sec": 445,
        "text": "فإنه يقدرون لكي لا تكون جملة، هذه هي الخبر.",
        "video_link": null
      },
      {
        "ts": "7:35",
        "sec": 455,
        "text": "إذن شبه الجملة إما أن تكون ظرفاً أو جاراً ومجروراً أو",
        "video_link": null
      },
      {
        "ts": "7:44",
        "sec": 464,
        "text": "صفة صريحة. وَالثَّالِثُ: الصِّفَةُ الصَّرِيحَةُ، والمراد بها اسم الفاعل واسم المفعول، وتختص بالألف",
        "video_link": null
      },
      {
        "ts": "7:51",
        "sec": 471,
        "text": "واللام، نحن قد ذكرنا كما في المثال: {الْمُصَّدِّقِينَ وَالْمُصَّدِّقَاتِ}، قلنا الفاعل واسم المفعول",
        "video_link": null
      },
      {
        "ts": "8:03",
        "sec": 483,
        "text": "هذا لا يكون في الأسماء الموصولة الأخرى، لكن \"أل\" التي هي اسم موصول",
        "video_link": null
      },
      {
        "ts": "8:09",
        "sec": 489,
        "text": "ترتبط باسم فاعل أو اسم مفعول، هي هذا.",
        "video_link": null
      },
      {
        "ts": "8:17",
        "sec": 497,
        "text": "اسم الفاعل، هذا هو انتهينا من الصلة. العائد قال: وَالْعَائِدُ ضَمِيرٌ",
        "video_link": null
      },
      {
        "ts": "8:24",
        "sec": 504,
        "text": "مُطَابِقٌ لِلْمَوْصُولِ فِي الْإِفْرَادِ وَالتَّثْنِيَةِ وَالْجَمْعِ وَالتَّذْكِيرِ وَالتَّأْنِيثِ، كما تقدم في الأمثلة",
        "video_link": null
      },
      {
        "ts": "8:32",
        "sec": 512,
        "text": "المذكورة. في جميع ما ذكرناه نجد عائداً يعود على",
        "video_link": null
      },
      {
        "ts": "8:40",
        "sec": 520,
        "text": "الاسم الموصول؛ فحين أقول مثلاً: جَاءَ الَّذِي أُحِبُّهُ، هذا الضمير الهاء يرجع على الَّذِي،",
        "video_link": null
      },
      {
        "ts": "8:52",
        "sec": 532,
        "text": "واضح؟ جَاءَتِ الَّتِي أَكْرَمْتُهَا، لاحظ العائد يعود على الَّتِي، يطابق",
        "video_link": null
      },
      {
        "ts": "9:01",
        "sec": 541,
        "text": "العائد الاسم الموصول في هذه الأمور في الإفراد والتثنية والجمع والتذكير والتأنيث، وقد يحذف العائد.",
        "video_link": null
      },
      {
        "ts": "9:34",
        "sec": 574,
        "text": "أي: {وَيَشْرَبُ مِمَّا تَشْرَبُونَ مِنْهُ}، هذا العائد قد يحذف",
        "video_link": null
      },
      {
        "ts": "9:45",
        "sec": 585,
        "text": "في الكلام ما يدل عليه بحيث لا يحتاج إليه.",
        "video_link": null
      },
      {
        "ts": "9:52",
        "sec": 592,
        "text": "مثّل لحذف العائد المرفوع بقول الله سبحانه وتعالى: {ثُمَّ لَنَنزِعَنَّ مِن كُلِّ شِيعَةٍ",
        "video_link": null
      },
      {
        "ts": "10:00",
        "sec": 600,
        "text": "أَيُّهُمْ}، أَيُّ هنا بمعنى الَّذِي، يعني قراءة",
        "video_link": null
      },
      {
        "ts": "10:10",
        "sec": 610,
        "text": "عفواً، أَيُّهُمْ مبني على الضم في محل نصب مفعول به لـ {لَنَنزِعَنَّ}.",
        "video_link": null
      },
      {
        "ts": "10:19",
        "sec": 619,
        "text": "أَيُّهُمْ في محل نصب",
        "video_link": null
      },
      {
        "ts": "10:26",
        "sec": 626,
        "text": "وَأَشَدُّ: خبر مبتدأ محذوف تقديره \"هو\"، فيكون تقدير الكلام كما قال",
        "video_link": null
      },
      {
        "ts": "10:35",
        "sec": 635,
        "text": "المصنف: هُوَ أَشَدُّ.",
        "video_link": null
      },
      {
        "ts": "10:50",
        "sec": 650,
        "text": "{يَعْلَمُ مَا تُسِرُّونَ وَمَا تُعْلِنُونَ}، أصل الكلام: يَعْلَمُ مَا تُسِرُّونَهُ،",
        "video_link": null
      },
      {
        "ts": "11:04",
        "sec": 664,
        "text": "فعلاً هي يعني ضمير في محل رفع",
        "video_link": null
      },
      {
        "ts": "11:16",
        "sec": 676,
        "text": "فاعل، الهاء",
        "video_link": null
      },
      {
        "ts": "11:26",
        "sec": 686,
        "text": "المفروض أن تكون هي المفعول به،",
        "video_link": null
      },
      {
        "ts": "11:35",
        "sec": 695,
        "text": "العائد محذوف، وكذلك في {وَمَا تُعْلِنُونَ} أي: وَمَا تُعْلِنُونَهُ.",
        "video_link": null
      },
      {
        "ts": "11:46",
        "sec": 706,
        "text": "ونحو: {وَيَشْرَبُ مِمَّا تَشْرَبُونَ} {يَأْكُلُ مِمَّا تَأْكُلُونَ مِنْهُ}،",
        "video_link": null
      },
      {
        "ts": "11:53",
        "sec": 713,
        "text": "العائد المخفوض بالحرف،",
        "video_link": null
      },
      {
        "ts": "11:58",
        "sec": 718,
        "text": "حرف الجر لدلالة سياق الكلام عليه. المعرّف بالأداة؛",
        "video_link": null
      },
      {
        "ts": "12:08",
        "sec": 728,
        "text": "أي بـ \"أل\". قال: فَصْلٌ: وَأَمَّا الْمُعَرَّفُ بِالْأَدَاةِ فَهُوَ الْمُعَرَّفُ بِالْأَلِفِ وَاللَّامِ،",
        "video_link": null
      },
      {
        "ts": "12:16",
        "sec": 736,
        "text": "عهدية وجنسية. إذن قال: هذه إما أن تكون للعهد أو أن تكون للجنس. يبدأ",
        "video_link": null
      },
      {
        "ts": "12:26",
        "sec": 746,
        "text": "بالعهد؛ والعهد ذكري، أو للعهد الذهني،",
        "video_link": null
      },
      {
        "ts": "12:34",
        "sec": 754,
        "text": "أو للعهد الحضوري. إذن أول قسمي \"أل\" هي العهدية.",
        "video_link": null
      },
      {
        "ts": "12:45",
        "sec": 765,
        "text": "إذا كانت للعهد الذكري كما في قول الله سبحانه وتعالى:",
        "video_link": null
      },
      {
        "ts": "12:52",
        "sec": 772,
        "text": "{فِي زُجَاجَةٍ ۖ الزُّجَاجَةُ كَأَنَّهَا كَوْكَبٌ دُرِّيٌّ}، {مِصْبَاحٌ ۖ الْمِصْبَاحُ فِي زُجَاجَةٍ}،",
        "video_link": null
      },
      {
        "ts": "13:03",
        "sec": 783,
        "text": "الزجاجة، {فِي زُجَاجَةٍ ۖ الزُجَاجَةُ}؛ الزجاجة معرفة",
        "video_link": null
      },
      {
        "ts": "13:17",
        "sec": 797,
        "text": "هي نفسها الزجاجة المذكورة أولاً،",
        "video_link": null
      },
      {
        "ts": "13:24",
        "sec": 804,
        "text": "هذه العهد الذكري؛ أي شيء معهود في الذكر قد ذُكر من قبل،",
        "video_link": null
      },
      {
        "ts": "13:32",
        "sec": 812,
        "text": "جميل. وقد يكون للعهد الذهني، بأن يكون",
        "video_link": null
      },
      {
        "ts": "13:39",
        "sec": 819,
        "text": "ما تصاحبه معهوداً في الذهن، لم يسبق له ذكر في الكلام ولكنه معهود في الذهن، كما في قول",
        "video_link": null
      },
      {
        "ts": "13:47",
        "sec": 827,
        "text": "الله سبحانه وتعالى: {إِذْ هُمَا فِي الْغَارِ}، لم يُذكر هذا الغار من قبل",
        "video_link": null
      },
      {
        "ts": "13:54",
        "sec": 834,
        "text": "ولكنه معهود في أذهان المخاطبين أن المقصود بذلك غار ثور وهو معروف عندهم.",
        "video_link": null
      },
      {
        "ts": "14:03",
        "sec": 843,
        "text": "وقد يكون للعهد الحضوري، بأن يكون هذا هذا الاسم",
        "video_link": null
      },
      {
        "ts": "14:11",
        "sec": 851,
        "text": "حاضراً زمن الخطاب حين وقع هذا الكلام، كما في قول الله سبحانه وتعالى: {الْيَوْمَ",
        "video_link": null
      },
      {
        "ts": "14:20",
        "sec": 860,
        "text": "أَكْمَلْتُ لَكُمْ دِينَكُمْ}، إذن \"أل\" هذه للعهد الحضوري؛ هذا اليوم لم يُذكر من قبل في الكلام، وليس",
        "video_link": null
      },
      {
        "ts": "14:29",
        "sec": 869,
        "text": "شيئاً معهوداً في أذهان الناس وإنما هو شيء حاضر، لأن هذه الآية نزلت في",
        "video_link": null
      },
      {
        "ts": "14:36",
        "sec": 876,
        "text": "يوم عرفة: {الْيَوْمَ أَكْمَلْتُ لَكُمْ دِينَكُمْ}، إذن حين نزلت هذه الآية كان ذلك اليوم حاضراً فهذه",
        "video_link": null
      },
      {
        "ts": "14:46",
        "sec": 886,
        "text": "للعهد الحضوري. إذن هذه ثلاثة أنواع من العهد.",
        "video_link": null
      },
      {
        "ts": "14:54",
        "sec": 894,
        "text": "ثم الجنسية؛ والجنسية إما لتعريف الماهية أو لاستغراق",
        "video_link": null
      },
      {
        "ts": "15:02",
        "sec": 902,
        "text": "الأفراد أو لاستغراق خصائص الأفراد. الجنسية لتعريف الماهية كما في قول الله",
        "video_link": null
      },
      {
        "ts": "15:11",
        "sec": 911,
        "text": "سبحانه وتعالى: {وَجَعَلْنَا مِنَ الْمَاءِ كُلَّ شَيْءٍ حَيٍّ}،",
        "video_link": null
      },
      {
        "ts": "15:18",
        "sec": 918,
        "text": "بمعنى أن هل هذه \"أل\" هذه التي هي لتعريف الماهية؛ أي تعرف ماهية الشيء وحقيقته من حيث هو،",
        "video_link": null
      },
      {
        "ts": "15:27",
        "sec": 927,
        "text": "بغض النظر يعني عن الأفراد الداخلة في هذه الماهية. وعلامتها",
        "video_link": null
      },
      {
        "ts": "15:36",
        "sec": 936,
        "text": "من الناحية اللفظية أنه يمكن أن،",
        "video_link": null
      },
      {
        "ts": "15:44",
        "sec": 944,
        "text": "لا يمكن أن تخلفها أو تحل محلها \"كل\"،",
        "video_link": null
      },
      {
        "ts": "15:53",
        "sec": 953,
        "text": "كما في قول ربنا سبحانه وتعالى: {وَجَعَلْنَا مِنَ الْمَاءِ كُلَّ شَيْءٍ حَيٍّ}.",
        "video_link": null
      },
      {
        "ts": "16:02",
        "sec": 962,
        "text": "ما معنى {وَجَعَلْنَا مِنَ الْمَاءِ}؟ أي من حقيقة الماء، من ماهية الماء كل شيء حي،",
        "video_link": null
      },
      {
        "ts": "16:08",
        "sec": 968,
        "text": "وليس المعنى: وجعلنا من كل ماء، يكون المعنى غير صحيح.",
        "video_link": null
      },
      {
        "ts": "16:15",
        "sec": 975,
        "text": "فلذلك قلنا إن \"أل\" الجنسية هذه لا يصح أن",
        "video_link": null
      },
      {
        "ts": "16:20",
        "sec": 980,
        "text": "تحل \"كل\" محلها، فلا يمكنك أن تقول: وجعلنا من",
        "video_link": null
      },
      {
        "ts": "16:26",
        "sec": 986,
        "text": "كل ماء كل شيء حي، المعنى خطأ. لكن من جنس الماء، من حقيقة الماء، من ماهية الماء",
        "video_link": null
      },
      {
        "ts": "16:34",
        "sec": 994,
        "text": "جعلنا منه كل شيء حي، فهذا الفرق بين",
        "video_link": null
      },
      {
        "ts": "16:40",
        "sec": 1000,
        "text": "الجنسية التي لتعريف الماهية. وأما استغراق الأفراد، هذه هي التي يصح",
        "video_link": null
      },
      {
        "ts": "16:49",
        "sec": 1009,
        "text": "أن تخلفها \"كل\"، كما في قول ربنا سبحانه وتعالى: {وَخُلِقَ الْإِنسَانُ",
        "video_link": null
      },
      {
        "ts": "16:57",
        "sec": 1017,
        "text": "ضَعِيفًا}، يمكن أن تعوض فتقول: وخلق كل إنسان",
        "video_link": null
      },
      {
        "ts": "17:05",
        "sec": 1025,
        "text": "ضعيفاً، يكون المعنى صحيحاً، ما يسمونه استغراق الأفراد وهو الذي يعرف",
        "video_link": null
      },
      {
        "ts": "17:16",
        "sec": 1036,
        "text": "عند الأصوليين بمعنى العموم، فـ \"أل\" هذه تفيد معنى العموم؛ {وَخُلِقَ الْإِنسَانُ ضَعِيفًا}: كل إنسان",
        "video_link": null
      },
      {
        "ts": "17:22",
        "sec": 1042,
        "text": "خُلق ضعيفاً، خلاف {وَجَعَلْنَا مِنَ الْمَاءِ كُلَّ شَيْءٍ حَيٍّ} ليس المعنى: وجعلنا من كل ماء كل شيء حي.",
        "video_link": null
      },
      {
        "ts": "17:38",
        "sec": 1058,
        "text": "وزاد وهو استغراق خصائص الأفراد، نحو: أَنْتَ الرَّجُلُ عِلْماً.",
        "video_link": null
      },
      {
        "ts": "17:47",
        "sec": 1067,
        "text": "وهذا لا يكون إلا على جهة المبالغة بحيث يصح أن تخلف \"أل\" هذه \"كل\"، ولكن على جهة",
        "video_link": null
      },
      {
        "ts": "17:56",
        "sec": 1076,
        "text": "المجاز لا على جهة الحقيقة. مثلاً: أَنْتَ الرَّجُلُ عِلْماً، يصح أن تقول مجازاً:",
        "video_link": null
      },
      {
        "ts": "18:04",
        "sec": 1084,
        "text": "أنت كل رجل علماً، كأنك كأنك تريد أن تقول لمخاطبك: قد اجتمع",
        "video_link": null
      },
      {
        "ts": "18:13",
        "sec": 1093,
        "text": "فيك كل ما تفرق في غيرك من الرجال من جهة ما عندك من العلم، فأنت يعني \"علماً\" هي التي",
        "video_link": null
      },
      {
        "ts": "18:22",
        "sec": 1102,
        "text": "تبين في أي شيء وقع هذا الاستغراق؛ جهة العلم.",
        "video_link": null
      },
      {
        "ts": "18:31",
        "sec": 1111,
        "text": "اجتمع فيك ما وُجد وما تفرق في الرجال كلهم،",
        "video_link": null
      },
      {
        "ts": "18:39",
        "sec": 1119,
        "text": "على جهة المجاز والمبالغة ولا يقصد به حقيقة الأمر، فهنا ليس المراد استغراق",
        "video_link": null
      },
      {
        "ts": "18:49",
        "sec": 1129,
        "text": "الأفراد استغراق الرجال؛ حين أقول: أَنْتَ الرَّجُلُ عِلْماً ليس المقصود أنه اجتمع فيك الرجال كلهم، لكن من جهة الخصائص، من جهة ما",
        "video_link": null
      },
      {
        "ts": "18:58",
        "sec": 1138,
        "text": "لديه من العلم كأن علم كل الرجال اجتمع فيك. وأخيراً قال:",
        "video_link": null
      },
      {
        "ts": "19:06",
        "sec": 1146,
        "text": "وَتُبْدَلُ لَامُهَا مِيماً فِي لُغَةِ حِمْيَرَ، هذه لغة للعرب خاصة؛",
        "video_link": null
      },
      {
        "ts": "19:15",
        "sec": 1155,
        "text": "يقلبون اللام ميماً. ويذكرون أن رسول الله صلى",
        "video_link": null
      },
      {
        "ts": "19:21",
        "sec": 1161,
        "text": "الله عليه وسلم خاطب بعض أهل حمير بلغتهم، فقال في الحديث المعروف: \"لَيْسَ مِنَ امْبِرِّ",
        "video_link": null
      },
      {
        "ts": "19:28",
        "sec": 1168,
        "text": "امْصِيَامُ فِي امْسَفَرِ\"، خاطبهم بذلك فقال: \"ليس من البر الصيام في السفر\".",
        "video_link": null
      },
      {
        "ts": "19:36",
        "sec": 1176,
        "text": "نعم، انتهينا إذن من المعرّف بالأداة. ثم قال: فَصْلٌ: وَأَمَّا الْمُضَافُ إِلَى وَاحِدٍ مِنْ هَذِهِ الْخَمْسَةِ فَنَحْوُ:",
        "video_link": null
      },
      {
        "ts": "19:47",
        "sec": 1187,
        "text": "غُلَامِي، وَغُلَامِ هَذَا، وَغُلَامِ الَّذِي قَامَ أَبُوهُ، وَغُلَامِ الرَّجُلِ، وَغُلَامِ زَيْدٍ.",
        "video_link": null
      },
      {
        "ts": "20:23",
        "sec": 1223,
        "text": "وننتقل حينئذٍ إلى باب جديد هو باب المرفوعات من الأسماء، إلى لقاء مقبل بإذن",
        "video_link": null
      },
      {
        "ts": "20:31",
        "sec": 1231,
        "text": "الله سبحانه وتعالى، والحمد لله وصلى الله وسلم على رسول الله.",
        "video_link": null
      }
    ]
  },
  {
    "subject": "nahw",
    "subjectLabel": "علم النحو والصرف",
    "lesson": "الدرس 15",
    "lessonNum": 15,
    "title": "الدرس 15",
    "summary": "📚 <b>الملخص الشامل لباب الفاعل - أكاديمية الباجي</b>\n\n🔹 <b>الخلاصة المحورية للدرس:</b>\n<blockquote>يتناول هذا الدرس \"باب المرفوعات\"، مع التركيز التفصيلي على المرفوع الأول وهو \"الفاعل\". يوضح الدرس تعريف الفاعل، وأقسامه (ظاهر ومضمر)، ودور العوامل التي ترفعه (الفعل وما في تأويله)، بالإضافة إلى الأحكام النحوية المتعلقة بترتيبه وتأنيث الفعل معه.</blockquote>\n\n🔹 <b>الأحداث والوقائع / القواعد والمسائل بالتفصيل:</b>\n\n<blockquote>\n• <b>تعريف الفاعل:</b> هو الاسم المرفوع الذي ذُكر قبله فعله (أو ما في تأويل الفعل)، وهو العمدة في الكلام الذي لا يجوز حذفه، فإذا لم يظهر في اللفظ اعتُبر ضميراً مستتراً.\n• <b>العوامل الرافعة للفاعل:</b> لا يقتصر رفع الفاعل على الفعل الصريح فقط، بل يشمل \"ما في تأويل الفعل\" (أي المشتقات التي تعمل عمل الفعل) مثل: اسم الفاعل (نحو: أَقَائِمٌ الزَّيْدَانِ)، والصفة المشبهة، واسم الفعل، والمصدر.\n• <b>أقسام الفاعل:</b>\n    1. <b>الظاهر:</b> مثل لفظ الجلالة في (قَالَ اللَّهُ)، والمثنى (قَالَ رَجُلَانِ)، وجمع المذكر السالم (جَاءَ الْمُعَذِّرُونَ).\n    2. <b>المضمر:</b> الضمائر المتصلة (مثل: ضَرَبْتُ، ضَرَبْنَا).\n• <b>أحكام الفاعل:</b>\n    1. <b>وجوب التأخير عن الفعل:</b> لا يتقدم الفاعل على فعله، فإن وُجد ما ظاهره التقديم (نحو: زيدٌ قام)، يُعرب المتقدم مبتدأً، والفاعل ضميراً مستتراً.\n    2. <b>توحيد الفعل مع الفاعل:</b> الأصل أن يُوحد الفعل (يبقى مفرداً) سواء كان الفاعل مفرداً أو مثنى أو جمعاً (قَالَ رَجُلَانِ، جَاءَ الْمُعَذِّرُونَ)، مع وجود لغة لبعض العرب تُلحق علامة التثنية والجمع بالفعل (لغة \"أكلوني البراغيث\").\n    3. <b>تأنيث الفعل:</b> يجب تأنيث الفعل إذا كان الفاعل حقيقي التأنيث (قامت هند)، ويجوز التأنيث أو التذكير إذا كان الفاعل مجازي التأنيث أو جمع تكسير (طلعت الشمس / طلع الشمس).\n    4. <b>ترتيب الجملة:</b> الأصل هو (فعل + فاعل + مفعول)، وقد يتقدم المفعول على الفاعل جوازاً، أو وجوباً (إذا كان المفعول ضميراً متصلاً يخشى انفصاله، أو إذا كان عود الضمير على متأخر لفظاً ورتبة، أو إذا كان المفعول له الصدارة كأسماء الاستفهام).\n</blockquote>\n\n🔹 <b>الأسماء والمصطلحات الرئيسية:</b>\n\n<blockquote>\n• <b>اسم الفاعل:</b> اسم مشتق يعمل عمل الفعل فيرفع فاعلاً (مثل: مختلف في قوله تعالى \"مختلف ألوانه\").\n• <b>العمدة:</b> هو الركن الأساسي في الجملة الذي لا يستقيم الكلام بدونه (كالفاعل والمبتدأ).\n• <b>الفضلة:</b> ما يمكن حذفها من الكلام ويبقى المعنى مستقيماً (كالمفعول به في بعض السياقات).\n• <b>لغة \"أكلوني البراغيث\":</b> لغة عند بعض العرب تُلحق الفعل علامة الجمع إذا كان الفاعل جمعاً، وهي خلاف الأصل الفصيح.\n• <b>حقيقي التأنيث ومجازيه:</b> الحقيقي ما له فرج (من ذوات الأرواح)، والمجازي ما لا فرج له (كالجمادات).\n</blockquote>\n\n🔹 <b>العِبر والأحكام المستفادة:</b>\n\n<blockquote>\n• وجوب اتباع \"اللغة المطردة\" (لغة القرآن) في إفراد الفعل مع الفاعل المثنى والجمع.\n• التفريق بين الأصل في الإعراب وبين التخريجات النحوية التي تعالج حالات خاصة (كالتقديم والوجوب).\n• مراعاة السياق في قواعد اللغة، حيث إن الضمير لا ينفصل إذا أمكن اتصاله، ولا يعود على متأخر لفظاً ورتبة.\n</blockquote>\n\n🔹 <b>سؤال تدبر ومراجعة ذاتية:</b>\n<blockquote>إذا قلنا \"ضربني أخوك\"، فهل يجوز تقديم \"أخوك\" على الفعل فنقول \"أخوك ضربني\"؟ وكيف نعربها في الحالتين بناءً على القاعدة التي تعلمناها في الدرس حول وجوب تقديم المفعول أو تأخيره؟</blockquote>",
    "full_text": "بسم الله الرحمن الرحيم، الحمد لله رب العالمين، وصلى الله وسلم وبارك على نبينا محمد وعلى آله وصحبه والتابعين، ومن تبعهم بإحسان إلى يوم الدين. هذا باب جديد هو باب المرفوعات من الأسماء، بدأ بسرد هذه المرفوعات قبل أن يفصل فيها لاحقاً، فقال: الْمَرْفُوعَاتُ عَشَرَةٌ؛ وَهِيَ: الْفَاعِلُ، وَالْمَفْعُولُ الَّذِي لَمْ يُسَمَّ فَاعِلُهُ، وَالْمُبْتَدَأُ وَخَبَرُهُ، وَاسْمُ كَانَ وَأَخَوَاتِهَا، وَاسْمُ أَفْعَالِ الْمُقَارَبَةِ، وَاسْمُ الْحُرُوفِ الْمُشَبَّهَةِ بِـ \"لَيْسَ\"، وَخَبَرُ إِنَّ وَأَخَوَاتِهَا، وَخَبَرُ لَا الَّتِي لِنَفْيِ الْجِنْسِ، وَالتَّابِعُ لِلْمَرْفُوعِ؛ وَهُوَ أَرْبَعَةُ أَشْيَاءَ: النَّعْتُ، وَالْعَطْفُ، وَالتَّوْكِيدُ، وَالْبَدَلُ. هذا سرد لا نحتاج إلى الإطالة في الحديث عنه. المرفوع الأول هو الفاعل. بَابُ الْفَاعِلِ؛ قال: هُوَ الِاسْمُ الْمَرْفُوعُ الْمَذْكُورُ قَبْلَهُ فِعْلُهُ، أو ما في تأويل الفعل. وهو على قسمين ظاهر، إذن كل اسم مرفوع قبله، يعني حين نقول اسم مرفوع قد يكون هذا الاسم صريحاً وقد يكون مؤولاً. وسيأتينا أن الفعل قد يشبك مع حرف مصدري، يعني حرف مصدري ومعه صلته فيكون ما ما هو كالاسم، فيكون اسماً مؤولاً كما في قول الله سبحانه وتعالى: {أَلَمْ يَأْنِ لِلَّذِينَ آمَنُوا أَن تَخْعَشَعَ}، كما لو قيل: ألم يأنِ خشوع قلوبهم، {أَن تَخْشَعَ قُلُوبُهُمْ} خشوع قلوبهم، فإذن هذا الفاعل هو اسم، قلنا صريح أو مؤول، اسم مرفوع مذكور قبله فعل، وهذا الفعل هو العامل في الفاعل هو الذي يرفعه، أو ما هو في تأويل الفعل أي ما يشبه الفعل في عمله وهو اسم الفاعل، والصفة المشبهة، والمصدر، واسم الفعل، إلى غير ذلك، فهذه الأشياء أيضاً تقتضي فاعلاً. ثم وهذا سيأتينا في موضعه بإذن الله عز وجل، ثم هذا الفاعل على قسمين: إما أن يكون ظاهراً أو أن يكون مضمراً. فَالظَّاهِرُ نحو: قَالَ اللَّهُ، قَالَ: فعل ماضٍ مبني على الفتح، واسم الجلالة فاعل، اللَّهُ: فاعل. قَالَ رَجُلَانِ، رَجُلَانِ: فاعل مرفوع وعلامة رفعه الالف نيابة عن الضمة لأنه مثنى. {جَاءَ الْمُعَذِّرُونَ}، الْمُعَذِّرُونَ: فاعل مرفوع علامة رفعه الواو النائبة عن الضمة لأنه جمع مذكر سالم. {يَوْمَ يَقُومُ النَّاسُ}، هنا يَقُومُ: فعل مضارع، النَّاسُ: فاعل مرفوع. {يَوْمَئِذٍ يَفْرَحُ الْمُؤْمِنُونَ}، الْمُؤْمِنُونَ: فاعل مرفوع وعلامة رفعه الواو النائبة عن الضمة لأنه جمع مذكر سالم. {قَالَ أَبُوهُمْ}، أَبُو: فاعل مرفوع وعلامة رفعه الواو النائبة عن الضمة لأنه من الأسماء الستة. هذه كلها أمثلة مختلفة كطريقة المصنف في هذا المتن متنوعة، أمثلة على الفاعل حين يكون اسماً ظاهراً. ثم هذا الفاعل قد يكون مضمراً أي ضميراً، كقولك: ضَرَبْتُ، التاء هنا ضمير متصل مبني في محل رفع فاعل، ضَرَبْنَا كذلك ضمير متصل مبني في محل رفع فاعل، إلى آخره كما تقدم في فصل المضمر فلا نحتاج إلى إعادة الكلام عنه. والذي في تأويل الفعل، إذن هذا الفعل واضح عندنا، الذي في تأويل الفعل نحو: أَقَائِمٌ الزَّيْدَانِ؟ وقوله تعالى: {مُخْتَلِفٌ أَلْوَانُهُ}. ففي نحو أَقَائِمٌ الزَّيْدَانِ؟ قَائِمٌ هذا اسم ولكنه في صيغته الصرفية هو اسم فاعل، فقائم الزيدان في قوة قولك أو في تأويل قولك: أيقوم الزيدان؟ أَقَائِمٌ الزَّيْدَانِ، يقوم الزيدان. قَائِمٌ: مبتدأ ومبتدأ مرفوع علامة رفعه الضمة ظاهرة على آخره، وقائم اسم فاعل، واسم الفاعل يعمل عمل الفعل فيرفع فاعلاً وينصب مفعولاً. هذه كلها أشياء ستأتينا في موضعها، لكن نحن نذكرها هنا من باب البيان. الزَّيْدَانِ: فاعل، أنت ما تعرفه في الأصل هو أن يكون الفاعل لفعل، يكون الفعل هو الذي يرفع الفاعل، لكن قلنا إن هنالك أشياء أخرى غير الفعل تعمل عمل الفعل منها اسم الفاعل في هذه الصورة، فإذن الزيدان فاعل لاسم الفاعل، ونقول عنه فاعل سد مسد الخبر، أو أغنى عن الخبر. هذا سنأخذه إن شاء الله تعالى في بحث المبتدأ والخبر. وكذلك قوله تعالى: {مُخْتَلِفٌ أَلْوَانُهُ}، فهو في قوة أو في تأويل: يختلف أو تختلف ألوانه، واضح؟ {مُخْتَلِفٌ أَلْوَانُهُ}، مُخْتَلِفٌ: مبتدأ وألوانه، وهو اسم اسم فاعل، مُخْتَلِفٌ اسم فاعل يعمل عمل الفعل فيرفع الفاعل وينصب المفعول، وإذن ألوانُ: فاعل له، وهو مرفوع علامة رفعه الضمة الظاهرة على آخره، جميل. إذن نحن فهمنا الآن أن الفاعل يكون العامل فيه فعلاً، هذا معروف لديكم لا جديد فيه، لكن ربما الذي قد يكون جديداً عند كثير من المبتدئين هو أن اسم الفاعل أيضاً وما أشبهه من هذه الصفات يمكنه كذلك أن يعمل عمل الفعل فيكون عندنا فاعل لاسم الفاعل. قال: وَلِلْفَاعِلِ أَحْكَامٌ؛ مِنْهَا: أَنَّهُ لَا يَجُوزُ حَذْفُهُ، لأنه عمدة؛ فيما سنذكره انطلاقاً من الآن هنالك أشياء نقول عنها إنها عمدة في الكلام، وأشياء أخرى نقول عنها إنها فضلة في الكلام. عمدة: أي يقوم الكلام عليها لا سبيل إلى ماذا؟ إلى حذفها من الكلام، إذا حُذفت من الكلام يعني لم يصح لم يستقم الكلام. والأشياء التي هي فضلة لا شك أنها تفيد معنى ولكنها لو حُذفت من الكلام يبقى مع ذلك كلاماً مستقيماً صالحاً، فالفاعل عمدة لا يجوز حذفه، واضح؟ فَإِنْ ظَهَرَ فِي اللَّفْظِ نحو: قَامَ زَيْدٌ، وَالزَّيْدَانِ قَامَا، فذاك؛ وَإِلَّا فَهُوَ ضَمِيرٌ مُسْتَتِرٌ. بمعنى كأنه يتوقع سؤالاً يسأله من يقرأ هذا الكلام؛ حين تقول له، حين يقول إن الفاعل عمدة فلا يجوز حذفه، كأن سائلاً يسأل: طيب ولكن في نحو زَيْدٌ قَامَ، زيدٌ مبتدأ، قامَ فعل، أين فاعله؟ فإذن هل حُذف فاعله؟ لا، يقول لك: لا، إذا كان الفاعل ظاهراً في اللفظ هذا لا إشكال فيه؛ قَامَ زَيْدٌ، قام فعل زيد فاعله، الزَّيْدَانِ قَامَا، قَامَا الفاعل هو الألف هذا الضمير. إن كان كذلك فلا إشكال، وإلا إذا لم يكن الفاعل ظاهراً في اللفظ فحينئذٍ نحتاج إلى أن نقول إنه ضمير مستتر، وهذا كله لأجل عدم إمكان حذف الفاعل؛ فنقول في نحو زَيْدٌ قَامَ، قَامَ: فعل ماضٍ مبني على الفتح، والفاعل ضمير مستتر جوازاً تقديره هو، والجملة من الفعل والفاعل في محل رفع خبر المبتدأ، جميل. هذا الحكم الأول من أحكام الفاعل. الحكم الثاني: أَنَّهُ لَا يَجُوزُ تَقَدُّمُهُ عَلَى الْفِعْلِ، فَإِنْ وَجَدَ مَا ظَاهِرُهُ أَنَّهُ فَاعِلٌ مُقَدَّمٌ وَجَبَ تَقْدِيرُ الْفَاعِلِ ضَمِيراً مُسْتَتِراً، وَيَكُونُ الْمُقَدَّمُ إِمَّا مُبْتَدَأً نحو: زَيْدٌ، وَإِمَّا فَاعِلاً بِفِعْلٍ مَحْذُوفٍ نحو: {وَإِنْ أَحَدٌ مِّنَ الْمُشْرِكِينَ اسْتَجَارَكَ}، لِأَنَّ أَدَاةَ الشَّرْطِ لَا تَدْخُلُ عَلَى الْمُبْتَدَأِ، جميل. هنا الحكم الذي، الحكم الثاني من أحكام الفاعل هو أن الترتيب بين الفعل والفاعل دائماً هكذا: فعل أولاً وفاعل بعده، بمعنى أن الفاعل دائماً يأتي بعد الفعل ولا يتقدم عليه. ستقول لي: في نحو زَيْدٌ قَامَ، هل يمكنك أن تقول زَيْدٌ فاعل مقدم وقَامَ فعل جاء بعد الفاعل؟ لا، لا يصح ذلك ولا يجوز، بل تقول: زَيْدٌ مبتدأ كما قلنا في الإعراب، قَامَ فعل، فاعله ضمير مستتر، والجملة الفعلية خبر المبتدأ. وكذلك في قول ربنا سبحانه وتعالى: {وَإِنْ أَحَدٌ مِّنَ الْمُشْرِكِينَ اسْتَجَارَكَ فَأَجِرْهُ حَتَّىٰ يَسْمَعَ كَلَامَ اللَّهِ}، هنا لو فرضنا أن \"إن\" غير موجودة، \"أحدٌ من المشركين استجارك\"، أحدٌ استجارك، لو كان الكلام هكذا لصح لنا أن نقول مثل ما في زيد قامه، نقول: أحدٌ مبتدأ واستجار فعل وفاعله ضمير مستتر والجملة الفعلية خبر المبتدأ، لكن الإشكال هنا ما الذي وقع؟ هو أن \"إن\" هذه الشرطية موجودة، وأداة الشرط هذه تدخل على جملة فعلية ولا تدخل على الجمل الاسمية، لا يمكن أن تدخل على المبتدأ. فلأجل ذلك يعني أن لا بد بعدها من فعل هو فعل الشرط كما سيأتي في موضعه، فإذاً حينئذٍ نقدر فعلاً محذوفاً تقديره: وإن استجارك أحدٌ من المشركين استجارك، واضح؟ لأجل ذلك نقدر فعلاً محذوفاً، ولذلك قال: وَإِمَّا فَاعِلاً بِفِعْلٍ مَحْذُوفٍ نحو: {وَإِنْ أَحَدٌ مِّنَ الْمُشْرِكِينَ اسْتَجَارَكَ}، وعلل عدم إمكان إعراب \"أحد\" مبتدأ بقوله: لِأَنَّ أَدَاةَ الشَّرْطِ لَا تَدْخُلُ عَلَى الْمُبْتَدَأِ. هذا الحكم الثاني. الحكم الثالث قال: وَمِنْهَا أَنَّ فِعْلَهُ يُوَحَّدُ مَعَ تَثْنِيَتِهِ وَجَمْعِهِ كَمَا يُوَحَّدُ مَعَ إِفْرَادِهِ، فَتَقُولُ: قَامَ الزَّيْدَانِ، وَقَامَ الزَّيْدُونَ، كَمَا تَقُولُ: قَامَ زَيْدٌ. قال الله تعالى: {قَالَ رَجُلَانِ}، و {جَاءَ الْمُعَذِّرُونَ}، و {وَقَالَ الظَّالِمُونَ}، و {وَقَالَ نِسْوَةٌ}، واضح؟ إذن هذا هو الأصل، هذه هي الجادة، هذه لغة القرآن، هذه هي اللغة المطردة عند العرب، وهي أن الفعل يكون موحداً، ما معنى موحد؟ يكون على صيغة الواحد \"قَامَ\" مثلاً، مع كون الفاعل قد يكون مثنى قد يكون مفرداً وقد يكون مثنى وقد يكون جماعة؛ فتقول: قام الزيدون كما تقول قام الزيدان وقام الزيدان. ومثّل من القرآن: {قَالَ رَجُلَانِ}، إذن \"قال\" هذا مفرد موحد يعني ورجلان مثنى، {جَاءَ الْمُعَذِّرُونَ} نفس الشيء المعذرون جمع، {قَالَ الظَّالِمُونَ}، {وَقَالَ نِسْوَةٌ} جمع إناث لكن \"قال\" قلنا هذه هي اللغة المطردة. لكن هنالك لغة أخرى لبعض العرب قال: وَمِنَ الْعَرَبِ مَنْ يُلْحِقُ الْفِعْلَ عَلَامَةَ التَّثْنِيَةِ وَالْجَمْعِ إِذَا كَانَ الْفَاعِلُ مُثَنًّى أَوْ مَجْمُوعاً، فَتَقُولُ: قَامَا الزَّيْدَانِ، وَقَامُوا الزَّيْدُونَ، وَقُمْنَ الْهِنْدَاتُ، وتسمى لغة \"أَكَلُونِي الْبَرَاغِيثُ\" لأن هذا اللفظ سُمع من بعضهم، ومنه الحديث: \"يَتَعَاقَبُونَ فِيكُمْ مَلَائِكَةٌ بِاللَّيْلِ وَمَلَائِكَةٌ بِالنَّهَارِ\". إذن هذه اللغة المسماة عند أكثر النحاة لغة \"أكلوني البراغيث\" لأن ذلك سُمع من بعض العرب، يعني بعض العرب قال هذه الكلمة قال: \"أكلوني البراغيث\" فاشتهرت عند النحاة بهذا اللفظ. وابن مالك وأشباهه من النحاة الذين يعظمون الحديث النبوي يقولون: الأفضل أن نسميها لغة \"يتعاقبون الملائكة\" أخذاً من هذا الحديث: \"يَتَعَاقَبُونَ فِيكُمْ مَلَائِكَةٌ بِاللَّيْلِ وَمَلَائِكَةٌ بِالنَّهَارِ\". هذه اللغة فيها إثبات علامة التثنية والجمع في الفعل إذا كان الفاعل مثنى أو مجموعاً، في لغة أكلوني البراغيث يقولون هكذا، لكن في اللغة الأصلية الجادة كيف نقول؟ نقول: أكلني البراغيث، ويتعاقبون ملائكة كيف نقول؟ نقول: يتعاقب فيكم ملائكة، لكن ورد الحديث بهذه الرواية على هذا أو على هذه اللغة، وحتى يعني يوجد في القرآن ما حمل ما حمله بعضهم على هذه اللغة قول الله سبحانه وتعالى: {وَأَسَرُّوا النَّجْوَى الَّذِينَ ظَلَمُوا}، قالوا على لغة أكلوني البراغيث، لأنه الأصل أن يقال: وأسرّ النجوى الذين ظلموا، لكن هنالك طرق أخرى لإعراب الآية وتخريجها على لغة أخرى، لأن لغة أكلوني البراغيث ليست لغة يعني فصيحة، فالأفضل أن لا يحمل عليها شيء من القرآن الكريم. أما الحديث فإنكم تعرفون أن الحديث يمكن أن يروى بالمعنى، يمكن أن يكون الراوي هو الذي أورد الحديث بهذه على هذه اللغة، ولا يكون ذلك بالضرورة من كلام رسول الله صلى الله عليه وسلم، ويمكن أن يكون رسول الله صلى الله عليه وسلم قد حدث قوماً بلغتهم وما أشبه ذلك، جميل. قال: وَالصَّحِيحُ أَنَّ الْأَلِفَ وَالْوَاوَ وَالنُّونَ أَحْرُفٌ دَالَّةٌ عَلَى التَّثْنِيَةِ وَالْجَمْعِ، وَأَنَّ الْفَاعِلَ مَا بَعْدَهَا. بمعنى الذي يريد أن يقوله المصنف هنا أن الصحيح أن هذه اللغة في نحو مثلاً \"يتعاقبون الملائكة\"، أن تكون الواو هنا مجرد حرف دال على الجمع والفاعل هو ملائكة، في نحو نفس الشيء في أكلوني البراغيث ومثلاً في قَامَا الزَّيْدَانِ الألف حرف دال على التثنية والفاعل هو الزيدان وهكذا، وَأَنَّ الْفَاعِلَ مَا بَعْدَهَا. وهذا هو الصحيح الذي اختاره المصنف، والقول الآخر أن هذه اللواحق نفسها ليست مجرد حروف وإنما هي ضمائر وإنها هي الفاعل، والمرفوع بعدها مثلاً يمكنك أن تعربه بدلاً منه؛ فتقول مثلاً في يتعاقبون ملائكة: الواو واو الجماعة فاعل على الأصل، وملائكة بدل من واو الجماعة، جميل. وَمِنْهَا -أي من أحكام الفاعل- قال: وَمِنْهَا أَنَّهُ يَجِبُ تَأْنِيثُ الْفِعْلِ بِتَاءٍ سَاكِنَةٍ فِي آخِرِ الْمَاضِي، وَبِتَاءِ الْمُضَارَعَةِ فِي أَوَّلِ الْمُضَارِعِ إِذَا كَانَ الْفَاعِلُ مُؤَنَّثاً حَقِيقِيَّ التَّأْنِيثِ، نحو: قَامَتْ هِنْدٌ، وَتَقُومُ هِنْدٌ. إذا كان الفاعل حقيقي التأنيث، يعني امرأة أو أنثى من مثلاً حتى من النساء أو من غير النساء لكن أنثى حقيقية، إذا كان الفاعل مؤنثاً حقيقي التأنيث كهند وزينب وغير ذلك، فالفعل يجب أن يؤنث؛ إذا كان ماضياً يؤنث بتاء التأنيث الساكنة في آخره فتقول: قَامَتْ هِنْدٌ، وإذا كان الفعل مضارعاً يؤنث بالتاء في أوله تاء المضارعة فتقول: تَقُومُ هِنْدٌ. هذا بالنسبة لـ الفاعل إذا كان حقيقياً، يقولون حقيقي التأنيث: ما له فرج، ومجازي التأنيث: ما لا فرج له، جميل. مجازي التأنيث قال: وَيَجُوزُ تَرْكُ التَّاءِ إِنْ كَانَ الْفَاعِلُ مَجَازِيَّ التَّأْنِيثِ، نحو: طَلَعَ الشَّمْسُ. الشمس حقيقة ليست أنثى حقيقة وإنما أنثى على جهة المجاز أو مؤنثة، فتقول: طلعت الشمس، وييجوز أن تقول: طلع الشمس. وكما في قوله تعالى: {وَمَا كَانَ صَلَاتُهُمْ عِندَ الْبَيْتِ إِلَّا مُكَاءً وَتَصْدِيَةً}، الشاهد قوله سبحانه: {وَمَا كَانَ صَلَاتُهُمْ}، كان الصلاة؛ الصلاة مجازي التأنيث، فيجوز أن تقول: كانت صلاتهم، أو أن تقول: كان صلاتهم. قال: وَحُكْمُ الْمُثَنَّى وَالْمَجْمُوعِ جَمْعَ تَصْحِيحٍ حُكْمُ الْمُفْرَدِ؛ فَتَقُولُ: قَامَ الزَّيْدَانِ، وَقَامَ الزَّيْدُونَ، وَقَامَتِ الْمُسْلِمَتَانِ، وَقَامَتِ الْمُسْلِمَاتُ، واضح؟ وَأَمَّا جَمْعُ التَّكْسِيرِ فَحُكْمُهُ حُكْمُ الْمَجَازِيِّ التَّأْنِيثِ. جمع التكسير مثل مجازي التأنيث، مثل الشمس والصلاة ونحو ذلك؛ تقول: قَامَ الرِّجَالُ، وَقَامَتِ الرِّجَالُ يجوز ذلك، وقام الهنود وقامت الهنود (هنود جمع هند). فهنا جمع التكسير ليس جمع المذكر السالم أو جمع المؤنث السالم، لا، جمع التكسير يعامل معاملة مجازي التأنيث فلأجل ذلك يصح لك أن تقول قامت الرجال كما تقول قام الرجال. اشتهر عند بعضهم قولهم: \"كل جمع مؤنث\"، وذكروا عن الزمخشري أنه من ضمن أبيات له أنه قال: \"إن قومي تجمعوا وبقتلي تحدثوا، لا أبالي بجمعهم كل جمع مؤنث\" فالمقصود جمع التكسير يعني كالرجال ونحو ذلك. حكم آخر من أحكام الفاعل قال: وَمِنْهَا أَنَّ الْأَصْلَ فِيهِ أَنْ يَلِيَ فِعْلَهُ ثُمَّ يُذْكَرُ الْمَفْعُولُ بهذا الترتيب: فعل فاعل مفعول، نحو: {وَوَرِثَ سُلَيْمَانُ دَاوُودَ}؛ وَوَرِثَ: فعل ماضٍ مبني على الفتح، سُلَيْمَانُ: فاعل مرفوع وعلامة رفعه الضمة الظاهرة على آخره ولم ينون لأنه ممنوع من الصرف للعالمية والعجمة، دَاوُودَ: مفعول به منصوب وعلامة نصبه الفتحة الظاهرة على آخره ولم ينون كذلك لأنه ممنوع من الصرف العالمية والعجمة. لكن قد يعاد قد يقدم ويؤخر، قال: وَقَدْ يَتَأَخَّرُ الْفَاعِلُ وَيَتَقَدَّمُ الْمَفْعُولُ جَوَازاً، نحو: {وَلَقَدْ جَاءَ آلَ فِرْعَوْنَ النُّذُرُ}. جَاءَ: فعل ماضٍ مبني على الفتح، آلَ: مفعول به منصوب مقدم وعلامة نصبه الفتحة الظاهرة على آخره وهو مضاف، فِرْعَوْنَ: مضاف إليه مجرور وعلامة جره الفتحة النائبة عن الكسرة لأنه ممنوع من الصرف للعالمية، النُّذُرُ: فاعل مؤخر مرفوع وعلامة رفعه الضمة الظاهرة على آخره. لكن هذا التقديم والتأخير جائز وليس واجباً، لأنه يمكن أن يقال في غير القرآن: ولقد جاء النذر آل فرعون، كما قيل: ولقد جاء آل فرعون النذر، يجوز التقديم والتأخير. وقد يكون هذا التقديم والتأخير واجباً قال: وَوُجُوباً، ما معنى وجوباً؟ أي لسبب اقتضى ذلك، نحو: {شَغَلَتْنَا أَمْوَالُنَا}، واضح؟ شَغَلَتْنَا أَمْوَالُنَا؛ شَغَلَ: فعل ماضٍ مبني على الفتح، التاء: تاء التأنيث الساكنة، نا: ضمير متصل مبني في محل نصب مفعول به مقدم، أَمْوَالُ: فاعل مؤخر مرفوع وعلامة رفعه الضمة الظاهرة على آخره وهو مضاف، نا: ضمير متصل مبني في محل جر مضاف إليه، جميل. فهنا لما قلنا بأن التقديم والتأخير هنا واجب، لأنه لو قدمنا الفاعل حينئذٍ، لو قلنا: شغلت أموالنا نا، حينئذٍ نحتاج إلى أن نأتي يعني الضمير الذي هو المفعول به أن نأتي به متأخراً في مكانه الأصلي، لكن حينئذٍ بما أنه ضمير متصل سنحتاج إلى فصله واضح، فيلزم انفصال الضمير الذي هو مفعول فنقول: شغلت أموالنا إيانا، هكذا نقول. والقاعدة التي ذكرناها من قبل أنه لا يؤتى بالضمير منفصلاً متى أمكن الإتيان به متصلاً، هذا ذكرناه في فصل الضمير، والإتيان بالضمير هنا متصلاً ممكن، يكفي أن نأتي به مقدماً متصلاً، فلأجل ذلك نقول هنا يجب أن يكون الترتيب هكذا؛ يجب تقديم المفعول على الفاعل، لأنه السبب في هذه الحالة، السبب أنه لو جيء بالمفعول مؤخراً لوجب انفصال الضمير، والحال أنه لا يؤتى بالضمير منفصلاً إذا كان بالإمكان أن يؤتى به متصلاً. وقد يكون هناك أسباب أخرى نعم، نعم في مثل: {وَإِذِ ابْتَلَىٰ إِبْرَاهِيمَ رَبُّهُ}، ابْتَلَى: فعل ماضٍ مبني على الفتح المقدر، إِبْرَاهِيمَ: مفعول به منصوب مقدم، رَبُّ: فاعل مرفوع مؤخر، واضح؟ فهنا أيضاً التقديم والتأخير واجب، لمَ؟ لأنه لو أُخر المفعول فقيل: ابتلى ربه إبراهيم، حينئذٍ ما الذي يقع؟ ابتلى ربه إبراهيم، الهاء في \"ربه\" ترجع على إبراهيم، فيكون الضمير حينئذٍ -الذي هو الهاء- يكون هذا الضمير عائداً على متأخر لفظاً ورتبة، متأخر لفظاً، هذا يتكرر كثيرا في كلام النحاة: العود عود الضمير على متأخر لفظاً ورتبة. ما معنى متأخر لفظاً؟ أي الضمير هنا وهو يعود على شيء يأتي بعده متأخر يأتي بعده في اللفظ، هذا هو معنى عائد على متأخر في اللفظ. ومتأخر رتبة لمَ؟ لأننا قلنا إن إبراهيم مفعول به، فهذا الضمير يعود على متأخر؛ الضمير الموجود مع الفاعل يرجع على المفعول، والمفعول متأخر في المرتبة بالمقارنة مع الفاعل، والقاعدة عندهم أن الأصل -قد يعدل عن هذا الأصل- لكن الأصل أن الضمير لا يعود على متأخر لفظاً ورتبة؛ لذلك لا يمكنك أن تقول: ابتلى ربه إبراهيم، لا بد يجب أن تقول: {وَإِذِ ابْتَلَىٰ إِبْرَاهِيمَ رَبُّهُ} فتقدم المفعول على الفاعل. قال: وَقَدْ يَتَقَدَّمُ الْمَفْعُولُ عَلَى الْفِعْلِ وَالْفَاعِلِ مَعاً. ما سبق هو في تقدم المفعول على الفاعل وحده، الآن تقدم المفعول على الفعل والفاعل معاً جَوَازاً وَأَيْضاً وُجُوباً. جَوَازاً نحو: {فَرِيقًا كَذَّبُوا وَفَرِيقًا يَقْتُلُونَ}؛ فَرِيقًا: مفعول به منصوب مقدم، كَذَّبُوا: كَذَّبَ فعل ماضٍ مبني على الضم لاتصاله بواو الجماعة، وواو الجماعة فاعل. فإذن الفعل والفاعل، وجاء المفعول به مقدماً عليهما، ولكن هذا تقديم جائز لأنه يمكن أن يقال في غير القرآن: كذبوا فريقاً، ونفس الشيء {وَفَرِيقًا يَقْتُلُونَ} (يقتلون فريقاً)، هذا تقديم جائز. وَوُجُوباً نحو: {فَأَيَّ آيَاتِ اللَّهِ تُنكِرُونَ}، أَيَّ: مفعول به مقدم، تُنكِرُونَ: فعل وفاعله. لمَ هذا التقديم واجب؟ إذن هنا تقدم المفعول على الفعل والفاعل، لكن لمَ هو تقديم واجب؟ لأن \"أَيَّ\" اسم استفهام، وأسماء الاستفهام كما يقولون لها صدر الكلام. قال: لِأَنَّ الِاسْتِفْهَامَ لَهُ صَدْرُ الْكَلَامِ، ما معنى له صدر الكلام؟ يعني اسم الاستفهام يكون في بداية الكلام دائماً؛ فلا يمكنك أن تقول: تنكرون أيَّ آيات الله، لا، اسم الاستفهام له صدر الكلام فلأجل ذلك يقدم، لأن تأخير المفعول حينئذٍ ينافي هذه الصدارة التي تحدثنا عنها. فإذن هذا هذه بعض الأحكام الجميلة عن الفاعل والترتيب، خاصة هذا الحكم الأخير المتعلق بالترتيب بين الفعل والفاعل والمفعول. انتهينا من باب الفاعل، وبعده يأتي باب المفعول الذي لم يسمى فاعله. أقول قولي هذا وأستغفر الله لي ولكم، والحمد لله رب العالمين.",
    "blocks_search_text": "تعريف الفاعل وأقسامه هُوَ الِاسْمُ الْمَرْفُوعُ الْمَذْكُورُ قَبْلَهُ فِعْلُهُ، أو ما في تأويل الفعل... إما أن يكون ظاهراً أو أن يكون مضمراً. عرف الشيخ الفاعل بأنه الاسم المرفوع الذي يسبقه فعل أو ما يشبهه (كاسم الفاعل والمصدر)، موضحاً أن الفاعل ينقسم إلى اسم ظاهر أو ضمير مستتر أو متصل. أحكام الفاعل الأساسية وَلِلْفَاعِلِ أَحْكَامٌ؛ مِنْهَا: أَنَّهُ لَا يَجُوزُ حَذْفُهُ، لأنه عمدة... الحكم الثاني: أَنَّهُ لَا يَجُوزُ تَقَدُّمُهُ عَلَى الْفِعْلِ... الحكم الثالث: أَنَّ فِعْلَهُ يُوَحَّدُ مَعَ تَثْنِيَتِهِ وَجَمْعِهِ. شرح الشيخ أن الفاعل عمدة لا يحذف، ولا يتقدم على فعله، وأن الأصل في الفعل أن يبقى مفرداً حتى لو كان الفاعل مثنى أو جمعاً، مع الإشارة للغة 'أكلوني البراغيث'. تأنيث الفعل وتأخير الفاعل أَنَّهُ يَجِبُ تَأْنِيثُ الْفِعْلِ... إِذَا كَانَ الْفَاعِلُ مُؤَنَّثاً حَقِيقِيَّ التَّأْنِيثِ... وَيَجُوزُ تَرْكُ التَّاءِ إِنْ كَانَ الْفَاعِلُ مَجَازِيَّ التَّأْنِيثِ... وَقَدْ يَتَأَخَّرُ الْفَاعِلُ وَيَتَقَدَّمُ الْمَفْعُولُ جَوَازاً وَوُجُوباً. فصّل الشيخ في وجوب تأنيث الفعل مع المؤنث الحقيقي وجوازه مع المجازي، وبيّن أحكام الترتيب بين الفاعل والمفعول به، موضحاً حالات التقديم والتأخير بينهما.",
