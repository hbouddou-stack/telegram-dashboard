      },
      {
        "ts": "3:39",
        "sec": 219,
        "text": "الباب. دوماً هذا دور العلماء؛ العالم ينبري للرد على",
        "video_link": null
      },
      {
        "ts": "3:47",
        "sec": 227,
        "text": "الضلالات وعلى الانحرافات حفاظاً على عقائد المسلمين، لأن هذا هو دور العالم.",
        "video_link": null
      },
      {
        "ts": "3:55",
        "sec": 235,
        "text": "توحيد الأسماء والصفات؛ فما هو توحيد الأسماء والصفات؟ الأسماء؛ ما المقصود بالأسماء؟ الأسماء",
        "video_link": null
      },
      {
        "ts": "4:04",
        "sec": 244,
        "text": "جمع اسم، والاسم في اللغة هو اللفظ الموضوع للتمييز والتعيين؛",
        "video_link": null
      },
      {
        "ts": "4:11",
        "sec": 251,
        "text": "تريد أن تعين شيئاً تعطيه اسماً، تريد أن تميزه تعطيه اسماً، هذا هو الهدف من التسمية:",
        "video_link": null
      },
      {
        "ts": "4:21",
        "sec": 261,
        "text": "هو التمييز والتعيين؛ أن تعينه بالضبط، فتقول مثلاً: هذا شيء اسمه كأس، فتعرفه.",
        "video_link": null
      },
      {
        "ts": "4:29",
        "sec": 269,
        "text": "فأيضاً هناك مجموعة من الأمور فلكي تميز الكأس وتقول ذلك الشيء اسمه كأس، إذاً أصلاً",
        "video_link": null
      },
      {
        "ts": "4:36",
        "sec": 276,
        "text": "هو لوحده تعينه وأيضاً إذا اختلط بأمور أخرى فإنك تميزه. هذا هو الاسم؛ الاسم هو",
        "video_link": null
      },
      {
        "ts": "4:45",
        "sec": 285,
        "text": "اللفظ الموضوع للتمييز والتعيين. أسماء الله ما هي أسماء الله؟ أسماء الله",
        "video_link": null
      },
      {
        "ts": "4:49",
        "sec": 289,
        "text": "وسلم، هكذا باختصار وبكل بساطة. ما هي أسماء الله؟ ماذا نقصد بأسماء الله؟ هي ما سمى",
        "video_link": null
      },
      {
        "ts": "4:52",
        "sec": 292,
        "text": "في الاصطلاح هي ما سمى الله به نفسه في كتابه أو على لسان رسوله صلى الله عليه",
        "video_link": null
      },
      {
        "ts": "5:07",
        "sec": 307,
        "text": "الله به نفسه، الله تعالى سمى نفسه بأسماء؛ إذن ما سمى الله به نفسه في كتابه أو على",
        "video_link": null
      },
      {
        "ts": "5:15",
        "sec": 315,
        "text": "لسان رسوله صلى الله عليه وسلم. إذن هي أسماء ثبت لدينا أن الله تعالى أخبرنا أنها من",
        "video_link": null
      },
      {
        "ts": "5:24",
        "sec": 324,
        "text": "أسمائه، وما ما هي هذه المصادر؟ هو كلامه سبحانه وتعالى في القرآن الكريم ثم في السنة",
        "video_link": null
      },
      {
        "ts": "5:32",
        "sec": 332,
        "text": "النبوية الصحيحة. وقد تقدم معنا أن من مصادر علم العقيدة والتوحيد: السنة النبوية",
        "video_link": null
      },
      {
        "ts": "5:38",
        "sec": 338,
        "text": "الصحيحة، أما الأحاديث الضعيفة فلا تُعتبر في باب العقائد. قال تعالى: {وَلِلَّهِ الْأَسْمَاءُ",
        "video_link": null
      },
      {
        "ts": "5:45",
        "sec": 345,
        "text": "الْحُسْنَىٰ فَادْعُوهُ بِهَا}؛ فعندنا آيات أخبرتنا أن الله تعالى له أسماء، وعندنا آيات",
        "video_link": null
      },
      {
        "ts": "5:53",
        "sec": 353,
        "text": "فهمنا أنها من أسماء الله؛ أن هناك أسماء هي من أسماء الله تعالى بدون أن يقول تعالى إن من أسمائي كذا، مثلاً قوله تعالى:",
        "video_link": null
      },
      {
        "ts": "6:03",
        "sec": 363,
        "text": "{الْحَمْدُ لِلَّهِ رَبِّ الْعَالَمِينَ * الرَّحْمَٰنِ الرَّحِيمِ}، الرَّحْمَٰنِ الرَّحِيمِ؛ ففهمنا أن من أسماء الله",
        "video_link": null
      },
      {
        "ts": "6:11",
        "sec": 371,
        "text": "تعالى الرحمن ومن أسمائه أيضاً الرحيم. طبعاً من صفاته الرحمة ولكن {الرَّحْمَٰنِ الرَّحِيمِ} هكذا بالتعريف دل هذا على أن هذين",
        "video_link": null
      },
      {
        "ts": "6:20",
        "sec": 380,
        "text": "اللفظين هما من أسماء الله تعالى. إذن عندنا دليل عام هو قوله تعالى: {وَلِلَّهِ الْأَسْمَاءُ الْحُسْنَىٰ}، وعندنا أدلة خاصة وهي",
        "video_link": null
      },
      {
        "ts": "6:29",
        "sec": 389,
        "text": "الأسماء التي جاءت باللفظ. قال تعالى أيضاً:",
        "video_link": null
      },
      {
        "ts": "6:36",
        "sec": 396,
        "text": "{اللَّهُ لَا إِلَٰهَ إِلَّا هُوَ ۖ لَهُ الْأَسْمَاءُ الْحُسْنَىٰ} في سورة طه. وروى الشيخان عن أبي هريرة ردي",
        "video_link": null
      },
      {
        "ts": "6:43",
        "sec": 403,
        "text": "الله عنه أن رسول الله صلى الله عليه وسلم قال: \"إِنَّ لِلَّهِ تِسْعَةً وَتِسْعِينَ اسْمًا،",
        "video_link": null
      },
      {
        "ts": "6:51",
        "sec": 411,
        "text": "مَنْ أَحْصَاهَا دَخَلَ الْجَنَّةَ\". إِنَّ لِلَّهِ تِسْعَةً وَتِسْعِينَ اسْمًا، طبعاً العلماء قالوا هذا لا يفيد الحصر ولكن من",
        "video_link": null
      },
      {
        "ts": "6:59",
        "sec": 419,
        "text": "أحصى لله تسعة وتسعين اسماً دخل الجنة. هذا ما يتعلق في أسماء الله تعالى في الاصطلاح. أما",
        "video_link": null
      },
      {
        "ts": "7:07",
        "sec": 427,
        "text": "الصفات؛ نقول توحيد الأسماء والصفات، أو توحيد أسماء الله تعالى وصفاته، حين نقول توحيد الأسماء والصفات فإننا نعني أسماء",
        "video_link": null
      },
      {
        "ts": "7:16",
        "sec": 436,
        "text": "الله تعالى وصفاته بالطبع؛ نقول هكذا اختصاراً توحيد الأسماء والصفات. بعض الناس المبتدئ ربما يقول: ما المقصود",
        "video_link": null
      },
      {
        "ts": "7:23",
        "sec": 443,
        "text": "بالأسماء؟ ما المقصود بالصفات؟ بعضهم يقول لكي يزيل هذا الغموض فيقول: توحيد أسماء",
        "video_link": null
      },
      {
        "ts": "7:30",
        "sec": 450,
        "text": "الله وتوحيد صفات الله. الصفات جمع صفة، وهي في اللغة ما يقوم",
        "video_link": null
      },
      {
        "ts": "7:37",
        "sec": 457,
        "text": "بالشيء من الأمور الذاتية أو الفعلية أو المعنوية؛ ما يقوم بالشيء، نصف الشيء من جهة ذاته أو",
        "video_link": null
      },
      {
        "ts": "7:48",
        "sec": 468,
        "text": "فعله أو معانيه؛ الصفات المعنوية أو الجانب المعنوي. فمن الأمور الذاتية نقول مثلاً: هذا",
        "video_link": null
      },
      {
        "ts": "7:57",
        "sec": 477,
        "text": "شخص طويل، الآن نحن في اللغة، هذا شخص قصير،",
        "video_link": null
      },
      {
        "ts": "8:02",
        "sec": 482,
        "text": "هذا شخص نحيف، فنحن نصف ذاته؛ إذن هذا من من الأمور الذاتية. ثم عندنا من الأمور",
        "video_link": null
      },
      {
        "ts": "8:11",
        "sec": 491,
        "text": "الفعلية فنقول مثلاً: هذا شخص جالس، هذا شخص",
        "video_link": null
      },
      {
        "ts": "8:16",
        "sec": 496,
        "text": "قائم، نصف شيئاً متعلقاً بفعله، نصفه من جهة الفعل؛ أو شخص قادم، أو شخص منصرف.",
        "video_link": null
      },
      {
        "ts": "8:26",
        "sec": 506,
        "text": "هذا هذه صفة في الجانب كلها صفات؛ النوع الأول يتعلق بالذات والنوع الثاني",
        "video_link": null
      },
      {
        "ts": "8:34",
        "sec": 514,
        "text": "يتعلق بالفعل. ثم عندنا الصفات المعنوية؛ أمور معنوية لا تُرى في ذاته أو في فعله",
        "video_link": null
      },
      {
        "ts": "8:43",
        "sec": 523,
        "text": "ولكن تُرى إما بالاحتكاك معه أو بالإخبار ونحو ذلك؛ مثل هذا شخص شجاع، نحن نصف شيئاً",
        "video_link": null
      },
      {
        "ts": "8:52",
        "sec": 532,
        "text": "معنوياً لا يظهر، يعني نصل إليه",
        "video_link": null
      },
      {
        "ts": "8:59",
        "sec": 539,
        "text": "ونراه من خلاله كما قلت الاحتكاك أو الإخبار عنه ونحو ذلك؛ هذا شخص كريم،",
        "video_link": null
      },
      {
        "ts": "9:07",
        "sec": 547,
        "text": "هذا شخص شهم، هذه صفة تتعلق بالأمور المعنوية. إذن أعيد: الصفة إما تتعلق",
        "video_link": null
      },
      {
        "ts": "9:13",
        "sec": 553,
        "text": "بالأمور الذاتية كطويل قصير، أو أمور فعلية كقائم جالس، أو أمور معنوية",
        "video_link": null
      },
      {
        "ts": "9:21",
        "sec": 561,
        "text": "كشجاع وكريم؛ هذا من جهة اللغة. صفات الله في علم العقيدة وفي علم التوحيد ماذا نقصد",
        "video_link": null
      },
      {
        "ts": "9:29",
        "sec": 569,
        "text": "بصفات الله؟ هي ما وصف الله به نفسه في كتابه، في كتابه أو على لسان رسوله صلى الله عليه",
        "video_link": null
      },
      {
        "ts": "9:38",
        "sec": 578,
        "text": "وسلم باختصار شديد. كما قلنا في الأسماء؛ ما هي أسماء الله تعالى؟ هي ما سمى الله تعالى به نفسه في كتابه أو على لسان رسوله صلى",
        "video_link": null
      },
      {
        "ts": "9:47",
        "sec": 587,
        "text": "الله عليه وسلم، هكذا باختصار نعم هكذا بكل بساطة. ما هي صفات الله؟ ما هي صفات الله؟ هي ما وصف الله",
        "video_link": null
      },
      {
        "ts": "9:55",
        "sec": 595,
        "text": "تعالى به نفسه في كتابه أو على لسان رسوله صلى الله عليه وسلم؛ يعني الأمور عندها علاقة بالمصدرية، فلا نسمي الله تعالى من",
        "video_link": null
      },
      {
        "ts": "10:05",
        "sec": 605,
        "text": "عندنا ولا نصف الله تعالى من عندنا، بل نسميه بما سمى به نفسه ونصفه بما وصف به",
        "video_link": null
      },
      {
        "ts": "10:13",
        "sec": 613,
        "text": "نفسه، على بعض التفصيل سنذكره لاحقاً. فهي أيضاً صفات ذاتية وصفات فعلية وصفات معنوية، وسيأتي بيان كل",
        "video_link": null
      },
      {
        "ts": "10:21",
        "sec": 621,
        "text": "هذا لاحقاً؛ هي صفات ذاتية: \"الكبير\" هذا صفة للذات جل جلاله نحن لا",
        "video_link": null
      },
      {
        "ts": "10:29",
        "sec": 629,
        "text": "نعرفها ولكن نعرف أن الله تعالى كبير بذاته. من الصفات الفعلية أنه",
        "video_link": null
      },
      {
        "ts": "10:36",
        "sec": 636,
        "text": "يتكلم، أنها من صفاته الكلام؛ هذه صفة فعلية وهي أيضاً صفة ذاتية كما سيأتي معنا.",
        "video_link": null
      },
      {
        "ts": "10:44",
        "sec": 644,
        "text": "ومن الصفات المعنوية أنه كريم، أنه رحيم، هذه كلها صفات معنوية. قال تعالى",
        "video_link": null
      },
      {
        "ts": "10:52",
        "sec": 652,
        "text": "-من هذه كلها تتعلق ب هذه الآية أو الأدلة سنذكرها تتعلق بالصفات- {لَمْ يَلِدْ وَلَمْ يُولَدْ}؛",
        "video_link": null
      },
      {
        "ts": "11:02",
        "sec": 662,
        "text": "هذه من الصفات الذاتية، {لَا تَأْخُذُهُ سِنَةٌ وَلَا نَوْمٌ}، {الرَّحْمَٰنُ عَلَى الْعَرْشِ اسْتَوَىٰ}، {وَكَلَّمَ اللَّهُ مُوسَىٰ",
        "video_link": null
      },
      {
        "ts": "11:09",
        "sec": 669,
        "text": "تَكْلِيمًا}، كل هذا يدخل في صفات الله تعالى؛ أي يتعلق بأمور إما في ذات الله أو في",
        "video_link": null
      },
      {
        "ts": "11:17",
        "sec": 677,
        "text": "أفعاله أو في أمور معنوية. وفي السنة وصف النبي صلى الله عليه وسلم في كثير من الأحاديث الله سبحانه وتعالى،",
        "video_link": null
      },
      {
        "ts": "11:26",
        "sec": 686,
        "text": "فقال مثلاً: \"إِنَّكُمْ لا تَدْعُونَ أَصَمَّ وَلا غَائِبًا، إِنَّكُمْ تَدْعُونَ سَمِيعًا قَرِيبًا\"، \"إِنَّكُمْ لا تَدْعُونَ أَصَمَّ",
        "video_link": null
      },
      {
        "ts": "11:33",
        "sec": 693,
        "text": "وَلا غَائِبًا، إِنَّكُمْ تَدْعُونَ سَمِيعًا قَرِيبًا\"؛ فوصفه بأنه سميع قريب. وفي حديث الدجال قال عليه الصلاة والسلام:",
        "video_link": null
      },
      {
        "ts": "11:41",
        "sec": 701,
        "text": "\"إِنَّ اللَّهَ لَيْسَ بِأَعْوَرَ، وَإِنَّ الْمَسِيحَ الدَّجَّالَ أَعْوَرُ\". وقال عليه الصلاة والسلام: \"اشْتَدَّ غَضَبُ اللَّهِ",
        "video_link": null
      },
      {
        "ts": "11:50",
        "sec": 710,
        "text": "عَلَى قَوْمٍ فَعَلُوا بِنَبِيِّهِ كَذَا كَذَا وَكَذَا\" يشير إلى رباعيته، فذكر أن الله تعالى من صفاته الغضب؛ أنه يغضب",
        "video_link": null
      },
      {
        "ts": "12:00",
        "sec": 720,
        "text": "مثلاً. أحد الصحابة كان دوماً يقرأ الإخلاص؛ قال عليه الصلاة والسلام: \"أَخْبِرُوهُ أَنَّ اللَّهَ عَزَّ وَجَلَّ يُحِبُّهُ\"، من صفاته أن الله",
        "video_link": null
      },
      {
        "ts": "12:09",
        "sec": 729,
        "text": "تعالى يحب. ووصف أيضاً بأن الله تعالى يرضى، ووصف أنه يضحك ويتعجب وغير ذلك ويستحيي،",
        "video_link": null
      },
      {
        "ts": "12:18",
        "sec": 738,
        "text": "وغير ذلك من الصفات. وطبعاً إثباتها نحتاج فيه إلى شيء من القواعد، إثبات هاته الصفات؛ لأنها نحن نثبتها نحن نتحدث الآن فقط عن",
        "video_link": null
      },
      {
        "ts": "12:28",
        "sec": 748,
        "text": "الأدلة، ولكن في إثبات هاته الصفات هناك شيء من القواعد حتى لا يقع الإنسان في محظورين:",
        "video_link": null
      },
      {
        "ts": "12:36",
        "sec": 756,
        "text": "التشبيه والتعطيل؛ أن يعطل الإنسان هذه الصفة أو أن يشبه",
        "video_link": null
      },
      {
        "ts": "12:43",
        "sec": 763,
        "text": "الله تعالى من جهة الصفة، وهذا سأذكره. أما توحيد الأسماء والصفات ما هو توحيد الأسماء والصفات؟ ما المقصود بتوحيد",
        "video_link": null
      },
      {
        "ts": "12:50",
        "sec": 770,
        "text": "الأسماء والصفات بشيء من البيان؟ قلنا إن إنه هو إفراد الله بذاته، ويمكن أن نقول",
        "video_link": null
      },
      {
        "ts": "12:57",
        "sec": 777,
        "text": "أيضاً: هو الإيمان بأسماء الله تعالى وصفاته وإثباتها له بما يليق بجلاله، هذا هو توحيد",
        "video_link": null
      },
      {
        "ts": "13:04",
        "sec": 784,
        "text": "الأسماء والصفات، أو الإمامة بالله من جهة أسمائه وصفاته. ما هو الإيمان بأسماء الله تعالى وصفاته؟ الإيمان عنده علاقة بالتوحيد؛",
        "video_link": null
      },
      {
        "ts": "13:12",
        "sec": 792,
        "text": "هو الإيمان بأسمائه وصفاته وإثباتها له بما يليق بجلاله. لا نكتفي",
        "video_link": null
      },
      {
        "ts": "13:20",
        "sec": 800,
        "text": "بالإيمان؛ نعتقدها ونثبتها لكي نبين بعض الأمور التي وقع فيها المعطلة والمشبهة،",
        "video_link": null
      },
      {
        "ts": "13:27",
        "sec": 807,
        "text": "أنهم أيضاً يؤمنون بأسماء أسماء الله تعالى وصفاته هم أيضاً يؤمنون، ولكن أين وقع الخلل؟ في",
        "video_link": null
      },
      {
        "ts": "13:33",
        "sec": 813,
        "text": "الإثبات؛ هؤلاء أثبتوها وعطلوها، وأولئك أثبتوها",
        "video_link": null
      },
      {
        "ts": "13:40",
        "sec": 820,
        "text": "ومثلوها. التعطيل هو الإثبات اللفظي فقط؛ يقولون مثلاً رحيم بدون رحمة، غفور بدون",
        "video_link": null
      },
      {
        "ts": "13:49",
        "sec": 829,
        "text": "مغفرة، سميع بدون سمع -هذا مثال فقط و يعني نفصل لاحقاً- سميع بدون سمع كالمعتزلة",
        "video_link": null
      },
      {
        "ts": "13:57",
        "sec": 837,
        "text": "وغيرهم والجهمية وغيرهم. مثلاً يقولون: إذا قلت إن الله تعالى يسمع فقد شبهته، لا بد أن",
        "video_link": null
      },
      {
        "ts": "14:04",
        "sec": 844,
        "text": "تزيل صفة السمع لأن السمع هو ما يفعله الإنسان، هو الحاسة الموجودة في الإنسان؛ فإذاً الله تعالى سميع فقط، نثبت الاسم فقط",
        "video_link": null
      },
      {
        "ts": "14:14",
        "sec": 854,
        "text": "أن من أسمائه السميع، ومن صفاته لا نقول إن الله تعالى يسمع؛ لأن إذا قلنا إن إنه يسمع",
        "video_link": null
      },
      {
        "ts": "14:20",
        "sec": 860,
        "text": "فإننا نشبهه. لذلك يعني ينبغي الحذر في هذه المباحث لأن ينبغي السير أن فيها يعني",
        "video_link": null
      },
      {
        "ts": "14:29",
        "sec": 869,
        "text": "مضلة الأفهام إن لم يتمسك الإنسان بظواهر الكتاب والسنة، والقاعدة التي سنذكرها إن شاء الله تعالى لاحقاً وهي الأمرار؛ كما",
        "video_link": null
      },
      {
        "ts": "14:39",
        "sec": 879,
        "text": "جاءت بدون التفصيل والتدقيق والخوض في الكيفيات. أمروها كما جاءت كما قال مالك",
        "video_link": null
      },
      {
        "ts": "14:45",
        "sec": 885,
        "text": "والشافعي وأحمد وغيرهم من الأئمة؛ من أئمة أهل السنة؛ أن نمرر الأسماء والصفات كما",
        "video_link": null
      },
      {
        "ts": "14:52",
        "sec": 892,
        "text": "جاءت لا نخوض فيها. طبعاً نتأمل ونتدبر ونتعبد الله تعالى بأسمائه وصفاته ولكن لا",
        "video_link": null
      },
      {
        "ts": "14:59",
        "sec": 899,
        "text": "يُخاض فيها بل نتعبد بمقتضاها. مثلاً في الثلث الأخير من الليل ينزل ربنا سبحانه وتعالى، هذا ثبت في الحديث، فلا نخوض في كيف",
        "video_link": null
      },
      {
        "ts": "15:07",
        "sec": 907,
        "text": "ينزل؛ هل ينزل هنا ولا ينزل هناك؟ هذا كله خوض في الكيفيات التي لا يمكن فهمها. نفهم أن الله تعالى يكون في السماء الدنيا في",
        "video_link": null
      },
      {
        "ts": "15:15",
        "sec": 915,
        "text": "الثلث الأخير من الليل، فما الذي ينبغي عليك أن تفعله أيها المسلم؟ أن تقوم وتصلي وتدعو الله تعالى أنه يكون قريباً منك؛ هل",
        "video_link": null
      },
      {
        "ts": "15:22",
        "sec": 922,
        "text": "ينزل؟ هل ينتقل؟ هل يتحرك؟ هذا كله لا دخل لك فيه لأنك لا تعرف ذاته، فبالتالي لن تعرف",
        "video_link": null
      },
      {
        "ts": "15:29",
        "sec": 929,
        "text": "صفات أفعال صفات أفعاله. أنت لا تعرف الذات الإلهية كيف هي، فلا يمكنك أن تتعرف على",
        "video_link": null
      },
      {
        "ts": "15:36",
        "sec": 936,
        "text": "الصفة والكيفيات، والقول في الصفة كالقول في الذات؛ ما يُقال في الذات الذات الإلهية لا",
        "video_link": null
      },
      {
        "ts": "15:44",
        "sec": 944,
        "text": "نعرف كيف هي. أنا حين أقول لك وضعت شيئاً فوق مائدة، أنت لا يمكنك أن تتعرف عن هذا الشيء، ولله المثل الأعلى، هذا هذه أمور في",
        "video_link": null
      },
      {
        "ts": "15:53",
        "sec": 953,
        "text": "في المخلوقات فكيف بالخالق؟! في الجمادات فكيف بالله تعالى؟! قال لك شخص: \"وضعت شيئاً فوق المائدة\"، هل",
        "video_link": null
      },
      {
        "ts": "16:02",
        "sec": 962,
        "text": "يمكنك أن تتعرف كيف وُضع هذا الشيء؟ لا، لأنك لم تخبر عن ذات الشيء، لا تعرفه؛ فبالتالي",
        "video_link": null
      },
      {
        "ts": "16:11",
        "sec": 971,
        "text": "لا يمكنك أن تعرف كيف تم وضعه. ولكن إذا قال لك شخص: \"وضعت كأساً فوق المائدة\"، يمكنك",
        "video_link": null
      },
      {
        "ts": "16:18",
        "sec": 978,
        "text": "أن تتخيل كأساً، وإن كان تخيلك قد لا يكون مطابقاً",
        "video_link": null
      },
      {
        "ts": "16:25",
        "sec": 985,
        "text": "بالكلية لما فعله ذلك الشخص، ولكن على كل حال الكأس تعرفه فتقيسه، تقول: نعم الكأس،",
        "video_link": null
      },
      {
        "ts": "16:32",
        "sec": 992,
        "text": "ربما بعضكم الآن تخيل كأساً من الزجاج، شخص آخر ربما تخيل كأساً من البلاستيك، شخص آخر تخيل تخيل كأساً كبيراً،",
        "video_link": null
      },
      {
        "ts": "16:41",
        "sec": 1001,
        "text": "آخر تخيل كأساً صغيراً؛ المهم تخيل كأساً لأنه يعرف كيف هو الكأس، فيمكنه الآن أن يتصور",
        "video_link": null
      },
      {
        "ts": "16:50",
        "sec": 1010,
        "text": "كيف تم وضع الكأس فوق المائدة. وإذا قيل لك \"شيء\" فإنك لا لا يمكن أن تتصور",
        "video_link": null
      },
      {
        "ts": "16:57",
        "sec": 1017,
        "text": "هذا الشيء، ولله المثل الأعلى. فإذن مثال ذلك من أسماء الله تعالى: \"الحي\"؛",
        "video_link": null
      },
      {
        "ts": "17:06",
        "sec": 1026,
        "text": "فنؤمن أن الحي هاته الكلمة \"الحي\" من أسماء الله تعالى، ونحن نفهم معنى الحياة؛ الحياة هاته نفهم معناها ونثبت ونثبت له",
        "video_link": null
      },
      {
        "ts": "17:15",
        "sec": 1035,
        "text": "صفة الحياة ونفهم معنى الحياة. ولكن هل حياته مادتها وكيفيتها وماهيتها ماهية",
        "video_link": null
      },
      {
        "ts": "17:23",
        "sec": 1043,
        "text": "حياة الله، هل هي كماهية حياة الناس؟ لا، لكن نفهم هذا الفهم المجرد للحياة، فنثبت له صفة الحياة",
        "video_link": null
      },
      {
        "ts": "17:32",
        "sec": 1052,
        "text": "بما يليق به، وهي الحياة الكاملة التي لم يسبقها عدم ولا يلحقها عدم؛ كما كشأن",
        "video_link": null
      },
      {
        "ts": "17:40",
        "sec": 1060,
        "text": "الإنسان مسبوق بالعدم ويلحقه العدم فحياته محصورة، أما الله تعالى فإنه لا بداية له ولا نهاية له.",
        "video_link": null
      },
      {
        "ts": "17:50",
        "sec": 1070,
        "text": "ونتعبد الله نتعبد الله تعالى بهذا الاسم، ونبحث ماذا قيل في مثل ذلك قوله تعالى: {وَتَوَكَّلْ عَلَى الْحَيِّ الَّذِي لَا يَمُوتُ}؛ فوكّل عليه،",
        "video_link": null
      },
      {
        "ts": "17:59",
        "sec": 1079,
        "text": "أما غيره فإنه عاجز ميت. الله تعالى الحياة الكاملة",
        "video_link": null
      },
      {
        "ts": "18:06",
        "sec": 1086,
        "text": "المقرونة مع بالقدرة والقوة ونحو ذلك. ونؤمن مثلاً -هذا مثال تقريبي- ونؤمن مثلاً",
        "video_link": null
      },
      {
        "ts": "18:13",
        "sec": 1093,
        "text": "بأن من أسماء الله تعالى: \"الرحيم\"؛ هذا اسم من أسماء الله تعالى، ومن صفاته الرحمة وهي",
        "video_link": null
      },
      {
        "ts": "18:21",
        "sec": 1101,
        "text": "لا تشبه رحمة غيره. ونؤمن بأن من آثار هذا الاسم أن الله تعالى يرحم مَن يشاء؛ أي",
        "video_link": null
      },
      {
        "ts": "18:27",
        "sec": 1107,
        "text": "يكرمهم ويغفر لهم ويتجاوز عن أخطائهم.",
        "video_link": null
      },
      {
        "ts": "18:33",
        "sec": 1113,
        "text": "يعني هذا يعني آيات كثيرة ذُكرت فيها الرحيم وكذلك فيها الرحمن. ونؤمن مثلاً بأن",
        "video_link": null
      },
      {
        "ts": "18:41",
        "sec": 1121,
        "text": "من أسماء الله تعالى: \"القدير\"؛ ويتضمن صفة القدرة، ومعنى ذلك أنه فعال لما يريد؛ هذا",
        "video_link": null
      },
      {
        "ts": "18:49",
        "sec": 1129,
        "text": "هو هذه القدرة ولا يعجزه شيء، هذه هذا من معانيها. وهكذا في كل الأسماء والصفات.",
        "video_link": null
      },
      {
        "ts": "18:58",
        "sec": 1138,
        "text": "وخلاصة القول في مجمل الاعتقاد، مجملاً اعتقاد أهل السنة؛ نقول الآن أهل السنة لأن",
        "video_link": null
      },
      {
        "ts": "19:04",
        "sec": 1144,
        "text": "هنا تميز في الأسماء والصفات نقول السنة؛ أما في توحيد الألوهية فإننا نتميز عن باقي عن",
        "video_link": null
      },
      {
        "ts": "19:10",
        "sec": 1150,
        "text": "عن الأديان الأخرى وعن الشركيات بالمناسبة، توحيد الربوبية يميزنا عن الملاحدة وعن",
        "video_link": null
      },
      {
        "ts": "19:19",
        "sec": 1159,
        "text": "لأن الملاحدة وبعض الأديان الباطلة الذين يعتقدون أن لهم خالقين أو هي الطبيعة ونحو",
        "video_link": null
      },
      {
        "ts": "19:26",
        "sec": 1166,
        "text": "ذلك؛ توحيد الربوبية يميزنا عن أصحاب الأديان الباطلة والملاحدة. أو نقول إن شئتم الإيمان وجود الله، نرجع فنقول تذكرون أن",
        "video_link": null
      },
      {
        "ts": "19:35",
        "sec": 1175,
        "text": "عندنا أمور أربعة: أن نؤمن بوجوده، وأن نوحده في ربوبيته وألوهيته وأسمائه وصفاته.",
        "video_link": null
      },
      {
        "ts": "19:41",
        "sec": 1181,
        "text": "الأمر الأول: الإيمان بوجوده، هذا نتبرا ونتميز به عن الملاحدة. توحيد الله في ربوبيته؛ نتميز عن الذين",
        "video_link": null
      },
      {
        "ts": "19:50",
        "sec": 1190,
        "text": "يثبتون الخلق لغير الله. وتوحيد الألوهية؛ نتميز به عن باقي الأديان الأخرى بما في ذلك أهل الكتاب، لأن عندهم شركيات وعندهم",
        "video_link": null
      },
      {
        "ts": "20:00",
        "sec": 1200,
        "text": "كل الأديان الباطلة؛ نتميز عنهم بأننا نعبد إلهاً واحداً المستحق للعبادة اللي هو الله سبحانه وتعالى. ثم يأتي توحيد الأسماء",
        "video_link": null
      },
      {
        "ts": "20:08",
        "sec": 1208,
        "text": "والصفات فهو دائرة أخص، لذلك توحيد الأسماء والصفات هذا يكون فيه النقاش بين الطوائف الإسلامية؛ فلا يُخاض في قضايا توحيد",
        "video_link": null
      },
      {
        "ts": "20:17",
        "sec": 1217,
        "text": "الأسماء والصفات مع أهل الكتاب مثلاً، أو مع الملاحدة، أو مع الأديان أو مع الهندوس ونحو ذلك، لا. التوحيد الأسماء والصفات نعم بعض",
        "video_link": null
      },
      {
        "ts": "20:26",
        "sec": 1226,
        "text": "المباحث يمكن أن تُستعمل في قضايا الإلحاد كالخلق ونحو ذلك، ولكن عموماً",
        "video_link": null
      },
      {
        "ts": "20:32",
        "sec": 1232,
        "text": "هذا المبحث خاص فيما بين الطرق الإسلامية، لأنه فيه نقاش بين المتكلمين",
        "video_link": null
      },
      {
        "ts": "20:39",
        "sec": 1239,
        "text": "وأهل السنة والمعتزلة والجهمية؛ كلها الطوائف التي تنتسب للإسلام الكلام يكون",
        "video_link": null
      },
      {
        "ts": "20:46",
        "sec": 1246,
        "text": "في هاته الحدود. إذاً خلاصة القول في مجمل اعتقاد أهل السنة",
        "video_link": null
      },
      {
        "ts": "20:53",
        "sec": 1253,
        "text": "في الأسماء والصفات: أنهم يثبتون أسماء الله تعالى وصفاته كما وردت في الكتاب والسنة على ظاهرها وما تدل عليه ألفاظها",
        "video_link": null
      },
      {
        "ts": "21:02",
        "sec": 1262,
        "text": "من المعاني على الوجه الذي يليق بجلاله، هكذا نقول دوماً: على الوجه الذي يليق",
        "video_link": null
      },
      {
        "ts": "21:08",
        "sec": 1268,
        "text": "بجلاله. ولا تؤول ولا تحرّف دلالاتها، ولا نتجاوز ما جاء في الكتاب والسنة في",
        "video_link": null
      },
      {
        "ts": "21:16",
        "sec": 1276,
        "text": "إثبات ما ينبغي إثباته ونفي ما ينبغي نفيه؛ فما أثبته الله ورسوله أثبتناه،",
        "video_link": null
      },
      {
        "ts": "21:24",
        "sec": 1284,
        "text": "وما نفاه الله ورسوله نفيناه، هذا هو الإجمال. وما سكت عنه -الأمر الثالث والمهم-",
        "video_link": null
      },
      {
        "ts": "21:31",
        "sec": 1291,
        "text": "وما سكت عنه، سكت عنه الكتاب والسنة أيضاً ينبغي أن نسكت عنه ولا نخوض فيه. وبذلك",
        "video_link": null
      },
      {
        "ts": "21:39",
        "sec": 1299,
        "text": "نكون يعني قدمنا بهذا الكلام، قدمنا هذا القسم اللي هو توحيد الأسماء والصفات. هناك",
        "video_link": null
      },
      {
        "ts": "21:46",
        "sec": 1306,
        "text": "أمور طبعاً قواعد وضوابط وبعض المباحث سنذكرها إن شاء الله تعالى في الدروس المقبلة. أقول قولي هذا وأستغفر الله لي",
        "video_link": null
      },
      {
        "ts": "21:55",
        "sec": 1315,
        "text": "ولكم، والسلام عليكم ورحمة الله تعالى وبركاته.",
        "video_link": null
      }
    ]
  },
  {
    "subject": "aqeeda",
    "subjectLabel": "العقيدة والتوحيد",
    "lesson": "الدرس 18",
    "lessonNum": 18,
    "title": "الدرس 18",
    "summary": "📚 <b>الملخص الشامل لدرس: توحيد الأسماء والصفات (الأهمية والقواعد)</b>\n\n🔹 <b>الخلاصة المحورية للدرس:</b>\n<blockquote>يُعد توحيد الأسماء والصفات ركناً جوهرياً في عقيدة المسلم، فهو البوابة الحقيقية لمعرفة الخالق ومعنى الوجود والمصير. يؤكد الدرس أن هذه المعرفة واجبة شرعاً وفطرة، وتستند إلى الوحي (القرآن والسنة) كمرجع وحيد، مع التنبيه على ضرورة التفرقة بين الأسماء (توقيفية لفظاً ومعنى) والصفات (توقيفية معنىً)، والالتزام بقواعد أهل السنة في إثباتها ونفي ما لم يرد.</blockquote>\n\n🔹 <b>المسائل والقواعد التفصيلية:</b>\n<blockquote>\n• <b>أهمية معرفة الله:</b> الإنسان مطالب بفطرته وعقله بالتعرف على \"أصل وجوده، وغايته، ومصيره\". والسبيل الوحيد لتحقيق ذلك هو معرفة الله من خلال أسمائه وصفاته، إذ لا يمكن عبادة الله على الوجه الصحيح دون العلم بمن نعبده.\n• <b>محدودية العقل:</b> رغم قدرة العقل على استنتاج بعض صفات الخالق من خلال التأمل في الآيات الكونية، إلا أنها تظل معرفة قاصرة ومحدودة؛ لذا كانت بعثة الأنبياء ضرورة لإرشاد البشرية إلى كمال المعرفة بالله.\n• <b>الفرق بين الأسماء والصفات:</b> \n  - <b>الأسماء:</b> هي كل عَلم دل على ذات الله مع صفات الكمال، وهي توقيفية (لا نثبت منها إلا ما ورد في الكتاب والسنة).\n  - <b>الصفات:</b> هي نعوت الكمال القائمة بذات الله (كالعلم، السمع، البصر). بابها أوسع من باب الأسماء، فكل اسم يتضمن صفة، ولكن ليست كل صفة تشتق منها اسماً.\n• <b>قاعدة التوقيف:</b> \n  - <b>في الأسماء:</b> توقيفية لفظاً ومعنىً؛ لا يجوز اشتقاق اسم لله لم يرد في الشرع، حتى لو كان المعنى صحيحاً (مثال: لا نسمي الله \"المدبر\" كاسم، وإن جاز الإخبار عنه بأنه يدبر الأمور).\n  - <b>في الصفات:</b> توقيفية في المعنى؛ يجوز الإخبار عن الله بصفات لم ترد بلفظها إذا كان معناها صحيحاً ومستنداً إلى الوحي، كقول الإمام أحمد \"يا دليل الحائرين\".\n• <b>قاعدة التعامل مع ما لم يرد فيه دليل (نفي أو إثبات):</b> نتوقف فيه ولا نثبته ولا ننفيه، كالأمور التي لم يخبرنا الله عنها بشيء، فنفوض علمها إلى الله ولا نبتدع في صفاته.\n</blockquote>\n\n🔹 <b>الأسماء والمصطلحات الرئيسية:</b>\n<blockquote>\n• <b>ابن القيم (رحمه الله):</b> عالم جليل استشهد الدرس بكلامه حول حاجة الأرواح لمعرفة بارئها كأعظم الحاجات.\n• <b>التوقيف:</b> مصطلح شرعي يعني وجوب التوقف عند حدود النص (الكتاب والسنة) وعدم الاجتهاد بالعقل في تسمية الله أو وصفه.\n• <b>الآيات الكونية والشرعية:</b> الآيات الكونية (المنظورة في الكون) والآيات الشرعية (المسطورة في القرآن)، وهما وسيلتان للتعرف على الله.\n</blockquote>\n\n🔹 <b>العِبر والأحكام المستفادة:</b>\n<blockquote>\n• وجوب اتباع الوحي في باب العقيدة وعدم اللجوء إلى القياس أو العقل المحض في إثبات الأسماء والصفات.\n• تعظيم الله تعالى يقتضي التأدب معه، فلا يُسمى ولا يُوصف إلا بما سمى ووصف به نفسه.\n• الإقبال على تعلم العقيدة وأسماء الله وصفاته دليل على رغبة العبد في التقرب إلى الله، والله ينزل العبد من نفسه حيث ينزله العبد من نفسه.\n</blockquote>\n\n🔹 <b>سؤال تدبر ومراجعة ذاتية:</b>\n<blockquote>بناءً على ما درست في هذه الحلقة، لماذا لا يجوز لنا اشتقاق اسم \"النازل\" لله تعالى على الرغم من ثبوت صفة \"النزول\" في السنة النبوية؟</blockquote>",
    "full_text": "بسم الله الرحمن الرحيم، الحمد لله والصلاة والسلام على رسول الله وعلى آله وصحبه ومن والاه. أما بعد، فهذا درس جديد من دروس التوحيد والعقيدة للسنة الأولى في أكاديمية الباجي للعلوم الشرعية. وكنا قد تناولنا في الدرس الماضي الكلام والحديث عن قسم من أقسام التوحيد وهو توحيد الأسماء والصفات، وتحدثنا عن هذا القسم وأنه مرتبط بالذات الإلهية؛ بإفراد الله تعالى في الذات الإلهية، لأن الذات الإلهية لا سبيل إلى معرفتها إلا عن طريق معرفة أسماء الله تعالى وصفاته. ونكمل الكلام عن هذا القسم وسنبين بعض الأمور المتعلقة به وكذا بعض القواعد التي وضعها علماء أهل السنة لضبط هذا قسم من أقسام التوحيد الذي -كما قلنا في السابق- يعني كان من الأمور التي اختلف فيها أو اختلفت فيها الطوائف الإسلامية. هذا التوحيد أهميته تكمن في أنه يعرّفنا بالله تعالى؛ تعرّف الله تعالى من خلال معرفته بأسمائه وصفاته وأفعاله. ومعرفة الله تعالى هذه من الأمور التي يُطالب بها الإنسان، أنت أيها الإنسان لك خالق، فأنت تؤمن بوجود خالق فمطالب بفطرتك وبعقلك بأن تتعرف على هذا الخالق لأنه مرتبط بأمور ثلاثة وضع العقلاء، قال العقلاء بصفة عامة: ينبغي أن تعرف أصل وجودك، ومعنى وجودك، ومصير وجودك. هذا كما قلنا باتفاق العقلاء من أهل كل الطوائف والأديان؛ لا بد أن تتعرف على أصل وجودك من أين أتيت، وما الغاية من وجودك، وما مصيرك بعد الموت. فمعرفة الله تعالى هي المعينة على هذه الأمور لأنها مرتبطة بمعرفة موجدك وبمعرفة الغاية من وجودك؛ لماذا أوجدك هذا الخالق؟ لك خالق، ما الغاية من إيجادك؟ ثم عندنا مسألة ثالثة وهي معرفة مصيرك أي ما بعد وفاتك. كل هذا طبعاً مرتبط بالإيمان بالله، حين تكون مؤمناً بالله سبحانه وتعالى فيرتبط إيمانك بالتعرف على الله، بالتعرف أنت تؤمن بالله فطبيعيٌ بغريزة سليمة أو بعقل صحيح تقبل على معرفة خالقك وموجدك تعالى. وكما هو معلوم لدى المسلمين؛ خُلق الناس ليعبدوه، كما قال تعالى: {وَمَا خَلَقْتُ الْجِنَّ وَالْإِنسَ إِلَّا لِيَعْبُدُونِ}، {إِلَّا لِيَعْبُدُونِ} أي إلا ليوحدون. والله تعالى سمى نفسه بأسماء ووصف نفسه ووصف ذاته بصفات لكي يتعرف الناس عليه من خلال هذه الأسماء وهذه الصفات، لأن المعبود لا بد أن يُعرف، الله تعالى يُعبد بعلم فلا بد أن تتعرف على هذا المعبود. إذن الاشتغال بمثل الأمور واجب على المسلمين، واجب على الموحدين، وإهمال هذه الأمور -إهمال العناية بمجال أسماء الله وصفاته- إنما هو إهمال لما خُلق الإنسان له، أنت خُلقت لعبادته فعليك أن تتعرف على معبودك. والعباد إذا أرادوا أن يتعرفوا على الله لا سبيل إلى ذلك المعرفة الحقيقية المعرفة الصحيحة إلا إلا باتباع كلامه واتباع ما قاله الخالق عن ذاته. فلذلك نقول هذا الكلام لأن وُجد من الطوائف -طبعاً كانت خارج الإسلام ثم هذا أيضاً تسرب للمسلمين- من رام أن يتعرف على الله سبحانه وتعالى ولكن باستخدام العقل بمعزل عن الوحي، وهذا يمكن أن يصيب فيه الإنسان ولكن بشكل محدود جداً، لأن أسماء الله تعالى -كما سيأتي معنا وصفاته- توقيفية. كيف لك أن تتعرف على خالقك بعقلك فقط؟ نعم، من خلال تدبر بعض الآيات الكونية يمكنك أن تصل إلى بعض الصفات، بعض صفات هذا الخالق، فترى ربما صفات تتجلى في هذا الوجود كحكمته مثلاً أو لطفه؛ الخالق وحكمة الخالق وقوة الخالق وغير ذلك مما يمكن أن يصل إليه الإنسان بعقله، هذا صحيح ولكنها تبقى معرفة تبقى معرفة قاصرة محدودة. من هنا يظهر لنا حاجة الناس إلى بعثة الأنبياء والرسل، لأن الأنبياء والرسل هم الذين يعرّفون بالله ويدعون إليه ويدلون عليه. للإمام ابن القيم رحمه الله تعالى كلمة في كتابه لما شرح قصيدة النونية، وكتابه هذا يسمى \"الانتصار للفرقة الناجية\"، سأقرأها عليكم ويمكنكم الرجوع إلى كتابه \"الانتصار للفرقة الناجية\"؛ قال ابن القيم رحمه الله: \"وليست حاجة الأرواح قط إلى شيء أعظم منها إلى معرفة بارئها وفاطرها\" لا بد الأرواح محتاجة إلى معرفة من أوجدها \"بارئها وفاطرها\" أي موجدها \"ومحبته وذكره والابتهاج به وطلب الوسيلة إليه والزلفة عنده\" التقرب \"ولا سبيل إلى هذا إلا بمعرفة أوصافه وأسمائه\"، من هنا تظهر الحاجة إلى معرفة الأسماء والصفات، \"فكلما كان العبد بها أعلم كان بالله أعرف\"، كلما كان العبد أعلم بهذه الأسماء والصفات كلما كان أعرف بالله وهذا واضح، \"وله أطلب وإليه أقرب، وكلما كان أنكر كان بالله أجهل\"، كلما أنكر هذا مجال مجال الأسماء والصفات كلما كان أجهل بالله سبحانه وتعالى \"ومنه أبعد والله المستعان. والله ينزل العبد من نفسه حيث ينزله العبد من نفسه\". كلما أقبلت على الله أقبل الله عليك، إذا رغبت في التعرف على الله تعالى وفقك الله تعالى لهذه المعرفة. لذلك الله تعالى في كلامه من الأمور التي تكررت كثيراً في القرآن الكريم بالطبع أسماؤه، أسماؤه وصفاته تكررت كثيراً في القرآن الكريم، وآيات يعني صريحة في بيان صفات الله وأسمائه؛ مثل ذلك آية الكرسي مثلاً فهي آية تعرّف بالله تعالى، لذلك كانت أعظم آية في القرآن الكريم، وكذلك أواخر سورة الحشر وسورة الإخلاص وغيرها من الآيات والسور فيها تعريف بالله سبحانه وتعالى. فهذا من هنا تتجلى أهمية هذا المبحث، مبحث الأسماء والصفات ليس ليس مبحثاً ثانوياً هو مبحث رئيسي أساسي في عقيدة المسلمين، في عقيدة أهل السنة والجماعة. كما قلنا: نوحد الله في ربوبيته وخالقيته؛ أي لا خالق ولا رب إلا الله سبحانه وتعالى، ونوحد الله في عبوديته وفي ألوهيته فلا نصرف عبادة من العبادات إلا لله، ثم يأتي معرفة هذا الله، هذا الخالق؛ نتعرف عليه، نتعرف عليه بماذا؟ هل نشاهده؟ هذا هذا الله تعالى {لَّا تُدْرِكُهُ الْأَبْصَارُ}. وعفواً، ثم هل نقيسه على غيره؟ الله تعالى الله تعالى لا يراه الناس طبعاً لا تدركه الأبصار كما قلنا، فبالتالي هناك ننتقل إلى الوسيلة الثانية لمعرفة الأمور وهي القياس؛ نقيسه على غيره، نعرفه إن كنا لا نراه فربما نقيس على أمور نراها، هذا أيضاً يستحيل؛ لأن الله تعالى يقول: {لَيْسَ كَمِثْلِهِ شَيْءٌ} فلا داعي للقياس، {وَلَمْ يَكُن لَّهُ كُفُوًا أَحَدٌ}، {فَلَا تَضْرِبُوا لِلَّهِ الْأَمْثَالَ}. ثم تأتي الوسيلة الثالثة لمعرفته سبحانه وتعالى وهي من خلال آياته الكونية؛ كما قلنا تتأمل في هذا الكون فترى عظمة الخالق، فترى قوة الخالق وترى قدرة الخالق، هذا يُرى بالعقل ويُرى بالتدبر. ثم الآيات الأخرى الشرعية اللي هي القرآن الكريم؛ الله تعالى يُعرف بنوعين من الآيات: الآيات الكونية كما قلنا هذا يُعرف بالعقل لكنها تبقى محدودة، ثم تأتي الآيات الشرعية؛ يعني الآيات الكونية أو الآيات المنظورة، الآيات المنظورة يُعرف بها الله سبحانه وتعالى، ثم عندنا الآيات المسطورة، الآيات الشرعية الآيات التي تُقرأ، الكتاب المقروء اللي هو كلامه جل في علاه. فالله سبحانه وتعالى تكلم عن نفسه ووصف ذاته لكي يعرفه الناس، هذه هي المعرفة المطلوبة؛ نتعرف على الله تعالى من خلال أسمائه وصفاته. ثم هنا مسألة يعني نحب أن ننبه عليها وهي قضية الفرق بين الأسماء والصفات؛ الأسماء أسماء الله تعالى -نكرر كثيراً أسماء الله تعالى وصفاته- ولكن لا بد أن نفرق بين أسماء الله تعالى وصفاته. الأسماء هي كل ما دل على ذات الله مع صفات كمال القائمة بهذه الأسماء. كل اسم دل على ذات الله هذا هو اسم، هو كل عَلَم دل على ذات الله مع صفات الكمال، لأن كل اسم من أسماء الله تعالى وليس اسماً فقط مجرداً كما دعت بعض الطوائف الإسلامية كالمعتزلة والجهمية؛ جعلوا الأسماء أسماء مجردة؛ سميع أي اسمه من أسمائه السميع ولا يصفونه بسمعه، نحن قلنا: كل اسم يتضمن لتلك الصفة. حين نقول إن الله تعالى من أسمائه الحكيم، فهذا أفادنا أمرين: أفادنا أن الله تعالى من أسمائه الحكيم، هذا اسم من أسمائه ثابت بالكتاب والسنة، ثم أفادنا مسألة ثانية وهي الحكمة؛ أن من صفاته الحكمة، فكل اسم يتضمن الصفة المذكورة في ذلك الاسم. حين نقول السميع، فمن صفاته السمع زيادة على أنه اسم من أسماء الله تعالى. هذا بخلاف مثلاً بخلاف الناس؛ الناس قد تجد شخصاً اسمه كريم ولا يعني أن من صفاته الكرم هو اسمه كريم وقد تجده بخيلاً، أو شخص مثلاً اسمه خالد لكنه ليس خالداً هو هذا هذا اسم فقط وليست الصفة. الله تعالى أسماؤه تتضمن الصفات القائمة بذلك الاسم. أما الصفات فهي نعوت الكمال القائمة بذات الله تعالى كالحكمة والعلم والسمع والبصر، فالاسم يدل على أمرين والصفة تدل على أمر واحد وهي تلك الصفة، طبعاً بالكمال؛ حين نقول الله تعالى من صفاته الحكمة فنستحضر الحكمة المطلقة، من صفاته العلم نستحضر العلم المطلق بكامله هكذا بإطلاق. باب الصفات أوسع من باب الأسماء، وهذا واضح؛ لأن قلنا كل اسم قلنا كل اسم يتضمن صفة والصفات ليست كلها تتضمن الأسماء؛ فمثلاً من صفاته وهي صفات فعلية لأن الصفات تنقسم إلى صفات فعلية أو صفات ذاتية وصفات خبرية، الصفات الفعيلة كالإتيان فهذه صفة فعلية لله سبحانه وتعالى، والمجيء، والنزول، والاستواء، وغير ذلك مما ثبت بالكتاب والسنة، وليس لنا أن نشتق اسماً من هذه الصفات فلا نقول الاتي؛ الله تعالى يأتي، ينزل، ولا نقول من أسمائه النازل، لا، لا يحق لنا أن نصوغ أو نشتق اسماً من الصفات، بابها أوسع. ثم عندنا من صفات الله تعالى ما يتعلق أيضاً بأفعاله الذاتية كالفرح والضحك والغضب، فباب الصفات كما ترون باب أوسع من الأسماء؛ فكل اسم يدل على الصفة التي فيه، والصفات هناك صفات مشتقة من الأسماء ونشتقها من الأسماء وهناك صفات لا يجوز لنا اشتقاق الأسماء منها، أو أن هناك صفات فيها أسماء؛ فمن صفاته الحكمة ومن أسمائه الحكيم مثلاً. يقول الله سبحانه الله سبحانه وتعالى: {...إِنَّنِي مَعَكُمَا أَسْمَعُ وَأَرَىٰ} هناك بإثبات الصفة، ثم عندنا السميع البصير. فإذن السمع ثبت كأنه صفة، ثم ثبت صفة السمع ثبت من خلال الاسم؛ فنقول إن الله تعالى من صفاته السمع لأن ثبتت بقوله تعالى: {أَسْمَعُ}، ثم من صفاته أنه يبصر فالله تعالى بصير، وقال لموسى وهارون عليه مثلاً: {إِنَّنِي مَعَكُمَا أَسْمَعُ وَأَرَىٰ}. أيضاً من الأمور المتعلقة دوماً بالأسماء والصفات؛ أسماء الله تعالى ومعاني صفاته توقيفية، هذه هذا أمر مهم يمكنك أن تجعلها القاعدة وإن كان هناك درس خاص بالقواعد ولكن هذا أمر في غاية الأهمية؛ أسماء الله تعالى ومعاني صفاته، لم أقل صفاته قلت معاني صفاته توقيفية. الأسماء توقيفية باللفظ والمعنى، أما الصفات فإنها توقيفية في المعنى فقط. بمعنى هذا الكلام؟ معنى أننا لا يجوز لنا أن نعطي اسماً لله سبحانه وتعالى إلا بدليل، توقيف؛ أين نتوقف؟ الأمر إما توفيقي أو توقيفي؛ الأمر التوقيفي هو أمر نتوقف فيه ولا نتحرك فيه إلا بدليل، أما الأمر التوفيقي هو الأمر الاجتهادي يمكن لنا أن نشاهد. فعندنا أول شيء بالنسبة للأسماء، أسماء الله تعالى فهي توقيفية لفظاً ومعنى، فلا يجوز لنا أن نسمي، أي نعطي اسماً لله سبحانه وتعالى. أصلاً الإنسان لا يحق لك أن تعطي له اسماً هكذا، بل الشخص منا قد يغضب إذا ناديته باسم آخر ليس هو من أسمائه، ليس ليس اسمه، ولله المثل، فكيف يأتي الإنسان فيحدث اسماً جديداً ويعطيه لله سبحانه وتعالى؟! فهذا لا يجوز وإن كان المعنى صحيحاً، ولكن هذا من باب الأدب الذي يُطالب به المسلم خصوصاً في باب العقيدة؛ لا يجوز لك أيها المسلم أن تعطي اسماً لله سبحانه وتعالى فلا نسمي الله، على هذه قاعدة تذكروها: لا نسمي الله تعالى إلا بما سمى به نفسه، لا نسمي الله تعالى إلا بما سمى به نفسه نفسه؛ مثلاً الرحمن هذا من أسماء الله تعالى، الرحمن الرحيم الملك القدوس السلام المؤمن المهيمن وإلى آخره، فهذه كلها أسماء ثابتة بالكتاب أو السنة. ثم نأتي إلى الصفات؛ فلا نصف الله تعالى إلا بصفات وردت معانيها في الشرع، سواء بنفس اللفظ أو بما يرادفها، هنا الباب الصفات باب أوسع بالمقارنة مع الأسماء؛ الأسماء توقيفية حتى في اللفظ، أما الصفات ومثل الإخبار عن الله تعالى حين تتحدث عن الله تعالى من باب الإخبار لا من باب التسمية؛ تريد أن تتحدث عن الله تعالى فتقول: الله تعالى مدبر، مدبر هكذا، الله تعالى مدبر مدبر الأمور، لكن هل يوجد اسم من أسماء الله تعالى بهذا هذا بهذا بهذه الحروف \"المدبر\"؟ هذا لم يثبت، لا يوجد، إن كان على صحيح نعم الله تعالى هو مدبر الأمور {يُدَبِّرُ الْأَمْرَ}، وإن كنا نريد أن نخبر عن الله أو نصف الله تعالى نقول: الله تعالى مدبر الأمور أو مدبر، أي يدبر الأمور أو يدبر بالفعل، هذا كله. ولكن أن نأتي فنشتق اسماً ونقول: الله تعالى من أسمائه المدبر، فهذا لا يجوز ولا يحق للمسلم أن يحدث اسماً بدون دليل. أعيد: لا نسمي الله تعالى إلا بما سمى به نفسه في آية صريحة أو في أحاديث صحيحة، هذا هو الأصل. الصفات بابها أوسع؛ يمكنك أن تصف الله تعالى بألفاظ لم ترد ولكن بشرط أن تكون صحيحية، أن يوجد ما يرادفها، أن يوجد ما يريد الله تعالى وإن لم يقل مثلاً أنه مثلاً، كان يقول الإمام أحمد: \"يا دليل الحائرين دلني\" من دعاء الإمام أحمد \"يا دليل الحائرين دلني\"، فدليل الحائرين هذه صفة من صفات الله وهذا إخبار عن الله تعالى، فهذه الألفاظ \"دليل الحائرين\" هل ثبتت في آية أو حديث؟ لا، لم يثبت ولكن المعنى صحيح، بل هو معنى في الذروة من الصحة؛ فدليل الحائرين هو الله سبحانه وتعالى. وهذا من فقه الإمام أحمد أنه كان يدعو الله تعالى بهذا الدعاء: \"يا دليل الحائرين دلني\"، أو كما كان يقول الإمام ابن تيمية: \"يا معلم آدم علمني، ويا مفهم سليمان فهمني\"، فهذا كله من باب الإخبار عن الله تعالى، وإن كانت لم ترد هذه الألفاظ \"يا معلم آدم\" فالمعنى صحيح؛ الله تعالى هو الذي علم آدم {وَعَلَّمَ آدَمَ الْأَسْمَاءَ كُلَّهَا}، وفهمنا سليمان هذا كله ثابت، فيقول: \"يا مفهم\" إذاً صاغها صفة إخباراً، إن كان يبدو كاسم لكنه ليس اسماً، لم يقل المفهم أو المعلم، لا؛ \"يا معلم آدم علمني ويا مفهم سليمان فهمني\". إذن أعيد: الأسماء أمرها واضح؛ لا نسمي الله تعالى إلا بما سمى به نفسه. الصفات والإخبار عن الله والحديث عن أفعال الله أيضاً توقيفية في المعنى؛ نتوقف في المعنى فلا نتحدث عن الأمور إلا بالمعاني الصحيحة، ولا يجوز أن نحدث معنى لم يثبت لا في الكتاب ولا في السنة لا لفظاً ولا معنى. ثم نأتي الآن قضية ما لم يثبت ولم يُنفَ عن الله سبحانه وتعالى، هذا نتوقف فيه؛ سواء كان اسماً أو صفة أو فعلاً ليس لدينا دليل على أنه منسوب لله تعالى وليس لنا دليل على أنه منفي عن الله تعالى فلا نثبته ولا ننفيه بل نتوقف فيه. نسأل: الله تعالى أخبر أن له أعين، {تَجْرِي بِأَعْيُنِنَا} وغير، {وَلِتُصْنَعَ عَلَىٰ عَيْنِي} وغير، وإنك بأعين، {فَإِنَّكَ بِأَعْيُنِنَا} وغير ذلك من الآيات، لكن الله تعالى أخبر أن له آذان؟ طبعاً آذان الآن عن كيفية الآذان، فقط من باب الإخبار؛ الله تعالى يسمع؟ نعم يسمع، هل أخبرنا أن له آذان؟ لا، نقول: لا، ولا نقول: نعم، فلا نقول نعم لأنه لا دليل عليه، ولا يعني أن الله تعالى لم يذكر الآذان أنه ليست لديه آذان، ماذا نقول؟ لا ندري، نثبت أو نقول بأن هذا هذه الأمور نتجاوزها ولا نثبتها ولا ننفيها ولكن نفوضها، نقول: الله أعلم؛ الله تعالى له آذان أو غير ذلك، قسها على هذا الأمر. كل ما يقال في الأسماء والصفات: كل ما ثبت في الكتاب والسنة من الأسماء والصفات نثبته، وهذه طريقة الإثبات لها قواعد أيضاً، هناك قواعد في طريقة إثبات الأسماء والصفات، وهذا ما سنراه في الدرس المقبل إن شاء الله تعالى. أقول قولي هذا وأستغفر الله لي ولكم، وبارك الله فيكم، والسلام عليكم ورحمة الله تعالى وبركاته.",
    "blocks_search_text": "أهمية توحيد الأسماء والصفات وسبيل معرفة الله هذا التوحيد أهميته تكمن في أنه يعرّفنا بالله تعالى؛ تعرّف الله تعالى من خلال معرفته بأسمائه وصفاته وأفعاله. يوضح الشيخ أهمية معرفة الله من خلال أسمائه وصفاته، مبيناً حاجة الأرواح والعباد إلى هذه المعرفة، والسبل الموصلة إليها عن طريق الآيات الكونية والشرعية. الفرق بين أسماء الله تعالى وصفاته الأسماء هي كل ما دل على ذات الله مع صفات كمال القائمة بهذه الأسماء... أما الصفات فهي نعوت الكمال القائمة بذات الله تعالى يشرح الشيخ الفارق الدقيق بين الاسم والصفة؛ فالاسم يدل على الذات والصفة معاً، بينما تدل الصفة على نعت الكمال فقط، مع بيان أن باب الصفات أوسع من باب الأسماء. قاعدة التوقيف في أسماء الله وصفاته ومسألة الإخبار أسماء الله تعالى ومعاني صفاته توقيفية... لا نسمي الله تعالى إلا بما سمى به نفسه يبين الشيخ أن أسماء الله وصفاته توقيفية لا يجوز الابتداع فيها، مفرقاً بين التسمية وباب الإخبار الأوسع، مع توضيح الموقف الشرعي مما لم يرد إثباته ولا نفيه.",
