        "video_link": null
      },
      {
        "ts": "5:32",
        "sec": 332,
        "text": "كانوا يعتقدون أن لهذه الأصنام والأوثان تصرفات ولها قدرة ولها قوة ولها تدبير،",
        "video_link": null
      },
      {
        "ts": "5:42",
        "sec": 342,
        "text": "فترتب عن هذا وقوعهم في الخوف. طبعاً نحن نقول بأن هذا أشرنا إليه بأن إصلاح الخلل في الألوهية",
        "video_link": null
      },
      {
        "ts": "5:51",
        "sec": 351,
        "text": "يمر عبر إصلاح الخلل في الربوبية؛ لماذا يخاف هؤلاء من الصنم أن تمسهم تمسهم بسوء؟",
        "video_link": null
      },
      {
        "ts": "5:59",
        "sec": 359,
        "text": "لأنهم اعتقدوا أنها فعلاً عندها عندها قدرة على ذلك. طبعاً العلاج هذا واضح، لكن الآن",
        "video_link": null
      },
      {
        "ts": "6:05",
        "sec": 365,
        "text": "نحن نبين هاته الصور لكي يتجنبها الإنسان بالطرق بالطرق السليمة؛ فخوف الإنسان من",
        "video_link": null
      },
      {
        "ts": "6:13",
        "sec": 373,
        "text": "الصنم، أو من الوثن، أو من الضريح؛ لا، هذا الضريح ربما سيؤذيني، أو هذا القبر إذا",
        "video_link": null
      },
      {
        "ts": "6:20",
        "sec": 380,
        "text": "فعلت كذا وكذا فإن هذا القبر له قوة وسيمنعني وسيفعل لي كذا وكذا وكذا، هذا كله",
        "video_link": null
      },
      {
        "ts": "6:27",
        "sec": 387,
        "text": "خوف شركي ينبغي أن يحارب بالعقيدة السليمة. قال الله سبحانه وتعالى: {إِنَّمَا يَعْمُرُ مَسَاجِدَ",
        "video_link": null
      },
      {
        "ts": "6:36",
        "sec": 396,
        "text": "اللَّهِ مَنْ آمَنَ بِاللَّهِ وَالْيَوْمِ الْآخِرِ وَأَقَامَ الصَّلَاةَ وَآتَى الزَّكَاةَ وَمَلْ يَخْشَ إِلَّا اللَّهَ ۖ",
        "video_link": null
      },
      {
        "ts": "6:43",
        "sec": 403,
        "text": "فَعَسَىٰ أُولَٰئِكَ أَن يَكُونُوا مِنَ الْمُهْتَدِينَ}؛ قال ابن عطية المالكي في المحرر:",
        "video_link": null
      },
      {
        "ts": "6:50",
        "sec": 410,
        "text": "\"يريد خشية التعظيم والعبادة والطاعة\" هاته هي الخشية المطلوبة المقرونة بالتعظيم",
        "video_link": null
      },
      {
        "ts": "6:58",
        "sec": 418,
        "text": "والعبادة والطاعة؛ هي ينبغي أن تكون لله. إذن عندنا الخوف، نعيد الخوف ثلاثة أقسام:",
        "video_link": null
      },
      {
        "ts": "7:05",
        "sec": 425,
        "text": "خوف شرعي وهو أن يخاف الإنسان من الله كما ينبغي بدون تجاوز الحدود التي توقع",
        "video_link": null
      },
      {
        "ts": "7:11",
        "sec": 431,
        "text": "الإنسان في اليأس، وسيأتي بيان هذا باستعمال أيضاً الرجاء؛ لأن الخوف والرجاء هما عبادتان وكما يقال الجناحان يطير بهما",
        "video_link": null
      },
      {
        "ts": "7:21",
        "sec": 441,
        "text": "المؤمن بدون أن يغلب الخوف على الرجاء وسنذكر الرجاء. إذن ينبغي أن يخاف من الله هذا خوف شرعي، ثم عندنا خوف طبيعي وهو أن",
        "video_link": null
      },
      {
        "ts": "7:29",
        "sec": 449,
        "text": "يخاف الإنسان من مكروه محتمل أو مكروه واقع أو غالب الظن دون الوقوع في الخوف",
        "video_link": null
      },
      {
        "ts": "7:37",
        "sec": 457,
        "text": "الذي يمنع من فعل الواجبات؛ كأن مثلاً يقول إنسان: \"هناك شيء من الظلمة\" فيقول: \"أنا لن",
        "video_link": null
      },
      {
        "ts": "7:44",
        "sec": 464,
        "text": "أذهب إلى الصلاة لأن صلاة المغرب مثلاً لأن هناك شيء من الظلمة\" فهذا خوف مذموم؛ لأن",
        "video_link": null
      },
      {
        "ts": "7:50",
        "sec": 470,
        "text": "هذا أوقعه في ترك في ترك فعل عبادته، أو يقول: \"أنا لن أتوضأ لأنني",
        "video_link": null
      },
      {
        "ts": "7:58",
        "sec": 478,
        "text": "أخاف أن أمرض\" ولكن طبعاً نحن لا نتحدث عن أمور التي الغالب على الظن، ولكن ذلك",
        "video_link": null
      },
      {
        "ts": "8:04",
        "sec": 484,
        "text": "الخوف المبالغ فيه؛ إذاً عندنا خوف مباح، ولكن هذا الخوف المباح إذا تجاوز حده قد",
        "video_link": null
      },
      {
        "ts": "8:12",
        "sec": 492,
        "text": "يوقع صاحبه في أمور مذمومة. ثم عندنا الخوف الشركي كما قلنا وهو الخوف",
        "video_link": null
      },
      {
        "ts": "8:19",
        "sec": 499,
        "text": "المقرون بتعظيم ذلك الشيء الذي خِيف منه.",
        "video_link": null
      },
      {
        "ts": "8:26",
        "sec": 506,
        "text": "عندنا العبادة الثانية: المحبة، وتنقسم بدورها كما تقدم إلى ثلاثة أقسام: محبة",
        "video_link": null
      },
      {
        "ts": "8:33",
        "sec": 513,
        "text": "شرعية، ومحبة جبلية طبيعية (وهي من قبيل المباح)، ومحبة شركية. المحبة الشرعية هي",
        "video_link": null
      },
      {
        "ts": "8:42",
        "sec": 522,
        "text": "محبة الله سبحانه وتعالى، ومحبة دينه، ومحبة نبيه، ومحبة كل ما يحبه الله سبحانه وتعالى؛ أن تحب كل",
        "video_link": null
      },
      {
        "ts": "8:51",
        "sec": 531,
        "text": "ما يحبه الله سبحانه وتعالى، وهي محبة واجبة مطلوبة وهي نافعة للمسلم؛ قال تعالى:",
        "video_link": null
      },
      {
        "ts": "8:59",
        "sec": 539,
        "text": "{وَالَّذِينَ آمَنُوا أَشَدُّ حُبًّا لِّلَّهِ}، وقال النبي عليه الصلاة",
        "video_link": null
      },
      {
        "ts": "9:06",
        "sec": 546,
        "text": "والسلام فيما رواه الشيخان من حديث أنس بن مالك رضي الله عنه، قال: \"ثَلَاثٌ مَنْ كُنَّ فِيهِ وَجَدَ",
        "video_link": null
      },
      {
        "ts": "9:14",
        "sec": 554,
        "text": "بِهِنَّ حَلَاوَةَ الْإِيمَانِ: أَنْ يَكُونَ اللَّهُ وَرَسُولُهُ أَحَبَّ إِلَيْهِ مِمَّا سِوَاهُمَا، وَأَنْ يُحِبَّ الْمَرْءَ لَا",
        "video_link": null
      },
      {
        "ts": "9:22",
        "sec": 562,
        "text": "يُحِبُّهُ إِلَّا لِلَّهِ، وَأَنْ يَكْرَهَ أَنْ يَعُودَ فِي الْكُفْرِ بَعْدَ أَنْ أَنْقَذَهُ اللَّهُ مِنْهُ كَمَا يَكْرَهَ أَنْ",
        "video_link": null
      },
      {
        "ts": "9:30",
        "sec": 570,
        "text": "يُقْذَفَ فِي النَّارِ\". إذن هذه هي المحبة الشرعية. هذا التفصيل مهم جداً حتى نبين كل محبة وكل",
        "video_link": null
      },
      {
        "ts": "9:38",
        "sec": 578,
        "text": "جزء من هذه المحبات؛ يعني بذلك يمكن للإنسان أن يتجنب المحبة",
        "video_link": null
      },
      {
        "ts": "9:45",
        "sec": 585,
        "text": "الشركية المذمومة. ثم عندنا المحبة الجبلية الطبيعية وهي من قبيل المباح؛ كمحبة الوالدين لأولادهم، أو",
        "video_link": null
      },
      {
        "ts": "9:55",
        "sec": 595,
        "text": "محبة الزوجين لبعضهما، أو محبة الإنسان لماله ولصحته طبعاً دوماً في إطار المعقول،",
        "video_link": null
      },
      {
        "ts": "10:04",
        "sec": 604,
        "text": "أو محبة المؤمن للمؤمن ومحبته لمصلحته دوماً في الإطار المعقول؛ كل",
        "video_link": null
      },
      {
        "ts": "10:12",
        "sec": 612,
        "text": "هذا جائز كما قلنا بشرط أن لا تتجاوز القدر المعقول وأن لا يصحبها ذل ولا تعظيم،",
        "video_link": null
      },
      {
        "ts": "10:20",
        "sec": 620,
        "text": "لأن ذلك قد يوقع الإنسان في أمور مذمومة ومحرمة؛ قال تعالى: {قُلْ إِن كَانَ آبَاؤُكُمْ",
        "video_link": null
      },
      {
        "ts": "10:30",
        "sec": 630,
        "text": "وَأَبْنَاؤُكُمْ وَإِخْوَانُكُمْ وَأَزْوَاجُكُمْ وَعَشِيرَتُكُمْ وَأَمْوَالٌ اقْتَرَفْتُمُوهَا وَتِجَارَةٌ تَخْشَوْنَ كَسَادَهَا",
        "video_link": null
      },
      {
        "ts": "10:36",
        "sec": 636,
        "text": "وَمَسَاكِنُ تَرْضَوْنَهَا أَحَبَّ إِلَيْكُم مِّنَ اللَّهِ وَرَسُولِهِ وَجِهَادِ فِي سَبِيلِهِ فَتَرَبَّصُوا حَتَّىٰ يَأْتِيَ",
        "video_link": null
      },
      {
        "ts": "10:44",
        "sec": 644,
        "text": "اللَّهُ بِأَمْرِهِ ۗ وَاللَّهُ لَا يَهْدِي الْقَوْمَ الْفَاسِقِينَ}، فهذا فيه نوع من الفسق أن يبالغ الإنسان في محبة هذه الأمور؛ إذاً هذا واضح",
        "video_link": null
      },
      {
        "ts": "10:51",
        "sec": 651,
        "text": "كما قلنا محبة طبيعية لا يحارب الإنسان فطرته وجبلته، لكن يهذبها ويضعها في الإطار",
        "video_link": null
      },
      {
        "ts": "11:00",
        "sec": 660,
        "text": "المقبول والمعقول. ثم عندنا المحبة التي نريد أن نبينها لنتجنبها وهي المحبة",
        "video_link": null
      },
      {
        "ts": "11:06",
        "sec": 666,
        "text": "الشركية، وهي التي تكون لمخلوق وتكون -كالخوف- مقرونة بالتذلل والخضوع",
        "video_link": null
      },
      {
        "ts": "11:15",
        "sec": 675,
        "text": "والتعظيم؛ أن يعظم المحب ذلك الشيء المحبوب، وأن",
        "video_link": null
      },
      {
        "ts": "11:21",
        "sec": 681,
        "text": "يتذلل له وأن يخضع له؛ قال تعالى: {وَمِنَ النَّاسِ مَن يَتَّخِذُ مِن دُونِ اللَّهِ أَندَادًا يُحِبُّونَهُمْ كَحُبِّ",
        "video_link": null
      },
      {
        "ts": "11:31",
        "sec": 691,
        "text": "اللَّهِ}؛ يحبونهم يحبون الأنداد كحب الله، فهذا مذموم. هذا فيه إشارة إلى محبة توقع صاحبها",
        "video_link": null
      },
      {
        "ts": "11:39",
        "sec": 699,
        "text": "في الشرك. ومرة أخرى هذا مرتبط بما ذكرناه في الربوبية؛ أنه حين اعتقد الناس أن",
        "video_link": null
      },
      {
        "ts": "11:46",
        "sec": 706,
        "text": "هذه المخلوقات وهاته الأشياء لها تصرفات ولها قدرة في بعض الأمور، نتج عن ذلك هذه",
        "video_link": null
      },
      {
        "ts": "11:53",
        "sec": 713,
        "text": "الأعمال القلبية التي تصرف لغير الله. ثم عندنا العمل القلبي الآخر وهو الرجاء، وهو",
        "video_link": null
      },
      {
        "ts": "12:01",
        "sec": 721,
        "text": "يأتي في مقابل الخوف، نقول الخوف والرجاء؛ ويعني نسير على نفس التقسيم، ينقسم إلى",
        "video_link": null
      },
      {
        "ts": "12:07",
        "sec": 727,
        "text": "ثلاثة أقسام: رجاء رجاء شرعي، ورجاء جبلي طبيعي",
        "video_link": null
      },
      {
        "ts": "12:14",
        "sec": 734,
        "text": "من قبيل المباح، ورجاء شركي. فالرجاء الشرعي ما هو؟ هو أن يرجو الإنسان الله سبحانه",
        "video_link": null
      },
      {
        "ts": "12:22",
        "sec": 742,
        "text": "وتعالى، وأن يرغب في فضله، وأن تكون له يعني يتمنى ويرجو ما يكرم الله",
        "video_link": null
      },
      {
        "ts": "12:32",
        "sec": 752,
        "text": "تعالى به عباده؛ قال تعالى: {أُولَٰئِكَ الَّذِينَ يَدْعُونَ يَبْتَغُونَ إِلَىٰ رَبِّهِمُ الْوَسِيلَةَ أَيُّهُمْ أَقْرَبُ وَيَرْجُونَ رَحْمَتَهُ}؛",
        "video_link": null
      },
      {
        "ts": "12:42",
        "sec": 762,
        "text": "ويرجون رحمته، هذا الرجاء هذا متعلق بصفة من صفات الله تعالى وهي الرحمة،",
        "video_link": null
      },
      {
        "ts": "12:49",
        "sec": 769,
        "text": "فهو رجاء من الله سبحانه وتعالى. وقال تعالى في آخر سورة الكهف: {... فَمَن كَانَ يَرْجُو",
        "video_link": null
      },
      {
        "ts": "12:55",
        "sec": 775,
        "text": "لِقَاءَ رَبِّهِ فَلْيَعْمَلْ عَمَلًا صَالِحًا وَلَا يُشْرِكْ بِعِبَادَةِ رَبِّهِ أَحَدًا}. وروى الترمذي عن أنس",
        "video_link": null
      },
      {
        "ts": "13:03",
        "sec": 783,
        "text": "بن مالك رضي الله عنه أن النبي صلى الله عليه وسلم دخل على شاب وهو في الموت فقال: \"كَيْفَ تَجِدُكَ؟\" قال: والله يا رسول الله إني أرجو",
        "video_link": null
      },
      {
        "ts": "13:12",
        "sec": 792,
        "text": "الله وإني أخاف ذنوبي، فقال عليه الصلاة والسلام: \"لَا يَجْتَمِعَانِ فِي قَلْبِ عَبْدٍ فِي مِثْلِ هَذَا",
        "video_link": null
      },
      {
        "ts": "13:20",
        "sec": 800,
        "text": "الْمَوْطِنِ إِلَّا أَعْطَاهُ اللَّهُ مَا يَرْجُو، وَآمَنَهُ مِمَّا يَخَافُ\". هذا هو الرجاء الشرعي؛ أن يرجو",
        "video_link": null
      },
      {
        "ts": "13:27",
        "sec": 807,
        "text": "الإنسان الله وما عند الله. ثم عندنا الرجاء الجبلي وهو التمني والرغبة في الخير",
        "video_link": null
      },
      {
        "ts": "13:35",
        "sec": 815,
        "text": "والنفع من مخلوق، إذاً مرتبط بالشيء المرجو اللي هو المخلوق؛ هذا وارد وطبيعي ومباح.",
        "video_link": null
      },
      {
        "ts": "13:44",
        "sec": 824,
        "text": "فقد يرجو الإنسان من شخص مثلاً أن يعينه أو يرشده أو يوجهه، كل هذا من قبيل المباح؛",
        "video_link": null
      },
      {
        "ts": "13:54",
        "sec": 834,
        "text": "فلا إشكال بالطبع في هذا. هذا التفصيل مهم حتى لا يتخبط الناس يقول كيف هل أتعامل هل",
        "video_link": null
      },
      {
        "ts": "14:01",
        "sec": 841,
        "text": "أسأل هل أرجو؟ نعم هذا كله من قبيل المباح. روى الإمام أحمد عن أبي هريرة رضي الله",
        "video_link": null
      },
      {
        "ts": "14:09",
        "sec": 849,
        "text": "عنه أن رسول الله صلى الله عليه وسلم قال: \"خَيْرُكُمْ مَنْ يُرْجَى خَيْرُهُ وَيُؤْمَنُ شَرُّهُ، وَشَرُّكُمْ مَنْ لَا",
        "video_link": null
      },
      {
        "ts": "14:17",
        "sec": 857,
        "text": "يُرْجَى خَيْرُهُ وَلَا يُؤْمَنُ شَرُّهُ\"؛ فأثبت النبي صلى الله عليه وسلم هذا الأمر، بأن هناك من الناس من",
        "video_link": null
      },
      {
        "ts": "14:25",
        "sec": 865,
        "text": "يرجى خيره، له خير له بذل له عطاء له تدخل يمكن أن يشفع للناس، يمكن أن يكرم الناس،",
        "video_link": null
      },
      {
        "ts": "14:34",
        "sec": 874,
        "text": "فهذا يرجى خيره فالناس ترجو الخير من عنده؛ فهذا لا يتناقض مع عقيدتنا ولا إشكال في",
        "video_link": null
      },
      {
        "ts": "14:41",
        "sec": 881,
        "text": "هذا. ثم عندنا الرجاء الشركي على غرار ما ذكرنا في المحبة والخوف، وهو",
        "video_link": null
      },
      {
        "ts": "14:48",
        "sec": 888,
        "text": "أن يرجو من غير الله ما لا يقدر عليه إلا الله؛ كمن يرجو مثلاً من مخلوق أن يرزقه",
        "video_link": null
      },
      {
        "ts": "14:55",
        "sec": 895,
        "text": "مثلاً الرزق، أو يهب له الولد. هذا كله -كما قلنا مرة أخرى- مرتبط بما قد يقع من الخلل",
        "video_link": null
      },
      {
        "ts": "15:04",
        "sec": 904,
        "text": "في الربوبية؛ فإذا اعتقد أن لهذه المخلوقات تصرفات فإنه قد يترتب عن هذا الاعتقاد أنه",
        "video_link": null
      },
      {
        "ts": "15:14",
        "sec": 914,
        "text": "يرجو؛ فيرجو من الضريح أن يمده بالشفاء، ويرجو من الضريح أن يمده",
        "video_link": null
      },
      {
        "ts": "15:21",
        "sec": 921,
        "text": "بالصحة، ويرجو من الضريح أن يمده بالذرية وغير ذلك مما لا يرجى فيه إلا الله سبحانه",
        "video_link": null
      },
      {
        "ts": "15:29",
        "sec": 929,
        "text": "وتعالى. قال تعالى: {وَإِلَىٰ رَبِّكَ فَارْغَب}؛ {وَإِلَىٰ رَبِّكَ فَارْغَب}",
        "video_link": null
      },
      {
        "ts": "15:37",
        "sec": 937,
        "text": "وهنا مرة أخرى عندنا التقديم والتأخير، {وَإِلَىٰ رَبِّكَ فَارْغَب} أي لا ترغب إلا لله؛ تقديم",
        "video_link": null
      },
      {
        "ts": "15:44",
        "sec": 944,
        "text": "المعمول يفيد الحصر. لم يقل الله سبحانه وتعالى: \"وارغب إلى الله\"؛ فإذا قال قائل \"وارغب إلى الله\" فدل هذا على",
        "video_link": null
      },
      {
        "ts": "15:54",
        "sec": 954,
        "text": "مشروعية الرغبة إلى الله، ولكن معنى النفي (نفي الرغبة عن غير الله) غير",
        "video_link": null
      },
      {
        "ts": "16:00",
        "sec": 960,
        "text": "موجود وغير واضح. حين تقول -كما قلنا دوماً في قضايا التقديم والتأخير- حين تقول:",
        "video_link": null
      },
      {
        "ts": "16:08",
        "sec": 968,
        "text": "\"أرغب إلى فلان\" أي أذهب عنده وأرجو الخير من عنده، ولا يعني أنك",
        "video_link": null
      },
      {
        "ts": "16:14",
        "sec": 974,
        "text": "تمنعه من أن يرغب إلى غيره؛ لكن إذا قلت له: \"إلى فلان فارغب\" أو \"إلى فلان فاذهب\"، فما",
        "video_link": null
      },
      {
        "ts": "16:23",
        "sec": 983,
        "text": "يفهم العربي أنك حصرت له الاختيار؛ أنه لا ينبغي عليه أن يذهب إلا إلى ذلك الذي ذكرت",
        "video_link": null
      },
      {
        "ts": "16:30",
        "sec": 990,
        "text": "له، وفي هذا واضح: {وَإِلَىٰ رَبِّكَ فَارْغَب} أي لا ترغب إلا إلى الله. وقال تعالى مقارناً بين",
        "video_link": null
      },
      {
        "ts": "16:38",
        "sec": 998,
        "text": "الموحدين والمشركين: {... وَتَرْجُونَ مِنَ اللَّهِ مَا لَا يَرْجُونَ...}؛ فالموحد يرجو الله والمشرك",
        "video_link": null
      },
      {
        "ts": "16:46",
        "sec": 1006,
        "text": "يرجو غير الله (قد يرجو من الله ولكن الخلل عنده أنه قد يرجو مع الله؛ يرجو مع الله أو يتخذ",
        "video_link": null
      },
      {
        "ts": "16:55",
        "sec": 1015,
        "text": "مع الله أشياء أخرى يرجوها وهذا هو الذي أوقعه في الشرك). ثم عندنا العمل القلبي الآخر اللي هو شرك التوكل؛",
        "video_link": null
      },
      {
        "ts": "17:04",
        "sec": 1024,
        "text": "التوكل في اللغة هو الاعتماد، وله أيضاً ثلاث صور: هناك التوكل الشرعي، والتوكل الطبيعي أو المباح، والتوكل الشركي. التوكل",
        "video_link": null
      },
      {
        "ts": "17:13",
        "sec": 1033,
        "text": "الشرعي هو اعتماد القلب على الله عز وجل في استجلاب المنافع ودفع المضار من أمور",
        "video_link": null
      },
      {
        "ts": "17:20",
        "sec": 1040,
        "text": "الدنيا والآخرة، من أمور الدنيا والآخرة؛ وهو واجب، بل قال فيه سعيد بن المسيب: \"هو",
        "video_link": null
      },
      {
        "ts": "17:27",
        "sec": 1047,
        "text": "جماع الإيمان\"، وقال ابن القيم: \"التوكل نصف الدين\". وهؤلاء العلماء خصوصاً ابن القيم كانت له عناية بالأعمال القلبية، وأنا أنصح",
        "video_link": null
      },
      {
        "ts": "17:36",
        "sec": 1056,
        "text": "بكتبه في هذه القضايا التي ندندن حولها؛ كل أعمال القلوب هذه فمن أفضل من تكلم فيها الإمام ابن القيم رحمه الله تعالى. قال",
        "video_link": null
      },
      {
        "ts": "17:45",
        "sec": 1065,
        "text": "تعالى: {وَتَوَكَّلْ عَلَى اللَّهِ ۚ وَكَفَىٰ بِاللَّهِ وَكِيلًا}؛ {وَتَوَكَّلْ عَلَى اللَّهِ} هذا أمر بالتوكل على الله،",
        "video_link": null
      },
      {
        "ts": "17:54",
        "sec": 1074,
        "text": "هذا أمر والأمر للوجوب، ثم متى ظهر الحصر في الآية التي تأتي بعد ذلك؟ {وَتَوَكَّلْ",
        "video_link": null
      },
      {
        "ts": "18:01",
        "sec": 1081,
        "text": "عَلَى اللَّهِ ۚ وَكَفَىٰ بِاللَّهِ وَكِيلًا} أي أنه هو الوكيل الوحيد. ثم عندنا آية أخرى مثلاً قوله تعالى: {... وَعَلَى",
        "video_link": null
      },
      {
        "ts": "18:09",
        "sec": 1089,
        "text": "اللَّهِ فَتَوَكَّلُوا إِن كُنتُم مُّؤْمِنِينَ}؛ {وَعَلَى اللَّهِ فَتَوَكَّلُوا} مرة أخرى دوماً نفس القاعدة:",
        "video_link": null
      },
      {
        "ts": "18:16",
        "sec": 1096,
        "text": "التقديم والتأخير، {وَعَلَى اللَّهِ فَتَوَكَّلُوا} معناها لا تتوكلوا إلا على الله؛ لأن التقديم العربي إذا قدمت له المعمول فهم",
        "video_link": null
      },
      {
        "ts": "18:25",
        "sec": 1105,
        "text": "من كلامك الحصر. إذا قلت له \"فتوكلوا على الله\" سيتوكل على الله، ولكن من كلامك هذا لن",
        "video_link": null
      },
      {
        "ts": "18:33",
        "sec": 1113,
        "text": "يفهم أنك منعتَه من التوكل على غير الله، لكن إذا قلت له:",
        "video_link": null
      },
      {
        "ts": "18:40",
        "sec": 1120,
        "text": "\"وعلى الله فتوكل\" سيفهم العربي أنك تحصر له التوكل في الله وتمنعه من التوكل على غير",
        "video_link": null
      },
      {
        "ts": "18:49",
        "sec": 1129,
        "text": "الله. وقال أيضاً في آية أخرى: {... فَعَلَيْهِ تَوَكَّلُوا إِن كُنتُم مُّسْلِمِينَ}؛ الأولى كانت في سورة المائدة أما هذه في",
        "video_link": null
      },
      {
        "ts": "18:57",
        "sec": 1137,
        "text": "سورة يونس. إذاً هذا هو التوكل الشرعي وهو واجب، وقلنا إنه كما قال ابن القيم هو نصف",
        "video_link": null
      },
      {
        "ts": "19:03",
        "sec": 1143,
        "text": "الدين، وطبعاً هو الأمر معلوم لدى المسلمين. ثم عندنا التوكل المباح وهو أن",
        "video_link": null
      },
      {
        "ts": "19:10",
        "sec": 1150,
        "text": "يعتمد الإنسان على إنسان في قضاء مصلحة، وفي جلب منفعة، في تيسير أمر، في",
        "video_link": null
      },
      {
        "ts": "19:19",
        "sec": 1159,
        "text": "توجيه، في إرشاد، في نفع، في عون؛ هذا من المباح ومن الطبيعي",
        "video_link": null
      },
      {
        "ts": "19:27",
        "sec": 1167,
        "text": "طبعاً دوماً في الأمور التي يقدر عليها ذلك الإنسان، مع الاعتقاد دوماً واستحضار هذا الأمر وهو أن الله تعالى هو المتصرف هو",
        "video_link": null
      },
      {
        "ts": "19:36",
        "sec": 1176,
        "text": "الجالب للخير والدافع للمضار. والعلماء في التوكل",
        "video_link": null
      },
      {
        "ts": "19:44",
        "sec": 1184,
        "text": "الجبلي الطبيعي المباح ينبهون على قضية وهي أنه عدم استعمال هذا اللفظ؛ لا تقل -وإن كان في الأمر أمر مباح",
        "video_link": null
      },
      {
        "ts": "19:53",
        "sec": 1193,
        "text": "يقدر عليه يمكنك أن تعتمد عليه فيه- فلا تقول: \"أنا أتوكل عليك\" من جهة اللفظ؛ لأن",
        "video_link": null
      },
      {
        "ts": "20:01",
        "sec": 1201,
        "text": "التوكل هذا كما قال الله تعالى: {وَتَوَكَّلْ عَلَى الْحَيِّ الَّذِي لَا يَمُوتُ} و {وَعَلَى اللَّهِ فَتَوَكَّلُوا}، قالوا قال العلماء: هذه الكلمة لا ينبغي -من باب الأدب- أن",
        "video_link": null
      },
      {
        "ts": "20:10",
        "sec": 1210,
        "text": "تستعمل إلا في حق الله، فلا تقول: \"أتوكل عليك\" أو \"أنا أتوكل عليك\"؛ لا، يمكن أن تقول: \"أعتمد عليك، وأنتظر منك أن تساعدني، أستند",
        "video_link": null
      },
      {
        "ts": "20:19",
        "sec": 1219,
        "text": "إليك\" هذا لا إشكال فيه. أما استعمال هذا اللفظ فهي من المنهي؛ فهي مكروهة على كل",
        "video_link": null
      },
      {
        "ts": "20:26",
        "sec": 1226,
        "text": "حال، العلماء لم يقولوا لم يحكموا على المتلفظ بها بالشرك ولا بالمعصية، ولكن",
        "video_link": null
      },
      {
        "ts": "20:33",
        "sec": 1233,
        "text": "قالوا من الأفضل -صيانة لجناب العقيدة والتوحيد- من الأفضل أن لا تقال في الإنسان:",
        "video_link": null
      },
      {
        "ts": "20:41",
        "sec": 1241,
        "text": "\"أتوكل عليك\" بل تقال في في الله سبحانه وتعالى؛ وهذا دوماً يحافظ -كما قلنا- على",
        "video_link": null
      },
      {
        "ts": "20:49",
        "sec": 1249,
        "text": "إيمان الإنسان. ثم عندنا الصورة الثالثة المقصودة وهي التوكل الشركي، وهي صورتها هي:",
        "video_link": null
      },
      {
        "ts": "20:57",
        "sec": 1257,
        "text": "الاعتماد على غير الله في الأمور التي لا يقدر عليها إلا الله؛ كأن يتوكل الإنسان على",
        "video_link": null
      },
      {
        "ts": "21:03",
        "sec": 1263,
        "text": "الميت، يعتمد عليه في تيسير أمر هو يعني يسعى في قضية من القضايا أو فعل من",
        "video_link": null
      },
      {
        "ts": "21:09",
        "sec": 1269,
        "text": "الأفعال أو في عمل من الأعمال وقلبه -لأنها مسألة قلبية كما بينا في البداية التوكل عبادة قلبية؛ هي",
        "video_link": null
      },
      {
        "ts": "21:19",
        "sec": 1279,
        "text": "ليست باللسان ولا بالأفعال ولكن بالقلب- إذاً الإنسان يشرع في عمل من الأعمال وقلبه",
        "video_link": null
      },
      {
        "ts": "21:28",
        "sec": 1288,
        "text": "يعتمد على غير الله في تحقيق ذلك العمل الذي هو بصدده، كيفما كان هذا العمل؛ إذا",
        "video_link": null
      },
      {
        "ts": "21:36",
        "sec": 1296,
        "text": "تعلق قلبه واعتمد واستند إلى غير الله فقد وقع في الشرك والعياذ بالله في كل الأمور",
        "video_link": null
      },
      {
        "ts": "21:45",
        "sec": 1305,
        "text": "التي ذكرنا في استجلاب بعض مطالبه التي يحتاج إليها في حياته؛ كالنصر، والحفظ، والرزق، والتيسير،",
        "video_link": null
      },
      {
        "ts": "21:55",
        "sec": 1315,
        "text": "والصحة، والشفاء، والعلاج؛ كل هذا لا ينبغي أن أن يصرف إلا لله سبحانه وتعالى. مثلاً",
        "video_link": null
      },
      {
        "ts": "22:04",
        "sec": 1324,
        "text": "إنسان يذهب عند طبيب ويتعلق قلبه 100% بفعل الطبيب؛ الطبيب ذلك رجل",
        "video_link": null
      },
      {
        "ts": "22:11",
        "sec": 1331,
        "text": "أنت اتخذته سبباً لاستجلاب الصحة والعلاج والشفاء، فاعلم أن الشافي هو الله، وأن ذلك",
        "video_link": null
      },
      {
        "ts": "22:20",
        "sec": 1340,
        "text": "الطبيب إنما هو إنسان، هو أيضاً يعني قد يقع في مشكلة صحية ولا يمكن أن يخرج نفسه منها،",
        "video_link": null
      },
      {
        "ts": "22:28",
        "sec": 1348,
        "text": "فهو سبب لاستجلاب العلاج والصحة، وإنما الشافي الواهب للصحة هو الله سبحانه",
        "video_link": null
      },
      {
        "ts": "22:36",
        "sec": 1356,
        "text": "وتعالى؛ فقلبك قد يعتمد إلى حد ما على ما سيفعله من الدواء، بأن هذا هذا القلب في",
        "video_link": null
      },
      {
        "ts": "22:42",
        "sec": 1362,
        "text": "قضية السببية فقط؛ أنك تشرب الدواء ولكن ترجو من الله تعالى الشفاء، فلا تعارض بين",
        "video_link": null
      },
      {
        "ts": "22:51",
        "sec": 1371,
        "text": "الأمور ولا تناقض ولا إشكال. بعض الناس قد يستشكل الأمر، هذا لا إشكال فيه؛ أنت تأخذ",
        "video_link": null
      },
      {
        "ts": "22:58",
        "sec": 1378,
        "text": "عقاقير مثلاً أو حقناً، ولكن لا ينبغي أن يغيب عن ذهنك أيها المسلم أيها المؤمن أيها الموحد أن الشافي",
        "video_link": null
      },
      {
        "ts": "23:07",
        "sec": 1387,
        "text": "هو الله سبحانه وتعالى، وبأن ذلك السبب الذي اتخذته إنما هو سبب فقط لـ",
        "video_link": null
      },
      {
        "ts": "23:17",
        "sec": 1397,
        "text": "إيصال الصحة إليك، والذي أوصل حقيقة هو الله سبحانه وتعالى. ثم عندنا بعد ذكرنا",
        "video_link": null
      },
      {
        "ts": "23:24",
        "sec": 1404,
        "text": "أعمال القلوب، نأتي لأعمال الجوارح وسنذكر صورة مشهورة معروفة عند الناس لا بد من بيانها،",
        "video_link": null
      },
      {
        "ts": "23:33",
        "sec": 1413,
        "text": "وهي الذبح؛ ذبح البهائم وذبح الأنعام.",
        "video_link": null
      },
      {
        "ts": "23:39",
        "sec": 1419,
        "text": "ذبح الأنعام من البقر والغنم والإبل",
        "video_link": null
      },
      {
        "ts": "23:45",
        "sec": 1425,
        "text": "والشاة وغير ذلك، فيه أيضاً ثلاث صور: هناك الذبح الذي هو قربة لله سبحانه وتعالى",
        "video_link": null
      },
      {
        "ts": "23:53",
        "sec": 1433,
        "text": "ويكون في الأضاحي وفي الهدي؛ هدي التمتع والقران في الحج؛",
        "video_link": null
      },
      {
        "ts": "23:59",
        "sec": 1439,
        "text": "قال تعالى: {فَصَلِّ لِرَبِّكَ وَانْحَرْ}، ويدخل أيضاً فيه العقيقة وغير ذلك مما يكون مرتبطاً بشعائر",
        "video_link": null
      },
      {
        "ts": "24:08",
        "sec": 1448,
        "text": "محددة؛ {فَصَلِّ لِرَبِّكَ وَانْحَرْ} أي فصل لربك ولربك فانحر. وقال تعالى: {وَأَتِمُّوا الْحَجَّ وَالْعُمْرَةَ لِلَّهِ ۚ",
        "video_link": null
      },
      {
        "ts": "24:16",
        "sec": 1456,
        "text": "فَإِنْ أُحْصِرْتُمْ فَمَا اسْتَيْسَرَ مِنَ الْهَدْيِ}، الهدي هو الذبح؛ إذا هذا ذبح هو قربة وشعيرة",
        "video_link": null
      },
      {
        "ts": "24:25",
        "sec": 1465,
        "text": "ويكون لله وهو يكون ركناً وفرضاً وواجباً في بعض العبادات. ثم عندنا الصورة الثانية",
        "video_link": null
      },
      {
        "ts": "24:33",
        "sec": 1473,
        "text": "هو الذبح المباح، وهو ما يكون في في للأكل",
        "video_link": null
      },
      {
        "ts": "24:40",
        "sec": 1480,
        "text": "والإطعام والتجارة أيضاً؛ حتى الجزارون هؤلاء يعني يذبحون ولكن يذبحون بنية",
        "video_link": null
      },
      {
        "ts": "24:48",
        "sec": 1488,
        "text": "التجارة، طبعاً لا بد من ذكر الله وبعض الأمور، لكن نحن نتحدث عن النية عن مقصده",
        "video_link": null
      },
      {
        "ts": "24:54",
        "sec": 1494,
