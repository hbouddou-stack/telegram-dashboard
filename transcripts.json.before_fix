        "ts": "1:29",
        "sec": 89,
        "text": "ومجهول الحال أي مجهول العدالة أو الفسق، يعني إنسان نعيّنه إمامًا للمسلمين ونحن لا نعرف حاله: هل هو صالح مستقيم أم لا؟",
        "video_link": null
      },
      {
        "ts": "1:52",
        "sec": 112,
        "text": "فالعدالة هنا هي العدالة في مقابل الفسق.",
        "video_link": null
      },
      {
        "ts": "2:01",
        "sec": 121,
        "text": "قال الناظم: «والعدل من يجتنب الكبائر ويتقي في الأغلب الصغائر»",
        "video_link": null
      },
      {
        "ts": "2:09",
        "sec": 129,
        "text": "يعني العدل هو الذي يجتنب كبائر الذنوب، ولا يصر على الصغائر.",
        "video_link": null
      },
      {
        "ts": "2:18",
        "sec": 138,
        "text": "فنحن نجهل حال هذا الإمام، فكيف نقدمه للناس؟",
        "video_link": null
      },
      {
        "ts": "2:26",
        "sec": 146,
        "text": "فقالوا: ينبغي أن يرتب في الإمامة من عُرفت عدالته وحمدت سيرته.",
        "video_link": null
      },
      {
        "ts": "2:35",
        "sec": 155,
        "text": "أو من تاب من ذنب مشهور، كمن كان يعمل عمل قوم لوط ثم تاب إلى الله عز وجل وصلح حاله.",
        "video_link": null
      },
      {
        "ts": "2:50",
        "sec": 170,
        "text": "فقالوا: تكره إمامته حتى لا تنطلق الألسن بذكر مساوئه السابقة.",
        "video_link": null
      },
      {
        "ts": "3:06",
        "sec": 186,
        "text": "لأن منصب الإمامة منصب شريف.",
        "video_link": null
      },
      {
        "ts": "3:12",
        "sec": 192,
        "text": "فالفقهاء يحرصون على ألا يلي هذا المنصب من تتناوله ألسنة الناس بالسوء.",
        "video_link": null
      },
      {
        "ts": "3:20",
        "sec": 200,
        "text": "قال: «ومن ابنًا وأغلف»",
        "video_link": null
      },
      {
        "ts": "3:28",
        "sec": 208,
        "text": "الأغلف هو غير المختتن.",
        "video_link": null
      },
      {
        "ts": "3:38",
        "sec": 218,
        "text": "قالوا: تكره إمامته لأنه قد لا يتمكن من التطهر جيدًا.",
        "video_link": null
      },
      {
        "ts": "3:46",
        "sec": 226,
        "text": "فقد تبقى نجاسة البول تحت القلفة.",
        "video_link": null
      },
      {
        "ts": "4:04",
        "sec": 244,
        "text": "«وعبد» أي أن العبد غير الحر تكره إمامته عندهم.",
        "video_link": null
      },
      {
        "ts": "4:14",
        "sec": 254,
        "text": "«وخصي» أي مقطوع الخصيتين.",
        "video_link": null
      },
      {
        "ts": "4:30",
        "sec": 270,
        "text": "«وابن زنا»",
        "video_link": null
      },
      {
        "ts": "4:40",
        "sec": 280,
        "text": "قالوا: حتى لا يتكلم الناس فيه بالسوء وهو في هذا المنصب الشريف.",
        "video_link": null
      },
      {
        "ts": "4:46",
        "sec": 286,
        "text": "ثم قال رحمه الله: «وجاز عنين وأعمى وألكن ومجذوم خف»",
        "video_link": null
      },
      {
        "ts": "5:02",
        "sec": 302,
        "text": "يعني بعدما ذكر شروط الكمال، قد يتبادر إلى الذهن: هل تصح إمامة من فقد بعضها؟",
        "video_link": null
      },
      {
        "ts": "5:25",
        "sec": 325,
        "text": "فقال: «وجاز عنين» العنين هو العاجز عن إتيان النساء.",
        "video_link": null
      },
      {
        "ts": "5:42",
        "sec": 342,
        "text": "فتجوز إمامته.",
        "video_link": null
      },
      {
        "ts": "5:48",
        "sec": 348,
        "text": "«وأعمى» أي الأعمى تصح إمامته.",
        "video_link": null
      },
      {
        "ts": "5:56",
        "sec": 356,
        "text": "وكان النبي ﷺ يستخلف عبد الله بن أم مكتوم رضي الله عنه ليصلي بالناس.",
        "video_link": null
      },
      {
        "ts": "6:15",
        "sec": 375,
        "text": "«وألكن» الألكن هو العاجز عن إخراج بعض الحروف من مخارجها.",
        "video_link": null
      },
      {
        "ts": "6:30",
        "sec": 390,
        "text": "كمن ينطق الراء لامًا أو يعجز عن بعض الحروف.",
        "video_link": null
      },
      {
        "ts": "6:52",
        "sec": 412,
        "text": "فهذا تصح إمامته لأنه معذور.",
        "video_link": null
      },
      {
        "ts": "7:08",
        "sec": 428,
        "text": "«ومجذوم خف» أي صاحب الجذام الخفيف.",
        "video_link": null
      },
      {
        "ts": "7:20",
        "sec": 440,
        "text": "أما إن كان شديدًا يؤذي الناس فلا.",
        "video_link": null
      },
      {
        "ts": "7:35",
        "sec": 455,
        "text": "ثم انتقل رحمه الله إلى أحكام المأموم فقال:",
        "video_link": null
      },
      {
        "ts": "7:53",
        "sec": 473,
        "text": "«والمقتدي الإمام يتبع خلا زيادة قد حققت عنها عدله»",
        "video_link": null
      },
      {
        "ts": "8:10",
        "sec": 490,
        "text": "أي أن المأموم يتبع إمامه.",
        "video_link": null
      },
      {
        "ts": "8:27",
        "sec": 507,
        "text": "لقول النبي ﷺ: «إنما جعل الإمام ليؤتم به»",
        "video_link": null
      },
      {
        "ts": "8:49",
        "sec": 529,
        "text": "لكن يستثنى إذا تيقن المأموم أن الإمام زاد في الصلاة.",
        "video_link": null
      },
      {
        "ts": "9:07",
        "sec": 547,
        "text": "فإنه لا يتابعه في هذه الزيادة.",
        "video_link": null
      },
      {
        "ts": "9:32",
        "sec": 572,
        "text": "مثال ذلك: إذا قام الإمام إلى خامسة في الظهر.",
        "video_link": null
      },
      {
        "ts": "9:52",
        "sec": 592,
        "text": "فإن المأموم يسبح به.",
        "video_link": null
      },
      {
        "ts": "10:01",
        "sec": 601,
        "text": "فإن لم يرجع الإمام، فلا يجوز للمأموم متابعته.",
        "video_link": null
      },
      {
        "ts": "10:25",
        "sec": 625,
        "text": "بل يبقى جالسًا حتى يسلم الإمام.",
        "video_link": null
      },
      {
        "ts": "10:52",
        "sec": 652,
        "text": "وكذلك لو زاد سجدة ثالثة.",
        "video_link": null
      },
      {
        "ts": "11:01",
        "sec": 661,
        "text": "ثم قال رحمه الله: «والمقتدي الإمام يتبع خلا زيادة قد حققت عنها عدله»",
        "video_link": null
      },
      {
        "ts": "11:14",
        "sec": 674,
        "text": "ثم شرع في أحكام المسبوق فقال:",
        "video_link": null
      },
      {
        "ts": "11:21",
        "sec": 681,
        "text": "«وأحرم المسبوق فورًا ودخل مع الإمام كيفما كان العمل»",
        "video_link": null
      },
      {
        "ts": "11:46",
        "sec": 706,
        "text": "أي إذا دخل المسجد والإمام يصلي، فإنه يكبر فورًا ويدخل معه على أي حال كان الإمام.",
        "video_link": null
      },
      {
        "ts": "12:29",
        "sec": 749,
        "text": "فلا ينتظر حتى يقوم الإمام.",
        "video_link": null
      },
      {
        "ts": "12:56",
        "sec": 776,
        "text": "لقول النبي ﷺ: «إذا أتى أحدكم الصلاة والإمام على حال فليصنع كما يصنع الإمام»",
        "video_link": null
      },
      {
        "ts": "13:26",
        "sec": 806,
        "text": "فإن كان راكعًا ركع معه، وإن كان ساجدًا سجد معه.",
        "video_link": null
      },
      {
        "ts": "13:48",
        "sec": 828,
        "text": "لكن لا بد من تكبيرة الإحرام أولًا.",
        "video_link": null
      },
      {
        "ts": "14:04",
        "sec": 844,
        "text": "فمن ركع مباشرة دون تكبيرة الإحرام فصلاته باطلة.",
        "video_link": null
      },
      {
        "ts": "14:19",
        "sec": 859,
        "text": "وكذلك لا يضيع فضل الجماعة بالانتظار.",
        "video_link": null
      },
      {
        "ts": "14:44",
        "sec": 884,
        "text": "ثم قال: «مكبرًا إن ساجدًا أو راكعًا ألفاه لا في جلسة»",
        "video_link": null
      },
      {
        "ts": "15:00",
        "sec": 900,
        "text": "أي إذا وجد الإمام راكعًا أو ساجدًا يكبر تكبيرة انتقال.",
        "video_link": null
      },
      {
        "ts": "15:32",
        "sec": 932,
        "text": "أما إن وجده قائمًا فلا يحتاج تكبيرة ثانية.",
        "video_link": null
      },
      {
        "ts": "16:38",
        "sec": 998,
        "text": "وأما إذا وجده جالسًا ففي المذهب المشهور لا يكبر للنزول.",
        "video_link": null
      },
      {
        "ts": "17:07",
        "sec": 1027,
        "text": "«وتابع» أي يتابع الإمام.",
        "video_link": null
      },
      {
        "ts": "17:22",
        "sec": 1042,
        "text": "ثم قال رحمه الله: «إن سلم الإمام قام قاضي أقواله وفي الأفعال بانيًا»",
        "video_link": null
      },
      {
        "ts": "17:39",
        "sec": 1059,
        "text": "أي إذا سلم الإمام قام المسبوق ليأتي بما فاته.",
        "video_link": null
      },
      {
        "ts": "18:06",
        "sec": 1086,
        "text": "ثم شرح مسألة القضاء والبناء.",
        "video_link": null
      },
      {
        "ts": "18:25",
        "sec": 1105,
        "text": "لقول النبي ﷺ: «فما أدركتم فصلوا وما فاتكم فأتموا»",
        "video_link": null
      },
      {
        "ts": "18:43",
        "sec": 1123,
        "text": "وفي رواية: «فاقضوا»",
        "video_link": null
      },
      {
        "ts": "19:00",
        "sec": 1140,
        "text": "فاختلف العلماء: * هل يبني؟ * أم يقضي؟",
        "video_link": null
      },
      {
        "ts": "19:21",
        "sec": 1161,
        "text": "فالبناء: أن ما أدركه مع الإمام هو أول صلاته.",
        "video_link": null
      },
      {
        "ts": "19:50",
        "sec": 1190,
        "text": "مثاله في العشاء: إذا أدرك الركعتين الأخيرتين.",
        "video_link": null
      },
      {
        "ts": "20:28",
        "sec": 1228,
        "text": "فإنهما أول صلاته عند أهل البناء.",
        "video_link": null
      },
      {
        "ts": "20:44",
        "sec": 1244,
        "text": "فإذا قام بعد سلام الإمام أتى بالركعتين الأخيرتين سرًا.",
        "video_link": null
      },
      {
        "ts": "21:24",
        "sec": 1284,
        "text": "وفي المغرب إذا أدرك ركعة واحدة.",
        "video_link": null
      },
      {
        "ts": "21:42",
        "sec": 1302,
        "text": "فإنها أول صلاته.",
        "video_link": null
      },
      {
        "ts": "22:04",
        "sec": 1324,
        "text": "ثم يأتي بركعة جهرية ويتشهد، ثم ركعة سرية.",
        "video_link": null
      },
      {
        "ts": "22:48",
        "sec": 1368,
        "text": "أما القضاء: فالمسبوق يجعل ما أدركه آخر صلاته.",
        "video_link": null
      },
      {
        "ts": "23:23",
        "sec": 1403,
        "text": "فيقضي ما فاته كما فاته.",
        "video_link": null
      },
      {
        "ts": "23:52",
        "sec": 1432,
        "text": "ففي العشاء يأتي بالركعتين جهريتين.",
        "video_link": null
      },
      {
        "ts": "24:14",
        "sec": 1454,
        "text": "وفي المغرب يأتي بركعتين جهريتين بلا تشهد بينهما.",
        "video_link": null
      },
      {
        "ts": "24:51",
        "sec": 1491,
        "text": "ثم ذكر المذهب المشهور عند المالكية:",
        "video_link": null
      },
      {
        "ts": "25:07",
        "sec": 1507,
        "text": "«قاضي أقواله وفي الأفعال بانيًا»",
        "video_link": null
      },
      {
        "ts": "25:32",
        "sec": 1532,
        "text": "أي يقضي في الأقوال ويبني في الأفعال.",
        "video_link": null
      },
      {
        "ts": "26:28",
        "sec": 1588,
        "text": "ثم أعاد أمثلة المغرب تفصيلًا لتوضيح الفرق بين: * البناء * القضاء * القضاء في الأقوال والبناء في الأفعال.",
        "video_link": null
      },
      {
        "ts": "29:06",
        "sec": 1746,
        "text": "ثم قال رحمه الله: «ويسجد المسبوق قبلي الإمام معه وبعدي يقضي بعد السلام»",
        "video_link": null
      },
      {
        "ts": "33:24",
        "sec": 2004,
        "text": "أي إذا سجد الإمام سجودًا قبليًا سجد معه المسبوق.",
        "video_link": null
      },
      {
        "ts": "34:22",
        "sec": 2062,
        "text": "أما السجود البعدي فإنه يقضي صلاته أولًا ثم يسجد بعد السلام.",
        "video_link": null
      },
      {
        "ts": "35:45",
        "sec": 2145,
        "text": "ثم قال: «وبطلت لمقتد بمبطل على الإمام»",
        "video_link": null
      },
      {
        "ts": "35:58",
        "sec": 2158,
        "text": "أي إذا بطلت صلاة الإمام بطلت صلاة المأموم.",
        "video_link": null
      },
      {
        "ts": "36:17",
        "sec": 2177,
        "text": "إلا إذا تذكر الإمام أنه محدث أو طرأ عليه الحدث.",
        "video_link": null
      },
      {
        "ts": "36:59",
        "sec": 2219,
        "text": "فإذا خرج مباشرة من الصلاة لا تبطل صلاة المأمومين.",
        "video_link": null
      },
      {
        "ts": "37:26",
        "sec": 2246,
        "text": "ويستحب أن يقدم الإمام من يتم الصلاة بالناس.",
        "video_link": null
      },
      {
        "ts": "37:47",
        "sec": 2267,
        "text": "كما فعل عمر بن الخطاب رضي الله عنه لما طُعن في الصلاة، فقدم عبد الرحمن بن عوف رضي الله عنه.",
        "video_link": null
      },
      {
        "ts": "38:29",
        "sec": 2309,
        "text": "فإن لم يستخلف الإمام أحدًا: * إما أن يقدم المأمومون واحدًا منهم، * أو يكمل كل واحد صلاته منفردًا.",
        "video_link": null
      },
      {
        "ts": "38:45",
        "sec": 2325,
        "text": "وهذا ختام الحديث عن الأحكام المتعلقة بالصلاة.",
        "video_link": null
      },
      {
        "ts": "38:52",
        "sec": 2332,
        "text": "وفي المجلس المقبل إن شاء الله نشرع في كتاب الزكاة بإذن الله تعالى.",
        "video_link": null
      },
      {
        "ts": "39:00",
        "sec": 2340,
        "text": "ونسأل الله تعالى أن يتقبل منا ومنكم، والله تعالى أعلى وأعلم. سبحانك اللهم وبحمدك، أشهد أن لا إله إلا أنت، أستغفرك وأتوب إليك. وصلى الله وسلم وبارك على سيدنا محمد وعلى آله، والحمد لله رب العالمين.",
        "video_link": null
      }
    ]
  },
  {
    "subject": "nahw",
    "subjectLabel": "علم النحو والصرف",
    "lesson": "الدرس 14",
    "lessonNum": 14,
    "title": "الدرس 14",
    "summary": "إليك ملخصاً أكاديمياً شاملاً ومنظماً للدرس، مصاغاً بأسلوب سلس وميسر للقراءة والدراسة:\n\n---\n\n### موضوع الدرس الرئيسي\n\nتناول الأستاذ في هذا الدرس استكمال مباحث الأسماء المعرفة في النحو العربي، مسلطاً الضوء على ثلاثة محاور أساسية: أحكام صلة الموصول والعائد المرتبط بها، وتفصيل أنواع المعرف بالأداة \"أل\"، وأخيراً المعرف بالإضافة إلى واحد من المعارف.\n\n---\n\n### المحاور والنقاط الأساسية\n\n#### أولاً: صلة الموصول وعائدها\nالاسم الموصول يفتقر دائماً إلى صلة متأخرة عنه توضح معناه، وإلى عائد يربطه بها. وتأتي صلة الموصول على نوعين رئيسيين:\n\n1. <b>الجملة</b>: وتكون على صورتين:\n<i>   <b>جملة فعلية</b>: تتكون من فعل وفاعل.\n</i>   <b>جملة اسمية</b>: تتكون من مبتدأ وخبر.\n<i>   </i>قاعدة إعرابية<i>: جملة الصلة (سواء كانت فعلية أو اسمية) لا محل لها من الإعراب.\n\n2. <b>شبه الجملة</b>: وتتضمن ثلاثة أشياء:\n</i>   <b>الظرف</b>: ظرف مكان أو زمان.\n<i>   <b>الجار والمجرور</b>.\n</i>   <i>توجيه نحوي في إعراب الظرف والجار والمجرور</i>: الإعراب الميسر يجعلهما صلة الموصول مباشرة. أما الإعراب الأصح والأدق نحوياً، فهو تعلقهما بفعل محذوف وجوباً تقديره \"استقرّ\"، لتكون الصلة في الأصل جملة فعلية محذوفة الفعل.\n<i>   <b>الصفة الصريحة</b>: وهي اسم الفاعل أو اسم المفعول، وتختص بالاتصال بـ \"أل\" التي هي بمعنى الاسم الموصول.\n\n3. <b>العائد وأحكام حذفه</b>:\nالعائد هو ضمير يربط الصلة بالاسم الموصول ويطابقه في الإفراد والتثنية والجمع والتذكير والتأنيث. وقد يحذف هذا العائد لدلالة السياق عليه، ويأتي الحذف في حالات ثلاث:\n</i>   <b>حذف العائد المرفوع</b>: عندما يكون مبتدأً في جملة الصلة.\n<i>   <b>حذف العائد المنصوب</b>: عندما يكون مفعولاً به.\n</i>   <b>حذف العائد المجرور بالحرف</b>.\n\n#### ثانياً: المعرف بالأداة (أل)\nتنقسم \"أل\" التعريفية إلى قسمين رئيسيين:\n\n1. <b>أل العهدية</b>: وتأتي على ثلاثة أنواع:\n<i>   <b>العهد الذكري</b>: إذا سبق ذكر الكلمة نكرة ثم أُعيدت معرفة بـ \"أل\".\n</i>   <b>العهد الذهني</b>: إذا كان المدخول معهوداً في أذهان المخاطبين دون سابق ذكر في اللفظ.\n<i>   <b>العهد الحضوري</b>: إذا كان المصحوب حاضراً في زمن الخطاب.\n\n2. <b>أل الجنسية</b>: وتأتي على ثلاثة أنواع:\n</i>   <b>لتعريف الماهية (الحقيقة)</b>: لبيان حقيقة الشيء وجنسه، وضابطها ألا يصح حلول كلمة \"كل\" مكانها.\n<i>   <b>لاستغراق الأفراد</b>: وتفيد العموم، وضابطها صحة حلول كلمة \"كل\" مكانها على جهة الحقيقة.\n</i>   <b>لاستغراق خصائص الأفراد</b>: وتفيد المبالغة والمجاز، وضابطها صحة حلول \"كل\" مكانها مجازاً لإثبات أن صفات الجنس كله قد اجتمعت في هذا الفرد.\n\n<i>   </i>فائدة لغوية<i>: تُبدل لام التعريف ميماً في لغة قبيلة \"حمير\" العربية، فتصبح \"أل\" لديهم \"أم\".\n\n#### ثالثاً: المضاف إلى واحد من المعارف\nهو الاسم النكرة الذي يكتسب التعريف والوضوح بسب إضافته إلى واحد من المعارف الخمسة المذكورة سابقاً في النحو (الضمير، اسم الإشارة، الاسم الموصول، المعرف بأل، العلم).\n\n---\n\n### الأمثلة والتطبيقات\n\n</i>   <b>الصلة جملة فعلية</b>: \n    <i>   مثال عام: \"جاء الذي قام أبوه\" (قام أبوه: فعل وفاعل، وجملة الصلة لا محل لها من الإعراب).\n    </i>   شاهد قرآني: {الْحَمْدُ لِلَّهِ الَّذِي صَدَقَنَا وَعْدَهُ} (صدقنا وعده: صلة الموصول).\n\n<i>   <b>الصلة جملة اسمية</b>:\n    </i>   مثال عام: \"جاء الذي أبوه قائم\" (أبوه قائم: مبتدأ وخبر، وجملة الصلة لا محل لها من الإعراب).\n    <i>   شاهد قرآني: {الَّذِي هُمْ فِيهِ مُخْتَلِفُونَ} (هم مختلفون: مبتدأ وخبر، صلة الموصول).\n\n</i>   <b>الصلة شبه جملة (ظرف)</b>:\n    <i>   مثال عام: \"جاء الذي عندك\".\n    </i>   شاهد قرآني: {مَا عِندَكُمْ يَنفَدُ ۖ وَمَا عِندَ اللَّهِ بَاقٍ} (\"باقٍ\" اسم منقوص مرفوع بضمة مقدرة على الياء المحذوفة لالتقاء الساكنين).\n\n<i>   <b>الصلة شبه جملة (جار ومجرور)</b>:\n    </i>   مثال عام: \"جاء الذي في الدار\".\n    <i>   شاهد قرآني: {وَأَلْقَتْ مَا فِيهَا وَتَخَلَّتْ} (فيها: جار ومجرور متعلقان بـ \"استقر\" المحذوف وجوباً).\n\n</i>   <b>الصلة صفة صريحة</b>:\n    <i>   شاهد قرآني: {الْمُصَّدِّقِينَ وَالْمُصَّدِّقَاتِ} (حيث اتصلت \"أل\" الموصولة باسم الفاعل).\n\n</i>   <b>حذف العائد المرفوع</b>:\n    <i>   شاهد قرآني: {ثُمَّ لَنَنزِعَنَّ مِن كُلِّ شِيعَةٍ أَيُّهُمْ أَشَدُّ} (التقدير: أيهم [هو] أشدّ، وحذف الضمير \"هو\").\n\n</i>   <b>حذف العائد المنصوب</b>:\n    <i>   شاهد قرآني: {يَعْلَمُ مَا تُسِرُّونَ وَمَا تُعْلِنُونَ} (التقدير: ما تسرونه وما تعلنونه).\n\n</i>   <b>حذف العائد المجرور</b>:\n    <i>   شاهد قرآني: {وَيَشْرَبُ مِمَّا تَشْرَبُونَ} (التقدير: تشربون منه).\n\n</i>   <b>أنواع أل العهدية</b>:\n    <i>   </i>العهد الذكري<i>: {فِي زُجَاجَةٍ ۖ الزُّجَاجَةُ كَأَنَّهَا كَوْكَبٌ دُرِّيٌّ}، و{مِصْبَاحٌ ۖ الْمِصْبَاحُ فِي زُجَاجَةٍ}.\n    </i>   <i>العهد الذهني</i>: {إِذْ هُمَا فِي الْغَارِ} (والمقصود غار ثور المعهود في الأذهان).\n    <i>   </i>العهد الحضوري<i>: {الْيَوْمَ أَكْمَلْتُ لَكُمْ دِينَكُمْ} (المقصود اليوم الحاضر وهو يوم عرفة).\n\n</i>   <b>أنواع أل الجنسية</b>:\n    <i>   </i>لتعريف الماهية<i>: {وَجَعَلْنَا مِنَ الْمَاءِ كُلَّ شَيْءٍ حَيٍّ} (أي من حقيقة الماء وجنسه).\n    </i>   <i>لاستغراق الأفراد</i>: {وَخُلِقَ الْإِنسَانُ ضَعِيفًا} (أي خلق كل إنسان ضعيفاً).\n    <i>   </i>لاستغراق الخصائص<i>: \"أنت الرجل علماً\" (أي اجتمعت فيك خصال الرجال في العلم مبالغةً).\n\n</i>   <b>لغة حمير</b>:\n    <i>   الحديث الشريف: \"لَيْسَ مِنَ امْبِرِّ امْصِيَامُ فِي امْسَفَرِ\" (التقدير: ليس من البر الصيام في السفر).\n\n</i>   <b>المضاف إلى المعارف الخمسة</b>:\n    *   \"غلامي\" (مضاف للضمير)، \"غلام هذا\" (مضاف لاسم الإشارة)، \"غلام الذي قام أبوه\" (مضاف للموصول)، \"غلام الرجل\" (مضاف للمعرّف بأل)، \"غلام زَيْدٍ\" (مضاف للعلم).\n\n---\n\n### الخلاصة\n\nما يجب على الطالب حفظه وإتقانه من هذا الدرس:\n\n1.  <b>قاعدة الافتقار</b>: الأسماء الموصولة مبهمة وتحتاج دائماً إلى صلة وعائد يوضح معناها، وجملة الصلة لا محل لها من الإعراب.\n2.  <b>أقسام صلة الموصول</b>: حفظ أنواع الصلة (جملة اسمية، جملة فعلية، ظرف، جار ومجرور، صفة صريحة) مع فهم التقدير النحوي الأصح لشبه الجملة بمتعلَّق محذوف تقديره \"استقر\".\n3.  <b>أحكام حذف العائد</b>: تمييز مواضع حذف عائد الموصول وتقديره في الآيات الكريمة والشواهد النحوية (مرفوعاً، منصوباً، أو مجروراً).\n4.  <b>تقسيمات أل التعريفية</b>: استيعاب وفهم الفروق الدقيقة بين (أل) العهدية بأنواعها الثلاثة، و(أل) الجنسية بأنواعها الثلاثة، مع حفظ الضوابط النحوية للتفريق بينها (مثل ضابط حلول كلمة \"كل\").\n5.  <b>المعرفة بالإضافة</b>: إدراك أن النكرة تكتسب التعريف الكامل إذا أُضيفت لواحد من المعارف الخمسة، وبذلك تكتمل أبواب المعارف في النحو العربي.",
    "full_text": "بسم الله الرحمن الرحيم، الحمد لله رب العالمين، وصلى الله وسلم وبارك على نبينا محمد وعلى آله وصحبه والتابعين، ومن تبعهم بإحسان إلى يوم الدين. ذكرنا الاسم الموصول وأنواعه ومجموعة من المباحث التي تتعلق به، ثم وصلنا إلى قضية الصلة والعائد. قال: وَتَفْتَقِرُ المَوْصُولَاتُ كُلُّهَا إِلَى صِلَةٍ مُتَأَخِّرَةٍ عَنْهَا وَعَائِدٍ، ذكرناه في تعريف الاسم الموصول فقط. فإذن قال: وَصِلَتُهُ إِمَّا جُمْلَةٌ أَوْ شِبْهُهَا. إذن ما الجملة وما شبه الجملة؟ فالجملة ما تركب من فعل وفاعل، نحو: جَاءَ الَّذِي قَامَ أَبُوهُ، جَاءَ: فعل ماضٍ مبني على الفتح، الَّذِي: اسم موصول مبني في محل رفع فاعل، قَامَ: فعل ماضٍ مبني على الفتح، أَبُو: فاعل مرفوع وعلامة رفعه الواو النائبة عن الضمة لأنه من الأسماء الستة وهو مضاف، الهاء: ضمير متصل مبني في محل جر مضاف إليه. وجملة قَامَ أَبُوهُ الجملة الفعلية في، والجملة الفعلية صلة الموصول لا محل لها من الإعراب. وقوله تعالى: {الْحَمْدُ لِلَّهِ الَّذِي صَدَقَنَا وَعْدَهُ}، الَّذِي: نعت لاسم الجلالة، وجملة صَدَقَنَا وَعْدَهُ: جملة فعلية مكونة من شيء آخر غير الفاعل، همم يعني مفعولين اثنين؛ هذه الجملة الفعلية هي صلة الموصول. إذن هذه الأولى، أو من مبتدأ وخبر، نحو: جَاءَ الَّذِي أَبُوهُ قَائِمٌ، جَاءَ الَّذِي أعربناها من قبل، أَبُو: مبتدأ وهو مضاف، الهاء: مضاف إليه، قَائِمٌ: خبر، وجملة المبتدأ والخبر الجملة الاسمية في محل عفواً، الجملة الاسمية صلة الموصول لا محل لها من الإعراب. قضية إعراب الجمل؛ أنا ذكرت لكم الآن مثالاً على ذلك قلت مثلاً: صلة الموصول لا محل لها من الإعراب، مثل هذه القضايا هل الجملة لها محل من الإعراب أو ليس لها محل من الإعراب؟ هذا موضوع آخر لا نريد أن ندخل فيه، وليس من الأشياء التي يعتني بها المبتدئ في علم النحو، لكن هناك أصلاً متون مخصصة لإعراب الجمل. وقوله تعالى: {الَّذِي هُمْ فِيهِ مُخْتَلِفُونَ}، هُمْ: مبتدأ، مُخْتَلِفُونَ: خبر، وجملة المبتدأ والخبر، إذن هذا عن صلة الموصول حين تكون جملة فعلية كانت أو اسمية. وأما شبه الجملة فما المراد بذلك؟ قال: وَشِبْهُ الْجُمْلَةِ ثَلَاثَةُ أَشْيَاءَ؛ أَحَدُهَا: الظَّرْفُ، نحو: جَاءَ الَّذِي عِنْدَكَ، عِنْدَ: ظرف مكان وهو مضاف، ظرف مكان منصوب وهو مضاف، الكاف: ضمير متصل مبني في محل جر مضاف إليه. شبه الجملة المكونة من هذا الظرف هي صلة الموصول. وقوله تعالى: {مَا عِندَكُمْ يَنفَدُ ۖ وَمَا عِندَ اللَّهِ بَاقٍ}، فإذن مَا: اسم موصول مبتدأ، عِنْدَ: ظرف وهو مضاف، والكاف مضاف إليه، يَنفَدُ: هذه مكونة من فعل مضارع وفاعله ضمير مستتر، وهذه الجملة الفعلية هي في محل رفع خبر المبتدأ. {وَمَا عِندَ اللَّهِ بَاقٍ}، الثانية نفس الإعراب إلا أن الذي يتغير أن الخبر هنا ليس جملة. فباقي مع التنوين صارت باقٍ، لالتقاء الساكنين أولهما لين فتصبح باقٍ، وذلك هذا الاسم المنقوص مرفوع وخبر مرفوع وعلامة رفعه الضمة المقدرة على الياء المحذوفة لالتقاء الساكنين. هذا النوع الأول من شبه الجملة. النوع الثاني: جار ومجرور، نحو: جَاءَ الَّذِي فِي الدَّارِ، فِي الدَّارِ: اسم مجرور، شبه الجملة من الجار والمجرور صلة الموصول. {وَأَلْقَتْ مَا فِيهَا وَتَخَلَّتْ}، فِيهَا: في حرف جر، والضمير هَا: ضمير مبني في محل جر اسم يعني، الجار والمجرور صلة الموصول. شبه جملة الموصول الظرف والجار والمجرور يتعلقان، يتعلق الظرف والجار والمجرور إذا وقعا صلة بفعل محذوف وجوباً تقديره \"استقر\". طيب، حالة الإعراب السهل هو الذي ذكرته لكم من قبل؛ أن تقول عِنْدَ ظرف صلة الموصول، وتقول فِي الدَّارِ جار ومجرور شبه جملة صلة الموصول. الإعراب الأصح هو هذا الذي يذكره هنا، فيقول: لا، الظرف متعلق بفعل محذوف تقديره \"استقر\"، فيكون تقدير الكلام مثلاً: جَاءَ الَّذِي عِنْدَكَ؛ جَاءَ الَّذِي اسْتَقَرَّ عِنْدَكَ، وحينئذٍ شبه الجملة لأن أصل الكلام يصبح جملة فعلية. جَاءَ الَّذِي فِي الدَّارِ؛ أي جَاءَ الَّذِي اسْتَقَرَّ فِي الدَّارِ، وحينئذٍ يشبه الجملة أنك تقدر فعلاً وجوباً تقديره \"استقر\"، فصلة الموصول تبقى على الأصل من أنها جملة جملة فعلية. صلة الموصول. أو بحرف جر ناوين معنى كائن أو استقر، فحتى حين يكون الخبر فإنه يقدرون لكي لا تكون جملة، هذه هي الخبر. إذن شبه الجملة إما أن تكون ظرفاً أو جاراً ومجروراً أو صفة صريحة. وَالثَّالِثُ: الصِّفَةُ الصَّرِيحَةُ، والمراد بها اسم الفاعل واسم المفعول، وتختص بالألف واللام، نحن قد ذكرنا كما في المثال: {الْمُصَّدِّقِينَ وَالْمُصَّدِّقَاتِ}، قلنا الفاعل واسم المفعول هذا لا يكون في الأسماء الموصولة الأخرى، لكن \"أل\" التي هي اسم موصول ترتبط باسم فاعل أو اسم مفعول، هي هذا. اسم الفاعل، هذا هو انتهينا من الصلة. العائد قال: وَالْعَائِدُ ضَمِيرٌ مُطَابِقٌ لِلْمَوْصُولِ فِي الْإِفْرَادِ وَالتَّثْنِيَةِ وَالْجَمْعِ وَالتَّذْكِيرِ وَالتَّأْنِيثِ، كما تقدم في الأمثلة المذكورة. في جميع ما ذكرناه نجد عائداً يعود على الاسم الموصول؛ فحين أقول مثلاً: جَاءَ الَّذِي أُحِبُّهُ، هذا الضمير الهاء يرجع على الَّذِي، واضح؟ جَاءَتِ الَّتِي أَكْرَمْتُهَا، لاحظ العائد يعود على الَّتِي، يطابق العائد الاسم الموصول في هذه الأمور في الإفراد والتثنية والجمع والتذكير والتأنيث، وقد يحذف العائد. أي: {وَيَشْرَبُ مِمَّا تَشْرَبُونَ مِنْهُ}، هذا العائد قد يحذف في الكلام ما يدل عليه بحيث لا يحتاج إليه. مثّل لحذف العائد المرفوع بقول الله سبحانه وتعالى: {ثُمَّ لَنَنزِعَنَّ مِن كُلِّ شِيعَةٍ أَيُّهُمْ}، أَيُّ هنا بمعنى الَّذِي، يعني قراءة عفواً، أَيُّهُمْ مبني على الضم في محل نصب مفعول به لـ {لَنَنزِعَنَّ}. أَيُّهُمْ في محل نصب وَأَشَدُّ: خبر مبتدأ محذوف تقديره \"هو\"، فيكون تقدير الكلام كما قال المصنف: هُوَ أَشَدُّ. {يَعْلَمُ مَا تُسِرُّونَ وَمَا تُعْلِنُونَ}، أصل الكلام: يَعْلَمُ مَا تُسِرُّونَهُ، فعلاً هي يعني ضمير في محل رفع فاعل، الهاء المفروض أن تكون هي المفعول به، العائد محذوف، وكذلك في {وَمَا تُعْلِنُونَ} أي: وَمَا تُعْلِنُونَهُ. ونحو: {وَيَشْرَبُ مِمَّا تَشْرَبُونَ} {يَأْكُلُ مِمَّا تَأْكُلُونَ مِنْهُ}، العائد المخفوض بالحرف، حرف الجر لدلالة سياق الكلام عليه. المعرّف بالأداة؛ أي بـ \"أل\". قال: فَصْلٌ: وَأَمَّا الْمُعَرَّفُ بِالْأَدَاةِ فَهُوَ الْمُعَرَّفُ بِالْأَلِفِ وَاللَّامِ، عهدية وجنسية. إذن قال: هذه إما أن تكون للعهد أو أن تكون للجنس. يبدأ بالعهد؛ والعهد ذكري، أو للعهد الذهني، أو للعهد الحضوري. إذن أول قسمي \"أل\" هي العهدية. إذا كانت للعهد الذكري كما في قول الله سبحانه وتعالى: {فِي زُجَاجَةٍ ۖ الزُّجَاجَةُ كَأَنَّهَا كَوْكَبٌ دُرِّيٌّ}، {مِصْبَاحٌ ۖ الْمِصْبَاحُ فِي زُجَاجَةٍ}، الزجاجة، {فِي زُجَاجَةٍ ۖ الزُجَاجَةُ}؛ الزجاجة معرفة هي نفسها الزجاجة المذكورة أولاً، هذه العهد الذكري؛ أي شيء معهود في الذكر قد ذُكر من قبل، جميل. وقد يكون للعهد الذهني، بأن يكون ما تصاحبه معهوداً في الذهن، لم يسبق له ذكر في الكلام ولكنه معهود في الذهن، كما في قول الله سبحانه وتعالى: {إِذْ هُمَا فِي الْغَارِ}، لم يُذكر هذا الغار من قبل ولكنه معهود في أذهان المخاطبين أن المقصود بذلك غار ثور وهو معروف عندهم. وقد يكون للعهد الحضوري، بأن يكون هذا هذا الاسم حاضراً زمن الخطاب حين وقع هذا الكلام، كما في قول الله سبحانه وتعالى: {الْيَوْمَ أَكْمَلْتُ لَكُمْ دِينَكُمْ}، إذن \"أل\" هذه للعهد الحضوري؛ هذا اليوم لم يُذكر من قبل في الكلام، وليس شيئاً معهوداً في أذهان الناس وإنما هو شيء حاضر، لأن هذه الآية نزلت في يوم عرفة: {الْيَوْمَ أَكْمَلْتُ لَكُمْ دِينَكُمْ}، إذن حين نزلت هذه الآية كان ذلك اليوم حاضراً فهذه للعهد الحضوري. إذن هذه ثلاثة أنواع من العهد. ثم الجنسية؛ والجنسية إما لتعريف الماهية أو لاستغراق الأفراد أو لاستغراق خصائص الأفراد. الجنسية لتعريف الماهية كما في قول الله سبحانه وتعالى: {وَجَعَلْنَا مِنَ الْمَاءِ كُلَّ شَيْءٍ حَيٍّ}، بمعنى أن هل هذه \"أل\" هذه التي هي لتعريف الماهية؛ أي تعرف ماهية الشيء وحقيقته من حيث هو، بغض النظر يعني عن الأفراد الداخلة في هذه الماهية. وعلامتها من الناحية اللفظية أنه يمكن أن، لا يمكن أن تخلفها أو تحل محلها \"كل\"، كما في قول ربنا سبحانه وتعالى: {وَجَعَلْنَا مِنَ الْمَاءِ كُلَّ شَيْءٍ حَيٍّ}. ما معنى {وَجَعَلْنَا مِنَ الْمَاءِ}؟ أي من حقيقة الماء، من ماهية الماء كل شيء حي، وليس المعنى: وجعلنا من كل ماء، يكون المعنى غير صحيح. فلذلك قلنا إن \"أل\" الجنسية هذه لا يصح أن تحل \"كل\" محلها، فلا يمكنك أن تقول: وجعلنا من كل ماء كل شيء حي، المعنى خطأ. لكن من جنس الماء، من حقيقة الماء، من ماهية الماء جعلنا منه كل شيء حي، فهذا الفرق بين الجنسية التي لتعريف الماهية. وأما استغراق الأفراد، هذه هي التي يصح أن تخلفها \"كل\"، كما في قول ربنا سبحانه وتعالى: {وَخُلِقَ الْإِنسَانُ ضَعِيفًا}، يمكن أن تعوض فتقول: وخلق كل إنسان ضعيفاً، يكون المعنى صحيحاً، ما يسمونه استغراق الأفراد وهو الذي يعرف عند الأصوليين بمعنى العموم، فـ \"أل\" هذه تفيد معنى العموم؛ {وَخُلِقَ الْإِنسَانُ ضَعِيفًا}: كل إنسان خُلق ضعيفاً، خلاف {وَجَعَلْنَا مِنَ الْمَاءِ كُلَّ شَيْءٍ حَيٍّ} ليس المعنى: وجعلنا من كل ماء كل شيء حي. وزاد وهو استغراق خصائص الأفراد، نحو: أَنْتَ الرَّجُلُ عِلْماً. وهذا لا يكون إلا على جهة المبالغة بحيث يصح أن تخلف \"أل\" هذه \"كل\"، ولكن على جهة المجاز لا على جهة الحقيقة. مثلاً: أَنْتَ الرَّجُلُ عِلْماً، يصح أن تقول مجازاً: أنت كل رجل علماً، كأنك كأنك تريد أن تقول لمخاطبك: قد اجتمع فيك كل ما تفرق في غيرك من الرجال من جهة ما عندك من العلم، فأنت يعني \"علماً\" هي التي تبين في أي شيء وقع هذا الاستغراق؛ جهة العلم. اجتمع فيك ما وُجد وما تفرق في الرجال كلهم، على جهة المجاز والمبالغة ولا يقصد به حقيقة الأمر، فهنا ليس المراد استغراق الأفراد استغراق الرجال؛ حين أقول: أَنْتَ الرَّجُلُ عِلْماً ليس المقصود أنه اجتمع فيك الرجال كلهم، لكن من جهة الخصائص، من جهة ما لديه من العلم كأن علم كل الرجال اجتمع فيك. وأخيراً قال: وَتُبْدَلُ لَامُهَا مِيماً فِي لُغَةِ حِمْيَرَ، هذه لغة للعرب خاصة؛ يقلبون اللام ميماً. ويذكرون أن رسول الله صلى الله عليه وسلم خاطب بعض أهل حمير بلغتهم، فقال في الحديث المعروف: \"لَيْسَ مِنَ امْبِرِّ امْصِيَامُ فِي امْسَفَرِ\"، خاطبهم بذلك فقال: \"ليس من البر الصيام في السفر\". نعم، انتهينا إذن من المعرّف بالأداة. ثم قال: فَصْلٌ: وَأَمَّا الْمُضَافُ إِلَى وَاحِدٍ مِنْ هَذِهِ الْخَمْسَةِ فَنَحْوُ: غُلَامِي، وَغُلَامِ هَذَا، وَغُلَامِ الَّذِي قَامَ أَبُوهُ، وَغُلَامِ الرَّجُلِ، وَغُلَامِ زَيْدٍ. وننتقل حينئذٍ إلى باب جديد هو باب المرفوعات من الأسماء، إلى لقاء مقبل بإذن الله سبحانه وتعالى، والحمد لله وصلى الله وسلم على رسول الله.",
    "blocks_search_text": "صلة الموصول (الجملة وشبه الجملة والصفة الصريحة) وَتَفْتَقِرُ المَوْصُولَاتُ كُلُّهَا إِلَى صِلَةٍ مُتَأَخِّرَةٍ عَنْهَا وَعَائِدٍ... وَصِلَتُهُ إِمَّا جُمْلَةٌ أَوْ شِبْهُهَا. يتناول هذا المحور شرح صلة الموصول وأنواعها، مبيناً أنها قد تأتي جملة اسمية أو فعلية، أو شبه جملة كالظرف والجار والمجرور، أو صفة صريحة. العائد في صلة الموصول وأحكام حذفه وَالْعَائِدُ ضَمِيرٌ مُطَابِقٌ لِلْمَوْصُولِ فِي الْإِفْرَادِ وَالتَّثْنِيَةِ وَالْجَمْعِ وَالتَّذْكِيرِ وَالتَّأْنِيثِ يوضح هذا المحور مفهوم العائد الذي يربط صلة الموصول بالاسم الموصول ووجوب مطابقته له، مع تفصيل حالات حذفه جوازاً إذا كان مرفوعاً أو منصوباً أو مجروراً. المعرف بالأداة (أل) وأقسامها العهدية والجنسية وَأَمَّا الْمُعَرَّفُ بِالْأَدَاةِ فَهُوَ الْمُعَرَّفُ بِالْأَلِفِ وَاللَّامِ، عهدية وجنسية. يشرح هذا الجزء المعرّف بـ 'أل' مبيناً انقسامها إلى عهدية (ذكري، ذهني، حضوري) وجنسية (لتعريف الماهية، واستغراق الأفراد أو خصائصهم)، مع التنبيه على لغة حمير.",
