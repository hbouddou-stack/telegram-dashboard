        "video_link": null
      },
      {
        "ts": "0:08",
        "sec": 8,
        "text": "والعقيدة للسنة الأولى في أكاديمية الباجي للعلوم الشرعية. قلنا في الدرس الماضي إن الشرك هو صرف",
        "video_link": null
      },
      {
        "ts": "0:25",
        "sec": 25,
        "text": "شيء من خصائص الله لغير الله. ثم يمكن أن نفصل في هذه الخصائص انطلاقاً",
        "video_link": null
      },
      {
        "ts": "0:32",
        "sec": 32,
        "text": "من تقسيم التوحيد؛ قلنا إن التوحيد يمكن أن نقسمه إلى أقسام ثلاثة: توحيد في الربوبية،",
        "video_link": null
      },
      {
        "ts": "0:41",
        "sec": 41,
        "text": "وتوحيد في الألوهية، وتوحيد في الأسماء والصفات. فبالتالي الشرك يقع أيضاً في هذه",
        "video_link": null
      },
      {
        "ts": "0:49",
        "sec": 49,
        "text": "الأقسام الثلاثة، فنجد: الشرك في الربوبية، والشرك في الألوهية، والشرك في الأسماء",
        "video_link": null
      },
      {
        "ts": "0:56",
        "sec": 56,
        "text": "والصفات. ودرس اليوم سنتناول فيه الشرك في الربوبية، يعني بعض",
        "video_link": null
      },
      {
        "ts": "1:05",
        "sec": 65,
        "text": "صوره وبعض الأقوام السابقين الذين وقعوا في هذا الشرك.",
        "video_link": null
      },
      {
        "ts": "1:12",
        "sec": 72,
        "text": "قبل ذلك، عموماً كان المشركون في الجزيرة العربية وكثير من المشركين في المناطق",
        "video_link": null
      },
      {
        "ts": "1:20",
        "sec": 80,
        "text": "المناطق الأخرى يثبتون الربوبية لله تعالى عموماً أو بإجمال، ويمكن",
        "video_link": null
      },
      {
        "ts": "1:29",
        "sec": 89,
        "text": "نقول يثبتون كثيراً من خصائص الربوبية لله سبحانه وتعالى؛ يقول الله جل في علاه: {وَلَئِن",
        "video_link": null
      },
      {
        "ts": "1:39",
        "sec": 99,
        "text": "سَأَلْتَهُم مَّنْ خَلَقَ السَّمَاوَاتِ وَالْأَرْضَ وَسَخَّرَ الشَّمْسَ وَالْقَمَرَ لَيَقُولُنَّ اللَّهُ}،",
        "video_link": null
      },
      {
        "ts": "1:45",
        "sec": 105,
        "text": "وقال تعالى: {وَلَئِن سَأَلْتَهُم مَّن نَّزَّلَ مِنَ السَّمَاءِ مَاءً فَأَحْيَا بِهِ الْأَرْضَ مِن بَعْدِ مَوْتِهَا لَيَقُولُنَّ",
        "video_link": null
      },
      {
        "ts": "1:54",
        "sec": 114,
        "text": "اللَّهُ}؛ هذه أفعال الربوبية؛ الخلق وإنزال الماء من السماء",
        "video_link": null
      },
      {
        "ts": "2:00",
        "sec": 120,
        "text": "وإحياء الأرض. وقال تعالى: {وَلَئِن سَأَلْتَهُم مَّنْ خَلَقَ السَّمَاوَاتِ وَالْأَرْضَ لَيَقُولُنَّ اللَّهُ}، وقال",
        "video_link": null
      },
      {
        "ts": "2:08",
        "sec": 128,
        "text": "تعالى: {وَلَئِن سَأَلْتَهُم مَّنْ خَلَقَ السَّمَاوَاتِ وَالْأَرْضَ لَيَقُولُنَّ خَلَقَهُنَّ الْعَزِيزُ الْعَلِيمُ}.",
        "video_link": null
      },
      {
        "ts": "2:14",
        "sec": 134,
        "text": "وغيرها من الآيات، وقال تعالى: {قُلْ مَن يَرْزُقُكُم مِّنَ السَّمَاءِ وَالْأَرْضِ أَمَّن يَمْلِكُ السَّمْعَ وَالْأَبْصَارَ وَمَن يُخْرِجُ الْحَيَّ مِنَ",
        "video_link": null
      },
      {
        "ts": "2:24",
        "sec": 144,
        "text": "الْمَيِّتِ وَيُخْرِجُ الْمَيِّتَ مِنَ الْحَيِّ وَمَن يُدَبِّرُ الْأَمْرَ ۚ فَسَيَقُولُونَ اللَّهُ}. كل هذه الآيات تتحدث عن",
        "video_link": null
      },
      {
        "ts": "2:33",
        "sec": 153,
        "text": "الربوبية؛ الخلق والايجاد، وإنزال الماء، والإحياء، والتدبير،",
        "video_link": null
      },
      {
        "ts": "2:39",
        "sec": 159,
        "text": "والرزق؛ هذه هي أفعال الربوبية التي بيّناها في دروس سابقة. هؤلاء الأقوام هؤلاء هم مشركون،",
        "video_link": null
      },
      {
        "ts": "2:47",
        "sec": 167,
        "text": "ولكن إذا سُئلوا هذه الأسئلة المتعلقة بالربوبية أثبتوها لله؛ قال ابن عباس رضي",
        "video_link": null
      },
      {
        "ts": "2:54",
        "sec": 174,
        "text": "الله عنهما: \"كان إذا قيل لهم: مَن خلق السماء؟ أو مَن خلق الأرض؟ ومَن خلق الجبال؟ قالوا:",
        "video_link": null
      },
      {
        "ts": "3:00",
        "sec": 180,
        "text": "الله، وهم مشركون\"، مشركون كما سيأتي معنا في العبادة. وقال عكرمة ومجاهد وهما",
        "video_link": null
      },
      {
        "ts": "3:08",
        "sec": 188,
        "text": "تلميذان لابن عباس رضي الله عنهما، قالوا يعني طبعاً نفس الكلام؛ اللي هو",
        "video_link": null
      },
      {
        "ts": "3:15",
        "sec": 195,
        "text": "هم يعني تسألهم مَن خلقهم؟ مَن خلق المخلوقات؟ فيقولون: الله، وهم يعبدون غيره.",
        "video_link": null
      },
      {
        "ts": "3:24",
        "sec": 204,
        "text": "وقال عبد الرحمن بن زيد بن أسلم: \"ليس أحد يعبد مع الله غيره إلا وهو مؤمن",
        "video_link": null
      },
      {
        "ts": "3:31",
        "sec": 211,
        "text": "بالله، ويعرف أن الله ربه وأن الله خالقه وهو رازقه، وهو يشرك به\".",
        "video_link": null
      },
      {
        "ts": "3:40",
        "sec": 220,
        "text": "إذاً أين الخلل؟ الخلل أن هذا هذا الإثبات وهذا الإيمان بربوبية الله تعالى كان بإجمال،",
        "video_link": null
      },
      {
        "ts": "3:49",
        "sec": 229,
        "text": "ولم يكن سليماً مائة بالمائة؛ إذ لو كان سليماً بالمائة بالمائة لأنتج لنا",
        "video_link": null
      },
      {
        "ts": "3:57",
        "sec": 237,
        "text": "عبادة سليمة، لأنه ما من خلل موجود في",
        "video_link": null
      },
      {
        "ts": "4:03",
        "sec": 243,
        "text": "الألوهية إلا وسببه خلل موجود في الربوبية. لو صحت،",
        "video_link": null
      },
      {
        "ts": "4:11",
        "sec": 251,
        "text": "لو صحت اعتقادات هؤلاء الناس في ربوبية الله ووحدوا الله تعالى كما ينبغي في ربوبيته، لما",
        "video_link": null
      },
      {
        "ts": "4:19",
        "sec": 259,
        "text": "ظهر الشرك في الألوهية؛ لأن الشرك في الألوهية هؤلاء ما مقصده -وسنفصل لاحقاً- إن",
        "video_link": null
      },
      {
        "ts": "4:25",
        "sec": 265,
        "text": "هؤلاء الناس يسألون غير الله، السؤال: لماذا سألوا غير الله؟ لماذا عبدوا غير الله؟",
        "video_link": null
      },
      {
        "ts": "4:33",
        "sec": 273,
        "text": "لأنهم اعتقدوا مسبقاً أن الله تعالى سيعطيهم، عفواً غير الله يعطيهم؛ هم عبدوا",
        "video_link": null
      },
      {
        "ts": "4:42",
        "sec": 282,
        "text": "معبودات أخرى، لماذا عبدوا هذه المعبودات الأخرى؟ لأنهم اعتقدوا أنها تستجيب لهم، لها",
        "video_link": null
      },
      {
        "ts": "4:49",
        "sec": 289,
        "text": "قوة، لها قدرة، لها تصرف، وهذا مرتبط بالربوبية؛ اعتقاد أن لهذه المعبودات",
        "video_link": null
      },
      {
        "ts": "4:57",
        "sec": 297,
        "text": "تصرفات في الكون وقوة وقدرة على فعل أشياء، هذا خلل في",
        "video_link": null
      },
      {
        "ts": "5:05",
        "sec": 305,
        "text": "الربوبية. ولذلك كان الأنبياء والرسل يبدأون بالربوبية ليصلوا إلى الألوهية، وهو المنهج",
        "video_link": null
      },
      {
        "ts": "5:13",
        "sec": 313,
        "text": "الذي سار عليه العلماء؛ علماء العقيدة والعلماء ورثة الأنبياء. إذا أردت أن تحدث شخصاً",
        "video_link": null
      },
      {
        "ts": "5:21",
        "sec": 321,
        "text": "وتنهاه عن عبادة غير الله، حدثه عن ربوبية هذا المعبود؛ هل له معانٍ من معاني",
        "video_link": null
      },
      {
        "ts": "5:28",
        "sec": 328,
        "text": "الربوبية؟ هل يمكن أن، هل له تصرف؟ هل له قوة؟ وهل له قدرة؟",
        "video_link": null
      },
      {
        "ts": "5:36",
        "sec": 336,
        "text": "ولذلك الله تعالى بيّن أن هؤلاء المشركين وإن كانوا مقرين بربوبية الله كانت بإجمال،",
        "video_link": null
      },
      {
        "ts": "5:44",
        "sec": 344,
        "text": "وبيّن الله تعالى أنهم كانت لهم مجموعة من الأمور المختلة في هذا الجانب، قال تعالى:",
        "video_link": null
      },
      {
        "ts": "5:51",
        "sec": 351,
        "text": "{وَاتَّخَذُوا مِن دُونِ اللَّهِ آلِهَةً لِّيَكُونُوا لَهُمْ عِزًّا}، {وَاتَّخَذُوا مِن دُونِ اللَّهِ آلِهَةً لِّيَكُونُوا لَهُمْ عِزًّا}.",
        "video_link": null
      },
      {
        "ts": "5:59",
        "sec": 359,
        "text": "فإذاً هم ابتغوا العزة من عند غير الله، لماذا؟ لأنهم اعتقدوا أن غير الله يعطي",
        "video_link": null
      },
      {
        "ts": "6:06",
        "sec": 366,
        "text": "العزة، يعز؛ اعتقاد أن غير الله يعز هذا خلل في الربوبية ترتب عليه",
        "video_link": null
      },
      {
        "ts": "6:14",
        "sec": 374,
        "text": "خلل في الألوهية، الأمر يعني الأمر مرتبط. لماذا سألوا غير الله؟ لأنهم اعتقدوا أن",
        "video_link": null
      },
      {
        "ts": "6:23",
        "sec": 383,
        "text": "هذا المعبود غير الله يعطي ويعز فاتخذوه آلهة: {وَاتَّخَذُوا مِن دُونِ اللَّهِ آلِهَةً",
        "video_link": null
      },
      {
        "ts": "6:31",
        "sec": 391,
        "text": "لِّيَكُونُوا لَهُمْ عِزًّا}. كذلك من صور الشرك في الربوبية عند المشركين في الجزيرة العربية: اعتقاد",
        "video_link": null
      },
      {
        "ts": "6:40",
        "sec": 400,
        "text": "الأمطار من النجوم والأنواء، الأنواء هي منازل النجوم. روى الشيخان عن زيد بن خالد الجهني أنه قال:",
        "video_link": null
      },
      {
        "ts": "6:49",
        "sec": 409,
        "text": "\"صلى لنا رسول الله صلى الله عليه وسلم صلاة الصبح بالحديبية على إثر سماء كانت",
        "video_link": null
      },
      {
        "ts": "6:56",
        "sec": 416,
        "text": "من الليل\" أي على إثر مطر، \"فلما انصرف أقبل على الناس فقال: أتدرون ماذا قال ربكم؟",
        "video_link": null
      },
      {
        "ts": "7:03",
        "sec": 423,
        "text": "قالوا: الله ورسوله أعلم، قال: أصبح من عبادي مؤمن بي وكافر بي؛ فأما من قال مطرنا بفضل",
        "video_link": null
      },
      {
        "ts": "7:13",
        "sec": 433,
        "text": "الله ورحمته فذلك مؤمن بي كافر بالكوكب، وأما من قال مطرنا بنوء كذا وكذا فذلك",
        "video_link": null
      },
      {
        "ts": "7:20",
        "sec": 440,
        "text": "كافر بي مؤمن بالكوكب\". فهذا اعتقاد كان عند المشركين في الجزيرة العربية، وبقيت طبعاً",
        "video_link": null
      },
      {
        "ts": "7:27",
        "sec": 447,
        "text": "بعض الرواسب عندهم فنبّههم النبي عليه الصلاة والسلام، وقد جاء طبعاً لتصفية المعتقدات. كانوا يعتقدون أن المطر إنما",
        "video_link": null
      },
      {
        "ts": "7:36",
        "sec": 456,
        "text": "ينزله بعض النجوم والكواكب؛ فقال مَن اعتقد أن الأمطار هي التي تنزل المطر فهذا قد",
        "video_link": null
      },
      {
        "ts": "7:45",
        "sec": 465,
        "text": "أشرك بأن النجوم هي التي تنزل المطر، هذا شرك بالله؛ فاعتقاد أن هذه المخلوقات",
        "video_link": null
      },
      {
        "ts": "7:54",
        "sec": 474,
        "text": "لها هذا التصرف، هذا خلل في الربوبية وليس خللاً في الألوهية، بعد ذلك يترتب عليه خلل",
        "video_link": null
      },
      {
        "ts": "8:02",
        "sec": 482,
        "text": "هو العبادة والدعاء. فما من خلل في الألوهية إلا وينبغي تتبعه لإصلاحه وسنجد",
        "video_link": null
      },
      {
        "ts": "8:11",
        "sec": 491,
        "text": "أنه موجود في الربوبية؛ ما من خلل في الألوهية إلا ومرتبط بخلل في الربوبية، هذا",
        "video_link": null
      },
      {
        "ts": "8:18",
        "sec": 498,
        "text": "هذا منهج الإصلاح الذي ينبغي اتباعه. بعض الناس مثلاً يقول تجدوه يذهب عند الضريح",
        "video_link": null
      },
      {
        "ts": "8:25",
        "sec": 505,
        "text": "الفلاني ويسأله مثلاً الذرية، يسأله الصحة، امرأة تذهب وتسأله أن يعينها لكي تتزوج،",
        "video_link": null
      },
      {
        "ts": "8:33",
        "sec": 513,
        "text": "وشاب يريد أن يعمل؛ هذه بعض الصور الموجودة مع كامل الأسف في زماننا. لماذا لجأ هؤلاء الناس",
        "video_link": null
      },
      {
        "ts": "8:40",
        "sec": 520,
        "text": "لهذه الأضرحة ولهاته هاته مخلوقات وهذا وهذا وهؤلاء أموات أصلاً؟",
        "video_link": null
      },
      {
        "ts": "8:47",
        "sec": 527,
        "text": "لأنهم اعتقدوا أنها تعطي، واعتقادهم بأن هذه الأضرحة وهذه الأشياء",
        "video_link": null
      },
      {
        "ts": "8:55",
        "sec": 535,
        "text": "تعطي، هذا خلل في الربوبية ترتب عليه خلل في الألوهية وهي التقرب إليها. فهناك ارتباط",
        "video_link": null
      },
      {
        "ts": "9:03",
        "sec": 543,
        "text": "طبيعي بالطبع، لأن الربوبية مرتبطة بالألوهية بل الربوبية تستلزم الألوهية؛ توحيد الربوبية يستلزم توحيد الألوهية، وقد",
        "video_link": null
      },
      {
        "ts": "9:12",
        "sec": 552,
        "text": "رأينا هذا في الفروق بين التوحيدين، بين هذين القسمين، بين الربوبية والألوهية؛ توحيد الربوبية",
        "video_link": null
      },
      {
        "ts": "9:21",
        "sec": 561,
        "text": "يستلزم ويؤدي ويفضي إلى توحيد الألوهية، فهذا الارتباط يدفع المصلح",
        "video_link": null
      },
      {
        "ts": "9:29",
        "sec": 569,
        "text": "والداعي إلى العقيدة السليمة إلى أن يربط الخلل الموجود في الألوهية بخلل موجود في",
        "video_link": null
      },
      {
        "ts": "9:37",
        "sec": 577,
        "text": "الربوبية. ومرة أخرى ما نقولها ونؤكد عليها: ما من خلل وُجد في توحيد الألوهية إلا بسبب",
        "video_link": null
      },
      {
        "ts": "9:45",
        "sec": 585,
        "text": "خلل موجود في توحيد الربوبية، لو سلم توحيد الربوبية لسلم توحيد الألوهية. كذلك من صور",
        "video_link": null
      },
      {
        "ts": "9:53",
        "sec": 593,
        "text": "الشرك التي كانت موجودة في الجزيرة العربية -كل هذا لكي نبين بأن بعض الناس يقول بأن",
        "video_link": null
      },
      {
        "ts": "10:00",
        "sec": 600,
        "text": "المشركين كانوا مقرين وموحدين توحيد الربوبية الصافي الكامل، وهذا خطأ؛ لأنه لو",
        "video_link": null
      },
      {
        "ts": "10:07",
        "sec": 607,
        "text": "وُجد هذا الكمال في توحيد الربوبية لما وُجد خلل في توحيد الألوهية- قمت من الصور:",
        "video_link": null
      },
      {
        "ts": "10:14",
        "sec": 614,
        "text": "الاعتقاد في التمائم، فما هي؟ كل شيء هي جمع تميمة، وما كان يحمل الإنسان لكي",
        "video_link": null
      },
      {
        "ts": "10:22",
        "sec": 622,
        "text": "يعني يجلب له السلامة والعافية ويدفع ويدفع عنه الأضرار. روى أبو داود عن عبد",
        "video_link": null
      },
      {
        "ts": "10:31",
        "sec": 631,
        "text": "الله بن مسعود رضي الله عنه أنه دخل على امرأته وفي عنقها شيء يعوذ به فجذبه وقطعه،",
        "video_link": null
      },
      {
        "ts": "10:40",
        "sec": 640,
        "text": "ثم قال: \"لقد أصبح آل عبد الله\" يقصد عبد الله يحسد نفسه \"أغنياء عن أن يشركوا",
        "video_link": null
      },
      {
        "ts": "10:48",
        "sec": 648,
        "text": "بالله ما لم ينزل به سلطاناً\"، ثم قال: سمعت رسول الله صلى الله عليه وسلم يقول: \"إن",
        "video_link": null
      },
      {
        "ts": "10:56",
        "sec": 656,
        "text": "الرُّقَى وَالتَّمَائِمَ وَالتِّوَلَةَ شِرْكٌ\". إن التمائم والتولة شرك، الأمور التي ذكرت جمعتها؛ وهي الأمور التي",
        "video_link": null
      },
      {
        "ts": "11:05",
        "sec": 665,
        "text": "تُعلق لكي تجلب الحظ وتدفع الأضرار، والتِوَلَة هي الأمور التي كانت تدفع تحمل،",
        "video_link": null
      },
      {
        "ts": "11:13",
        "sec": 673,
        "text": "تفعلها النساء لكي يفضّل لكي يفضّلها زوجها لكي يحبها زوجها، يعني لأن كان عندهم",
        "video_link": null
      },
      {
        "ts": "11:21",
        "sec": 681,
        "text": "طبعاً هذا التعدد وكانوا يعني أصحاب أصحاب زوجات",
        "video_link": null
      },
      {
        "ts": "11:27",
        "sec": 687,
        "text": "ثلاثة وأربعة، فكانت الواحدة منها منهن تحمل شيئاً لكي تُحبَّب إلى زوجها لكي تُفضّل على",
        "video_link": null
      },
      {
        "ts": "11:36",
        "sec": 696,
        "text": "غيرها. ابن مسعود رضي الله عنه جذب هذا من عنق زوجته فقال يعني إن كنت تفعلين هذا من باب",
        "video_link": null
      },
      {
        "ts": "11:45",
        "sec": 705,
        "text": "التمائم أو من باب الشرك فهذه صورة صورة من صور الشرك في الربوبية التي ترتب عن هذا",
        "video_link": null
      },
      {
        "ts": "11:53",
        "sec": 713,
        "text": "الفعل؛ اعتقاد بأن التمائم تجلب المنافع هذا شرك",
        "video_link": null
      },
      {
        "ts": "12:01",
        "sec": 721,
        "text": "في الربوبية. إتيان الكهنة وتصديقهم هذا من الصور؛ أن المشركين في الجزيرة العربية",
        "video_link": null
      },
      {
        "ts": "12:09",
        "sec": 729,
        "text": "كانوا يعتقدون أن الكهنة لهم قدرة على جلب المصالح ودفع المفاسد وهذا",
        "video_link": null
      },
      {
        "ts": "12:19",
        "sec": 739,
        "text": "أيضاً من الشرك؛ قال عليه الصلاة والسلام: \"من أتى عرافاً أو كاهناً فصدقه بما يقول فقد كفر بما",
        "video_link": null
      },
      {
        "ts": "12:27",
        "sec": 747,
        "text": "أُنزل على محمد\"، \"من أتى عرافاً أو كاهناً فصدقه\" طبعاً هذا الإتيان هذا يكون في الألوهية ولكن",
        "video_link": null
      },
      {
        "ts": "12:35",
        "sec": 755,
        "text": "أين يكمن الشرك في الربوبية؟ هو التصديق، هو التصديق لأنه صدقه واعتقد أنه يعلم الغيب",
        "video_link": null
      },
      {
        "ts": "12:43",
        "sec": 763,
        "text": "وينفع ويجلب الخير ونحو ذلك. كذلك من صور الشرك في الربوبية: التطير، وهذا كان مشهوراً",
        "video_link": null
      },
      {
        "ts": "12:53",
        "sec": 773,
        "text": "أو معروفاً عنهم؛ روى أبو داود والترمذي عن عبد الله بن مسعود قال: قال عليه الصلاة والسلام: \"الطِّيَرَةُ شِرْكٌ\". التطير هذا من الطائر",
        "video_link": null
      },
      {
        "ts": "13:04",
        "sec": 784,
        "text": "طبعاً، كانوا لهم أنواع من الطائر بعضها تُسمى صوانح وبوارح، ما الذي يفعلونه؟ يأتون فيضعون هذه الطيور إذا أرادوا أن",
        "video_link": null
      },
      {
        "ts": "13:14",
        "sec": 794,
        "text": "يفعلوا شيئاً مستقبلاً في المستقبلي، يعني شيء لا يعرفون كيف سيكون بالطبع؛ مثلاً زواج،",
        "video_link": null
      },
      {
        "ts": "13:21",
        "sec": 801,
        "text": "تجارة، رحلة، هجرة، يعني شراء شيء،",
        "video_link": null
      },
      {
        "ts": "13:27",
        "sec": 807,
        "text": "أي شيء في المستقبل كانوا يأتون لهذه الطيور فيهيجونها، فإذا طارت يميناً قالوا:",
        "video_link": null
      },
      {
        "ts": "13:34",
        "sec": 814,
        "text": "\"نعم، هذا فعل حسن سنفعله\"، وإذا طارت شمالاً تشاءموا وأحجموا عن فعله. فجاء النبي عليه",
        "video_link": null
      },
      {
        "ts": "13:41",
        "sec": 821,
        "text": "الصلاة وأبطل هذا، وطبعاً البديل وطبعاً هو الاستشارة والاستخارة؛ يعني حتى عقلاً هذا",
        "video_link": null
      },
      {
        "ts": "13:48",
        "sec": 828,
        "text": "باطل، كيف تربط يعني اتجاه الطيور شمالاً أو يميناً بأن هذا الفعل فيه خير وإذا اتجهت",
        "video_link": null
      },
      {
        "ts": "13:56",
        "sec": 836,
        "text": "يساراً بأن هذا الفعل فيه شر؟! حتى عقلاً هذا الربط، ولذلك يعني هذه الفترة تُسمى الجاهلية",
        "video_link": null
      },
      {
        "ts": "14:03",
        "sec": 843,
        "text": "من هذا الباب، من هذا الارتباط العقلي بين الأمور. ولكن",
        "video_link": null
      },
      {
        "ts": "14:10",
        "sec": 850,
        "text": "كانوا مقرين كما قلنا رغم كل هذه الصور عموماً وإجمالاً من، في أمور الخلق وفي أمور",
        "video_link": null
      },
      {
        "ts": "14:18",
        "sec": 858,
        "text": "الكبرى، في أمور الرزق كانوا مقرين بتوحيد الربوبية. أما في التاريخ القديم فقط يعني",
        "video_link": null
      },
      {
        "ts": "14:27",
        "sec": 867,
        "text": "ظهر أيضاً هذا الخلل، الشرك في الربوبية عند القدامى؛ قال تعالى حكاية عن قوم عاد وهم",
        "video_link": null
      },
      {
        "ts": "14:34",
        "sec": 874,
        "text": "يخاطبون نبيهم هوداً عليه السلام: {إِن نَّقُولُ إِلَّا اعْتَرَاكَ بَعْضُ آلِهَتِنَا بِسُوءٍ}، انظروا! وهم",
        "video_link": null
      },
      {
        "ts": "14:41",
        "sec": 881,
        "text": "كانوا يعتقدون أن تلك الآلهة التي كانوا يعبدونها كانت يمكنها أن تسيء إلى الناس،",
        "video_link": null
      },
      {
        "ts": "14:50",
        "sec": 890,
        "text": "فقالوا: {إِن نَّقُولُ إِلَّا اعْتَرَاكَ بَعْضُ آلِهَتِنَا بِسُوءٍ} فنسبوا الإساءة والضرر والضرر إلى آلهتهم",
        "video_link": null
      },
      {
        "ts": "14:59",
        "sec": 899,
        "text": "أنها بإمكانها أن تسيء وتضر الناس. كذلك ما قاله النمروذ بن كنعان وهو الذي",
        "video_link": null
      },
      {
        "ts": "15:09",
        "sec": 909,
        "text": "كان في عهد إبراهيم عليه السلام أنه نسب الإحياء والإماتة لنفسه، وهذا شرك في الربوبية لأنه اعتقد هو أنه هو الذي يميت،",
        "video_link": null
      },
      {
        "ts": "15:18",
        "sec": 918,
        "text": "وكذلك هذا أمر واضح وجاء مصرحاً به في قصة فرعون قال: {أَنَا رَبُّكُمُ الْأَعْلَىٰ}.",
        "video_link": null
      },
      {
        "ts": "15:28",
        "sec": 928,
        "text": "كذلك ما وقع فيه المجوس، وهذا أيضاً مهم لأن المجوس كانوا قريبين من الجزيرة العربية وهم اعتقدوا وجود ربين، تعالى الله عما",
        "video_link": null
      },
      {
        "ts": "15:37",
        "sec": 937,
        "text": "يقولون؛ قالوا: يوجد في الكون ربان؛ رب خالق للخير ورب خالق للشر،",
        "video_link": null
      },
      {
        "ts": "15:46",
        "sec": 946,
        "text": "والأول يسمونه رب النور والثاني يسمونه رب الظلام، يعني هناك من يقول إنه كان له",
        "video_link": null
      },
      {
        "ts": "15:54",
        "sec": 954,
        "text": "أسماء \"يزدان\" واسم آخر لا يحضرني الآن؛ اعتقدوا أن هذين هما الربان",
        "video_link": null
      },
      {
        "ts": "16:03",
        "sec": 963,
        "text": "المتصرفان في الكون. كذلك الدهرية أيضاً هؤلاء وقعوا في الشرك",
        "video_link": null
      },
      {
        "ts": "16:11",
        "sec": 971,
        "text": "وإن قالوا بوجود الله، ولكن هم لم يلحدوا بالاصطلاح العصري",
        "video_link": null
      },
      {
        "ts": "16:18",
        "sec": 978,
        "text": "ولكن هم مشركون من جهة الربوبية لأنهم نسبوا التصرف للدهر ومثل هؤلاء الذين",
        "video_link": null
      },
      {
        "ts": "16:26",
        "sec": 986,
        "text": "يقولون الطبيعة تفعل كل شيء ونحو ذلك. فهؤلاء قال تعالى حكاية عنهم: {وَقَالُوا مَا هِيَ إِلَّا حَيَاتُنَا الدُّنْيَا نَمُوتُ وَنَحْيَا وَمَا يُهْلِكُنَا إِلَّا",
        "video_link": null
      },
      {
        "ts": "16:35",
        "sec": 995,
        "text": "الدَّهْرُ}، هو الدهر هو الذي يتصرف في الكون؛ هذه كلها من صور الشرك في الربوبية في العصر القديم. ثم",
        "video_link": null
      },
      {
        "ts": "16:44",
        "sec": 1004,
        "text": "عندنا أيضاً صور من الشرك في الربوبية في هذا العصر كما قلنا قبل قليل؛ هؤلاء الذين",
        "video_link": null
      },
      {
        "ts": "16:50",
        "sec": 1010,
        "text": "نسبوا الخلق للطبيعة أو التصرف للطبيعة، وأصحاب نظرية التطور ونحو ذلك، هذا شرك في",
        "video_link": null
      },
      {
        "ts": "16:56",
        "sec": 1016,
        "text": "الربوبية لأنهم نسبوا الخلق والفعل وكل ما يقع للطبيعة؛ الطبيعة هي التي تفعل كل شيء.",
        "video_link": null
      },
      {
        "ts": "18:05",
        "sec": 1085,
        "text": "فاعتقاد هذا الأمر أيضاً من صور الشرك في الربوبية. وكذلك كما قلت قبل قليل قضية",
        "video_link": null
      },
      {
        "ts": "18:12",
        "sec": 1092,
        "text": "الأضرحة التي انتشرت في المجتمعات الإسلامية، ولا زالت مع كامل الأسف، أنهم كانوا يعني الناس يذهبون إليها",
        "video_link": null
      },
      {
        "ts": "18:21",
        "sec": 1101,
        "text": "ويقصدونها لجلب المصالح ودفع المفاسد؛ لماذا؟ لأنهم يعتقدون أن هذه الأضرحة،",
        "video_link": null
      },
      {
        "ts": "18:30",
        "sec": 1110,
        "text": "وأيضاً حتى يلحقوا بهم هؤلاء المشعوذين أنهم يذهبون يذهبون الناس إليهم ليسألوهم عن بعض الأمور الغيبية، ويسألون بعض الأمور",
        "video_link": null
      },
      {
        "ts": "18:39",
        "sec": 1119,
        "text": "التي تجلب لهم المنافع وتدفع عنهم المفاسد، كل هذا يدخل ويندرج تحت الشرك في الربوبية.",
        "video_link": null
      },
      {
        "ts": "18:48",
        "sec": 1128,
        "text": "وهذا طبعاً باطل في باطل، وإصلاحه هو إصلاح لما للعقيدة الصحيحة اللي هي عبادة الله",
        "video_link": null
      },
      {
        "ts": "18:57",
        "sec": 1137,
        "text": "وحده. المطلوب من الإنسان أنت لكي تعبد الله وحده لا بد أن",
        "video_link": null
      },
      {
        "ts": "19:03",
        "sec": 1143,
        "text": "تصحح عقيدة الربوبية؛ أن تكون، أن تبطل كل هذه الأمور عن غير الله، فلا فلا تجعل شيئاً",
        "video_link": null
      },
      {
        "ts": "19:13",
        "sec": 1153,
        "text": "من خصائص الربوبية لغير الله. هذا هذا التصرف يفضي بك إن شاء الله تعالى",
        "video_link": null
      },
      {
        "ts": "19:18",
        "sec": 1158,
        "text": "إلى سلامة العبادات، لأن قلنا ما هو الشرك؟ تعريفه العام:",
        "video_link": null
      },
      {
        "ts": "19:25",
        "sec": 1165,
