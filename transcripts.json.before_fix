    "video_url": null,
    "segments": [
      {
        "ts": "0:00",
        "sec": 0,
        "text": "بسم الله الرحمن الرحيم، الحمد لله رب العالمين، والصلاة والسلام على نبينا محمد وعلى آله وصحبه والتابعين، ومن تبعهم",
        "video_link": null
      },
      {
        "ts": "0:09",
        "sec": 9,
        "text": "بإحسان إلى يوم الدين. نواصل تدارسنا لمتن متممة الآجرومية، ونحن في \"إِنَّ\" وأخواتها.",
        "video_link": null
      },
      {
        "ts": "0:20",
        "sec": 20,
        "text": "بعد أن ذكرنا بعض المباحث، نواصل حديثنا بذكر مسائل أخرى متعلقة بِإِنَّ وأخواتها؛ قال:",
        "video_link": null
      },
      {
        "ts": "0:28",
        "sec": 28,
        "text": "وتدخل لام الابتداء بعد إِنَّ المكسورة فقط.",
        "video_link": null
      },
      {
        "ts": "0:37",
        "sec": 37,
        "text": "لام الابتداء هذه هي التي تُسمى اللام المزحلقة،",
        "video_link": null
      },
      {
        "ts": "0:43",
        "sec": 43,
        "text": "فهي ابتدائية في الأصل لكنها تُزحلق عن موضعها في الجملة؛ تقول:",
        "video_link": null
      },
      {
        "ts": "0:51",
        "sec": 51,
        "text": "\"إن زيداً لقائمٌ\"؛ هذه اللام أنت ترى أنها",
        "video_link": null
      },
      {
        "ts": "0:57",
        "sec": 57,
        "text": "مقترنة بالخبر، لكن أصلها فيما يقولون أنها ابتدائية؛ بمعنى في ابتداء الكلام \"لَإنَّ زيداً قائمٌ\"، فكرهوا اجتماع مؤكِّدَين في بدء الجملة، ولأجل",
        "video_link": null
      },
      {
        "ts": "1:16",
        "sec": 76,
        "text": "ذلك زحلقوا اللام من موضعها في بدء الكلام إلى ماذا؟ إلى",
        "video_link": null
      },
      {
        "ts": "1:24",
        "sec": 84,
        "text": "الخبر. فيقول: تدخل هذه اللام بعد إِنَّ المكسورة فقط",
        "video_link": null
      },
      {
        "ts": "1:34",
        "sec": 94,
        "text": "على أربعة أشياء: على خبرها بشرط كونه مؤخراً مثبتاً، نحو: {إِنَّ",
        "video_link": null
      },
      {
        "ts": "1:43",
        "sec": 103,
        "text": "رَبَّكَ لَسَرِيعُ الْعِقَابِ وَإِنَّهُ لَغَفُورٌ رَّحِيمٌ}؛ إنَّ",
        "video_link": null
      },
      {
        "ts": "1:51",
        "sec": 111,
        "text": "ربكَ: اسم إنَّ، سريعُ: هذا هو ماذا؟ الخبر، فهو",
        "video_link": null
      },
      {
        "ts": "1:57",
        "sec": 117,
        "text": "مضاف، العقابِ: مضاف إليه؛ فإذن اللام المزحلقة ولام الابتداء ارتبطت إذن هنا",
        "video_link": null
      },
      {
        "ts": "2:04",
        "sec": 124,
        "text": "بالخبر وقد توفر الشرط وهو كونه مؤخراً مثبتاً؛ أي غير منفي.",
        "video_link": null
      },
      {
        "ts": "2:14",
        "sec": 134,
        "text": "وكذلك، نعم معنى كونه مؤخراً أي مؤخراً عن الاسم؛ يعني",
        "video_link": null
      },
      {
        "ts": "2:23",
        "sec": 143,
        "text": "في الترتيب أن يكون الاسم أولاً ثم الخبر؛ فمثلاً في قول الله سبحانه وتعالى: {إِنَّ لَدَيْنَا أَنكَالًا وَجَحِيمًا} لا يمكن أن ندخل اللام لأن الخبر هنا مقدم على الاسم. وكذلك لا بد أن",
        "video_link": null
      },
      {
        "ts": "2:40",
        "sec": 160,
        "text": "يكون مثبتاً، فإذا كان منفياً لم تدخل عليه اللام؛ يعني مثلاً في: \"إن",
        "video_link": null
      },
      {
        "ts": "2:50",
        "sec": 170,
        "text": "زيداً لم يقمْ\"، لم يجز دخول اللام في مثل ذلك.",
        "video_link": null
      },
      {
        "ts": "2:57",
        "sec": 177,
        "text": "قال: إذاً هذا الشيء الأول. الشيء الثاني: وعلى اسمها بشرط أن يتأخر عن الخبر،",
        "video_link": null
      },
      {
        "ts": "3:03",
        "sec": 183,
        "text": "نحو: {إِنَّ فِي ذَٰلِكَ لَعِبْرَةً}؛ هنا لام الابتداء المزحلقة دخلت على الاسم، على اسم إنَّ،",
        "video_link": null
      },
      {
        "ts": "3:13",
        "sec": 193,
        "text": "ولكن إنما دخلت عليه لأنه مؤخر؛ فالجار والمجرور \"في ذلك\" هو الخبر وهو مقدم،",
        "video_link": null
      },
      {
        "ts": "3:22",
        "sec": 202,
        "text": "و\"عبرةً\" اسم إنَّ مؤخر. ثالثاً: وعلى ضمير الفصل،",
        "video_link": null
      },
      {
        "ts": "3:30",
        "sec": 210,
        "text": "نحو: {إِنَّ هَٰذَا لَهُوَ الْقَصَصُ الْحَقُّ}؛ ضمير الفصل هو",
        "video_link": null
      },
      {
        "ts": "3:39",
        "sec": 219,
        "text": "ضمير، أو لنقل إنه في صيغته وفي لفظه هو ضمير",
        "video_link": null
      },
      {
        "ts": "3:47",
        "sec": 227,
        "text": "مرفوع، ولكن يؤتى به للفصل بين المبتدأ والخبر.",
        "video_link": null
      },
      {
        "ts": "3:57",
        "sec": 237,
        "text": "فهنا أنت ترى في نحو: {إِنَّ هَٰذَا لَهُوَ الْقَصَصُ الْحَقُّ}، هذا: اسم إنَّ،",
        "video_link": null
      },
      {
        "ts": "4:05",
        "sec": 245,
        "text": "القصصُ: خبر إنَّ، وجاء بينهما ضمير فصل: {إِنَّ هَٰذَا لَهُوَ الْقَصَصُ الْحَقُّ}، جاز دخول لام الابتداء على",
        "video_link": null
      },
      {
        "ts": "4:14",
        "sec": 254,
        "text": "ضمير الفصل: {إِنَّ هَٰذَا لَهُوَ الْقَصَصُ الْحَقُّ}.",
        "video_link": null
      },
      {
        "ts": "4:20",
        "sec": 260,
        "text": "وكذلك الشيء الرابع: وعلى معمول الخبر بشرط",
        "video_link": null
      },
      {
        "ts": "4:25",
        "sec": 265,
        "text": "تقدمه على الخبر، نحو: إن زيداً لَعَمْراً ضاربٌ؛ إنَّ",
        "video_link": null
      },
      {
        "ts": "4:33",
        "sec": 273,
        "text": "زيداً: اسمها، عمراً: معمول لضارب، لأن \"ضارب\" اسم فاعل يعمل عمل الفعل،",
        "video_link": null
      },
      {
        "ts": "4:43",
        "sec": 283,
        "text": "وضاربٌ: هو خبر إنَّ؛ اللام اقترنت بمعمول الخبر الذي هو عمراً، كما",
        "video_link": null
      },
      {
        "ts": "4:52",
        "sec": 292,
        "text": "قلنا لأنه تحقق فيه الشرط الذي هو كونه متقدماً على الخبر.",
        "video_link": null
      },
      {
        "ts": "5:00",
        "sec": 300,
        "text": "ولا تقول: \"إن زيداً ضاربٌ لعمراً\"، فلا تدخل اللام على عمرو إذا كان غير متقدم على",
        "video_link": null
      },
      {
        "ts": "5:08",
        "sec": 308,
        "text": "الخبر. وتتصل \"مَا\" الزائدة بهذه الأحرف",
        "video_link": null
      },
      {
        "ts": "5:16",
        "sec": 316,
        "text": "فيبطل عملها؛ الكلام هنا عن \"مَا\" التي تُسمى الكافة،",
        "video_link": null
      },
      {
        "ts": "5:22",
        "sec": 322,
        "text": "لأنها تكفُّ إنَّ وأخواتها عن العمل تبطل عملها،",
        "video_link": null
      },
      {
        "ts": "5:30",
        "sec": 330,
        "text": "نحو: {إِنَّمَا اللَّهُ إِلَٰهٌ وَاحِدٌ}.",
        "video_link": null
      },
      {
        "ts": "5:34",
        "sec": 334,
        "text": "أصلها قبل دخول ما: \"إنَّ اللهَ إلهٌ واحدٌ\"، حيـ",
        "video_link": null
      },
      {
        "ts": "5:42",
        "sec": 342,
        "text": "إذن إنَّ مع خبرها؛ حين دخلت \"مَا\" كفت إنَّ عن العمل فصارت لا تعمل هذا العمل الذي نتحدث عنه،",
        "video_link": null
      },
      {
        "ts": "5:51",
        "sec": 351,
        "text": "وصار حينئذٍ اللهُ: مبتدأ، إلهٌ: خبره. وكذلك: {قُلْ إِنَّمَا يُوحَىٰ إِلَيَّ}؛",
        "video_link": null
      },
      {
        "ts": "6:00",
        "sec": 360,
        "text": "ما: كافة عن العمل في أنَّ، {أَنَّمَا إِلَٰهُكُمْ إِلَٰهٌ وَاحِدٌ}؛ إلهُكم: مبتدأ، وإلهٌ:",
        "video_link": null
      },
      {
        "ts": "6:09",
        "sec": 369,
        "text": "خبره، وأنَّ لا تعمل. كـ \"كأنما زيدٌ قائمٌ\"؛ زيدٌ: مبتدأ، قائمٌ: الخبر؛ لِمَا؟",
        "video_link": null
      },
      {
        "ts": "6:19",
        "sec": 379,
        "text": "لأن \"كأنَّ\" التي هي حرف في الأصل حرف نصب وتشبيه لا تعمل لدخول ما الكافة. ولكن ما",
        "video_link": null
      },
      {
        "ts": "6:29",
        "sec": 389,
        "text": "زيدٌ قائمٌ الشيء نفسه، ولعلما زيدٌ قائمٌ؛ إذن في إنَّ وأخواتها كلها باستثناء ماذا؟",
        "video_link": null
      },
      {
        "ts": "6:37",
        "sec": 397,
        "text": "باستثناء ليتَ؛ قال: إلا لَيْتَ فيجوز فيها الإعمال والإهمال؛ أي حين تدخل \"مَا\" على ليتَ",
        "video_link": null
      },
      {
        "ts": "6:46",
        "sec": 406,
        "text": "فإنها يمكن أن تبطل عملها ويمكن أن تبقى",
        "video_link": null
      },
      {
        "ts": "6:51",
        "sec": 411,
        "text": "على أصل العمل؛ فتقول: ليتما زيدٌ قائمٌ بنصب",
        "video_link": null
      },
      {
        "ts": "6:57",
        "sec": 417,
        "text": "زيدٍ ورفعه؛ ليتما زيدٌ قائمٌ، زيدٌ: مبتدأ، قائمٌ: الخبر؛ ليتما زيداً قائمٌ، زيداً: اسم ليتَ",
        "video_link": null
      },
      {
        "ts": "7:07",
        "sec": 427,
        "text": "التي هي من أخوات إنَّ، وقائمٌ: خبر ليتَ.",
        "video_link": null
      },
      {
        "ts": "7:15",
        "sec": 435,
        "text": "وتُخفف \"إِنَّ\" المكسورة فيكثر إهمالها، نحو: {إِن كُلُّ نَفْسٍ لَّمَّا عَلَيْهَا حَافِظٌ}؛",
        "video_link": null
      },
      {
        "ts": "7:23",
        "sec": 443,
        "text": "ويقل إعمالها، نحو: {وَإِنَّ كُلًّا لَّمَّا لَيُوَفِّيَنَّهُمْ} في قراءة من خفف",
        "video_link": null
      },
      {
        "ts": "7:31",
        "sec": 451,
        "text": "\"إِنَّ\" و\"لَمَّا\" في الآيتين، جميل. الآن في قوله تعالى: {إِن كُلُّ نَفْسٍ لَّمَّا",
        "video_link": null
      },
      {
        "ts": "7:41",
        "sec": 461,
        "text": "عَلَيْهَا حَافِظٌ}، هذه في الأصل \"إِنَّ\" المكسورة؛ {إِن كُلُّ نَفْسٍ",
        "video_link": null
      },
      {
        "ts": "7:51",
        "sec": 471,
        "text": "لَّمَّا عَلَيْهَا حَافِظٌ} هذا هو الأصل، ثم خُففت إنَّ معنى خُففت أي صارت",
        "video_link": null
      },
      {
        "ts": "8:01",
        "sec": 481,
        "text": "\"إِنْ\"، فـ \"إِنْ\" هذه لا نقول فيها مثلاً الشرطية أو كذا، وإنما هي المخففة من إنَّ المكسورة،",
        "video_link": null
      },
      {
        "ts": "8:10",
        "sec": 490,
        "text": "ولما خُففت بطل عملها فلم نعد أمام اسمها وخبرها، وإنما مبتدأ",
        "video_link": null
      },
      {
        "ts": "8:19",
        "sec": 499,
        "text": "وخبر؛ فـ \"كلُّ\" مبتدأ وهو مضاف، \"نفسٍ\" مضاف إليه، لَمَّا، ثم",
        "video_link": null
      },
      {
        "ts": "8:27",
        "sec": 507,
        "text": "\"حافظٌ\" مبتدأ، \"عليها\" خبره، والجملة الاسمية من",
        "video_link": null
      },
      {
        "ts": "8:33",
        "sec": 513,
        "text": "المبتدأ والخبر في محل رفع خبر المبتدأ الأول، واضح؛",
        "video_link": null
      },
      {
        "ts": "8:40",
        "sec": 520,
        "text": "هنا يعني ليست عاملة فقد أُهملت بعد تخفيفها.",
        "video_link": null
      },
      {
        "ts": "8:48",
        "sec": 528,
        "text": "لكن يمكن -وهذا هو الكثير- لكن يمكن أن تبقى على عملها مع كونها مخففة:",
        "video_link": null
      },
      {
        "ts": "8:58",
        "sec": 538,
        "text": "{وَإِنَّ كُلًّا لَّمَّا لَيُوَفِّيَنَّهُمْ}، {وَإِنَّ كُلًّا لَّمَّا لَيُوَفِّيَنَّهُمْ}؛ فـ \"إِنْ\" هذه مخففة",
        "video_link": null
      },
      {
        "ts": "9:07",
        "sec": 547,
        "text": "من الثقيلة، \"كُلاًّ\" اسمها؛ إذاً بقيت على العمل بقيت عاملة مع تخفيفها، \"كُلاًّ\" اسمها، لَمَّا لَيُوَفِّيَنَّهُمْ",
        "video_link": null
      },
      {
        "ts": "9:17",
        "sec": 557,
        "text": "الجملة كلها هي خبر إنْ المخففة.",
        "video_link": null
      },
      {
        "ts": "9:30",
        "sec": 570,
        "text": "طيب. وتلزم اللام في خبرها إذا أُهملت،",
        "video_link": null
      },
      {
        "ts": "9:38",
        "sec": 578,
        "text": "وتلزم اللام في خبرها إذا أُهملت وإن خُففت... إلى اخره؛ وتلزم اللام في خبرها إذا أُهملت",
        "video_link": null
      },
      {
        "ts": "9:46",
        "sec": 586,
        "text": "كما في هذه الصورة التي ذكرنا في هذه الآية {وَإِن كُلُّ}،",
        "video_link": null
      },
      {
        "ts": "9:52",
        "sec": 592,
        "text": "عفواً في حالة الإهمال: {إِن كُلُّ نَفْسٍ لَّمَّا",
        "video_link": null
      },
      {
        "ts": "9:57",
        "sec": 597,
        "text": "عَلَيْهَا حَافِظٌ} فهنا اللام ملازمة في الخبر.",
        "video_link": null
      },
      {
        "ts": "10:06",
        "sec": 606,
        "text": "وإذا خُففت \"أَنَّ\" المفتوحة؛ إذن انتهينا من تخفيف إنَّ المكسورة، الآن ننتقل إلى تخفيف أَنَّ",
        "video_link": null
      },
      {
        "ts": "10:13",
        "sec": 613,
        "text": "المفتوحة؛ وإذا خُففت أَنَّ المفتوحة بقي إعمالها، ولكن يجب أن يكون اسمها ضمير",
        "video_link": null
      },
      {
        "ts": "10:21",
        "sec": 621,
        "text": "الشأن محذوفاً، ويجب أن يكون خبرها جملة؛ نحو: {عَلِمَ أَن سَيَكُونُ}،",
        "video_link": null
      },
      {
        "ts": "10:28",
        "sec": 628,
        "text": "أصلها \"علم أنه سيكون\"؛ فأصلها أَنَّ الثقيلة،",
        "video_link": null
      },
      {
        "ts": "10:35",
        "sec": 635,
        "text": "واسمها ضمير الشأن، وخبرها هو جملة \"سيكون\"؛ فخبرها جملة، فحينئذٍ",
        "video_link": null
      },
      {
        "ts": "10:45",
        "sec": 645,
        "text": "حين خُففت أَنَّ المفتوحة بقي إعمالها فقيل: {عَلِمَ أَن سَيَكُونُ}، فنقول: \"أَنْ\" مخففة من",
        "video_link": null
      },
      {
        "ts": "10:54",
        "sec": 654,
        "text": "الثقيلة واسمها ضمير الشأن محذوف، وجملة \"سيكون\" خبر.",
        "video_link": null
      },
      {
        "ts": "11:03",
        "sec": 663,
        "text": "وإذا خُففت \"كَأَنَّ\" (يعني صارت كَأَنْ) بقي إعمالها، ويجوز حذف اسمها وذكره؛ كقوله: *\"كَأَنْ ظَبْيَةً تَعْطُو إِلَى وَارِقِ السَّلَمْ\"*. إذا خُففت كَأَنَّ فصارت كَأَنْ، جاز إعمالها أو",
        "video_link": null
      },
      {
        "ts": "11:20",
        "sec": 680,
        "text": "إهمالها؛ \"كَأَنْ زَيْداً قَائِمٌ\"، \"كَأَنْ زَيْداً قَائِمٌ\"،",
        "video_link": null
      },
      {
        "ts": "11:27",
        "sec": 687,
        "text": "\"كَأَنْ زَيْدٌ قَائِمٌ\" يجوز الوجهان، ويجوز حذف اسمها أو ذكره؛",
        "video_link": null
      },
      {
        "ts": "11:36",
        "sec": 696,
        "text": "كما في قول الشاعر: *\"كَأَنْ ظَبْيَةً تَعْطُو إِلَى وَارِقِ السَّلَمْ\"*.",
        "video_link": null
      },
      {
        "ts": "11:44",
        "sec": 704,
        "text": "فقوله هنا: \"كَأَنْ ظَبْيَةً\" إلى آخره، هذا مثال على تخفيف كَأَنَّ فصارت كَأَنْ",
        "video_link": null
      },
      {
        "ts": "11:51",
        "sec": 711,
        "text": "وحذف، عفواً *\"كَأَنْ ظَبْيَةً تَعْطُو إِلَى وَارِقِ السَّلَمْ\"* نعم،",
        "video_link": null
      },
      {
        "ts": "11:59",
        "sec": 719,
        "text": "فهذا مثال على جواز حذف اسمها أو جواز ذكره في هذا البيت",
        "video_link": null
      },
      {
        "ts": "12:08",
        "sec": 728,
        "text": "الشعري. عفواً، هذا مثال على ذكر اسمها، أما حذف اسمها فكما في قول ربنا سبحانه",
        "video_link": null
      },
      {
        "ts": "12:16",
        "sec": 736,
        "text": "وتعالى: {كَأَن لَّمْ تَغْنَ بِالْأَمْسِ}؛ {كَأَن لَّمْ تَغْنَ بِالْأَمْسِ} فخبرها هو \"لم تغنَ بالامس\" واسمها محذوف. أما *\"كَأَنْ ظَبْيَةً تَعْطُو إِلَى وَارِقِ السَّلَمْ\"* لِمَا احتاج إلى الإتيان بهذا البيت؟ لأن",
        "video_link": null
      },
      {
        "ts": "12:30",
        "sec": 750,
        "text": "ذكر الاسم بعد التخفيف قليل، فلأجل ذلك احتاج إلى ذكر شاهده؛ فالاسم هنا هو \"ظبيةً\"،",
        "video_link": null
      },
      {
        "ts": "12:38",
        "sec": 758,
        "text": "\"كَأَنْ ظَبْيَةً\"، ظبيةً: اسم كَأَنْ، وجملة \"تعطو إلى وارق السلم\" خبرها، فهذا شاهد على",
        "video_link": null
      },
      {
        "ts": "12:45",
        "sec": 765,
        "text": "ذكر اسمها بعد تخفيفها. قال: وإذا خُففت \"لَكِنَّ\" وجب إهمالها،",
        "video_link": null
      },
      {
        "ts": "12:53",
        "sec": 773,
        "text": "يعني لَكِنَّ صارت لَكِنْ؛ وجب إهمالها فتقول:",
        "video_link": null
      },
      {
        "ts": "12:59",
        "sec": 779,
        "text": "\"زيدٌ شجاعٌ لَكِنْ\"، تهملها \"لَكِنْ هو كريمٌ\" مثلاً، \"لَكِنْ زيدٌ كريمٌ\"،",
        "video_link": null
      },
      {
        "ts": "13:09",
        "sec": 789,
        "text": "راح مبتدأ وخبر؛ فتهمل ولا تعمل مثل باقي إنَّ وأخواتها.",
        "video_link": null
      },
      {
        "ts": "13:19",
        "sec": 799,
        "text": "انتهينا من إنَّ وأخواتها. الآن يبدأ في \"لَا\" النافية للجنس؛ فصل:",
        "video_link": null
      },
      {
        "ts": "13:29",
        "sec": 809,
        "text": "وأما التي لنفي الجنس فهي التي يُراد بها نفي جميع الجنس",
        "video_link": null
      },
      {
        "ts": "13:37",
        "sec": 817,
        "text": "على سبيل التنصيص؛ مثلاً حين تقول: \"لا رجلَ في الدار\"، \"لا رجلَ في",
        "video_link": null
      },
      {
        "ts": "13:46",
        "sec": 826,
        "text": "الدار\"؛ ما المقصود؟ ما المقصود؟ نفي وجود أي فرد من أفراد جنس الرجال في الدار،",
        "video_link": null
      },
      {
        "ts": "13:56",
        "sec": 836,
        "text": "فحين تقول \"لا رجلَ في الدار\" فأنت تنفي جميع الجنس،",
        "video_link": null
      },
      {
        "ts": "14:02",
        "sec": 842,
        "text": "تنفي وجود جميع جنس الرجال أي فرد من أفراد الرجال في الدار، فلأجل ذلك تُسمى لَا",
        "video_link": null
      },
      {
        "ts": "14:10",
        "sec": 850,
        "text": "النافية للجنس؛ يُراد بها نفي جميع الجنس.",
        "video_link": null
      },
      {
        "ts": "14:17",
        "sec": 857,
        "text": "وهذه تعمل عمل إِنَّ فتنصب الاسم وترفع الخبر،",
        "video_link": null
      },
      {
        "ts": "14:23",
        "sec": 863,
        "text": "بشرط أن يكون اسمها وخبرها نكرتين، وأن يكون اسمها متصلاً بها؛ فإن كان اسمها",
        "video_link": null
      },
      {
        "ts": "14:31",
        "sec": 871,
        "text": "مضافاً أو مشبهاً بالمضاف فهو معرب منصوب، نحو: لا صاحبَ علمٍ ممقوتٌ. طيب.",
        "video_link": null
      },
      {
        "ts": "14:38",
        "sec": 878,
        "text": "فإذاً بشرط أن يكون اسمها وخبرها نكرتين \"لا رجلَ قائمٌ\" نكرة، وأن يكون اسمها متصلاً بها كما",
        "video_link": null
      },
      {
        "ts": "14:48",
        "sec": 888,
        "text": "في هذا المثال \"لا رجلَ قائمٌ\". الآن أمثلة",
        "video_link": null
      },
      {
        "ts": "14:54",
        "sec": 894,
        "text": "ما لا تتوفر فيه هذه الشروط؛ فإن كان اسمها",
        "video_link": null
      },
      {
        "ts": "15:01",
        "sec": 901,
        "text": "مضافاً أو مشبهاً بالمضاف فهو معرب منصوب، نحو: لا صاحبَ علمٍ ممقوتٌ؛ صاحبَ: اسم لا وهو",
        "video_link": null
      },
      {
        "ts": "15:11",
        "sec": 911,
        "text": "مضاف، علمٍ: مضاف إليه مجرور، ممقوتٌ: خبر لا.",
        "video_link": null
      },
      {
        "ts": "15:19",
        "sec": 919,
        "text": "\"لا طالعاً جبلاً حاضرٌ\"؛ طالعاً جبلاً، هذا مثال على المشبه",
        "video_link": null
      },
      {
        "ts": "15:27",
        "sec": 927,
        "text": "بالمضاف (الشبيه بالمضاف)، لأنه في الحقيقة \"طالعاً\" هذا يعمل لأنه اسم",
        "video_link": null
      },
      {
        "ts": "15:34",
        "sec": 934,
        "text": "فاعل يعمل عمل الفعل، و\"جبلاً\" معمول له؛ \"لا طالعاً جبلاً\"، فهذا ليس مضافاً لكنه مشبه به:",
        "video_link": null
      },
      {
        "ts": "15:42",
        "sec": 942,
        "text": "لا طالعاً جبلاً حاضرٌ، وحاضرٌ: خبر لا. وعرّف المشبه بالمضاف بقوله: والمشبه",
        "video_link": null
      },
      {
        "ts": "15:50",
        "sec": 950,
        "text": "بالمضاف هو ما اتصل به شيء من تمام معناه؛ أي شيء يتم به معنى هذا المشبه بالمضاف،",
        "video_link": null
      },
      {
        "ts": "16:00",
        "sec": 960,
        "text": "لأنك لو قلت \"طالعاً\"، \"ولا طالعاً\" هكذا دون \"جبلاً\" يكون",
        "video_link": null
      },
      {
        "ts": "16:06",
        "sec": 966,
        "text": "الكلام ناقصاً فلا يتم معنى \"طالعاً\" إلا بذكر هذا",
        "video_link": null
      },
      {
        "ts": "16:14",
        "sec": 974,
        "text": "ذكر كلمة \"جبلاً\". وهذا مثل ما أن المضاف لا يتم معناه إلا بذكر المضاف إليه، فلأجل",
        "video_link": null
      },
      {
        "ts": "16:22",
        "sec": 982,
        "text": "ذلك قالوا: هو مشبه أو شبيه بالمضاف؛ وهذا يكون في اسم الفاعل يكون أيضاً في الصفة",
        "video_link": null
      },
      {
        "ts": "16:27",
        "sec": 987,
        "text": "المشبهة \"لا حسناً وجهه\"، \"لا حسناً وجهه مذمومٌ\" مثلاً،",
        "video_link": null
      },
      {
        "ts": "16:36",
        "sec": 996,
        "text": "أو غير ذلك؛ يعني كل شيء يعني يدخل في هذا المعنى، معنى أنه يحتاج",
        "video_link": null
      },
      {
        "ts": "16:42",
        "sec": 1002,
        "text": "إلى أن يتصل به شيء هو من تمام معناه. فإذاً",
        "video_link": null
      },
      {
        "ts": "16:51",
        "sec": 1011,
        "text": "الصورة الأولى: إذا كان اسمها مضافاً أو مشبهاً بالمضاف فإنه يكون معرباً منصوباً.",
        "video_link": null
      },
      {
        "ts": "17:00",
        "sec": 1020,
        "text": "الصورة الثانية: إذا كان اسمها مفرداً؛ ما معنى مفرد؟ أي ليس مضافاً ولا شبيهاً",
        "video_link": null
      },
      {
        "ts": "17:07",
        "sec": 1027,
        "text": "بالمضاف؛ وإن كان اسمها مفرداً بُني على ما يُنصب به",
        "video_link": null
      },
      {
        "ts": "17:14",
        "sec": 1034,
        "text": "لو كان معرباً. في الحقيقة حين قلت (أريد أن أرجع إلى قوله:",
        "video_link": null
      },
      {
        "ts": "17:20",
        "sec": 1040,
        "text": "\"بشرط أن يكون اسمها وخبرها نكرتين، وأن يكون اسمها متصلاً بها\")، كنت بعد ذلك أنه",
        "video_link": null
      },
      {
        "ts": "17:27",
        "sec": 1047,
        "text": "سيذكر الأحوال التي لا تتوفر فيها الشروط وهذا غير صحيح ولم يذكر ذلك، لكن سيذكر",
        "video_link": null
      },
      {
        "ts": "17:34",
        "sec": 1054,
        "text": "أقسامها من جهة أن اسمها وخبرها هل يكون ذلك مبنياً أو معرباً، وإلا",
        "video_link": null
      },
      {
        "ts": "17:42",
        "sec": 1062,
        "text": "هذان الشرطان (أي شرط كون الاسم والخبر نكرتين، وأن يكون اسمها متصلاً بها) لم يذكر بعد ذلك أمثلة",
        "video_link": null
      },
      {
        "ts": "17:52",
        "sec": 1072,
        "text": "أمثلة انتفاء الشروط، واضح.",
        "video_link": null
      },
      {
        "ts": "17:59",
        "sec": 1079,
        "text": "من الطبيعي أن يكون اسمها نكرة لأنك تريد نفي الجنس فتقول: \"لا رجلَ قائمٌ\"،",
        "video_link": null
      },
      {
        "ts": "18:08",
        "sec": 1088,
        "text": "ما يمكن أن تقول \"لا زيدَ\" لأن زيداً معين وشخص بذاته فليس جنساً، ونحن كلامنا هنا عن لَا",
        "video_link": null
      },
      {
        "ts": "18:18",
        "sec": 1098,
        "text": "التي لنفي الجنس حين تكون نكرة وتنفيها كما يقول الأصوليون؛",
        "video_link": null
      },
      {
        "ts": "18:27",
        "sec": 1107,
        "text": "فإن النكرة في سياق النفي تفيد معنى العموم، وإذا كان الاسم نكرة فالخبر يكون نكرة",
        "video_link": null
      },
      {
        "ts": "18:35",
        "sec": 1115,
        "text": "لأنك تخبر عن النكرة بنكرة، فلأجل ذلك وجب أن يكون اسمها وخبرها نكرتين. إذن هذا",
        "video_link": null
      },
      {
        "ts": "18:43",
        "sec": 1123,
        "text": "رجعنا له بعد أن ذكرناه من قبل، لأن المصنف رحمه الله تعالى لم يذكر أمثلة",
        "video_link": null
      },
      {
        "ts": "18:50",
        "sec": 1130,
        "text": "انتفاء الشرط، وإنما انتقل مباشرة إلى ذكر أحوال أحوال اسمها. فإذاً أعيد فأقول: الحالة",
        "video_link": null
      },
      {
        "ts": "18:59",
        "sec": 1139,
        "text": "الأولى التي شرحناها هي أن يكون اسمها مضافاً أو مشبهاً بالمضاف إذاً معرب منصوب. الحالة الثانية: أن لا يكون مضافاً ولا",
        "video_link": null
      },
      {
        "ts": "19:06",
        "sec": 1146,
        "text": "شبيهاً بالمضاف، هذا هو الذي يقولون عنه أنه مفرد؛ فحينئذٍ ما الحكم؟ يقول:",
        "video_link": null
      },
      {
        "ts": "19:14",
        "sec": 1154,
        "text": "يُبنى على ما يُنصب به لو كان معرباً. قال: ونعني بالمفرد هنا وفي باب النداء ما",
        "video_link": null
      },
      {
        "ts": "19:22",
        "sec": 1162,
        "text": "ليس مضافاً ولا شبيها بالمضاف وإن كان مثنى أو مجموعاً، واضح.",
        "video_link": null
      },
      {
        "ts": "19:30",
        "sec": 1170,
        "text": "فتقول مثلاً: \"لا رجلَ\" كما في الأمثلة: لا رجلَ قائمٌ،",
        "video_link": null
      },
      {
        "ts": "19:40",
        "sec": 1180,
        "text": "هذا \"رجلَ\" الآن وهو اسمها مفرد؛ أي ليس مضافاً ولا شبيهاً بالمضاف،",
        "video_link": null
      },
      {
        "ts": "19:46",
        "sec": 1186,
        "text": "فنقول \"رجلَ\" مبني على ماذا؟ مبني على الفتح؛ لأن القاعدة قال: يُبنى على ما يُنصب به لو",
        "video_link": null
      },
      {
        "ts": "19:55",
        "sec": 1195,
        "text": "كان معرباً، \"رجلٌ\" لو كان معرباً بأي شيء يُنصب؟ ما علامة نصبه؟ علامة نصبه الفتحة، إذن نقول:",
        "video_link": null
      },
      {
        "ts": "20:02",
        "sec": 1202,
        "text": "مبني على الفتح. إذاً هذه هي الأحوال؛ الحالة الأولى: إذا كان مفرداً أو جمع تكسير بُني",
        "video_link": null
      },
      {
        "ts": "20:08",
        "sec": 1208,
        "text": "على الفتح، نحو: لا رجلَ حاضرٌ، ولا رجالَ حاضرون. لا: نافية للجنس، رجلَ: اسم... اسم لا عفواً",
        "video_link": null
      },
      {
        "ts": "20:19",
        "sec": 1219,
        "text": "النافية للجنس، مبني، وحاضرٌ: خبر؛ مبني على الفتح،",
        "video_link": null
      },
      {
        "ts": "20:29",
        "sec": 1229,
        "text": "وحاضرٌ: الخبر. إذا كان مثنى أو جمع مذكر أو جمع مذكر سالماً بُني على الياء؛ لِمَ يُبنى",
        "video_link": null
      },
      {
        "ts": "20:37",
        "sec": 1237,
        "text": "على الياء؟ لأن القاعدة التي ذكرنا أنه يُبنى على ما يُنصب به لو كان معرباً، والمثنى",
        "video_link": null
      },
      {
        "ts": "20:44",
        "sec": 1244,
        "text": "ما علامة نصبه حين يكون معرباً؟ علامة ذلك الياء، ما علامة نصبه إن كان جمع مذكر",
        "video_link": null
      },
      {
        "ts": "20:52",
        "sec": 1252,
        "text": "سالماً؟ علامة ذلك الياء، إذن يُبنى على الياء؛ فمثلاً: \"لا رجلينِ في الدار\"، تقول رجلينِ:",
        "video_link": null
      },
      {
        "ts": "21:01",
        "sec": 1261,
        "text": "اسم لا مبني على الياء النائبة عن الفتحة، لِمَا؟ لأنه كما قلنا",
        "video_link": null
      },
      {
        "ts": "21:10",
        "sec": 1270,
        "text": "يُبنى على ما يُنصب به لو كان معرباً. وكذلك: لا قائمينَ في السوق؛ قائمينَ: اسم لا مبني على",
        "video_link": null
      },
      {
        "ts": "21:18",
        "sec": 1278,
        "text": "الياء. وإن كان جمع مؤنث سالماً بُني على الكسرة،",
        "video_link": null
      },
      {
        "ts": "21:24",
        "sec": 1284,
        "text": "نحو: لا مسلماتِ حاضراتٌ؛ لِمَ يُبنى على الكسر؟ لأن جمع المؤنث السالم علامة نصبه هي",
        "video_link": null
      },
      {
        "ts": "21:32",
        "sec": 1292,
        "text": "الكسرة، فإذاً تقول مسلماتِ: اسم لا مبني على",
        "video_link": null
      },
      {
        "ts": "21:40",
        "sec": 1300,
        "text": "الكسرة، أي وهو ما يُعرب به وهو ما يُنصب به لو كان معرباً.",
        "video_link": null
      },
      {
        "ts": "21:49",
        "sec": 1309,
        "text": "إذن انتهينا من هذه الأحوال هذه الأمثلة الثلاثة التي ذكرها بقوله (أو هذه الصور الثلاثة بقوله): وإن كان مفرداً أو جمع تكسير،",
        "video_link": null
      },
      {
        "ts": "21:58",
        "sec": 1318,
        "text": "وإن كان مثنى أو جمع مذكر سالماً، وثالثاً: إن كان جمع مؤنث سالماً؛ هذه الثلاثة كلها",
        "video_link": null
      },
      {
        "ts": "22:04",
        "sec": 1324,
        "text": "داخلة في قوله إن كان اسمه مفرداً، لأن قلنا المفرد هو ما ليس مضافاً ولا شبيهاً",
        "video_link": null
      },
      {
        "ts": "22:11",
        "sec": 1331,
        "text": "بالمضاف؛ إذن يشمل هذا المفردُ: المفردَ، جمعَ التكسير، المثنى، جمعَ المذكر السالم، جمعَ المؤنث",
        "video_link": null
      },
      {
        "ts": "22:21",
        "sec": 1341,
        "text": "السالم، هذه كلها داخلة في معنى المفرد في هذا الباب. وما ليس مفرداً ما هو؟ هو المضاف أو",
        "video_link": null
      },
      {
        "ts": "22:27",
        "sec": 1347,
        "text": "الشبيه بالمضاف، هذا سبق قلناه لا يكون مبنياً وإنما يكون معرباً؛ فتقول: \"لا",
        "video_link": null
      },
      {
        "ts": "22:34",
        "sec": 1354,
        "text": "صاحبَ علمٍ ممقوتٌ\"، صاحبَ: اسم لا منصوب وعلامة نصبه الفتحة الظاهرة وهو مضاف، علمٍ: مضاف إليه.",
        "video_link": null
      },
      {
        "ts": "22:42",
        "sec": 1362,
        "text": "ثم قال: وقد يُبنى على الفتح... نعم، وإذا تكررت لا... وقد يُبنى على الفتح هذا",
        "video_link": null
      },
      {
        "ts": "22:52",
        "sec": 1372,
        "text": "ما سبق، وقد يُبنى على الفتح من تمام ما سبق؛ بمعنى",
        "video_link": null
      },
      {
        "ts": "22:59",
        "sec": 1379,
        "text": "أن في قوله \"لا مسلماتِ حاضراتٌ\" قد يُبنى على الفتح نظراً",
        "video_link": null
      },
      {
        "ts": "23:06",
        "sec": 1386,
        "text": "لمراعاة الأصل في المركبات. أما المسألة التالية فهي عند التكرار؛ قال:",
        "video_link": null
      },
      {
        "ts": "23:16",
        "sec": 1396,
        "text": "وإذا تكررت لا، نحو: لا حولَ ولا قوةَ، جاز في النكرة الأولى الفتح والرفع؛ فإن فتحتها",
        "video_link": null
      },
      {
        "ts": "23:25",
        "sec": 1405,
        "text": "جاز في الثانية ثلاثة أوجه: الفتح، والنصب، والرفع؛ وإن رفعت الأولى جاز لك في الثانية",
        "video_link": null
      },
      {
        "ts": "23:33",
        "sec": 1413,
        "text": "وجهان: الرفع، والفتح. فهذه كم؟ هذه خمسة أوجه",
        "video_link": null
      },
      {
        "ts": "23:42",
        "sec": 1422,
        "text": "في نحو: لا حولَ ولا قوةَ. الوجه الأول هو أن يكون",
        "video_link": null
      },
      {
        "ts": "23:50",
        "sec": 1430,
        "text": "\"حولَ\" فيها الفتح؛ حين يقول الفتح (أي مبني على الفتح)،",
        "video_link": null
      },
      {
        "ts": "23:56",
        "sec": 1436,
        "text": "إذا كانت مبنية على الفتح ففي قوة يجوز أن تكون أيضاً مبنية على الفتح \"لا حولَ ولا قوةَ\"،",
        "video_link": null
      },
      {
        "ts": "24:05",
        "sec": 1445,
        "text": "ويجوز النصب \"لا حولَ ولا قوةً\"، ويجوز الرفع \"لا حولَ ولا قوةٌ\".",
        "video_link": null
      },
      {
        "ts": "24:14",
        "sec": 1454,
        "text": "فأما الفتح في النكرة الثانية",
        "video_link": null
      },
      {
        "ts": "24:20",
        "sec": 1460,
        "text": "فعلى أن تكون لا الثانية عاملة مثل عمل لا الأولى، هذا واضح؛ كما تقول \"لا حولَ\" تقول \"ولا",
        "video_link": null
      },
      {
        "ts": "24:29",
        "sec": 1469,
        "text": "قوةَ\"، وتُقدّر لكل واحدة منهما خبراً:",
        "video_link": null
      },
      {
        "ts": "24:38",
        "sec": 1478,
        "text": "لا حولَ كائنٌ لا قوةَ كائنةٌ إلا بالله عز وجل.",
        "video_link": null
      },
      {
        "ts": "24:44",
        "sec": 1484,
        "text": "أما إذا نصبت \"قوةً\" فتقدير ذلك أنك تجعل لا زائدة لتأكيد",
        "video_link": null
      },
      {
        "ts": "24:54",
        "sec": 1494,
        "text": "النفي، وعطف ما بعدها على محل اسم لا",
        "video_link": null
      },
      {
        "ts": "25:02",
        "sec": 1502,
        "text": "التي قبلها؛ لأن لا",
        "video_link": null
      },
      {
        "ts": "25:08",
        "sec": 1508,
        "text": "حولَ، حولَ: هذا اسم لا مبني، لكنه مبني في محل",
        "video_link": null
      },
      {
        "ts": "25:14",
        "sec": 1514,
        "text": "ماذا؟ مبني على الفتح في محل نصب، لأن اسم لا يكون منصوباً؛ إذن في محل نصب.",
        "video_link": null
      },
      {
        "ts": "25:22",
        "sec": 1522,
        "text": "إذن محل اسم لا الأولى هو النصب،",
        "video_link": null
      },
      {
        "ts": "25:29",
        "sec": 1529,
        "text": "فأنت تعطف \"قوةً\" على محل اسم لا الأولى؛ لا تعطف على",
        "video_link": null
      },
      {
        "ts": "25:38",
        "sec": 1538,
        "text": "يعني اسم لا وإنما على محل الاسم، ومحل هذا الاسم الأول هو النصب.",
        "video_link": null
      },
      {
        "ts": "25:47",
        "sec": 1547,
        "text": "وأما الرفع حين تقول \"لا حولَ ولا قوةٌ\"،",
        "video_link": null
      },
      {
        "ts": "25:53",
        "sec": 1553,
        "text": "فحينئذٍ تعطف \"قوةٌ\" على محل ماذا؟ على محل لا مع اسمها؛",
        "video_link": null
      },
      {
        "ts": "26:00",
        "sec": 1560,
        "text": "لأن محل لا مع اسمها الرفع على الابتداء، كما لو أنك جعلت لا مع اسمها كل ذلك له",
        "video_link": null
      },
      {
        "ts": "26:08",
        "sec": 1568,
        "text": "محل، محله هو الرفع لأنك عادة تبدأ بمبتدأ فيكون محله مرفوعاً؛ فإذاً تعطف \"قوةٌ\"",
        "video_link": null
      },
      {
        "ts": "26:16",
        "sec": 1576,
        "text": "على محل لا مع اسمها فتقول: \"ولا قوةٌ\". هذا كله إذا كانت",
        "video_link": null
      },
      {
        "ts": "26:22",
        "sec": 1582,
        "text": "إذا كانت اسم لا الأولى مبنياً على الفتح. إذا كان اسم لا الثانية مرفوعاً؛ قال: وإن",
        "video_link": null
      },
      {
        "ts": "26:32",
        "sec": 1592,
        "text": "رفعت الأولى (النكرة الأولى) جاز لك في الثانية وجهان: الرفع والفتح؛ حين ترفع",
        "video_link": null
      },
      {
        "ts": "26:40",
        "sec": 1600,
        "text": "الأولى فأنت ترفعها بالابتداء وتلغي لا، يعني صارت لا \"لا حولٌ\" صارت لا",
        "video_link": null
      },
      {
        "ts": "26:50",
        "sec": 1610,
        "text": "بطل عملها أو أُلغي عملها؛ فتقول: لا حولٌ، حولٌ: مبتدأ، ولا",
        "video_link": null
      },
      {
        "ts": "26:59",
        "sec": 1619,
        "text": "النكرة الثانية يجوز فيها الرفع والفتح. أما الرفع فواضح أنك تعطف",
        "video_link": null
      },
      {
        "ts": "27:06",
        "sec": 1626,
        "text": "مرفوعاً على مرفوع فـ لا الأولى لم تعمل؛",
        "video_link": null
      },
      {
        "ts": "27:17",
        "sec": 1637,
        "text": "يعني عطف ما بعدها على ما قبله. وأما الفتح",
        "video_link": null
      },
      {
        "ts": "27:25",
        "sec": 1645,
        "text": "بإعمال لا عمل إِنَّ،",
        "video_link": null
      },
      {
        "ts": "27:33",
        "sec": 1653,
        "text": "وحينئذٍ \"لا حولٌ ولا قوةَ\"، قوةَ: مبني على الفتح على أنه اسم لا؛ إذن هذه",
        "video_link": null
      },
      {
        "ts": "27:42",
        "sec": 1662,
        "text": "هي الأوجه الخمسة الجائزة في مثل \"لا حولَ ولا قوةَ\": إما مبني على الفتح مع مبني على الفتح هنا",
        "video_link": null
      },
      {
        "ts": "27:53",
        "sec": 1673,
        "text": "كلاهما عاملتان، أو مبني على الفتح مع منصوب لأنه معطوف على محل اسم لا الأولى،",
        "video_link": null
      },
      {
        "ts": "28:01",
        "sec": 1681,
        "text": "أو مبني على الفتح مع مرفوع لأنه معطوف على محل لا الأولى مع اسمها،",
        "video_link": null
      },
      {
        "ts": "28:10",
        "sec": 1690,
        "text": "أو أن يكون الأول مرفوعاً لأنك ألغيت",
        "video_link": null
      },
      {
        "ts": "28:17",
        "sec": 1697,
        "text": "لا الأولى لم تُعملها، وحينئذٍ الثانية",
        "video_link": null
      },
      {
        "ts": "28:25",
        "sec": 1705,
        "text": "النكرة الثانية تكون مرفوعة لأجل عطفها على مرفوع، أو تكون مبنية على",
        "video_link": null
      },
      {
        "ts": "28:32",
        "sec": 1712,
        "text": "مبنية على الفتح لأجل الأصل في لا الثانية العاملة عمل لَيْسَ (فتكون لا عاملة ليس ومعها",
        "video_link": null
      },
      {
        "ts": "28:42",
        "sec": 1722,
        "text": "اسمها المبني على الفتح).",
        "video_link": null
      },
      {
        "ts": "28:48",
        "sec": 1728,
        "text": "قال: وإن عطفت ولم تتكرر وجب فتح النكرة الأولى،",
        "video_link": null
      },
      {
        "ts": "28:56",
        "sec": 1736,
        "text": "وجاز في الثانية الرفع والنصب، نحو: لا حولَ وقوةٌ وقوةً.",
        "video_link": null
      },
      {
        "ts": "29:04",
        "sec": 1744,
        "text": "بمعنى إذا عطفت على ولم تكرر لا؛ ليس كـ \"لا حولَ ولا قوةَ\"، \"لا حولَ\"",
        "video_link": null
      },
      {
        "ts": "29:12",
        "sec": 1752,
        "text": "ولم تكرر لا الأولى؛ وجب فتحها لأنه لِمَا في الصورة الأولى في",
        "video_link": null
      },
      {
        "ts": "29:22",
        "sec": 1762,
        "text": "\"لا حولَ ولا قوةَ\" لِمَا جاز الرفع في الأولى؟ جاز الرفع في الأولى لأجل",
        "video_link": null
      },
      {
        "ts": "29:30",
        "sec": 1770,
        "text": "تكررها، أما هنا فلم تتكرر؛ إذن لا يجوز إهمالها لا بد أن تعمل. إذن الأولى عاملة ولا بد، إذا عملت فإذن النكرة بعدها مبنية",
        "video_link": null
      },
      {
        "ts": "29:46",
        "sec": 1786,
        "text": "على الفتح فلذلك قال: وجب فتح النكرة الأولى. إذن الكلام الآن والنقاش هو في الثانية؛",
        "video_link": null
      },
      {
        "ts": "29:52",
        "sec": 1792,
        "text": "وجاز في الثانية الرفع والنصب؛ أما الرفع فبالعطف على محل لا الأولى مع اسمها لأن",
        "video_link": null
      },
      {
        "ts": "30:02",
        "sec": 1802,
        "text": "قلنا محلهما هو الرفع بالابتداء، وأما النصب فبالعطف على محل اسمها؛ إذن ما بقي",
        "video_link": null
      },
      {
        "ts": "30:09",
        "sec": 1809,
        "text": "لك إلا وجهان من تلك الأوجه الخمسة التي ذكرنا من قبل، فتقول: \"لا حولَ وقوةً\"",
        "video_link": null
      },
      {
        "ts": "30:17",
        "sec": 1817,
        "text": "بالنصب، أو \"لا حولَ وقوةٌ\" بالرفع. وإذا نُعت اسم لا مفرداً بنعت مفرد ولم يُفصل",
        "video_link": null
      },
      {
        "ts": "30:26",
        "sec": 1826,
        "text": "بين النعت والمنعوت، فاسم النحو: لا رجلَ ظريفَ جالسٌ؛ جاز في النعت الفتح والنصب",
        "video_link": null
      },
      {
        "ts": "30:35",
        "sec": 1835,
        "text": "والرفع. إذاً في مثل هذه الصورة: لا رجلَ ظريفَ،",
        "video_link": null
      },
      {
        "ts": "30:42",
        "sec": 1842,
        "text": "أنت نعتَّ اسم لا بنعت مفرد؛ اسم لا الذي هو مفرد نعتَّه بنعت مفرد دون وجود فاصل بين",
        "video_link": null
      },
      {
        "ts": "30:51",
        "sec": 1851,
        "text": "النعت والمنعوت؛ يجوز لك كما قال هنا ثلاث صور أنت بالخيار بين",
        "video_link": null
      },
      {
        "ts": "30:58",
        "sec": 1858,
        "text": "ثلاثة أشياء؛ يجوز لك في النعت الفتح \"لا رجلَ ظريفَ\" على تقدير أن",
        "video_link": null
      },
      {
        "ts": "31:07",
        "sec": 1867,
        "text": "المنعوت ونعته رُكِّبا كمثل تركيب أربعة عشر أو خمسة عشر يعني كتركيب العدد",
        "video_link": null
      },
      {
        "ts": "31:15",
        "sec": 1875,
        "text": "مبني على فتح الجزءين. ويجوز أن تقول: لا رجلَ",
        "video_link": null
      },
      {
        "ts": "31:23",
        "sec": 1883,
        "text": "ظريفاً، لا رجلَ ظريفاً؛ حينئذٍ \"ظريفاً\" النعت لمحل اسم لا،",
        "video_link": null
      },
      {
        "ts": "31:31",
        "sec": 1891,
        "text": "ومحل اسم لا هو النصب لأنه نقول فيه مبني على الفتح في محل نصب.",
        "video_link": null
      },
      {
        "ts": "31:38",
        "sec": 1898,
        "text": "ويجوز في هذا النعت الرفع، ويكون الرفع كما قلنا",
        "video_link": null
      },
      {
        "ts": "31:45",
        "sec": 1905,
        "text": "آنفاً على أنه نعت لمحل لا مع اسمها؛ لمحل لا مع اسمها ومحل لا مع اسمها هو الرفع لأنه في",
        "video_link": null
      },
      {
        "ts": "31:53",
        "sec": 1913,
        "text": "موضع الابتداء؛ إذن: لا رجلَ ظريفَ جالسٌ، لا رجلَ",
        "video_link": null
      },
      {
        "ts": "32:01",
        "sec": 1921,
        "text": "ظريفاً جالسٌ، لا رجلَ ظريفٌ جالسٌ؛ هذا إذا لم يفصل بين النعت والمنعوت فاصل.",
        "video_link": null
      },
      {
        "ts": "32:08",
        "sec": 1928,
        "text": "فإن فُصل بين النعت والمنعوت فاصل، أو كان النعت غير مفرد، جاز الرفع والنصب فقط؛ نحو:",
        "video_link": null
      },
      {
        "ts": "32:17",
        "sec": 1937,
        "text": "لا رجلَ جالسٌ ظريفٌ؛ هنا فُصل بين النعت",
        "video_link": null
      },
      {
        "ts": "32:24",
        "sec": 1944,
        "text": "ومنعوته فاصل، فحينئذٍ لا يجوز إلا الرفع والنصب: لا رجلَ",
