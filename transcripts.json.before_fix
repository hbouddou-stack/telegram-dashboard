      },
      {
        "ts": "5:05",
        "sec": 305,
        "text": "وسلم: \"مِفْتَاحُ الصَّلَاةِ الطُّهُورُ، وَتَحْرِيمُهَا التَّكْبِيرُ، وَتَحْلِيلُهَا Тَّسْلِيمُ\".",
