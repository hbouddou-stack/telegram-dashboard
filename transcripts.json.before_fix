        "text": "الله تعالى ذم من يحرف كلامه كما ذم أهل الكتاب، قال تعالى: {يُحَرِّفُونَ الْكَلِمَ عَن مَّوَاضِعِهِ}،",
        "video_link": null
      },
      {
        "ts": "2:11",
        "sec": 131,
        "text": "{يُحَرِّفُونَ الْكَلِمَ عَن مَّوَاضِعِهِ} فهذا ذم بصفة عامة وهو من باب أولى فيما يتعلق بأسماء",
        "video_link": null
      },
      {
        "ts": "2:20",
        "sec": 140,
        "text": "الله تعالى وصفاته؛ فكل كلام لله سبحانه وتعالى الله تعالى ذم أن يحرف معناه فكيف",
        "video_link": null
      },
      {
        "ts": "2:27",
        "sec": 147,
        "text": "بكلام خاص به يصفه هو جل في علاه؟ فبالتالي لا ينبغي أن يحرف أو تحرف الأسماء، وهو",
        "video_link": null
      },
      {
        "ts": "2:37",
        "sec": 157,
        "text": "طبعاً المعاني، طبعاً الألفاظ محفوظة وهذا من حفظ الله تعالى هذا الدين الألفاظ محفوظة،",
        "video_link": null
      },
      {
        "ts": "2:44",
        "sec": 164,
        "text": "الألفاظ القرآنية والأحاديث النبوية هذه حُفظت، قيّض الله",
        "video_link": null
      },
      {
        "ts": "2:51",
        "sec": 171,
        "text": "لهذه النصوص رجالاً حفظوا، طبعاً الأسباب المعروفة أنهم حافظوا في الصدور",
        "video_link": null
      },
      {
        "ts": "2:57",
        "sec": 177,
        "text": "وكذا، يعني نُقلت لنا النصوص متواترة؛ الكتاب والسنة والأحاديث الصحيحة ونحو ذلك.",
        "video_link": null
      },
      {
        "ts": "3:05",
        "sec": 185,
        "text": "فبالتالي ما الذي فعله بعض هؤلاء المغرضين؟ حرفوا المعاني، لم يستطيعوا تحريف الألفاظ",
        "video_link": null
      },
      {
        "ts": "3:12",
        "sec": 192,
        "text": "-التحريف الألفاظي- فحرفوا المعاني. قال تعالى: {قُلْ إنَّمَا حَرَّمَ رَبِّيَ الْفَوَاحِشَ مَا ظَهَرَ",
        "video_link": null
      },
      {
        "ts": "3:21",
        "sec": 201,
        "text": "مِنْهَا وَمَا بَطَنَ وَالْإِثْمَ وَالْبَغْيَ بِغَيْرِ الْحَقِّ وَأَن تُشْرِكُوا بِاللَّهِ مَا لَمْ يُنَزِّلْ بِهِ سُلْطَانًا وَأَن",
        "video_link": null
      },
      {
        "ts": "3:29",
        "sec": 209,
        "text": "تَقُولُوا عَلَى اللَّهِ مَا لَا تَعْلَمُونَ}. قالوا هذا آخر ما قيل: {وَأَن تَقُولُوا عَلَى اللَّهِ مَا لَا تَعْلَمُونَ} هذا",
        "video_link": null
      },
      {
        "ts": "3:36",
        "sec": 216,
        "text": "من التحريف القول على الله بغير علم؛ أن تحرف اسمه أو تحرف معنى اسمه أو تحرف معنى",
        "video_link": null
      },
      {
        "ts": "3:44",
        "sec": 224,
        "text": "صفاته، فهذا من القول على الله بغير علم. والعلماء في هذه الآية قالوا: هذا فيه",
        "video_link": null
      },
      {
        "ts": "3:54",
        "sec": 234,
        "text": "انتقال من من شيء قبيح إلى شيء أقبح منه، فدل هذا على أن القول على الله",
        "video_link": null
      },
      {
        "ts": "4:03",
        "sec": 243,
        "text": "بغير علم أقبح من الشرك؛ الشرك شيء قبيح والله تعالى قال: {إِنَّ اللَّهَ لَا يَغْفِرُ أَن يُشْرَكَ بِهِ وَيَغْفِرُ مَا دُونَ ذَٰلِكَ}، ثم هنا",
        "video_link": null
      },
      {
        "ts": "4:09",
        "sec": 249,
        "text": "ذكر أمراً أقبح من الشرك لتعرفوا أن المسألة خطيرة جداً: {قُلْ إِنَّمَا حَرَّمَ رَبِّيَ",
        "video_link": null
      },
      {
        "ts": "4:18",
        "sec": 258,
        "text": "الْفَوَاحِشَ مَا ظَهَرَ مِنْهَا وَمَا بَطَنَ وَالْإِثْمَ وَالْبَغْيَ بِغَيْرِ الْحَقِّ} هنا انتقال من شيء قبيح إلى ما",
        "video_link": null
      },
      {
        "ts": "4:25",
        "sec": 265,
        "text": "هو أعلى، {وَأَن تُشْرِكُوا بِاللَّهِ مَا لَمْ يُنَزِّلْ بِهِ سُلْطَانًا وَأَن تَقُولُوا عَلَى اللَّهِ مَا لَا تَعْلَمُونَ}.",
        "video_link": null
      },
      {
        "ts": "4:31",
        "sec": 271,
        "text": "فإذاً أول شيء أن لا نحرف هذه المعاني، لا نغير معناها بغير دليل.",
        "video_link": null
      },
      {
        "ts": "4:40",
        "sec": 280,
        "text": "ثانياً: من غير تعطيل، أن نتجنب التعطيل. التعطيل من العَطَل، إبطال الشيء؛ شيء عاطل أي شيء",
        "video_link": null
      },
      {
        "ts": "4:48",
        "sec": 288,
        "text": "باطل شيء غير صحيح غير نافع. فالتعطيل هو توقيف معاني الأسماء والصفات،",
        "video_link": null
      },
      {
        "ts": "4:57",
        "sec": 297,
        "text": "أي إبطال معانيها، إبطال المعاني كما أشرنا في السابق. هذا وقع في بعض",
        "video_link": null
      },
      {
        "ts": "5:06",
        "sec": 306,
        "text": "المعتزلة والجهمية أنهم عطلوا معاني الأسماء والصفات، قالوا هم كما هو معلوم",
        "video_link": null
      },
      {
        "ts": "5:13",
        "sec": 313,
        "text": "هربوا من التنزيه، ولكن التنزيه لله تعالى ولكن المبالغة في التنزيه أسقطتهم في التعطيل؛ استعملوا فقط قواعد التنزيه: الله",
        "video_link": null
      },
      {
        "ts": "5:22",
        "sec": 322,
        "text": "تعالى {لَيْسَ كَمِثْلِهِ شَيْءٌ} ولا ينبغي أن يشبهه ولا ينبغي ولا ينبغي أن يثبتوا، فقالوا:",
        "video_link": null
      },
      {
        "ts": "5:29",
        "sec": 329,
        "text": "الله تعالى سميع من غير سمع، بصير من غير بصر، فعطلوا معاني الأسماء، فقالوا سميع هذا",
        "video_link": null
      },
      {
        "ts": "5:36",
        "sec": 336,
        "text": "فقط اسم من الأسماء، أزهر قولين الله لا اشتقاق له على القول بأن كلمة، فقد قيل",
        "video_link": null
      },
      {
        "ts": "5:45",
        "sec": 345,
        "text": "إن الله هذه أيضاً اسم مشتق من الإله على كل حال. قالوا هذا اسم فقط، اسم كما",
        "video_link": null
      },
      {
        "ts": "5:52",
        "sec": 352,
        "text": "نعطي الأسماء للأمور. الله تعالى أعطى لنفسه أسماء، وهذا غريب؛ لأن حتى من جهة اللغة كيف الله تعالى يعطي",
        "video_link": null
      },
      {
        "ts": "5:59",
        "sec": 359,
        "text": "لذاته اسماً لا معنى له؟ معنى في اللغة العربية كيف الله تعالى يسمي نفسه السميع البصير",
        "video_link": null
      },
      {
        "ts": "6:07",
        "sec": 367,
        "text": "وياتي شخص فيقول: نعم السميع ولا يعني أنه يسمع، والبصير يعني أنه يبصر! طبعاً هو كما قلت أغرقوا في التنزيه فوقعوا في، قال الله",
        "video_link": null
      },
      {
        "ts": "6:16",
        "sec": 376,
        "text": "تعالى: {وَلِلَّهِ الْأَسْمَاءُ الْحُسْنَىٰ فَادْعُوهُ بِهَا ۖ وَذَرُوا الَّذِينَ يُلْحِدُونَ فِي أَسْمَائِهِ ۚ سَيُجْزَوْنَ مَا",
        "video_link": null
      },
      {
        "ts": "6:23",
        "sec": 383,
        "text": "كَانُوا يَعْمَلُونَ}. {وَلِلَّهِ الْأَسْمَاءُ الْحُسْنَىٰ فَادْعُوهُ بِهَا} هذا واضح أنك",
        "video_link": null
      },
      {
        "ts": "6:29",
        "sec": 389,
        "text": "تدعو الله تعالى بمقتضى ذلك الاسم؛ حين تقول الله تعالى",
        "video_link": null
      },
      {
        "ts": "6:36",
        "sec": 396,
        "text": "عفو، ولذلك جاء في الدعاء: \"اللهم إنك عفو تحب العفو فاعفُ عنا\"، تدعو الله تعالى وتتعبد بها",
        "video_link": null
      },
      {
        "ts": "6:44",
        "sec": 404,
        "text": "بمقتضى عفوه مثلاً في هذا المثال، فتقول: يا رحيم ارحمني، يا غفور اغفر لي،",
        "video_link": null
      },
      {
        "ts": "6:54",
        "sec": 414,
        "text": "واضح؟ فإذاً كل اسم يتضمن مقتضى معيناً يفهمه العربي. {وَذَرُوا الَّذِينَ يُلْحِدُونَ فِي أَسْمَائِهِ} أي",
        "video_link": null
      },
      {
        "ts": "7:02",
        "sec": 422,
        "text": "اتركوا الذين يعطلون ويوقفون معاني الأسماء والصفات ويبطلونها،",
        "video_link": null
      },
      {
        "ts": "7:11",
        "sec": 431,
        "text": "{سَيُجْزَوْنَ مَا كَانُوا يَعْمَلُونَ}. في يعني عند المسلمين في منتصف الإسلام،",
        "video_link": null
      },
      {
        "ts": "7:19",
        "sec": 439,
        "text": "أول من حُفظت عنه مقالة التعطيل هو الجعد بن درهم؛ الجعد بن درهم هذا وتلميذه",
        "video_link": null
      },
      {
        "ts": "7:26",
        "sec": 446,
        "text": "الجهم بن صفوان، إليهم تنسب الجهمية والجعدية. الجعد بن درهم هذا كان يقول: لم يتخذ الله إبراهيم خليلاً ولم يكلم",
        "video_link": null
      },
      {
        "ts": "7:34",
        "sec": 454,
        "text": "موسى تكليماً، حتى تكذيب القرآن الكريم! يقول لم يتخذ الله إبراهيم، يقول: نعم هذه",
        "video_link": null
      },
      {
        "ts": "7:42",
        "sec": 462,
        "text": "هذا شأن المخلوقين، ولم يكلم موسى تكليماً قال: هذا شأن المخلوقين. فيقول: نعم هي كلمات",
        "video_link": null
      },
      {
        "ts": "7:49",
        "sec": 469,
        "text": "لكن لا معنى لا معنى لها، ليس كما يفهم العربي، لأن كل هذه ينبغي أن تعطل فيقرأ",
        "video_link": null
      },
      {
        "ts": "7:56",
        "sec": 476,
        "text": "ولا يفهمون؛ هذا تعطيل، تعطيل للأسماء والصفات. ثم عندنا الأمر الثالث أو الضابط الثالث",
        "video_link": null
      },
      {
        "ts": "8:06",
        "sec": 486,
        "text": "الذي ينبغي تجنبه هو التكييف؛ تكييف الأسماء والصفات، أي تضع لها كيفية؛ كيف هي؟ كيف هذا؟",
        "video_link": null
      },
      {
        "ts": "8:14",
        "sec": 494,
        "text": "كيف يسمع؟ كيف يبصر؟ كيف يرى؟ كيف يغضب؟",
        "video_link": null
      },
      {
        "ts": "8:19",
        "sec": 499,
        "text": "كيف يفرح؟ كيف يضحك؟ كيف ينزل؟ كيف استوى؟ كل هذا",
        "video_link": null
      },
      {
        "ts": "8:25",
        "sec": 505,
        "text": "منهي عنه لا ينبغي أن يخوض فيه الإنسان.",
        "video_link": null
      },
      {
        "ts": "8:32",
        "sec": 512,
        "text": "قال تعالى: {وَلَا تَقْفُ مَا لَيْسَ لَكَ بِهِ عِلْمٌ}، {وَلَا تَقْفُ مَا لَيْسَ لَكَ بِهِ عِلْمٌ} أي لا تتبع الأمور",
        "video_link": null
      },
      {
        "ts": "8:40",
        "sec": 520,
        "text": "التي لا علم لك بها، {إِنَّ السَّمْعَ وَالْبَصَرَ وَالْفُؤَادَ كُلُّ أُولَٰئِكَ كَانَ عَنْهُ مَسْئُولًا} أي لا تأخذ في مثل الأمور، لا تأخذ في الكيفيات.",
        "video_link": null
      },
      {
        "ts": "8:48",
        "sec": 528,
        "text": "ومن وأيضاً من قوله تعالى: {وَلَا يُحِيطُونَ بِهِ عِلْمًا} في سورة طه، ليس لا أقصد آية الكرسي {وَلَا",
        "video_link": null
      },
      {
        "ts": "8:57",
        "sec": 537,
        "text": "يُحِيطُونَ بِشَيْءٍ مِّنْ عِلْمِهِ إِلَّا بِمَا شَاءَ} هذا أمر آخر؛ هذه الإحاطة بالله سبحانه وتعالى التي تقتضي بالكيفيات قال الله تعالى: {وَلَا يُحِيطُونَ",
        "video_link": null
      },
      {
        "ts": "9:06",
        "sec": 546,
        "text": "بِهِ عِلْمًا}، بالتالي لا يمكن أن تتعرف على الكيفيات أو كيفية أسمائه وصفاته التي",
        "video_link": null
      },
      {
        "ts": "9:13",
        "sec": 553,
        "text": "أثبتها لنفسه. طبعاً الكيف ليس منفياً، موجود ولكنه مجهول؛ لا ندري كيف هي أسماؤه وصفاته. والعبارة",
        "video_link": null
      },
      {
        "ts": "9:24",
        "sec": 564,
        "text": "طبعاً المعروفة خصوصاً لدى المالكية مقالة مالك: \"الاستواء معلوم، والكيف مجهول، والإيمان",
        "video_link": null
      },
      {
        "ts": "9:32",
        "sec": 572,
        "text": "به واجب، والسؤال عنه بدعة\". وهذه العبارة أعطتنا قاعدة ذهبية يمكن تطبيقها أو يجب تطبيقها في سائر",
        "video_link": null
      },
      {
        "ts": "9:41",
        "sec": 581,
        "text": "الأسماء والصفات. سُئل في أحد مجالسه، قال له رجل: {الرَّحْمَٰنُ عَلَى الْعَرْشِ اسْتَوَىٰ} كيف استوى؟",
        "video_link": null
      },
      {
        "ts": "9:51",
        "sec": 591,
        "text": "فأطرق مالك حتى صار يتصبب عرقاً، ثم رفع",
        "video_link": null
      },
      {
        "ts": "9:57",
        "sec": 597,
        "text": "رأسه فقال: \"الاستواء معلوم، والكيف مجهول، والإيمان به واجب، والسؤال عنه بدعة\"، ثم قال",
        "video_link": null
      },
      {
        "ts": "10:05",
        "sec": 605,
        "text": "عبارة أخرى اختلف فيها قالوا: \"إني لأراك رجل سوء\"، ثم أمر بإخراجه. فهذا من هذا",
        "video_link": null
      },
      {
        "ts": "10:14",
        "sec": 614,
        "text": "يعني نرى هذه القاعدة وكيف ينبغي تطبيقها وأين، وهو",
        "video_link": null
      },
      {
        "ts": "10:22",
        "sec": 622,
        "text": "إمرار الكيفيات وعدم الخوض في الكيفيات؛ فلا نتحدث عن الكيفيات إطلاقاً، نثبت",
        "video_link": null
      },
      {
        "ts": "10:28",
        "sec": 628,
        "text": "الأسماء والصفات ومعانيها اللائقة بجلاله دون ذكر هاته الكيفيات. فهل نقول للشخص",
        "video_link": null
      },
      {
        "ts": "10:36",
        "sec": 636,
        "text": "المؤمن المسلم الموحد هكذا بفطرته دون النصوص، متى تقول هل الله تعالى يسمعك الآن؟",
        "video_link": null
      },
      {
        "ts": "10:44",
        "sec": 644,
        "text": "فيقول: نعم، هو يستطيع أن يؤمن بهذه، يستطيع أن يستطيع أن يؤمن بأن الله تعالى يسمعه وهل يراك؟ هنا",
        "video_link": null
      },
      {
        "ts": "10:53",
        "sec": 653,
        "text": "يقول: نعم هو يراني، لكن كيف كيف يسمعك؟ هذا مما لا ندريه ولا نعرفه، لماذا؟ لأن القول",
        "video_link": null
      },
      {
        "ts": "11:01",
        "sec": 661,
        "text": "في الكيف فرع عن القول في الذات، القول في الكيف فرع عن",
        "video_link": null
      },
      {
        "ts": "11:09",
        "sec": 669,
        "text": "القول في الذات؛ لا يمكنك أن تحيط بالكيفية",
        "video_link": null
      },
      {
        "ts": "11:14",
        "sec": 674,
        "text": "إلا إذا أحطت بالذات بصفة عامة. إذا قلت لك مثلاً:",
        "video_link": null
      },
      {
        "ts": "11:22",
        "sec": 682,
        "text": "وصفت لك جبلاً، أو وصفت لك جهازاً، أو وصفت لك شخصاً، أو وصفت لك شيئاً",
        "video_link": null
      },
      {
        "ts": "11:29",
        "sec": 689,
        "text": "كيفما كان هذا الشيء؛ إذا وصفته لك إن كنت تعرفه مسبقاً فيمكنك أن تتخيل كلما أذكر عنه",
        "video_link": null
      },
      {
        "ts": "11:39",
        "sec": 699,
        "text": "الكيفيات؛ أنه يمشي كذا ويجيء كذا ويوضع كذا ويتحرك كذا، كل هذه الأمور يمكنك أن",
        "video_link": null
      },
      {
        "ts": "11:47",
        "sec": 707,
        "text": "تتخيلها سيارة أو جهاز أو شخص، لماذا؟ لأنك تعرف الذات، فمعرفة معرفتك بالذات",
        "video_link": null
      },
      {
        "ts": "11:55",
        "sec": 715,
        "text": "أعانتك على أخذ فكرة عن الكيفية وإن كانت ليست مطابقة ولكن على كل حال يمكنك أن",
        "video_link": null
      },
      {
        "ts": "12:02",
        "sec": 722,
        "text": "تتخيل الكيفيات بدون أي إشكال. لكن الله تعالى {وَلَا يُحِيطُونَ بِهِ عِلْمًا} فكيف يمكنك أن",
        "video_link": null
      },
      {
        "ts": "12:09",
        "sec": 729,
        "text": "تخوض في الكيفيات؟ فما كيف نتعامل مع الصفات؟ نثبتها",
        "video_link": null
      },
      {
        "ts": "12:14",
        "sec": 734,
        "text": "ونتعبد الله بها ولا ولا نكيفها؛ فمثلاً الله تعالى ينزل في الثلث الأخير من الليل،",
        "video_link": null
      },
      {
        "ts": "12:23",
        "sec": 743,
        "text": "فأنت أيها المسلم الموحد تؤمن بها أنه ينزل أينما كنت، الذي يهمك أنه في تلك",
        "video_link": null
      },
      {
        "ts": "12:30",
        "sec": 750,
        "text": "الساعة أو في الثلث الأخير من الليل الله تعالى في السماء الدنيا قم فادعه. كيف ينزل؟ هل ينتقل أم لا ينتقل؟ هل يكون في العرش؟",
        "video_link": null
      },
      {
        "ts": "12:40",
        "sec": 760,
        "text": "هذه الأمور لا يمكنك أن تخوض فيها، هي امور متعلقة بالمخلوقات؛ فأنت من حيث لا تدري",
        "video_link": null
      },
      {
        "ts": "12:46",
        "sec": 766,
        "text": "بدأت تقيسه على المخلوقات، فهذا كله تغلق هذا الباب، تقول: أنا لا أعلم، كل ما أعرف أن الله تعالى في الثلث الأخير من الليل في",
        "video_link": null
      },
      {
        "ts": "12:55",
        "sec": 775,
        "text": "السماء فادعوه، غير ذلك هذا هذه أمور لا أخوض فيها أينما كنت فوق الكرة الأرضية في الثلث",
        "video_link": null
      },
      {
        "ts": "13:03",
        "sec": 783,
        "text": "الأخير من الليل. وقد يقول: وكيف؟ هل من هنا هذه شأن المخلوقات وشأن الجمادات، هذا شأن",
        "video_link": null
      },
      {
        "ts": "13:10",
        "sec": 790,
        "text": "الله العظيم هذا لا يقاس على غيره. الذي يقع لبعض الناس لكي الذين يعطلون أو يحرفون أو يغيرون المعاني،",
        "video_link": null
      },
      {
        "ts": "13:19",
        "sec": 799,
        "text": "يعني يؤتون من هذا الباب، أغلبهم يؤتى من باب القياس؛ أنه يقيس الخالق على المخلوق",
        "video_link": null
      },
      {
        "ts": "13:26",
        "sec": 806,
        "text": "فينكر هذه الأمور لأنه ينسى أنه يتحدث عن الخالق؛ يا عبد الله هذا الخالق الذي {لَيْسَ كَمِثْلِهِ شَيْءٌ}،",
        "video_link": null
      },
      {
        "ts": "13:35",
        "sec": 815,
        "text": "فلماذا تقيس على غيره؟ لماذا تقيس على غيره؟ بل يمكن أن نقول إن نجد أشياء مخلوقة",
        "video_link": null
      },
      {
        "ts": "13:42",
        "sec": 822,
        "text": "ويمكن أن تفعل بعض الأمور ونقول: إن كان هذا المخلوق استطاع أن يفعل هذه الأشياء",
        "video_link": null
      },
      {
        "ts": "13:49",
        "sec": 829,
        "text": "فالخالق من باب أولى، هذا ممكن وربما نمثل لاحقاً في هذه الأمور. قال ابن عبد البر المالكي رحمه الله تعالى:",
        "video_link": null
      },
      {
        "ts": "13:58",
        "sec": 838,
        "text": "\"أهل السنة مجمعون على الإقرار بالصفات الواردة في الكتاب والسنة وحملها على",
        "video_link": null
      },
      {
        "ts": "14:05",
        "sec": 845,
        "text": "الحقيقة لا على المجاز، إلا أنهم لم يكيفوا شيئاً من ذلك\". هذا كلام",
        "video_link": null
      },
      {
        "ts": "14:14",
        "sec": 854,
        "text": "حافظ المغرب الإمام ابن عبد البر المالكي المعروف، قال",
        "video_link": null
      },
      {
        "ts": "14:21",
        "sec": 861,
        "text": "يعني كلام واضح يبين عقيدته: \"أهل السنة مجمعون على الإقرار بالصفات الواردة في",
        "video_link": null
      },
      {
        "ts": "14:30",
        "sec": 870,
        "text": "الكتاب والسنة\" نقول الصفات فهذا يشمل أيضاً الأسماء لأن الأسماء فيها الصفات، \"وحملها على الحقيقة لا على المجاز\"، وأيضاً",
        "video_link": null
      },
      {
        "ts": "14:39",
        "sec": 879,
        "text": "قضية المجاز، \"إلا أنهم\" يعني هذه القاعدة \"أنهم لم يكيفوا شيئاً من ذلك\" لم يخوضوا في تكييف الأسماء",
        "video_link": null
      },
      {
        "ts": "14:48",
        "sec": 888,
        "text": "والصفات. إذن من غير تكييف. الأمر الرابع الذي ينبغي تجنبه هو التمثيل؛ أن نمثل، وهذا",
        "video_link": null
      },
      {
        "ts": "14:55",
        "sec": 895,
        "text": "يعني يشبه شيئاً أنه يختلف عليه لأنه نمثل يعني تضربوا له الأمثال؛ تقول الله تعالى",
        "video_link": null
      },
      {
        "ts": "15:03",
        "sec": 903,
        "text": "يفعل كذا مثل كذا، هذا لا يجوز؛ لأن أسماء الله تعالى وصفاته لا تماثل أسماء وصفات",
        "video_link": null
      },
      {
        "ts": "15:12",
        "sec": 912,
        "text": "غيره إطلاقاً، لا يوجد تماثل ولا تشابه ولا تقارب حتى في المعنى.",
        "video_link": null
      },
      {
        "ts": "15:21",
        "sec": 921,
        "text": "الأسماء الحسنى والصفات العلى التي اختص بها الله سبحانه وتعالى لنفسه،",
        "video_link": null
      },
      {
        "ts": "15:28",
        "sec": 928,
        "text": "وقضية الاشتراك في الاسم والصفة لا يوجب المماثلة. قد يقول: الله تعالى نحن نسمع الله تعالى يسمع؟ نعم،",
        "video_link": null
      },
      {
        "ts": "15:37",
        "sec": 937,
        "text": "هناك قدر مشترك في المعنى، ولكن حين يثبت لله فإنه يصير خاصاً بالله، وحين يثبت",
        "video_link": null
      },
      {
        "ts": "15:44",
        "sec": 944,
        "text": "للإنسان فإنه يصير خاصاً بالإنسان. فقالوا مثلاً نسمي الله تعالى حياً",
        "video_link": null
      },
      {
        "ts": "15:51",
        "sec": 951,
        "text": "ونثبت ونثبت لله صفة الحياة، ونسمي الإنسان أيضاً حين نقول هذا إنسان حي ونقول الله تعالى الحي، لكن حياة الله ليست كحياة",
        "video_link": null
      },
      {
        "ts": "16:00",
        "sec": 960,
        "text": "الإنسان؛ حياة الإنسان مسبوقة بالعدم ويلحقها العدم أيضاً، فهي محصورة بين عدمين،",
        "video_link": null
      },
      {
        "ts": "16:07",
        "sec": 967,
        "text": "والله تعالى لم يسبقه عدم ولا يلحقه عدم، هذا مثال.",
        "video_link": null
      },
      {
        "ts": "16:14",
        "sec": 974,
        "text": "الله تعالى له الحياة المطلقة بخلاف الإنسان له الحياة المحدودة والمحصورة.",
        "video_link": null
      },
      {
        "ts": "16:21",
        "sec": 981,
        "text": "دليل ذلك قوله تعالى كما قلنا في السابق: {لَيْسَ كَمِثْلِهِ شَيْءٌ ۖ وَهُوَ السَّمِيعُ الْبَصِيرُ}، {لَيْسَ كَمِثْلِهِ} انظروا الآن فيها نفي وفيها إثبات؛",
        "video_link": null
      },
      {
        "ts": "16:31",
        "sec": 991,
        "text": "{لَيْسَ كَمِثْلِهِ شَيْءٌ} هذا نفي مطلق، ولذلك كما قلنا في الذين بالغوا في التنزيه حتى وقعوا في",
        "video_link": null
      },
      {
        "ts": "16:39",
        "sec": 999,
        "text": "التعطيل، اكتفوا بهذا الطرف من الآيات {لَيْسَ كَمِثْلِهِ شَيْءٌ}، ولكن مباشرة يقول الله تعالى: {وَهُوَ السَّمِيعُ",
        "video_link": null
      },
      {
        "ts": "16:45",
        "sec": 1005,
        "text": "الْبَصِيرُ} تنبه وأنت تنزه أن تعطل؛ التنزيه شيء مطلوب ولكن الإغراق والمبالغة في",
        "video_link": null
      },
      {
        "ts": "16:53",
        "sec": 1013,
        "text": "التنزيه قد توقع الإنسان في التعطيل؛ نزه نزه ونزه ليس ليس ليس ليس ليس حتى نفوا",
        "video_link": null
      },
      {
        "ts": "17:00",
        "sec": 1020,
        "text": "كل الأسماء والصفات اللائقة بجلاله: {لَيْسَ كَمِثْلِهِ شَيْءٌ ۖ وَهُوَ السَّمِيعُ الْبَصِيرُ}، فالإغراق في النفي وفي التنزيه يوقع الإنسان في",
        "video_link": null
      },
      {
        "ts": "17:10",
        "sec": 1030,
        "text": "التعطيل، كما أن الإغراق في الإثبات يوقع الإنسان في التجسيد.",
        "video_link": null
      },
      {
        "ts": "17:19",
        "sec": 1039,
        "text": "المبالغة؛ الله تعالى يسمع ويبصر، والإغراق في مثل هذه الأمور وفي نصوص الإثبات دون",
        "video_link": null
      },
      {
        "ts": "17:27",
        "sec": 1047,
        "text": "استحضار نصوص التنزيه قد يوقع الإنسان في تجسيد الله تعالى.",
        "video_link": null
      },
      {
        "ts": "17:36",
        "sec": 1056,
        "text": "وقال تعالى: {فَلَا تَضْرِبُوا لِلَّهِ الْأَمْثَالَ}، وقال تعالى: {وَلَمْ يَكُن لَّهُ كُفُوًا أَحَدٌ}، وقال تعالى في سورة مريم: {رَّبُّ السَّمَاوَاتِ",
        "video_link": null
      },
      {
        "ts": "17:46",
        "sec": 1066,
        "text": "وَالْأَرْضِ وَمَا بَيْنَهُمَا فَاعْبُدْهُ وَاصْطَبِرْ لِعِبَادَتِهِ ۚ هَلْ تَعْلَمُ لَهُ سَمِيًّا}. بالمناسبة هذه الآية أشارت إلى أقسام التوحيد الثلاثة: توحيد",
        "video_link": null
      },
      {
        "ts": "17:54",
        "sec": 1074,
        "text": "الربوبية، وتوحيد الألوهية، وتوحيد أسماء الأسماء والصفات؛ {رَّبُّ السَّمَاوَاتِ وَالْأَرْضِ وَمَا بَيْنَهُمَا} توحيد الربوبية، {فَاعْبُدْهُ وَاصْطَبِرْ لِعِبَادَتِهِ}",
        "video_link": null
      },
      {
        "ts": "18:03",
        "sec": 1083,
        "text": "توحيد الألوهية، {هَلْ تَعْلَمُ لَهُ سَمِيًّا} توحيد الأسماء والصفات. السَمِي هو ذلك الشخص في اللغة",
        "video_link": null
      },
      {
        "ts": "18:09",
        "sec": 1089,
        "text": "العربية؛ سمي فلان هو الذي له نفس الاسم، نفس اسمه ونفس اسم الأب باللغة سنقول الاسم",
        "video_link": null
      },
      {
        "ts": "18:19",
        "sec": 1099,
        "text": "الشخصي الاسم العائلي؛ شخص له اسم شخصي اسم عائلي يجد شخصاً آخر له نفس الاسم الشخصي",
        "video_link": null
      },
      {
        "ts": "18:26",
        "sec": 1106,
        "text": "والعائلي فيقول: هذا هذا سميك، هذا سمي. مثلاً شخص اسمه محمد الشرقاوي مثلاً",
        "video_link": null
      },
      {
        "ts": "18:35",
        "sec": 1115,
        "text": "ويجد شخصاً آخر اسمه محمد الشرقاوي نقول فلان سمي، أي له نفس الاسم.",
        "video_link": null
      },
      {
        "ts": "18:42",
        "sec": 1122,
        "text": "وقال مثلاً لأحد العلماء المعاصرين فيقال هذا سمي البخاري لأن البخاري اسمه",
        "video_link": null
      },
      {
        "ts": "18:49",
        "sec": 1129,
        "text": "لأن البخاري اسمه محمد بن إسماعيل، فهذا هو السمي في اللغة العربية. الله تعالى خاطب",
        "video_link": null
      },
      {
        "ts": "18:55",
        "sec": 1135,
        "text": "العرب بلغتهم فقال: {هَلْ تَعْلَمُ لَهُ سَمِيًّا} هذا سؤال استنكار، أي لا يوجد له سمي، أي من له نفس",
        "video_link": null
      },
      {
        "ts": "19:03",
        "sec": 1143,
        "text": "الأسماء التي ذكر الله تعالى طبعاً باللفظ والمعنى؛ {هَلْ تَعْلَمُ لَهُ سَمِيًّا} أي ليس له",
        "video_link": null
      },
      {
        "ts": "19:10",
        "sec": 1150,
        "text": "سمي. وغيرها من الآيات، كما قال تعالى في بداية سورة الأنعام: {الْحَمْدُ لِلَّهِ الَّذِي خَلَقَ السَّمَاوَاتِ وَالْأَرْضَ وَجَعَلَ الظُّلُمَاتِ وَالنُّورَ ۖ ثُمَّ",
        "video_link": null
      },
      {
        "ts": "19:18",
        "sec": 1158,
        "text": "الَّذِينَ كَفَرُوا بِرَبِّهِمْ يَعْدِلُونَ}، يَعْدِلُونَ أي يمثلون ويساوون،",
        "video_link": null
      },
      {
        "ts": "19:26",
        "sec": 1166,
        "text": "لأن العديل جاءت من المعادلة، يعدل اتخذوا لله عديلاً.",
        "video_link": null
      },
      {
        "ts": "19:34",
        "sec": 1174,
        "text": "الكفار اتخذوا له مثيلاً وشبيهاً ونظيراً. يعني",
        "video_link": null
      },
      {
        "ts": "19:42",
        "sec": 1182,
        "text": "في اللغة العربية هو ما يُسمى عندنا في الدارجة \"السَّلِيف\"؛ عديلك هو الذي تزوج أخت",
        "video_link": null
      },
      {
        "ts": "19:50",
        "sec": 1190,
        "text": "زوجتك، فلان عديل فلان أي أنه كأنه كأنهما تعادلا في المصاهرة، كلاهما تزوج من نفس",
        "video_link": null
      },
      {
        "ts": "19:58",
        "sec": 1198,
        "text": "الأسرة تعادلا؛ فالعديل في اللغة العربية هو هذا، يطلق على الذي تزوج أخت الزوجة. فالله تعالى فالعرب",
        "video_link": null
      },
      {
        "ts": "20:07",
        "sec": 1207,
        "text": "يعني يقولون اتخذوا العديل أي اتخذوا يعني كالقرين كالقرين، كل هذا منفي عن الله",
        "video_link": null
      },
      {
        "ts": "20:16",
        "sec": 1216,
        "text": "تعالى فلا نمثل شيئاً بالله سبحانه وتعالى؛ من غير تمثيل أي من غير تشبيه ومن غير تقريب ومن غير",
        "video_link": null
      },
      {
        "ts": "20:23",
        "sec": 1223,
        "text": "تسوية ومن غير تعديل، كل هذا ينبغي تجنبه. كانت هذه هي القاعدة أو الأمر الرابع في",
        "video_link": null
      },
      {
        "ts": "20:32",
        "sec": 1232,
        "text": "القاعدة الأولى. القاعدة الأولى فيها أربعة أمور أو تجنب أربعة أمور: تجنب التحريف، وتجنب التعطيل، وتجنب",
        "video_link": null
      },
      {
        "ts": "20:43",
        "sec": 1243,
        "text": "التكييف، وتجنب التمثيل؛ يعني كاينه شويه ديال السجع والياء:",
        "video_link": null
      },
      {
        "ts": "20:49",
        "sec": 1249,
        "text": "التحريف والتعطيل والتكييف والتمثيل، هذه كانت القاعدة الأولى. القاعدة الثانية",
        "video_link": null
      },
      {
        "ts": "20:58",
        "sec": 1258,
        "text": "التي ينبغي استحضارها ونحن نثبت الأسماء والصفات لله سبحانه وتعالى: أن معاني هذه",
        "video_link": null
      },
      {
        "ts": "21:06",
        "sec": 1266,
        "text": "الأسماء والصفات فيها الكمال المطلق المنزه عن كل نقص، الكمال المطلق الذي يمكن أن يتصوره العقل",
        "video_link": null
      },
      {
        "ts": "21:14",
        "sec": 1274,
        "text": "يُثبت لله تعالى.",
        "video_link": null
      },
      {
        "ts": "22:05",
        "sec": 1325,
        "text": "قال تعالى: {وَلِلَّهِ الْمَثَلُ الْأَعْلَىٰ}، قال المفسرون: أي الكمال المطلق، {وَلِلَّهِ الْمَثَلُ الْأَعْلَىٰ} أي",
        "video_link": null
      },
      {
        "ts": "22:12",
        "sec": 1332,
        "text": "الكمال المطلق. وقال تعالى: {سُبْحَانَ رَبِّكَ رَبِّ الْعِزَّةِ عَمَّا يَصِفُونَ}.",
        "video_link": null
      },
      {
        "ts": "22:19",
        "sec": 1339,
        "text": "هذه الآية التي كثيراً ما نسمعها في الأدعية وفي خواتم الأدعية، يقول الله سبحانه ربك رب العزة وسلاماً والحمد لله رب",
        "video_link": null
      },
      {
        "ts": "22:28",
        "sec": 1348,
        "text": "العالمين نعم، لكن تعني معنى أي ننزهه تعالى عن كل وصف لا يليق بجلاله؛ {سُبْحَانَ رَبِّكَ} تسبيح",
        "video_link": null
      },
      {
        "ts": "22:37",
        "sec": 1357,
        "text": "وهنا التنزيه، {سُبْحَانَ رَبِّكَ رَبِّ الْعِزَّةِ عَمَّا يَصِفُونَ} كل وصف لا يليق بجلاله فإن فإننا",
        "video_link": null
      },
      {
        "ts": "22:44",
        "sec": 1364,
        "text": "ننزه الله تعالى عنه. ثم عندنا القاعدة الثالثة وهي ما تُسمى بالنفي المجمل والإثبات المفصل، النفي",
        "video_link": null
      },
      {
        "ts": "22:54",
        "sec": 1374,
        "text": "المجمل والإثبات المفصل.",
        "video_link": null
      },
      {
        "ts": "23:58",
        "sec": 1438,
        "text": "السميع البصير العليم؛ الله تعالى حين يتحدث عن الأمور التي يثبت عن نفسه يثبتها",
        "video_link": null
      },
      {
        "ts": "24:04",
        "sec": 1444,
        "text": "بتفصيل، لم يقل على ليس ليس بكذا وليس بكذا وليس لا،",
        "video_link": null
      },
      {
        "ts": "24:12",
        "sec": 1452,
        "text": "حين نريد أن نثبت نفصل لأن هذا فيه أدب جم مع الله سبحانه وتعالى.",
        "video_link": null
      },
      {
        "ts": "24:20",
        "sec": 1460,
        "text": "مثلاً في سورة البروج: {وَهُوَ الْغَفُورُ الْوَدُودُ * ذُو الْعَرْشِ الْمَجِيدُ * فَعَّالٌ لِّمَا يُرِيدُ} كل هذا من باب الإثبات فيه تفصيل. ولكن عند النفي تجد",
        "video_link": null
      },
      {
        "ts": "24:30",
        "sec": 1470,
        "text": "أن الآيات التي تنفي عن الله تعالى ما لا يقوم به جاءت بإجمال: {لَيْسَ كَمِثْلِهِ شَيْءٌ}،",
        "video_link": null
      },
      {
        "ts": "24:36",
        "sec": 1476,
        "text": "كما قلنا قبل قليل في نفس الآية: {وَهُوَ السَّمِيعُ الْبَصِيرُ}؛ حين أردنا أن نثبت بيّنا ما",
        "video_link": null
      },
      {
        "ts": "24:43",
        "sec": 1483,
        "text": "الذي نثبته \"سميع بصير\"، ولكن لما أردنا النفي نفينا بإجمال.",
        "video_link": null
      },
      {
        "ts": "24:50",
        "sec": 1490,
        "text": "أما غير أهل السنة فصاروا ذهبوا مذهباً آخر وهو النفي المفصل",
        "video_link": null
      },
      {
        "ts": "24:57",
        "sec": 1497,
        "text": "والإثبات المجمل، وهذا موجود في كتب كتبهم، بل هناك من يكتفي بالنفي المفصل لمجرد فقط فيقولون في التعريف بالله: \"ليس بجسم ولا",
        "video_link": null
      },
      {
        "ts": "25:07",
        "sec": 1507,
        "text": "شبح ولا صورة ولا جثة ولا لحم ولا عظم ولا شخص ولا آدم ولا جوهر ولا عرض\" تعالى الله",
        "video_link": null
      },
      {
        "ts": "25:16",
        "sec": 1516,
        "text": "عما يقول، يعني إغراق في أمور النفي بطريقة غير مقبولة. ويمثلون",
        "video_link": null
      },
      {
        "ts": "25:23",
        "sec": 1523,
        "text": "لبيان قبح هذا هذا الصنيع قالوا مثلاً: إذا جاء شخص -مرة أخرى إذا جاء شخص وأراد أن",
        "video_link": null
      },
      {
        "ts": "25:31",
        "sec": 1531,
        "text": "يمدح شخصاً ذا سلطان أو ذا جاه- من الأفضل هل يقول له: \"أنت كريم، أنت شجاع،",
        "video_link": null
      },
      {
        "ts": "25:42",
        "sec": 1542,
        "text": "أنت خدوم\" وغير ذلك مما يمكن أن يمدح به الإنسان؟ يقولون هذا أليق، بخلاف لو جاء",
        "video_link": null
      },
      {
        "ts": "25:51",
        "sec": 1551,
        "text": "فقال له: \"أنت لست بخيلاً، وأنت لست جباناً، وأنت...\" قالوا هذا ليس",
        "video_link": null
      },
      {
        "ts": "25:59",
        "sec": 1559,
        "text": "فيه مدح في الحقيقة، كأنما يعني ينفي عنه شيئاً كأنه كان متهماً به، كأنه وُجد احتمال أن",
        "video_link": null
      },
      {
        "ts": "26:07",
        "sec": 1567,
        "text": "يتصف بهذه الصفات القبيحة فجاء فنفاها عنه. ثم إنه حين ينفي عنه هذه الصفات فإنه لا يعني أنه يثبت نقيضها؛ حين تقول للشخص \"أنت لست",
        "video_link": null
      },
      {
        "ts": "26:17",
        "sec": 1577,
        "text": "بخيلاً ولا جباناً\" فلا يعني أنه كريم شجاع، قد يكون شخصاً",
        "video_link": null
      },
      {
        "ts": "26:24",
        "sec": 1584,
        "text": "محايداً كما يقال لا كريم ولا بخيل، لا شجاع ولا جبان، واضح؟ حين تنفي الصفات القبيحة",
        "video_link": null
      },
      {
        "ts": "26:34",
        "sec": 1594,
        "text": "فلا يعني أنك تثبت نقيضها، أنت تنفي فقط ففيها قلنا فيها أمران مذمومان؛ الأمر كأنك",
        "video_link": null
      },
      {
        "ts": "26:41",
        "sec": 1601,
        "text": "كأنه كان متهماً فنفيت عنه، وثانياً أنت لا تمدحه بنفي القبائح عنه، إذا أردت مدح شخص",
        "video_link": null
      },
      {
        "ts": "26:50",
        "sec": 1610,
        "text": "فإنك تثبت له المحاسن لا تنفي عنه المساوئ.",
        "video_link": null
      },
      {
        "ts": "26:56",
        "sec": 1616,
        "text": "كانت هذه القاعدة الثالثة. هناك تنبيهات سنختم بها؛ أولاً الواجب على المسلمين إجراء",
        "video_link": null
      },
      {
        "ts": "27:04",
        "sec": 1624,
        "text": "النصوص، نصوص الأسماء والصفات على ظاهرها، هذا هو الأصل هذا هو الذي ينبغي أن",
        "video_link": null
      },
      {
        "ts": "27:13",
        "sec": 1633,
        "text": "يسعى إليه المسلم الموحد المؤمن؛ إذا وصله نص فيه كلام عن اسم أو صفة فينبغي أن",
        "video_link": null
      },
      {
        "ts": "27:23",
        "sec": 1643,
        "text": "يبقيها، أن يبقيها على ظاهرها وأن لا يؤولها إلا ما إذا وُجدت نصوص فيها تأويلات",
        "video_link": null
      },
      {
        "ts": "27:30",
        "sec": 1650,
        "text": "هذا شيء آخر. مثلاً: \"إذا زرت المريض فإنك تجد الله عنده\"، قالوا هل سنجد الله تعالى عند المريض؟ مثلاً",
        "video_link": null
      },
      {
        "ts": "27:39",
        "sec": 1659,
        "text": "في الحديث، قال العلماء: هنا تأويل؛ ستجد رحمة الله، ستجد كرم الله، ستجد منّة الله، سيكرمك الله،",
        "video_link": null
      },
      {
        "ts": "27:47",
        "sec": 1667,
        "text": "سيرحمك الله، هذا هو المقصود هذا هو التأويل المقبول. هو يعني حمل صفة على غير",
        "video_link": null
      },
      {
        "ts": "27:53",
        "sec": 1673,
        "text": "ظاهرها بدليل، لأن لا ننزه الله تعالى أن يوجد عند المريض ولكن اللفظ هو هذا أنك لو",
        "video_link": null
      },
      {
        "ts": "28:01",
        "sec": 1681,
        "text": "زرته ولوجدتني عنده، قالوا لوجدت رحمته وجدت فضله بالقرائن الأخرى.",
        "video_link": null
      },
      {
        "ts": "28:10",
        "sec": 1690,
        "text": "ثانياً أو الأمر الثاني الذي ينبغي التنبيه عليه: أن نصوص الأسماء والصفات معلومة من جهة",
        "video_link": null
      },
      {
        "ts": "28:17",
        "sec": 1697,
        "text": "المعنى مجهولة مجهولة من جهة الكيف، المعاني نثبتها. فما الذي نفوضه؟ هناك",
        "video_link": null
      },
      {
        "ts": "28:25",
        "sec": 1705,
        "text": "مذهب التفويض، مذهب التفويض فيه مدرستان أو فيه اتجاهان: تفويض المعاني وتفويض",
        "video_link": null
      },
      {
        "ts": "28:31",
        "sec": 1711,
        "text": "الكيفيات. تفويض المعاني هذا مذهب مبتدع؛ أي أنك نفوض المعنى، هذه الصفات والأسماء",
        "video_link": null
      },
      {
        "ts": "28:39",
        "sec": 1719,
        "text": "لها معاني لكن لا نعلم ما معناها، لها معاني لكن نفوضها، وهؤلاء أيضاً بالغوا في",
        "video_link": null
      },
      {
        "ts": "28:46",
        "sec": 1726,
        "text": "التنزيه واستعملوا لفظ التفويض، والتفويض غير مطلوب هنا. أي تفويض أي تفويض يُطالب به هو",
        "video_link": null
      },
      {
        "ts": "28:54",
        "sec": 1734,
        "text": "تفويض الصفات الكيفيات، الكيفية هي التي لا نعلمها وهذا متفق عليه؛ نفوض الكيفيات",
        "video_link": null
      },
      {
        "ts": "29:02",
        "sec": 1742,
        "text": "ونثبت المعاني، وإلا سنكون قد عبدنا عدماً كما يقال: \"المفوضة أو المعطلة يعبدون عدماً،",
        "video_link": null
      },
      {
        "ts": "29:10",
        "sec": 1750,
        "text": "والمجسدة يعبدون صنماً، وأهل السنة يعبدون رباً خالقاً له أسماء وصفات\".",
        "video_link": null
      },
      {
        "ts": "29:21",
        "sec": 1761,
        "text": "أن معرفة الله تكون بما عرّف به نفسه كما تقدم معنا، ويستدل في هذا",
        "video_link": null
      },
      {
        "ts": "29:28",
        "sec": 1768,
        "text": "بما قاله أو بما رُوي عن علي بن أبي طالب رضي الله عنه قال، قيل له أو سُئل: بمَ عرفت",
        "video_link": null
      },
      {
        "ts": "29:34",
        "sec": 1774,
        "text": "ربك؟ قال: \"عرفته بما عرّفني نفسه\"، عرفته بما عرّفني نفسه؛ \"لا يدرك بالحواس ولا",
        "video_link": null
      },
      {
        "ts": "29:43",
        "sec": 1783,
        "text": "يقاس بالناس\". هذه من العبارات الجميلة المنسوبة للإمام علي رضي الله عنه؛ كيف عرفت ربك؟ قال:",
        "video_link": null
      },
      {
        "ts": "29:52",
        "sec": 1792,
        "text": "\"عرفته عرفته بما عرفني نفسه\"، فلم الشهيد برأي الأمور التي ذكر عن نفسه عرفت بها،",
        "video_link": null
      },
      {
        "ts": "29:58",
        "sec": 1798,
        "text": "ثم زاد: \"لا يدرك بالحواس ولا يقاس بالناس\"؛ أن الحواس لا تدلك لا سمع ولا بصر أو غير",
        "video_link": null
      },
      {
        "ts": "30:05",
        "sec": 1805,
        "text": "ذلك، ولا يقاس بالناس كما قلنا. ثم عندنا التنبيه الرابع والأخير؛ أن",
        "video_link": null
      },
      {
        "ts": "30:15",
        "sec": 1815,
        "text": "العناية بثمرتها هو المطلوب من المسلمين؛ أن تعتني بثمرات هذه الأسماء والصفات. فحين تستحضر",
        "video_link": null
      },
      {
        "ts": "30:25",
        "sec": 1825,
        "text": "أنه سميع وتتعبد الله تعالى بأنه سميع، ما المطالب منك أيها المسلم؟ أن تحذر مما",
        "video_link": null
      },
      {
        "ts": "30:32",
        "sec": 1832,
        "text": "تتلفظ به؛ حين تعرف أن الله تعالى يسمع فتقول الله تعالى يسمعني الآن فلا يجوز لي أن أتكلم بهذا الكلام. والله تعالى بصير",
        "video_link": null
      },
      {
        "ts": "30:41",
        "sec": 1841,
        "text": "يبصرني الآن فلا ينبغي أن أكون في هذا المكان. وأن الله تعالى أيضاً من قضية الدعاء هو",
        "video_link": null
      },
      {
        "ts": "30:49",
        "sec": 1849,
        "text": "يسمع، فإن كان يسمع فإني أطلب منه ويسمعني الآن، وغير ذلك من",
        "video_link": null
      },
      {
        "ts": "30:57",
        "sec": 1857,
        "text": "الثمرات التي يجنيها الموحد المسلم الذي يثبت الأسماء والصفات.",
        "video_link": null
      },
      {
        "ts": "31:05",
        "sec": 1865,
        "text": "وأن الله تعالى حكيم، وأنه لطيف، وأنه خبير؛ فتتعبد الله تعالى بلطف، يعني حتى في الحياة الدنيا ربما",
        "video_link": null
      },
      {
        "ts": "31:13",
        "sec": 1873,
        "text": "ربما أسأت في تصرفات فتطلب الله تعالى أن يغفر لك ويرحمك، وأن يتجاوز عنك وأن يعفو عنك، ثم",
        "video_link": null
      },
      {
        "ts": "31:23",
        "sec": 1883,
        "text": "تحتاج إلى إلى نصرة وعون فتطلب الله تعالى منه التيسير والسداد والتوفيق، ولذلك هذه هي",
        "video_link": null
      },
      {
        "ts": "31:30",
        "sec": 1890,
        "text": "الثمرة المطلوبة لأنها أنت من أين قطفتها؟ قطفتها من معاني أسماء صفات، فلو كنت معطلاً",
        "video_link": null
      },
      {
        "ts": "31:38",
        "sec": 1898,
        "text": "لكنت عابداً لعدم؛ فالمعطل لا يستطيع أن يتعبد الله بهذه",
        "video_link": null
      },
      {
        "ts": "31:45",
        "sec": 1905,
        "text": "الأسماء والصفات التي عطلها. وبالجملة لكي يسلم الإنسان من الخلل والزلل في قضية",
        "video_link": null
      },
      {
        "ts": "31:51",
        "sec": 1911,
        "text": "الأسماء والصفات، فعليه أن يستحضر أولاً عِظَم قدر الله تعالى، وأن يقدر ويقدس ويعظم",
        "video_link": null
      },
      {
        "ts": "31:59",
        "sec": 1919,
        "text": "النصوص الشرعية التي ذُكرت فيها هذه الأسماء والصفات، فيثبت -يعني يحترم نصوص هذا هو منهج- يثبت ما أثبته لنفسه، وينفي",
        "video_link": null
      },
      {
        "ts": "32:09",
        "sec": 1929,
        "text": "عنه ما نفى عن نفسه، وأن ينزهه عن كل ما لا يليق به. أقول قولي هذا وأستغفر الله لي",
        "video_link": null
      },
      {
        "ts": "32:16",
        "sec": 1936,
        "text": "ولكم، والسلام عليكم ورحمة الله تعالى وبركاته.",
        "video_link": null
      }
    ]
  },
  {
    "subject": "aqeeda",
    "subjectLabel": "العقيدة والتوحيد",
    "lesson": "الدرس 20",
    "lessonNum": 20,
    "title": "الدرس 20",
    "summary": "📚 <b>ملخص درس: حقيقة الشرك وأسباب ظهوره (أكاديمية الباجي)</b>\n\n🔹 <b>الخلاصة المحورية للدرس:</b>\n<blockquote>يُبين الدرس أن التوحيد هو الأصل الفطري للبشرية، وأن الشرك \"طارئ\" دخل على العقيدة السليمة نتيجة تراكمات من الجهل والغلو، مؤكداً على أهمية سد الذرائع لحماية جناب التوحيد.</blockquote>\n\n🔹 <b>الأحداث والوقائع والقواعد بالتفصيل:</b>\n<blockquote>\n• <b>تعريف الشرك:</b> \n  - <b>لغةً:</b> من الشركة، أي جعل الشيء بين اثنين أو أكثر (كما في قوله تعالى: {وَأَشْرِكْهُ فِي أَمْرِي}).\n  - <b>اصطلاحاً:</b> هو جعل شيء من خصائص الله لغير الله.\n• <b>الأصل في الإنسان (الفطرة):</b> الإنسان يولد على التوحيد (الحنيفية). وقد أخذ الله الميثاق على بني آدم بربوبيته، وهو ما أكدته الآيات (كآية الميثاق وسورة الروم) والحديث القدسي: \"إني خلقت عبادي حنفاء كلهم\".\n• <b>تاريخ الشرك الأول:</b> كان الناس أمة واحدة على التوحيد (ملة آدم)، ثم اختلفوا فظهر الشرك. وقد وقع الانحراف في قوم نوح عليه السلام بسبب الغلو في الصالحين (ود، سواع، يغوث، يعوق، نسر).\n• <b>قصة الأصنام:</b> أوحى الشيطان لقوم نوح بنصب تماثيل أو علامات لتذكر الصالحين، وبعدما مات الجيل المعاصر لهم ونُسي العلم، عُبدت تلك الأنصاب من دون الله.\n• <b>ظهور الشرك في الجزيرة العربية:</b> أدخله \"عمرو بن لحي الخزاعي\" بعد عودته من الشام، حيث استحسن عبادة الأوثان ونصب صنم \"هبل\" في جوف الكعبة، فتبعه الناس نظراً لمكانته الدينية بينهم.\n• <b>أسباب انتشار الشرك:</b>\n  1. <b>الجهل:</b> نسيان العلم الشرعي يفتح باب الانحراف.\n  2. <b>الغلو في المخلوق:</b> المبالغة في التعظيم توصل إلى التأليه (مثل غلو النصارى في عيسى عليه السلام).\n  3. <b>سوء الظن بالله:</b> الاعتقاد بأن الأصنام تشفع أو تنفع، وهو ضعف في معرفة قدرة الله وتوحيده.\n• <b>قاعدة سد الذرائع:</b> هي من أهم القواعد في العقيدة؛ فكل فعل يؤدي إلى مفسدة عقدية يُمنع وإن كان ظاهره مصلحة، لحماية التوحيد.\n</blockquote>\n\n🔹 <b>الأسماء والتواريخ والمصطلحات الرئيسية:</b>\n<blockquote>\n• <b>عياض بن حمار المجاشعي:</b> الصحابي الذي روى الحديث القدسي عن الفطرة.\n• <b>عشرة قرون:</b> المدة التي قضاها البشر على التوحيد بين آدم ونوح، والقرن هنا يعني \"الجيل\" أو \"الطبقة من الناس\".\n• <b>عمرو بن لحي الخزاعي:</b> أول من غير دين إبراهيم وأدخل الشرك والأصنام إلى مكة والجزيرة العربية، وقد توعده النبي صلى الله عليه وسلم بالنار.\n• <b>اللات والعزى ومناة:</b> أشهر الأصنام التي عُبدت في الجزيرة العربية بعد أن ساد الشرك.\n• <b>سد الذرائع:</b> قاعدة أصولية وعقدية تعني منع المباحات التي تؤدي إلى الوقوع في المحرمات.\n</blockquote>\n\n🔹 <b>العِبر والأحكام المستفادة:</b>\n<blockquote>\n• الشرك ليس أصلاً في البشرية بل هو أمر دخيل، والدعوة للتوحيد هي عودة للأصل.\n• تحريم الغلو في الأشخاص (حتى الأنبياء والصالحين) لقول النبي صلى الله عليه وسلم: \"لا تطروني كما أطرت النصارى عيسى\".\n• خطورة \"الجهل\" على سلامة الاعتقاد؛ فكلما غاب العلم، وجد الشيطان طريقاً لإغواء الناس.\n• التنبيه من خطورة التبرك بالتماثيل أو الأماكن بحجة التذكر، فهي باب من أبواب الشرك.\n</blockquote>\n\n🔹 <b>سؤال تدبر ومراجعة ذاتية:</b>\n<blockquote>\"لقد ذكر الشيخ أن الشيطان لا يُغوي الجيل الأول مباشرة، بل يمهد للأجيال اللاحقة.. استنبط من قصة قوم نوح كيف يمكن للمسلم اليوم أن يحمي عقيدته من الانزلاق في هذا المسار التدريجي؟\"</blockquote>",
    "full_text": "بسم الله الرحمن الرحيم، الحمد لله رب العالمين، والصلاة والسلام على أشرف الأنبياء والمرسلين نبينا محمد وعلى آله وصحبه أجمعين. أما بعد، فهذا درس جديد من دروس التوحيد والعقيدة للسنة الأولى في أكاديمية الباجي للعلوم الشرعية. بعدما تعرفنا على التوحيد، تعرفنا على معناه وعلى أقسامه، وجب أن نتعرف أيضاً على نقيضه؛ لأنه كما يقال: \"بضدها تتبين أو تتميز الأشياء\". وحين نتعرف على نقيض الشيء فإننا نزداد بياناً ونزداد أيضاً، نكون على بينة وعلى وضوح في ذلك الأمر. فالتوحيد ضده الشرك، فما هو الشرك؟ الشرك لغةً: من الشركة يشترك؛ نقول مثلاً: شركته في هذا الأمر؛ شاركته في البيع، شركته في المال، شركته في التجارة، أي جعلته أي جعلت له نصيباً من ذلك الأمر. والشركة هي جعل الشيء بين اثنين وأكثر بحيث لا ينفرد به أحد، هذا من جهة اللغة. وهو أيضاً هذا المعنى اللغوي جاء في القرآن الكريم، قال تعالى حكاية عن موسى عليه السلام لما طلب أن يكون إبراهيم أو عفواً هارون معه في النبوة، قال: {وَأَشْرِكْهُ فِي أَمْرِي}؛ اجعل يا ربنا هذا الأمر بيننا. أما في علم العقائد، فإن الشرك في العقيدة هو جعل شيء من خصائص الله لغير الله، هذا باختصار شديد؛ الشرك هو جعل شيء من خصائص الله لغير الله سبحانه وتعالى. وقد يتساءل سائل يعني: بما أن الأصل في الإنسان الفطرة والتوحيد، ولماذا يقع الشرك؟ قلنا إن الأصل في الإنسان أنه يولد على الفطرة، كما قال تعالى: {فَأَقِمْ وَجْهَكَ لِالدِّينِ حَنِيفًا ۚ فِطْرَتَ اللَّهِ الَّتِي فَطَرَ النَّاسَ عَلَيْهَا ۚ لَا تَبْدِيلَ لِخَلْقِ اللَّهِ ۚ ذَٰلِكَ الدِّينُ الْقَيِّمُ وَلَٰكِنَّ أَكْثَرَ النَّاسِ لَا يَعْلَمُونَ}. وقال تعالى: {وَإِذْ أَخَذَ رَبُّكَ مِن بَنِي آدَمَ مِن ظُهُورِهِمْ ذُرِّيَّتَهُمْ وَأَشْهَدَهُمْ عَلَىٰ أَنفُسِهِمْ أَلَسْتُ بِرَبِّكُمْ ۖ قَالُوا بَلَىٰ ۛ شَهِدْنَا ۛ أَن تَقُولُوا يَوْمَ الْقِيَامَةِ إِنَّا كُنَّا عَنْ هَٰذَا غَافِلِينَ}. قلنا بأن هذا من من الإشارات التي تدل على وجود الفطرة، لأن هذا الميثاق الذي أخذه الله تعالى على بني آدم -ذكرنا هذا في دروس سابقة- أن الله تعالى أوجد الخلق ثم أشهدهم على أنفسهم على ربوبيته وألوهيته فأقروا، ثم عاد الله تعالى بالبشرية إلى العدم، وهذا ثابت طبعاً بالكتاب والسنة. أثر هذا اللقاء والفطرة؛ وروى الإمام مسلم عن عياض بن حمار المجاشعي رضي الله عنه أن رسول الله صلى الله عليه وسلم يروي فيما يروي عن ربه، أي حديث قدسي، قال تعالى: \"إني خلقت عبادي حنفاء كلهم، وإنهم أتتهم الشياطين فاجتالتهم عن دينهم، وحرمت عليهم ما أحللت لهم، وأمرتهم أن يشركوا بي ما لم أنزل به سلطاناً، وإن الله نظر إلى أهل الأرض فمقتهم عجمهم وعربهم إلا بقايا من أهل الكتاب\". الشاهد هو قوله في هذا، قول الله تعالى: \"إني خلقت عبادي حنفاء كلهم\"؛ إذن الأصل في الإنسان أنه يولد على الحنيفية، هذه هي الفطرة التي ذكر الله تعالى في الآية التي تقدمت معنا: {فَأَقِمْ وَجْهَكَ لِالدِّينِ حَنِيفًا ۚ فِطْرَتَ اللَّهِ الَّتِي فَطَرَ النَّاسَ عَلَيْهَا}، فالحنيفية هي التوحيد، هي الفطرة السليمة، أي معرفة الله تعالى والإيمان به. ثم كما في الحديث جاءت الشياطين فاجتالت الناس أي أضلتهم. وعلى الحديث المعروف الذي رواه الشيخان عن أبي هريرة رضي الله عنه أن رسول الله صلى الله عليه وسلم قال: \"كل مولود\" أو في رواية \"ما من مولود إلا ويولد على الفطرة، فأبواه يهودانه أو ينصرانه أو يمجسانه\". وهذه طبعاً هي التي كانت آنذاك، فهذا هذا الفصل التفصيل النبي عليه الصلاة والسلام لم يقصد به الحصر. لا يقول قائل، لا يقول قائل عفواً: إنه لماذا ذكر النبي عليه الصلاة والسلام هذه الأديان فقط مع أنه كانت توجد أديان أخرى؟ هذه الأديان التي كانت معروفة في الجزيرة العربية وهي كانت منتشرة، فيُقاس على كل الأديان، فالعبرة الآن ليست بخصوص في هذا الحديث. فإذن الأصل في الإنسان أنه يولد موحداً ولا يولد مشركاً؛ فالشرك شيء طارئ، الشيء الشرك شيء يطرأ على الإنسان. وحتى البشرية لما نزل آدم عليه السلام، نزل طبعاً وهو نبي فكان موحداً بالطبع وذريته أيضاً، إذن الأصل في البشرية أيضاً التوحيد؛ البشرية كانت على التوحيد. والله تعالى يقول: {كَانَ النَّاسُ أُمَّةً وَاحِدًا فَبَعَثَ اللَّهُ النَّبِيِّينَ مُبَشِّرِينَ وَمُنذِرِينَ}، طبعاً هنا ينبغي أن نقدر محذوفاً: \"كان الناس أمة واحدة فاختلفوا\". دل ذلك، دل على ذلك قوله تعالى في آية أخرى في سورة يونس: {وَمَا كَانَ النَّاسُ إِلَّا أُمَّةً وَاحِدَةً فَاخْتَلَفُوا}، يعني عند بعض قد يقول قائل مثلاً: {كَانَ النَّاسُ أُمَّةً وَاحِدَةً فَبَعَثَ اللَّهُ النَّبِيِّينَ مُبَشِّرِينَ وَمُنذِرِينَ} لماذا بعث الله تعالى المبشرين والناس على أمة واحدة؟ فهناك محذوف ينبغي تقديره، أي: \"كان الناس أمة واحدة فاختلفوا فبعث الله النبيين مبشرين ومنذرين وأنزل معهم الكتاب\" الآية، وهي في سورة البقرة. المفسرون قالوا -في تفسير هذه الآية والآية الأخرى في سورة يونس- إن الناس كانوا على، كانوا أمة واحدة على دين واحد وعلى ملة واحدة وهي التوحيد بالطبع. وقال ابن كثير: الناس كانوا على ملة آدم عليه السلام ثم آلوا إلى أن عبدوا الأصنام. وهؤلاء الأقوام الذين بدأوا في عبادة الأصنام هم أول من أشرك بالله، وهم الذين بعث فيهم نوح عليه السلام، فكان نوح أول رسول إلى أهل الأرض لأن كل من كان قبله كانوا أنبياء. وطبعاً سنذكر لاحقاً الفرق بين النبي والرسول. روى الحاكم عن أبي أمامة الباهلي رضي الله عنه أن رسول الله صلى الله عليه وسلم قال: \"كان بين آدم ونوح عشرة قرون، كلهم على شريعة من الحق\"؛ كان بين آدم ونوح عشرة قرون كلهم على شريعة من الحق. حين نقول -بالمناسبة- حين نقول قرن، فلا يُفهم منه مائة سنة؛ الآن الاصطلاح الذي درج عليه الناس في أيامنا هذه أن القرن هو مائة سنة \"قرن\"، الحق أن القرن في نصوص الشرع وفي أصل العربية هم طبقة من الناس؛ عشرة قرون أي عشر طبقات من الناس وطبعاً هذا يعني يختلف باختلاف أعمار هؤلاء، فربما عاشوا مئات السنين خصوصاً يعني تعلم أن نوحاً عليه السلام عاش أو بعث في قومه ألف سنة إلا خمسين عاماً بعث فيها، وربما عاش أكثر من ذلك. فالشاهد هو أنه ينبغي يعني القرن حين يقول النبي عليه الصلاة والسلام: \"خير الناس قرني ثم الذين يلونهم ثم الذين يلونهم\" فيقصد به الطبقة التي كانت موجودة آنذاك من الناس، هما الآن تقريباً \"الجيل\" إن صح التعبير. {مَا بَالُ الْقُرُونِ الْأُولَىٰ}؛ أي الأقوام الذين كانوا في السابق. إذن مبدأ الشرك والانحراف كان في القوم الذين بُعث فيهم بعد ذلك نوح عليه السلام. روى البخاري عن ابن عباس رضي الله عنهما أنه قال -حديث هذا أثر، حديث موقوف قال ابن عباس في تفسير قوله تعالى في سورة نوح: {وَقَالُوا لَا تَذَرُنَّ آلِهَتَكُمْ وَلَا تَذَرُنَّ وَدًّا وَلَا سُوَاعًا وَلَا يَغُوثَ وَيَعُوقَ وَنَسْرًا}- قال ابن عباس رضي الله عنهما: \"هذه أسماء رجال صالحين من قوم نوح، هذه أسماء رجال صالحين من قوم نوح، فلما هلكوا أوحى الشيطان إلى قومهم أن ينصبوا إلى مجالسهم التي كانوا يجلسون فيها أنصاباً\". هؤلاء هذه أسماء رجال صالحين؛ ود، وسواع، ويغوث، ويعوق، ونسر؛ هذه أسماء هذه أسماء أعلام رجال كانوا صالحين في الأصل، وكانوا طبعاً قبل نوح عليه السلام. فلما ماتوا جاء الشيطان فأوحى إلى أقوامهم، إلى قومهم بأن يجعلوا أنصاباً. والأنصاب هذه تختلف عن علامات، وليس تمثالاً فقط، علامة مثلاً يأخذون أعواداً مثلاً أو أشياء فيجعلونها علامة على المكان الذي كانوا أو الأمكنة التي كانوا يجلسون فيها هؤلاء الأقوام الذين كانوا صالحين، ثم سموها بأسمائهم؛ يعني هناك كان يجلس نسر، هناك كان يجلس يغوث، هناك يجلس يعوق، وهناك يجلس ود وغير ذلك، فأُطلقت أسماؤهم على أسماء الأمكنة التي كانوا يجلسون فيها، ففعلوا. الشيطان الذي أوحى لهم، والشيطان له حيل لا يعمل على في بعض الأحيان، في كل الأحيان لا يعمل عاجلاً؛ الشيطان ربما يقصد يعني هدفه الأجيال القادمة، فلا يقصد مثلاً هذا الجيل، هذا الجيل ربما متمسك بدينه لكن يكفيه أن يحرفه أو يميل به ولو شيئاً قليلاً ولا يخرجه أبداً من الملة، ولكن ذلك الانحراف سيقع أكثر في ذريتهم ثم سيزداد ثم سيزداد إلى أن يخرج الناس من الملة والعياذ بالله. وهذا واضح؛ نرى أن في بعض الأقوام يكون هناك خير ثم ذلك يكون الانحراف قليلاً، فيأتي جيل الجيل الذي يليهم فيكون الانحراف فيه أشد؛ يعني الأمر كالزاوية، الزاوية هذه كلما ابتعدت كلما يعني ابتعد هذا الخط مع هذا الخط. قال: ففعلوا ولم تُعبد، في البداية لم تُعبد لأن الناس كانوا على الدين السليم والصحيح، وقالوا فقط: نحن سنضع هذه الأنصاب فقط لكي نتذكر هؤلاء الناس ونترحم عليهم، كما يفعل الآن يعني بعض التماثيل لكن فقط نقول: هذا تمثال لكي تذكار نتذكر به هؤلاء الناس ونترحم عليهم. وربما ياتوك، ربما ياتونك بأدلة يعني شرعية تشجعهم على فعل هذا؛ نعم هذا فيه مصلحة وهي أننا سنتذكرهم وسنتحدث عن أخبارهم وسنذكر أحاديثهم ومواعظهم، كل هذا فيه خير، نعم. لذلك في بعض الأحيان لا ينبغي يعني فتح باب هكذا على مصراعيه أمام كل من يزعم بأنه هناك مصلحة شرعية، قد تكون مفسدة تظهر الآن كالمصلحة ولكن يترتب عليها المفسدة. وهنا هذا دور الراسخين في العلم للتمييز بين المصالح والمفاسد، وعندنا قاعدة مهمة جداً وهي سد الذرائع، وقد تُستعمل كثيراً في باب العقائد أنه قد مثلاً قد يكون شيء جائزاً ولكن قد يفضي إلى خلل، إلى مسألة، إلى مخالفة عقدية فنغلق هذا الباب حفاظاً على جناب التوحيد. إذن قال ابن عباس: \"ففعلوا فلم تُعبد، حتى إذا هلك أولئك ونُسي العلم عُبدت\". أولئك الأقوام لما ماتوا الذين كانوا معاصرين وكانوا قريبين من هؤلاء، لما انتهى هذا الجيل جاء الجيل الذي يليهم فقلّ فيهم العلم، قال: \"ونُسي العلم عُبدت\". وهنا يشير إشارة مهمة جداً إلى أسباب انتشار الشرك وهي انعدام العلم وغياب العلم، فقال: \"نُسي العلم\"، أي أُهمل العلم وقلّ العلم، فُفتح باب الانحراف العقدي ووقع الناس في الشرك. هكذا انتشرت أو بدأت عبادة الأصنام والأوثان. والشياطين يعني لم يكتفوا بهذا بل زينوا للناس معبودات أخرى منها الجن؛ والجن هذا يعني لأنه مخلوق لا يُرى، ومخلوقات لا تُرى بالعين ويعني لهم عالمهم، فالشيطان يعني انتهز هذا الغياب الذي يغيب عن أنظار الناس فصار يخوف الناس منهم، قال تعالى: {وَيَوْمَ يَحْشُرُهُمْ جَمِيعًا ثُمَّ يَقُولُ لِلْمَلَائِكَةِ أَهَٰؤُلَاءِ إِيَّاكُمْ كَانُوا يَعْبُدُونَ * قَالُوا سُبْحَانَكَ أَنتَ وَلِيُّنَا مِن دُونِهِم ۖ بَلْ كَانُوا يَعْبُدُونَ الْجِنَّ ۖ أَكْثَرُهُم بِهِم مُّؤْمِنُونَ}؛ فكانوا يعبدون الجن وكانوا يستغيثون بهم ويستعيذون بهم. وعبدوا كذلك الكواكب والنجوم، إذن فُتح باب الشرك على مصراعيه كما في قوم إبراهيم عليه السلام الذي جاء لاحقاً بعد ذلك، قال تعالى يصف حاله؛ ما إن كان يعني هناك من كان هنا يناظر أم ينظر، على كل حال أنه كان يعني أظهر أن قومه كانوا يعبدون الكواكب والنجوم: {فَلَمَّا جَنَّ عَلَيْهِ اللَّيْلُ رَأَىٰ كَوْكَبًا ۖ قَالَ هَٰذَا رَبِّي ۖ فَلَمَّا أَفَلَ قَالَ لَا أُحِبُّ الْآفِلِينَ * فَلَمَّا رَأَى الْقَمَرَ بَازِغًا قَالَ هَٰذَا رَبِّي ۖ فَلَمَّا أَفَلَ قَالَ لَئِن لَّمْ يَهْدِنِي رَبِّي لَأَكُونَنَّ مِنَ الْقَوْمِ الضَّالِّينَ * فَلَمَّا رَأَى الشَّمْسَ بَازِغَةً قَالَ هَٰذَا رَبِّي هَٰذَا أَكْبَرُ ۖ فَلَمَّا أَفَلَتْ قَالَ يَا قَوْمِ إِنِّي بَرِيءٌ مِّمَّا تُشْرِكُونَ}؛ إن قومه كانوا عبَدة للكواكب والنجوم والشمس. إذن هكذا ظهر الشرك في البشرية؛ إذن الأصل في البشرية أنها كانت على التوحيد والشرك شيء طارئ، شيء حدث بعد أن كان التوحيد والإيمان الحق. ثم نأتي إلى الجزيرة العربية؛ أول من أدخل الشرك إلى الجزيرة العربية هو عمرو بن لحي الخزاعي، وهذا الرجل كان كان عُرف بفعل الخير وبالصدقة والحرص على على أمور الدين والعبادات، فكان ديّناً خيراً فأحبه الناس ويعني قدموه وصاروا يعني يستشيرونه ويسألونه، وصار كالزعيم أو السيد الذي يوجه الناس في في مكة ونواحيها، بل حتى إنهم قالوا صار الملك لمكة وولاية البيت كانت بيده. طبعاً كان فيها الآن فيها عن الحقبة التي تلت إسماعيل عليه السلام، يعني لم يكن هناك شرك؛ كان هؤلاء من ذرية إسماعيل عليه السلام كانوا على الحنيفية، كانوا مؤمنين وموحدين. ثم يعني ما الذي وقع؟ هذا الرجل هو عمرو بن لحي الخزاعي سافر إلى الشام فرأىهم يعبدون الأوثان فاستحسن هذا الأمر؛ لماذا؟ لأن الشام، الشام هذه محل ومهبط الأنبياء والرسل ومحل الرسالات معروفة، يعني كثير من الأنبياء بُعثوا في هذه البقعة من الأرض لهم الفضل على غيرهم، فلما رأى هذا الأمر استحسنه. ولما عاد إلى مكة جاء بصنم وهو \"هبل\" المعروف، فجعله في جوف الكعبة ودعا أهل مكة إلى عبادته فأطاعوه، والله المستعان! إذن هنا بدأ الشرك في مكة. إن ربما يقول يعني: هذا البيت الذي بناه هذه الكعبة التي المشرفة التي بنى إبراهيم عليه السلام وإسماعيل عليه السلام، إذن هؤلاء كانوا على التوحيد؟ نقول: نعم، كانوا على التوحيد، وذريتهم كذلك كانت على التوحيد. ولكن طال الأمد فتقسو القلوب كما قلنا أيضاً حتى في لما وقع للأقوام الذين أو للقوم الذين بُعث فيهم نوح عليه السلام؛ قال ابن عباس تلك الإشارة المهمة وهي: \"نُسي العلم\". فلما يعني يطول الأمد ويطول المدد، ربما يضعف الحق أو صوت الحق. ولما ظهر الشرك في مكة ومكة أيضاً يعني أهل الحجاز والقبائل في الجزيرة العربية كانوا يعظمون مكة كما أن مكة كانت تعظم الشام؛ القبائل والمناطق في الجزيرة العربية يعظمون مكة لأن فيها البيت الذي بناه إبراهيم عليه السلام، فلما رأوهم، رأوا أنهم بدأوا يعبدون صنماً في في الكعبة ظنوا أن ذلك من الحق ومن الأمور المشروعة، فنصبوا أوثاناً أوثاناً في عدة مناطق من الجزيرة العربية؛ بقديد مثلاً كان فيها \"مناة\" الذي ذكره الله تعالى، ثم ظهر \"اللات\" وظهر \"العزى\"، وهذه هي ثلاثة الأصنام الثلاثة التي اشتهرت، هي التي ذكرها الله تعالى في سورة النجم: {أَفَرَأَيْتُمُ اللَّاتَ وَالْعُزَّىٰ * وَمَنَاةَ الثَّالِثَةَ الْأُخْرَىٰ}. ثم كثر الشرك في الجزيرة العربية، ونصبت الأوثان في كل بقعة من هذه الجزيرة، بل في كل بيت حتى صار في كل بيت صنم بل أصنام في كل البيوت. وإذن كل هذا والله المستعان كان يرجع سببه إلى ذلك الرجل اللي هو عمرو بن لحي الخزاعي، ولا حول ولا قوة إلا بالله. عليه الصلاة والسلام شهد لهذا الرجل بالنار؛ رواه الشيخان عن أبي هريرة رضي الله عنه أن رسول الله صلى الله عليه وسلم قال: \"رأيت عمرو بن لحي يجر قصبه في النار\"، \"رأيت عمرو بن لحي يجر قصبه في النار\"، والقصب وهي الأمعاء، القُصْب الأمعاء. فهكذا ظهر الشرك في الجزيرة العربية؛ فأنتم ترون أن الأصل في الإنسان التوحيد، والأصل في البشرية التوحيد، فالشرك شيء طارئ. والدعوة للتوحيد إنما هي دعوة إلى الأصل، إلى البقاء على الأصل، إلى العودة إلى الأصل اللي هو التوحيد. وأن الأرضية التي ينبت فيها الشرك هي الأرضية التي يكثر فيها الجهل كما قلنا، بدليل ما قاله ابن عباس رضي الله، فقط قلنا إنه أشار إلى سبب مهم أو إلى الأرضية التي تكون يعني تعين على أن يظهر الشرك وهو الجهل، أرضية الجهل قال: \"ونُسي العلم\". بعض العلماء قال بالنظر إلى أسباب كل هذا، قال إن الشرك له سببان رئيسان بالإضافة طبعاً إلى الأرضية هي الجهل؛ قال هو الغلو في المخلوق، لأن لما، إذا تأملنا قصة قوم نوح فإنهم غلوا في أولئك الرجال الصالحين، هذاك التطرف هو مبالغة، مبالغة في التعظيم مبالغة في في المحبة قد توصل الإنسان إلى إلى مثل هذا، ولذلك قال النبي عليه الصلاة والسلام فيما رواه البخاري عن عمر بن الخطاب رضي الله عنه، قال: \"لا تطروني كما أطرت النصارى عيسى، فقولوا: أنا عبد الله ورسوله\". وهذا يشهد لما نحن الآن بصدده وهو المبالغة والغلو في المخلوق؛ النبي عليه الصلاة والسلام نهى أن يبالغ المسلمون في تعظيمه، نعم هو رجل معظم هو سيد الخلق ولكنه بشر. أما النصارى فإنها غلت في عيسى عليه السلام حتى ألّهته أو جعلته ابن الإله أو ثالث ثلاثة على يعني حسب الطوائف النصرانية، المهم أنها أخرجته من بشريته بسبب الغلو. فكان النبي عليه الصلاة والسلام ينهى عن هذا؛ لماذا؟ للدليل الذي ذكرناه هو الذي تقدم ذكره وهو سد الذرائع، ينبغي أن تسد الذرائع التي يمكن أن تفتح أبواب الانحراف العقدي. الأمر الثاني هو سوء الظن بالله؛ إذا اجتمع الغلو في المخلوق مع سوء الظن بالله في أرضية انتشر فيها الجهل، فإنها تفضي إلى ظهور الشرك. قال تعالى: {وَمَا قَدَرُوا اللَّهَ حَقَّ قَدْرِهِ}؛ لأن هؤلاء الناس الذين يسألون الأصنام فقد أساءوا الظن بالله؛ كيف تسأل أشياء صنعتها أنت بيدك ولا تثق في أفعال الله وفي قدرة الله وفي استجابة الله سبحانه وتعالى لك؟! لماذا تسأل ذلك الصنم؟ لأنك أسأت الظن بالله. والله تعالى قالها صراحة في القرآن الكريم، قال تعالى: {وَيُعَذِّبَ الْمُنَافِقِينَ وَالْمُنَافِقَاتِ وَالْمُشْرِكِينَ وَالْمُشْرِكَاتِ الظَّانِّينَ بِاللَّهِ ظَنَّ السَّوْءِ ۚ عَلَيْهِمْ دَائِرَةُ السَّوْءِ} دائرة، إذن السبب هو الظن، الظن بالسوء، {الظَّانِّينَ بِاللَّهِ ظَنَّ السَّوْءِ} هو ظن السوء هو السبب الذي إذا أُضيف إلى الغلو في المخلوق -كما قلت- في أرضية انتشر فيها الجهل، فإنها تفضي إلى الوقوع إلى ظهور الشرك والعياذ بالله. أقول قولي هذا وأستغفر الله لي ولكم، والسلام عليكم ورحمة الله تعالى وبركاته.",
    "blocks_search_text": "تعريف الشرك لغة واصطلاحاً وبيان فطرة التوحيد الشرك في العقيدة هو جعل شيء من خصائص الله لغير الله، هذا باختصار شديد؛ الشرك هو جعل شيء من خصائص الله لغير الله سبحانه وتعالى. عرّف الأستاذ الشرك في اللغة من مفهوم الشركة، وفي الاصطلاح العقدي بأنه صرف خصائص الإلهية لغير الله، مؤكداً أن الفطرة البشرية الأصلية مبنية على التوحيد. بداية ظهور الشرك في البشرية وقصة قوم نوح إذن مبدأ الشرك والانحراف كان في القوم الذين بُعث فيهم بعد ذلك نوح عليه السلام. أوضح الشيخ كيف تسلل الشرك لأول مرة في تاريخ البشرية من خلال تعظيم تماثيل الرجال الصالحين في قوم نوح، مستدلاً بأثر ابن عباس في نسيان العلم كسبب رئيسي للشرك. دخول الشرك إلى الجزيرة العربية والأسباب الرئيسية له أول من أدخل الشرك إلى الجزيرة العربية هو عمرو بن لحي الخزاعي، وهذا الرجل كان كان عُرف بفعل الخير وبالصدقة والحرص على على أمور الدين والعبادات. استعرض الشيخ قصة عمرو بن لحي الخزاعي الذي جلب الأصنام لمكة، ثم لخص أسباب الشرك في غياب العلم، والغلو في المخلوقين، وسوء الظن بالله سبحانه وتعالى.",
