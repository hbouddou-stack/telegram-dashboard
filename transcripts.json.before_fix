        "text": "قسمين: صلوات مفروضة فرضاً عينياً، وصلوات مفروضة فرضاً",
        "video_link": null
      },
      {
        "ts": "1:40",
        "sec": 100,
        "text": "كفائياً؛ هناك فرض فرض عين، هناك فرض",
        "video_link": null
      },
      {
        "ts": "1:46",
        "sec": 106,
        "text": "كفاية. وسبق لنا في المقدمة",
        "video_link": null
      },
      {
        "ts": "1:52",
        "sec": 112,
        "text": "الأصولية شرح هذه المصطلحات؛ فرض العين هو الذي",
        "video_link": null
      },
      {
        "ts": "2:01",
        "sec": 121,
        "text": "يُطلب من كل مكلف بعينه، لا ينوب فيه أحد عن",
        "video_link": null
      },
      {
        "ts": "2:11",
        "sec": 131,
        "text": "أحد. أما فرض الكفاية هو فرض يُطلب",
        "video_link": null
      },
      {
        "ts": "2:18",
        "sec": 138,
        "text": "حصوله بغض النظر عن مَن قام به، فإذا إذا قام به البعض",
        "video_link": null
      },
      {
        "ts": "2:27",
        "sec": 147,
        "text": "يكفي وتسقط المطالبة به عن الباقين. إذاً الصلوات المفروضة قسمان: فرض عين",
        "video_link": null
      },
      {
        "ts": "2:38",
        "sec": 158,
        "text": "وفرض كفاية؛ مثال فرض الكفاية مما سيذكره: صلاة",
        "video_link": null
      },
      {
        "ts": "2:45",
        "sec": 165,
        "text": "الجنازة، والفرض العين: الصلوات الخمس. النفل",
        "video_link": null
      },
      {
        "ts": "2:54",
        "sec": 174,
        "text": "يقسّمه المالكية إلى أقسام؛ الآن نتحدث عن النفل بصفة",
        "video_link": null
      },
      {
        "ts": "3:05",
        "sec": 185,
        "text": "عامة، النفل الذي هو في مقابل الفرض؛ هناك منه ما هو",
        "video_link": null
      },
      {
        "ts": "3:15",
        "sec": 195,
        "text": "سنة، ومنه ما يسمونه رغيبة، ومنه ما يُسمى",
        "video_link": null
      },
      {
        "ts": "3:23",
        "sec": 203,
        "text": "النافلة؛ في هذا الإطار ديال النفل هناك السنة مثل صلاة الكسوف مثلاً، هناك الرغيبة،",
        "video_link": null
      },
      {
        "ts": "3:31",
        "sec": 211,
        "text": "هناك النافلة المطلقة؛ هذه أنواع سيذكرها الناظم رحمه الله",
        "video_link": null
      },
      {
        "ts": "3:40",
        "sec": 220,
        "text": "تعالى. فبدأ فقال: \"فَصْلٌ وَخَمْسُ صَلَوَاتٍ فَرْضُ عَيْنْ\"؛",
        "video_link": null
      },
      {
        "ts": "3:48",
        "sec": 228,
        "text": "وخمس صلوات فرض",
        "video_link": null
      },
      {
        "ts": "3:54",
        "sec": 234,
        "text": "عين. الصلوات الصلوات المفروضة فرضاً",
        "video_link": null
      },
      {
        "ts": "3:59",
        "sec": 239,
        "text": "عينياً -بمعنى أنها تجب على كل مسلم بعينه، وعلى كل مسلمة بعينها- هي خمس صلوات؛ هي الصلوات",
        "video_link": null
      },
      {
        "ts": "4:13",
        "sec": 253,
        "text": "المعروفة: صلاة الصبح، والظهر، والعصر، والمغرب، والعشاء؛ خمس",
        "video_link": null
      },
      {
        "ts": "4:22",
        "sec": 262,
        "text": "صلوات. دليلها الكتاب والسنة والإجماع؛ مما يدل",
        "video_link": null
      },
      {
        "ts": "4:28",
        "sec": 268,
        "text": "عليها أنه لما جاء أعرابي (أو تحديداً السنة والإجماع، الكتاب",
        "video_link": null
      },
      {
        "ts": "4:34",
        "sec": 274,
        "text": "بالإشارة)؛ مما يدل عليها من السنة حديث الأعرابي الذي جاء إلى رسول",
        "video_link": null
      },
      {
        "ts": "4:42",
        "sec": 282,
        "text": "الله صلى الله عليه وسلم يسأله عن الإسلام، فقال له صلى الله عليه وسلم: \"خَمْسُ",
        "video_link": null
      },
      {
        "ts": "4:49",
        "sec": 289,
        "text": "صَلَوَاتٍ فِي الْيَوْمِ وَاللَّيْلَةِ\" (خمس صلوات في اليوم والليلة)؛ قال الرجل: \"هل عليَّ",
        "video_link": null
      },
      {
        "ts": "4:58",
        "sec": 298,
        "text": "غيرها؟\" قال صلى الله عليه وسلم: \"لَا، إِلَّا أَنْ تَطَّوَّعَ\" (أي إلا إذا أردت أن",
        "video_link": null
      },
      {
        "ts": "5:06",
        "sec": 306,
        "text": "تتطوع)؛ ففهم منها أو فأُخذ من هذا الحديث بصريح اللفظ النبوي أن الصلوات المفروضة",
        "video_link": null
      },
      {
        "ts": "5:15",
        "sec": 315,
        "text": "خمس. وكذلك تعلمون قصة فرض الصلاة ليلة الإسراء والمعراج، حيث فُرضت الصلاة أولاً",
        "video_link": null
      },
      {
        "ts": "5:26",
        "sec": 326,
        "text": "خمسين، وأشار كليم الله موسى عليه السلام أشار على الحبيب صلى الله عليه وسلم أن يراجع",
        "video_link": null
      },
      {
        "ts": "5:33",
        "sec": 333,
        "text": "ربه جل جلاله وهو الكريم سبحانه أن يراجعه في هذه المسألة، فبقي ربنا عز وجل يضع بعض الصلوات",
        "video_link": null
      },
      {
        "ts": "5:43",
        "sec": 343,
        "text": "عن أمة الإسلام حتى بقيت خمس صلوات؛ \"فَصْلٌ وَخَمْسُ صَلَوَاتٍ فَرْضُ عَيْنْ\". ثم قال: \"وَهْيَ",
        "video_link": null
      },
      {
        "ts": "5:53",
        "sec": 353,
        "text": "كِفَايَةٌ لِمَيْتٍ دُونَ مَيْنْ\"؛ وهي (أي الصلوات) كفاية (أي فرض كفاية) لِميت؛ أي",
        "video_link": null
      },
      {
        "ts": "6:02",
        "sec": 362,
        "text": "لِميت دون مين (أي دون شك)؛ أي أن الصلاة على",
        "video_link": null
      },
      {
        "ts": "6:10",
        "sec": 370,
        "text": "الجنازة فرض كفاية.",
        "video_link": null
      },
      {
        "ts": "6:19",
        "sec": 379,
        "text": "المسلم إذا مات، المسلم -الكافر لا يُصلى عليه- المسلم إذا",
        "video_link": null
      },
      {
        "ts": "6:27",
        "sec": 387,
        "text": "مات تجب الصلاة عليه، الصلاة على الميت",
        "video_link": null
      },
      {
        "ts": "6:36",
        "sec": 396,
        "text": "المسلم فريضة؛ هل هي فريضة عينية؟ لا، هي فريضة",
        "video_link": null
      },
      {
        "ts": "6:45",
        "sec": 405,
        "text": "كفائية؛ إذا قام بها بعض المسلمين سقطت",
        "video_link": null
      },
      {
        "ts": "6:51",
        "sec": 411,
        "text": "المطالبة بها عن الباقين. فالمسلم تجب الصلاة عليه إلا ما كان من الشهيد؛ شهيد",
        "video_link": null
      },
      {
        "ts": "6:58",
        "sec": 418,
        "text": "المعركة فهذا لا يُصلى عليه إلا استحباباً. قال: \"وَهْيَ كِفَايَةٌ لِمَيْتٍ دُونَ",
        "video_link": null
      },
      {
        "ts": "7:07",
        "sec": 427,
        "text": "مَيْنْ\". لما مات النجاشي، قال النبي صلى الله عليه وسلم: \"إِنَّ أَخاً لَكُمْ قَدْ",
        "video_link": null
      },
      {
        "ts": "7:13",
        "sec": 433,
        "text": "مَاتَ، فَقُومُوا فَصَلُّوا عَلَيْهِ\"؛ فصلى عليه النبي صلى الله عليه وسلم والصحابة الكرام رضوان الله",
        "video_link": null
      },
      {
        "ts": "7:20",
        "sec": 440,
        "text": "عليهم. وصلاته صلى الله عليه وسلم لعدد من الجنائز هذا مشهور مستفيض متواتر؛ فالصلاة",
        "video_link": null
      },
      {
        "ts": "7:29",
        "sec": 449,
        "text": "على الجنازة فريضة",
        "video_link": null
      },
      {
        "ts": "7:35",
        "sec": 455,
        "text": "كفائية. لما ذكر رحمه الله صلاة الجنازة استطرد",
        "video_link": null
      },
      {
        "ts": "7:43",
        "sec": 463,
        "text": "ليتحدث عن بعض ما يتعلق بها، ما يتعلق بالجنازة،",
        "video_link": null
      },
      {
        "ts": "7:50",
        "sec": 470,
        "text": "فذكر فروضها؛ أي فروض صلاة",
        "video_link": null
      },
      {
        "ts": "7:58",
        "sec": 478,
        "text": "الجنازة. ما هي فرائض صلاة الجنازة التي لا تصح صلاة الجنازة إلا",
        "video_link": null
      },
      {
        "ts": "8:03",
        "sec": 483,
        "text": "بها؟ قال رحمه الله: \"فَرْضُهَا التَّكْبِيرُ أَرْبَعاً\"؛",
        "video_link": null
      },
      {
        "ts": "8:10",
        "sec": 490,
        "text": "التكبير أربعاً؛ أي أن يكبر المصلي على الجنازة أربع",
        "video_link": null
      },
      {
        "ts": "8:20",
        "sec": 500,
        "text": "تكبيرات. أبو هريرة رضي الله عنه لما ذكر الحديث حديث صلاة النبي صلى الله عليه وسلم على",
        "video_link": null
      },
      {
        "ts": "8:29",
        "sec": 509,
        "text": "النجاشي، قال: \"فَصَفَّ بِهِمْ فَكَبَّرَ أَرْبَعاً\" (كبر أربعاً).",
        "video_link": null
      },
      {
        "ts": "8:38",
        "sec": 518,
        "text": "صلاة الجنازة -كما لا يخفى عليكم إن شاء الله- صلاة الجنازة ليس فيها ركوع وليس فيها",
        "video_link": null
      },
      {
        "ts": "8:48",
        "sec": 528,
        "text": "سجود؛ يكبر المصلي على الجنازة أربع",
        "video_link": null
      },
      {
        "ts": "8:55",
        "sec": 535,
        "text": "تكبيرات، كما دل على ذلك حديث أبي هريرة رضي الله عنه آنفاً قال: \"فصفَّ بهم وكبَّر أربع",
        "video_link": null
      },
      {
        "ts": "9:03",
        "sec": 543,
        "text": "تكبيرات\". ماذا يقول بين التكبيرات؟ قال الناظم رحمه الله تعالى: \"فَرْضُهَا",
        "video_link": null
      },
      {
        "ts": "9:11",
        "sec": 551,
        "text": "التَّكْبِيرُ أَرْبَعاً دُعَاءْ *** وَنِيَّةٌ سَلَامٌ سِرِّ تَابَعَا\"؛ الناظم رحمه الله ذكر أن فرائض صلاة صلاة الجنازة أربعة:",
        "video_link": null
      },
      {
        "ts": "9:20",
        "sec": 560,
        "text": "التكبير ويكون أربعاً، الدعاء، والنية، والسلام.",
        "video_link": null
      },
      {
        "ts": "9:29",
        "sec": 569,
        "text": "الدعاء؛ يُدعى للميت، يُدعى للميت، وأصل هذا",
        "video_link": null
      },
      {
        "ts": "9:36",
        "sec": 576,
        "text": "المقصد الأهم من الصلاة على الجنازة: الدعاء",
        "video_link": null
      },
      {
        "ts": "9:46",
        "sec": 586,
        "text": "للميت؛ كان الذين يصلون على",
        "video_link": null
      },
      {
        "ts": "9:52",
        "sec": 592,
        "text": "الميت يتوجهون إلى الله عز وجل أن يرحم هذا الميت الذي بين أيديهم،",
        "video_link": null
      },
      {
        "ts": "10:01",
        "sec": 601,
        "text": "وسيورونه في التراب بعد قليل، كأنهم يشفعون له عند",
        "video_link": null
      },
      {
        "ts": "10:08",
        "sec": 608,
        "text": "ربه فيسألون ربهم أن يغفر له. من الأدعية التي استحبها المالكية ما",
        "video_link": null
      },
      {
        "ts": "10:16",
        "sec": 616,
        "text": "رواه مالك رحمه الله في الموطأ عن أبي هريرة رضي الله عنه،",
        "video_link": null
      },
      {
        "ts": "10:23",
        "sec": 623,
        "text": "وفيه: \"اللَّهُمَّ إِنَّهُ عَبْدُكَ وَابْنُ عَبْدِكَ وَابْنُ أَمَتِكَ، كَانَ يَشْهَدُ أَنْ لَا إِلَهَ إِلَّا",
        "video_link": null
      },
      {
        "ts": "10:31",
        "sec": 631,
        "text": "اللَّهُ وَأَنَّ مُحَمَّداً عَبْدُكَ وَرَسُولُكَ وَأَنْتَ أَعْلَمُ بِهِ، اللَّهُمَّ إِنْ كَانَ مُحْسِناً فَزِدْ فِي",
        "video_link": null
      },
      {
        "ts": "10:39",
        "sec": 639,
        "text": "إِحْسَانِهِ، وَإِنْ كَانَ مُسِيئاً فَتَجَاوَزْ عَنْ سَيِّئَاتِهِ، اللَّهُمَّ اغْفِرْ لَنَا وَلَهُ، وَلَا تَفْتِنَّا",
        "video_link": null
      },
      {
        "ts": "10:48",
        "sec": 648,
        "text": "بَعْدَهُ وَلَا تَحْرِمْنَا أَجْرَهُ، اللَّهُمَّ مَنْ أَحْيَيْتَهُ مِنَّا فَأَحْيِهِ عَلَى",
        "video_link": null
      },
      {
        "ts": "10:55",
        "sec": 655,
        "text": "الْإِيمَانِ، وَمَنْ تَوَفَّيْتَهُ مِنَّا فَتَوَفَّهُ عَلَى الْإِسْلَامِ\"؛ فيستحبون هذا الدعاء.",
        "video_link": null
      },
      {
        "ts": "11:03",
        "sec": 663,
        "text": "وأي دعاء مطلق الدعاء للميت مشروع؛ ومما ثبت عن النبي صلى",
        "video_link": null
      },
      {
        "ts": "11:09",
        "sec": 669,
        "text": "الله عليه وسلم في ذلك أنه صلى على ميت فدعا له،",
        "video_link": null
      },
      {
        "ts": "11:16",
        "sec": 676,
        "text": "فقال: \"اللَّهُمَّ اغْفِرْ لَهُ وَارْحَمْهُ، وَعَافِهِ وَاعْفُ عَنْهُ، وَأَكْرِمْ نُزُلَهُ، وَوَسِّعْ",
        "video_link": null
      },
      {
        "ts": "11:25",
        "sec": 685,
        "text": "مُدْخَلَهُ، وَاغْسِلْهُ بِالْمَاءِ وَالثَّلْجِ وَالْبَرَدِ، وَنَقِّهِ مِنَ الْخَطَايَا كَمَا نَقَّيْتَ الثَّوْبَ",
        "video_link": null
      },
      {
        "ts": "11:32",
        "sec": 692,
        "text": "الْأَبْيَضَ مِنَ الدَّنَسِ، وَأَبْدِلْهُ دَاراً خَيْراً مِنْ دَارِهِ، وَأَهْلاً خَيْراً مِنْ",
        "video_link": null
      },
      {
        "ts": "11:41",
        "sec": 701,
        "text": "أَهْلِهِ، وَزَوْجاً خَيْراً مِنْ زَوْجِهِ، وَأَدْخِلْهُ الْجَنَّةَ، وَأَعِذْهُ مِنْ عَذَابِ الْقَبْرِ...\" وغيرها من الأدعية التي وردت بعض",
        "video_link": null
      },
      {
        "ts": "11:48",
        "sec": 708,
        "text": "الأدعية عن رسول الله صلى الله عليه وسلم، والإنسان يدعو. المهم أن يخلص الإنسان الدعاء للميت؛ قال صلى الله",
        "video_link": null
      },
      {
        "ts": "11:56",
        "sec": 716,
        "text": "عليه وسلم كما في سنن أبي داوود من حديث أبي هريرة رضي الله عنه: \"إِذَا صَلَّيْتُمْ عَلَى الْمَيِّتِ",
        "video_link": null
      },
      {
        "ts": "12:03",
        "sec": 723,
        "text": "فَأَخْلِصُوا لَهُ الدُّعَاءَ\" (إذا صليتم على الميت فأخلصوا له الدعاء). الإنسان يدعو للميت",
        "video_link": null
      },
      {
        "ts": "12:10",
        "sec": 730,
        "text": "بقلب خالص، لأن الإنسان اليوم نحن نصلي على ميت وغداً سيُصلى علينا؛ فنصلي على",
        "video_link": null
      },
      {
        "ts": "12:17",
        "sec": 737,
        "text": "الميت ونخلص الدعاء، لعل ربنا تعالى أن ييسر لنا مَن إذا صلى علينا يخلص لنا الدعاء؛ فلعله",
        "video_link": null
      },
      {
        "ts": "12:26",
        "sec": 746,
        "text": "يصلي علينا رجل صالح يخلص الدعاء فيستجيب الله عز وجل له فيرحمنا سبحانه. نسأل الله تعالى",
        "video_link": null
      },
      {
        "ts": "12:35",
        "sec": 755,
        "text": "رحمته، وكرمه، وحلمه، ومغفرته، وعفوه. قال: \"فَرْضُهَا\"؛ إذاً ذكر الناظم رحمه الله،",
        "video_link": null
      },
      {
        "ts": "12:42",
        "sec": 762,
        "text": "قال: \"فَرْضُهَا التَّكْبِيرُ أَرْبَعاً دُعَاءْ\"، ثم قال: \"وَنِيَّةٌ\".",
        "video_link": null
      },
      {
        "ts": "12:49",
        "sec": 769,
        "text": "النية؛ النية هذه خلاص، يقول النبي صلى الله عليه وسلم: \"إِنَّمَا الْأَعْمَالُ بِالنِّيَّاتِ\"؛ ينوي أنه يصلي صلاة",
        "video_link": null
      },
      {
        "ts": "12:56",
        "sec": 776,
        "text": "الجنازة. \"سَلَامٌ سِرٍّ تَبَعَا\"؛ الفرض",
        "video_link": null
      },
      {
        "ts": "13:05",
        "sec": 785,
        "text": "الرابع من فرائض صلاة الجنازة: السلام؛ لأن كل",
        "video_link": null
      },
      {
        "ts": "13:12",
        "sec": 792,
        "text": "صلاة كما مر معنا غير مرة: \"الصَّلَاةُ الطُّهُورُ، وَتَحْرِيمُهَا التَّكْبِيرُ، وَتَحْلِيلُهَا التَّسْلِيمُ\"؛ فيدخل",
        "video_link": null
      },
      {
        "ts": "13:19",
        "sec": 799,
        "text": "في الصلاة بالتكبير ويخرج بالتسليم. قال الناظم رحمه الله: \"سَلَامٌ سِرٍّ\" أي يُستحب الإسرار",
        "video_link": null
      },
      {
        "ts": "13:28",
        "sec": 808,
        "text": "بالسلام، يستحب؛ اختار المالكية رحمهم الله تعالى في المشهور",
        "video_link": null
      },
      {
        "ts": "13:34",
        "sec": 814,
        "text": "عندهم أن المصلي على الجنازة يسلم تسليمة",
        "video_link": null
      },
      {
        "ts": "13:42",
        "sec": 822,
        "text": "واحدة ويسر بها؛ الإمام يُسمع يسر فيسمع الإمام مَن يليه، وهكذا حتى يسلم",
        "video_link": null
      },
      {
        "ts": "13:51",
        "sec": 831,
        "text": "الجميع. فقال لذلك قال: \"سَلَامٌ سِرٍّ تَبَعَا\". انتبه هذه الهيئة هيئة الصلاة هذه التي",
        "video_link": null
      },
      {
        "ts": "13:59",
        "sec": 839,
        "text": "ذكرها الناظم معناها أن الإنسان يكبر \"الله أكبر\" ويدعو للميت",
        "video_link": null
      },
      {
        "ts": "14:05",
        "sec": 845,
        "text": "التكبيرة الأولى، ثم يقول \"الله أكبر\" يكبر التكبيرة الثانية ويدعو للميت، ثم يكبر التكبيرة الثالثة ويدعو للميت، ثم يكبر",
        "video_link": null
      },
      {
        "ts": "14:14",
        "sec": 854,
        "text": "التكبيرة الرابعة ثم يسلم. ا الواقع",
        "video_link": null
      },
      {
        "ts": "14:22",
        "sec": 862,
        "text": "أن في صفة صلاة الجنازة المنقولة عن رسول الله صلى الله عليه وسلم، نُقل شيء لم يشر إليه الناظم رحمه الله ولم لم يختاروه",
        "video_link": null
      },
      {
        "ts": "14:30",
        "sec": 870,
        "text": "المالكية، وهو قراءه الفاتحة؛ قراءة الفاتحة. المالكية رحمه الله",
        "video_link": null
      },
      {
        "ts": "14:38",
        "sec": 878,
        "text": "عليهم لم يروا قراءة الفاتحة في صلاة",
        "video_link": null
      },
      {
        "ts": "14:46",
        "sec": 886,
        "text": "الجنازة، وقالوا إن صلاة الجنازة كلها دعاء. والواقع أن قراءة الفاتحة في صلاة",
        "video_link": null
      },
      {
        "ts": "14:56",
        "sec": 896,
        "text": "الجنازة ثابتة عن رسول الله صلى الله عليه؛ ثبتت في صحيح",
        "video_link": null
      },
      {
        "ts": "15:05",
        "sec": 905,
        "text": "البخاري، ففي صحيح البخاري أن عبد الله بن عباس رضي الله",
        "video_link": null
      },
      {
        "ts": "15:12",
        "sec": 912,
        "text": "عنهما صلى صلاة الجنازة فقرأ الفاتحة وجهر",
        "video_link": null
      },
      {
        "ts": "15:20",
        "sec": 920,
        "text": "بها، فلما سلّم سُئل عن",
        "video_link": null
      },
      {
        "ts": "15:27",
        "sec": 927,
        "text": "ذلك لِمَ قرأت الفاتحة؟ فقال رضي الله عنه وأرضاه: \"لِتَعْلَمُوا أَنَّهَا سُنَّةٌ\".",
        "video_link": null
      },
      {
        "ts": "15:36",
        "sec": 936,
        "text": "\"لِتَعْلَمُوا أَنَّهَا سُنَّةٌ\"؛ قوله تعلموا أنها سنة، يقصد سنة",
        "video_link": null
      },
      {
        "ts": "15:46",
        "sec": 946,
        "text": "مَن؟ يقصد سنة النبى صلى الله عليه وسلم؛ الصحابي إذا قال \"من السنة",
        "video_link": null
      },
      {
        "ts": "15:54",
        "sec": 954,
        "text": "كذا\" فهو يقصد سنة الرسول صلى الله عليه. الحافظ زين الدين",
        "video_link": null
      },
      {
        "ts": "16:01",
        "sec": 961,
        "text": "العراقي في ألفيته في الحديث يقول: قَوْلُ الصَّحَابِيِّ مِنَ السُّنَّةِ أَوْ *** نَحْوُ أُمِرْنَا حُكْمُهُ الرَّفْعُ وَلَوْ بَعْدَ النَّبِيِّ قَالَهُ بِأَعْصُرِ *** إلى آخر الحديث. قال رحمه الله عليه الحافظ العراقي: قول الصحابي من",
        "video_link": null
      },
      {
        "ts": "16:24",
        "sec": 984,
        "text": "السنة أو نحو",
        "video_link": null
      },
      {
        "ts": "16:31",
        "sec": 991,
        "text": "\"أُمِرنا\"، هذا له حكم الرفع. ولعلكم درستم في مصطلح الحديث \"البيقونية\" أن المرفوع هو ما",
        "video_link": null
      },
      {
        "ts": "16:39",
        "sec": 999,
        "text": "نُسب إلى النبي صلى الله عليه وسلم؛ يقول البيقوني رحمه الله عليه: \"وَمَا أُضِيفَ لِلنَّبِيِّ الْمَرْفُوعُ\"؛ أو ما أدري المهم... ما أضيف للرسول في المصطلح المهم",
        "video_link": null
      },
      {
        "ts": "16:52",
        "sec": 1012,
        "text": "أنه المرفوع هو ما نُسب إلى النبي صلى الله عليه وسلم. والمرفوع قسمان: مرفوع صريح ومرفوع حكمي؛ هناك ما رُفع",
        "video_link": null
      },
      {
        "ts": "17:03",
        "sec": 1023,
        "text": "إلى رسول الله صلى الله عليه وسلم صريحاً وهناك ما رُفع حكماً. المرفوع الصريح هو أنك تجد: \"قال رسول الله صلى الله عليه وسلم\"، \"فعل رسول الله صلى الله عليه وسلم\" هذا مرفوع",
        "video_link": null
      },
      {
        "ts": "17:11",
        "sec": 1031,
        "text": "صريح. المرفوع حكماً هو من من هذا القبيل، منه ما ذكرنا من هذا القبيل: \"من السنة كذا\"،",
        "video_link": null
      },
      {
        "ts": "17:20",
        "sec": 1040,
        "text": "\"أُمِرنا\"، \"كانوا يؤمرون\"؛ كما رأينا في في أظن في المجلس قبل الماضي حديث أنس: \"كانوا",
        "video_link": null
      },
      {
        "ts": "17:30",
        "sec": 1050,
        "text": "يؤمرون أن يضع الرجل يده اليمنى على اليسرى في الصلاة\"؛ كانوا يؤمرون، مَن الذي كان يأمرهم؟ الرسول صلى الله عليه وسلم. مَن هم",
        "video_link": null
      },
      {
        "ts": "17:38",
        "sec": 1058,
        "text": "الذين كانوا يؤمرون؟ الصحابة؛ ده صحابي يتحدث عن أصحاب رسول الله صلى الله عليه وسلم، يبعد أن يتحدث عن التابعين ويتحدث عن الصحابة كانوا",
        "video_link": null
      },
      {
        "ts": "17:46",
        "sec": 1066,
        "text": "يؤمرون. فلذلك هنا فقول عمر قول عبد الله بن عباس رضي الله عنهما:",
        "video_link": null
      },
      {
        "ts": "17:54",
        "sec": 1074,
        "text": "\"لتعلموا أنها سنة\"، فإنما يقصد سنة رسول الله صلى الله عليه وسلم؛ فلذلك تشرع قراءة الفاتحة بعد",
        "video_link": null
      },
      {
        "ts": "18:03",
        "sec": 1083,
        "text": "التكبيرة الأولى. ففي صلاة الجنازة تقول \"الله أكبر\" ثم تقرأ",
        "video_link": null
      },
      {
        "ts": "18:09",
        "sec": 1089,
        "text": "الفاتحة، تقرأ الفاتحة. بعد التكبيرة الثانية أيضاً ثبت عن رسول الله صلى الله عليه وسلم",
        "video_link": null
      },
      {
        "ts": "18:17",
        "sec": 1097,
        "text": "الصلاة على رسول الله صلى الله عليه وسلم في صلاة الجنازة، وإن كان المالكية لم يختاروا هذه أيضاً؛ لكن ثبت أظن كـ في سنن أبي",
        "video_link": null
      },
      {
        "ts": "18:24",
        "sec": 1104,
        "text": "داوود وغيره الصلاة على رسول الله صلى الله عليه وسلم، فلذلك يستحب أن الإنسان",
        "video_link": null
      },
      {
        "ts": "18:31",
        "sec": 1111,
        "text": "يقرأ الفاتحة بعد التكبيرة الأولى، ثم يصلي على رسول الله صلى الله عليه وسلم بعد التكبيرة بعد التكبيرة الثانية، وبعد",
        "video_link": null
      },
      {
        "ts": "18:40",
        "sec": 1120,
        "text": "التكبيرة الثالثة والرابعة يدعو للميت، يدعو للميت ولعموم المسلمين. وفي الواقع هذا",
        "video_link": null
      },
      {
        "ts": "18:47",
        "sec": 1127,
        "text": "هذا هذا من أدب الدعاء أصلاً؛ الفاتحة فيها ثناء على الله تعالى وتمجيد له، ومن آداب",
        "video_link": null
      },
      {
        "ts": "18:55",
        "sec": 1135,
        "text": "الدعاء تقديم الثناء والتمجيد بين يدي ربنا جل جلاله؛ هذا من آداب الدعاء، ومن أدب الدعاء أن نقدم بالصلاة",
        "video_link": null
      },
      {
        "ts": "19:03",
        "sec": 1143,
        "text": "على رسول الله صلى الله عليه وسلم كما ورد من أدب في أدب الدعاء هذا.",
        "video_link": null
      },
      {
        "ts": "19:12",
        "sec": 1152,
        "text": "طيب. إذاً هذه فرائض صلاة الجنازة؛ قال رحمه الله: \"فَرْضُهَا التَّكْبِيرُ أَرْبَعاً دُعَاءْ *** وَنِيَّةٌ سَلَامٌ سِرٍّ تَبَعَا\".",
        "video_link": null
      },
      {
        "ts": "19:21",
        "sec": 1161,
        "text": "استطراد الناظم أيضاً استطراد، ما دام ذكر صلاة الجنازة فهو استطراد فقال: وَكَالصَّلَاةِ الْغُسْلُ دَفْنٌ وَكَفَنْ ***",
        "video_link": null
      },
      {
        "ts": "19:30",
        "sec": 1170,
        "text": "\"وَكَالصَّلَاةِ الْغُسْلُ دَفْنٌ وَكَفَنْ\"؛ كـ الصلاة",
        "video_link": null
      },
      {
        "ts": "19:38",
        "sec": 1178,
        "text": "الكاف كاف التشبيه، كالصلاة الغسل؛ الغسل يشبه الصلاة في ماذا؟",
        "video_link": null
      },
      {
        "ts": "19:45",
        "sec": 1185,
        "text": "في الفرضية؛ يقصد الناظم رحمه الله تعالى",
        "video_link": null
      },
      {
        "ts": "19:51",
        "sec": 1191,
        "text": "أن غسل الميت أو أن تغسيل الميت",
        "video_link": null
      },
      {
        "ts": "19:57",
        "sec": 1197,
        "text": "المسلم فرض أيضاً واجب، وهو أيضاً فرض كفاية؛ لا يجوز أن يُدفن",
        "video_link": null
      },
      {
        "ts": "20:06",
        "sec": 1206,
        "text": "المسلم دون غسل إلا ما كان من الشهيد؛ الشهيد لا",
        "video_link": null
      },
      {
        "ts": "20:18",
        "sec": 1218,
        "text": "يُغسل. في زمن رسول الله صلى الله عليه وسلم",
        "video_link": null
      },
      {
        "ts": "20:25",
        "sec": 1225,
        "text": "رجل وقصته ناقة، كان واقفاً بعرفة فوقصته ناقته فمات؛ فقال صلى الله عليه وسلم:",
        "video_link": null
      },
      {
        "ts": "20:33",
        "sec": 1233,
        "text": "\"اغْسِلُوهُ بِمَاءٍ وَسِدْرٍ، وَكَفِّنُوهُ فِي ثَوْبَيْهِ\"؛ فقال اغسلوه، اغسلوه فعل",
        "video_link": null
      },
      {
        "ts": "20:42",
        "sec": 1242,
        "text": "أمر، والأمر يفيد الوجوب كما رأيتم في الأصول؛",
        "video_link": null
      },
      {
        "ts": "20:51",
        "sec": 1251,
        "text": "فيُؤمر فالمسلمون مأمرون بتغسيل الميت المسلم.",
        "video_link": null
      },
      {
        "ts": "20:59",
        "sec": 1259,
        "text": "لما ماتت زينب بنت رسول الله صلى الله عليه وسلم، قال صلى الله عليه وسلم للنساء:",
        "video_link": null
      },
      {
        "ts": "21:06",
        "sec": 1266,
        "text": "\"اغْسِلْنَهَا ثَلَاثاً أَوْ خَمْساً أَوْ أَكْثَرَ مِنْ ذَلِكَ إِنْ رَأَيْتُنَّ ذَلِكَ بِمَاءٍ وَسِدْرٍ\"؛ فقال اغسلنها، فتغسيل",
        "video_link": null
      },
      {
        "ts": "21:14",
        "sec": 1274,
        "text": "الميت واجب. تغسيل الميت بالمناسبة، تغسيل",
        "video_link": null
      },
      {
        "ts": "21:22",
        "sec": 1282,
        "text": "الميت غسل الميت هو كغسل الجنابة، غسل الميت هو كغسل",
        "video_link": null
      },
      {
        "ts": "21:27",
        "sec": 1287,
        "text": "الجنابة؛ يُغسل الميت يُعصر بطنه عصراً رفيقاً،",
        "video_link": null
      },
      {
        "ts": "21:33",
        "sec": 1293,
        "text": "ثم يُغسل فرجه وما حوله من الأذى بعد أن",
        "video_link": null
      },
      {
        "ts": "21:38",
        "sec": 1298,
        "text": "يضع الغاسل يلف على يده على يده خرقة حتى يغسله يغسله",
        "video_link": null
      },
      {
        "ts": "21:46",
        "sec": 1306,
        "text": "بها باب الاستنجاء تنقية،",
        "video_link": null
      },
      {
        "ts": "21:54",
        "sec": 1314,
        "text": "ثم يوضئه الوضوء الأصغر للصلاة؛ يعني يبلل إصبعه أو قطنة ونحو ذلك",
        "video_link": null
      },
      {
        "ts": "22:04",
        "sec": 1324,
        "text": "فيمرها على أسنانه محل المضمضة، وكذلك",
        "video_link": null
      },
      {
        "ts": "22:10",
        "sec": 1330,
        "text": "أنفه محل الاستنشاق، بعد أن يكون قد غسل يديه ثم يغسل وجهه",
        "video_link": null
      },
      {
        "ts": "22:17",
        "sec": 1337,
        "text": "ويديه اليمنى ثم اليسرى للمرفق، ثم قدميه، ثم يغسل سائر الجسد؛ يبدأ بالشق الأيمن،",
        "video_link": null
      },
      {
        "ts": "22:24",
        "sec": 1344,
        "text": "طبعاً بعد ثم يغسل الرأس قبل ذلك، يغسل رأسه ثم يفيض الماء عليه؛ يغسل الشق الأيمن ثم",
        "video_link": null
      },
      {
        "ts": "22:31",
        "sec": 1351,
        "text": "الشق الأيسر كغـ كالغسل من الجنابة. ويستحب أن يكون تكون عدد",
        "video_link": null
      },
      {
        "ts": "22:39",
        "sec": 1359,
        "text": "الغسلات ثلاثاً ثلاثاً أي أو خمساً أو سبعاً أو أكثر؛ كما قال صلى الله",
        "video_link": null
      },
      {
        "ts": "22:47",
        "sec": 1367,
        "text": "عليه وسلم للنساء اللواتي كن يغسلن زينب رضي الله عنها: \"اغْسِلْنَهَا ثَلَاثاً أَوْ خَمْساً",
        "video_link": null
      },
      {
        "ts": "22:54",
        "sec": 1374,
        "text": "أَوْ أَكْثَرَ مِنْ ذَلِكَ إِنْ رَأَيْتُنَّ ذَلِكَ بِمَاءٍ وَسِدْرٍ\"؛ يعني إذا كانت الحاجة تدعو إلى تكرار عدد الغسلات أكثر من ثلاث. هذا باختصار",
        "video_link": null
      },
      {
        "ts": "23:04",
        "sec": 1384,
        "text": "شديد، الوقت لا يكفي للتوسع في قضية تغسيل الميت. قال رحمه الله تعالى: \"وَكَالصَّلَاةِ الْغُسْلُ\"",
        "video_link": null
      },
      {
        "ts": "23:13",
        "sec": 1393,
        "text": "\"دَفْنٌ\"؛ الدفن أيضاً الدفن أيضاً كالغسل في ماذا؟ في في الفرضية، فيجب دفن الميت المسلم؛ بل الواقع",
        "video_link": null
      },
      {
        "ts": "23:23",
        "sec": 1403,
        "text": "الدفن هذا الجاري به العمل عند البشر عند البشر كلهم، وقد امتن الله تعالى على",
        "video_link": null
      },
      {
        "ts": "23:29",
        "sec": 1409,
        "text": "الإنسان بمسألة الدفن؛ قال تعالى: {ثُمَّ أَمَاتَهُ فَأَقْبَرَهُ}؛ فلو لم يُدفن الإنسان لبقي",
        "video_link": null
      },
      {
        "ts": "23:38",
        "sec": 1418,
        "text": "فوق على ظهر الأرض جيفة تستقذر، وربما تتـ",
        "video_link": null
      },
      {
        "ts": "23:46",
        "sec": 1426,
        "text": "ـتناولها الكلاب والسباع والهوام والطيور؛ وفي هذا من التنقيص من كرامة الإنسان ما",
        "video_link": null
      },
      {
        "ts": "23:54",
        "sec": 1434,
        "text": "فيه، الحمد لله على ستره. قال:",
        "video_link": null
      },
      {
        "ts": "24:01",
        "sec": 1441,
        "text": "\"وَكَالصَّلَاةِ الْغُسْلُ دَفْنٌ وَكَفَنْ\"؛ أيضاً التكفين أيضاً هذا",
        "video_link": null
      },
      {
        "ts": "24:08",
        "sec": 1448,
        "text": "واجب، التكفين واجب؛ \"وَكَالصَّلَاةِ الْغُسْلُ دَفْنٌ وَكَفَنْ\". ذاك الذي وقصته ناقته، قال صلى الله",
        "video_link": null
      },
      {
        "ts": "24:16",
        "sec": 1456,
        "text": "عليه وسلم: \"وَكَفِّنُوهُ فِي ثَوْبَيْهِ\"؛ فيُكفن. وكُفن رسول الله صلى الله عليه",
        "video_link": null
      },
      {
        "ts": "24:23",
        "sec": 1463,
        "text": "وسلم في ثلاث؛ كما تقول أم المؤمنين عائشة رضي الله عنها: \"كُفِّنَ رَسُولُ اللَّهِ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ فِي ثَلَاثَةِ أَثْوَابٍ بِيضٍ سَحُولِيَّةٍ لَيْسَ",
        "video_link": null
      },
      {
        "ts": "24:33",
        "sec": 1473,
        "text": "فِيهَا قَمِيصٌ وَلَا عِمَامَةٌ\"؛ فيُكفن الرجل في ثلاثة أثواب؛ يوضع الثوب",
        "video_link": null
      },
      {
        "ts": "24:40",
        "sec": 1480,
        "text": "الأول ثم الثوب الثاني ثم الثوب الثالث ويدرج في الكفن درجاً. والمرأة مثل الرجل، وبعض العلماء استحبوا للمرأة أن يُزاد",
        "video_link": null
      },
      {
        "ts": "24:48",
        "sec": 1488,
        "text": "الخمار والدرع زيادة في الستر؛ يعني المهم هو لف الميت وستره بثوب قبل دفنه. قال:",
        "video_link": null
      },
      {
        "ts": "24:57",
        "sec": 1497,
        "text": "\"وَكَالصَّلَاةِ الْغُسْلُ دَفْنٌ وَكَفَنْ\". ثم قال الناظم رحمه الله: وِتْرٌ كُسُوفٌ عِيدٌ اسْتِسْقَا سُنَنْ ***",
        "video_link": null
      },
      {
        "ts": "25:06",
        "sec": 1506,
        "text": "كأنه يقول لك: \"أنا أنهيت الآن أنهيت لك حديثي عن الصلوات",
        "video_link": null
      },
      {
        "ts": "25:15",
        "sec": 1515,
        "text": "المفروضة؛ المفروضة فرضاً عينياً والمفروضة فرضاً كفائياً، الآن تعال لأحدثك عن الصلوات",
        "video_link": null
      },
      {
        "ts": "25:25",
        "sec": 1525,
        "text": "المسنونة وهي في الواقع السنة المؤكدة\"؛ قال: \"وِتْرٌ كُسُوفٌ عِيدٌ اسْتِسْقَا سُنَنْ\". صلاة الوتر، صلاة",
        "video_link": null
      },
      {
        "ts": "25:33",
        "sec": 1533,
        "text": "الكسوف، صلاة العيد، صلاة الاستسقاء. بالنسبة لـ الوتر،",
        "video_link": null
      },
      {
        "ts": "25:42",
        "sec": 1542,
        "text": "الوتر هذه؛ الوتر هو الوتر ضد",
        "video_link": null
      },
      {
        "ts": "25:48",
        "sec": 1548,
        "text": "الشفع، والعدد الفردي إن صح التعبير؛ العدد العدد الفردي يُسمى وتراً، كاين عدد فردي",
        "video_link": null
      },
      {
        "ts": "25:55",
        "sec": 1555,
        "text": "وعدد زوجي فالفردي يُسمى وتراً. شرع ربنا عز وجل",
        "video_link": null
      },
      {
        "ts": "26:03",
        "sec": 1563,
        "text": "لعباده أن يختموا صلاة يومهم وليلتهم بالوتر،",
        "video_link": null
      },
      {
        "ts": "26:09",
        "sec": 1569,
        "text": "بالوتر؛ وهذا الوتر سنة مؤكدة، أكد عليها النبي صلى الله عليه وسلم بفعله وبقوله",
        "video_link": null
      },
      {
        "ts": "26:17",
        "sec": 1577,
        "text": "وحث عليها وحض عليها؛ قال صلى الله عليه وسلم: \"صَلَاةُ اللَّيْلِ مَثْنَى مَثْنَى، فَإِذَا خَشِيَ أَحَدُكُمُ",
        "video_link": null
      },
      {
        "ts": "26:25",
        "sec": 1585,
        "text": "الصُّبْحَ صَلَّى رَكْعَةً وَاحِدَةً تُوتِرُ لَهُ مَا قَدْ صَلَّى\" (توتر له ما قد صلى)؛ مثلاً صليت ثمان ركعات تصلي",
        "video_link": null
      },
      {
        "ts": "26:34",
        "sec": 1594,
        "text": "ركعة واحدة فتوتر لك ما صليت فتصبح تسع ركعات. ونبينا صلى الله عليه وسلم يقول: \"إِنَّ",
        "video_link": null
      },
      {
        "ts": "26:42",
        "sec": 1602,
        "text": "اللَّهَ وِتْرٌ يُحِبُّ الْوِتْرَ\"؛ إن الله وتر يحب",
        "video_link": null
      },
      {
        "ts": "26:50",
        "sec": 1610,
        "text": "الوتر. النبي صلى الله عليه وسلم يقول: \"اجْعَلُوا آخِرَ صَلَاتِكُمْ بِاللَّيْلِ وِتْراً\" (اجعلوا آخر",
        "video_link": null
      },
      {
        "ts": "26:59",
        "sec": 1619,
        "text": "صلاتكم بالليل وتراً). قال النبي صلى الله عليه وسلم: \"يَا أَهْلَ",
        "video_link": null
      },
      {
        "ts": "27:05",
        "sec": 1625,
        "text": "الْقُرْآنِ أَوْتِرُوا، فَإِنَّ اللَّهَ وِتْرٌ يُحِبُّ الْوِتْرَ\"؛ يا أهل القرآن أوتروا",
        "video_link": null
      },
      {
        "ts": "27:13",
        "sec": 1633,
        "text": "فإن الله وتر يحب الوتر. هذا الوتر السنة",
        "video_link": null
      },
      {
        "ts": "27:22",
        "sec": 1642,
        "text": "المؤكدة وقته من بعد صلاة العشاء إلى انبلاج الفجر، إلى طلوع",
        "video_link": null
      },
      {
        "ts": "27:31",
        "sec": 1651,
        "text": "الفجر؛ هذا كله وقت للوتر، من بعد أن تصلي صلاة العشاء إلى طلوع الفجر كله وقت للوتر.",
        "video_link": null
      },
      {
        "ts": "27:44",
        "sec": 1664,
        "text": "طيب إذا أذن الفجر وأنت لم توتر بعد، لم تصلِّ الوتر",
        "video_link": null
      },
      {
        "ts": "27:51",
        "sec": 1671,
        "text": "بعد؛ توتر قبل أن تصلي صلاة الصبح، وهذا يسميه فقهاؤنا الوقت الضروري",
        "video_link": null
      },
      {
        "ts": "27:59",
        "sec": 1679,
        "text": "للوتر، الوقت الضروري للوتر؛ من أذان الفجر إلى أن تصلي صلاة",
        "video_link": null
      },
      {
        "ts": "28:05",
        "sec": 1685,
        "text": "الصبح. مثلاً كنت عازماً على القيام لتصلي صلاة الوتر في آخر الليل، لكن غلبك النوم فلم تستيقظ إلا مع أذان",
        "video_link": null
      },
      {
        "ts": "28:14",
        "sec": 1694,
        "text": "الفجر؛ تتوضأ وتصلي الوتر قبل أن تصلي صلاة الصبح. قال: \"وِتْرٌ\"، ثم قال:",
        "video_link": null
      },
      {
        "ts": "28:22",
        "sec": 1702,
        "text": "\"كُسُوفٌ\"؛ صلاة الكسوف. السنة المؤكدة الثانية: صلاة الكسوف، صلاة",
        "video_link": null
      },
      {
        "ts": "28:29",
        "sec": 1709,
        "text": "الكسوف. المقصود بالكسوف هنا -بالكاف- المقصود بالكسوف هنا: كسوف",
        "video_link": null
      },
      {
        "ts": "28:37",
        "sec": 1717,
        "text": "الشمس؛ ما معنى كسوف الشمس؟ ذهاب ضوئها، ذهاب ضوء",
        "video_link": null
      },
      {
        "ts": "28:43",
        "sec": 1723,
        "text": "الشمس؛ وذلك حين يأتي القمر بين الشمس وبيننا في الأرض، فـ يذهب ضوء الشمس فيقال:",
        "video_link": null
      },
      {
        "ts": "28:54",
        "sec": 1734,
        "text": "كسفت الشمس؛ هذه آية من آيات",
        "video_link": null
      },
      {
        "ts": "29:02",
        "sec": 1742,
        "text": "الله. إذا وقع هذا الكسوف، شُرع للمسلم أن يفزع إلى",
        "video_link": null
      },
      {
        "ts": "29:10",
        "sec": 1750,
        "text": "الصلاة. بالمناسبة، بغض النظر عن كيف يتم الكسوف؛ الطريقة التي ذكرناها ياتي القمر بين الشمس وبين الأرض، يبقى هذا من آيات",
        "video_link": null
      },
      {
        "ts": "29:19",
        "sec": 1759,
        "text": "الله؛ ربنا عز وجل يذكرنا به نعمته علينا وأنه قادر على أن يفعل في كونه ما يشاء؛ مثل الجسم تراه",
        "video_link": null
      },
      {
        "ts": "29:27",
        "sec": 1767,
        "text": "سليماً صحيحاً معافى فيدخله فيروس أو بسيط فيبعثه الجسم ويحدث فيه الحمى والآلام",
        "video_link": null
      },
      {
        "ts": "29:35",
        "sec": 1775,
        "text": "ونحو ذلك، فتتذكر أن سلامتك بأمن الله عز وجل وفضل من الله عز وجل، وربك قادر على أن",
        "video_link": null
      },
      {
        "ts": "29:42",
        "sec": 1782,
        "text": "يفعل في جسمك كما شاء كذلك في كونه؛ فشرع لنا أن نفزع إلى الصلاة. قال النبي صلى",
        "video_link": null
      },
      {
        "ts": "29:49",
        "sec": 1789,
        "text": "الله عليه وسلم كما في الصحيحين في البخاري ومسلم وغيرهما: \"إِنَّ الشَّمْسَ وَالْقَمَرَ",
        "video_link": null
      },
      {
        "ts": "29:55",
        "sec": 1795,
        "text": "آيَتَانِ مِنْ آيَاتِ اللَّهِ لَا يَنْكَسِفَانِ لِمَوْتِ أَحَدٍ وَلَا لِحَيَاتِهِ، فَإِذَا رَأَيْتُمُوهُمَا فَقُومُوا فَصَلُّوا\"",
        "video_link": null
      },
      {
        "ts": "30:04",
        "sec": 1804,
        "text": "(فإذا رأيتموهما فقوموا فصلوا) أو كما قال صلى الله عليه وسلم؛ لأن كان العرب قديماً",
        "video_link": null
      },
      {
        "ts": "30:12",
        "sec": 1812,
        "text": "كانوا إذا كسفت إذا كسفت الشمس يقولون: \"مات اليوم عظيم\" أو \"يُولد عظيم\"، ووافق أن انكسفت",
        "video_link": null
      },
      {
        "ts": "30:19",
        "sec": 1819,
        "text": "الشمس في عهد رسول الله صلى الله عليه وسلم وافق ذلك موت إبراهيم ابن رسول الله صلى الله عليه وسلم، فقال بعضهم: \"كسفت الشمس",
        "video_link": null
      },
      {
        "ts": "30:27",
        "sec": 1827,
        "text": "لموت إبراهيم ابن رسول الله صلى الله عليه وسلم\"؛ فقال لهم النبي عليه الصلاة والسلام: \"إِنَّ الشَّمْسَ وَالْقَمَرَ آيَتَانِ مِنْ آيَاتِ اللَّهِ لَا",
        "video_link": null
      },
      {
        "ts": "30:33",
        "sec": 1833,
        "text": "يَنْكَسِفَانِ لِمَوْتِ أَحَدٍ وَلَا لِحَيَاتِهِ\". ا",
        "video_link": null
      },
      {
        "ts": "30:42",
        "sec": 1842,
        "text": "الكسوف السنة المؤكدة، كيف تؤدى صلاة الكسوف؟ صلاة الكسوف",
        "video_link": null
      },
      {
        "ts": "30:51",
        "sec": 1851,
        "text": "ركعتان، في كل ركعة ركوعان؛ صلاة الكسوف ركعتان في كل ركعة",
        "video_link": null
      },
      {
        "ts": "31:01",
        "sec": 1861,
        "text": "ركوعان. بمعنى يكبر الإنسان، صفتها كالاتي: يكبر",
        "video_link": null
      },
      {
        "ts": "31:09",
        "sec": 1869,
        "text": "الإنسان \"الله أكبر\"؛ طبعاً بالمناسبة تشرع لها صلاة الجماعة، تشرع لها صلاة الجماعة في المسجد. الله",
        "video_link": null
      },
      {
        "ts": "31:18",
        "sec": 1878,
        "text": "أكبر، تقرأ الفاتحة ثم تقرأ سورة وتطيل؛ الكسوف النبي صلى الله",
        "video_link": null
      },
      {
        "ts": "31:26",
        "sec": 1886,
        "text": "عليه وسلم صلّى الكسوف قالوا: \"قدرنا قراءته الأولى بقدر سورة البقرة\"؛ بقدر خمسة أحزاب، فقرأ طويلاً",
        "video_link": null
      },
      {
        "ts": "31:36",
        "sec": 1896,
        "text": "صلى الله عليه وسلم بعد الفاتحة، ثم ركع؛ ركع ركوعاً",
        "video_link": null
      },
      {
        "ts": "31:44",
        "sec": 1904,
        "text": "طويلاً قريباً من قراءته، يعني ركوعه قريب من من تلك القراءة",
        "video_link": null
      },
      {
        "ts": "31:51",
        "sec": 1911,
        "text": "التي قرأها والتي قُدّرت بالبقرة؛ ركع ركوعاً",
        "video_link": null
      },
      {
        "ts": "31:58",
        "sec": 1918,
        "text": "طويلاً هذا الركوع الأول. لما تقوم من الركوع تقول: \"سمع الله لمن حمده، ربنا ولك",
        "video_link": null
      },
      {
        "ts": "32:04",
        "sec": 1924,
        "text": "لك الحمد\"؛ تقرأ الفاتحة مرة أخرى، ثم تقرأ سورة تقرأ القرآن مرة أخرى.",
        "video_link": null
      },
      {
        "ts": "32:12",
        "sec": 1932,
        "text": "وهذه القراءة الثانية كانت قريبة من الركوع؛ يعني الركوع أنقص قليلاً من من القراءة الأولى، والقراءة",
        "video_link": null
      },
      {
        "ts": "32:21",
        "sec": 1941,
        "text": "الثانية أنقص قليلاً من الركوع؛ ثم",
        "video_link": null
      },
      {
        "ts": "32:28",
        "sec": 1948,
        "text": "تركع، ثم ترفع، ثم تسجد سجدتين. إذاً الركعة الأولى فيها ركوعان",
        "video_link": null
      },
      {
        "ts": "32:38",
        "sec": 1958,
        "text": "اثنان وقراءتان اثنتان؛ تقرأ الفاتحة مرتين، وتقرأ السورة أو ما بعد الفاتحة مرتين؛ ثم",
        "video_link": null
      },
      {
        "ts": "32:48",
        "sec": 1968,
        "text": "تقوم للركعة الثانية وتفعل فيها مثل ما فعلت في الأولى أيضاً، وكانت كل قراءة أنقص من",
        "video_link": null
      },
      {
        "ts": "33:56",
        "sec": 2036,
        "text": "سابقتها؛ مثلاً القراءة الركوع الركوع الثاني في الركعة الأولى قريب من القراءة",
        "video_link": null
      },
      {
        "ts": "34:00",
        "sec": 2040,
        "text": "قريب من الفاتحة\"، فقالوا لو لو صلى جهراً لعُلم بما قرأ صلى الله عليه وسلم؛ لكن",
        "video_link": null
      },
      {
        "ts": "34:03",
        "sec": 2043,
        "text": "الثانية، والقراءة في الركعة الثانية القراءة الأولى في الركعة الثانية قريبة من الركوع الثاني في الركعة الأولى، وهكذا.",
        "video_link": null
      },
      {
        "ts": "34:08",
        "sec": 2048,
        "text": "الواقع أنه في صحيح البخاري عن عائشة رضي الله عنها: \"أَنَّ رَسُولَ اللَّهِ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ جَهَرَ فِي صَلَاةِ الْكُسُوفِ بِقِرَاءَتِهِ\"؛ فصرحت عائشة رضي الله",
        "video_link": null
      },
      {
        "ts": "34:10",
        "sec": 2050,
